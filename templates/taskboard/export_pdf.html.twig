      <ellipse cx="51" cy="61" rx="35" ry="15" fill="#F59E0B" fill-opacity="0.16"><animate attributeName="fill-opacity" values="0.10;0.22;0.10" dur="2.5s" repeatCount="indefinite"/></ellipse>
      <circle cx="28" cy="59" r="12" fill="url(#c_ga)"><animate attributeName="cy" values="59;56;59" dur="3s" repeatCount="indefinite"/></circle>
      <circle cx="51" cy="63" r="14" fill="url(#c_gb)"><animate attributeName="cy" values="63;60;63" dur="2.8s" repeatCount="indefinite"/></circle>
      <circle cx="74" cy="59" r="12" fill="url(#c_gc)"><animate attributeName="cy" values="59;56;59" dur="3.2s" repeatCount="indefinite"/></circle>
      <circle cx="24" cy="55" r="4" fill="#FFF7D6" fill-opacity="0.42"><animate attributeName="fill-opacity" values="0.25;0.6;0.25" dur="2s" repeatCount="indefinite"/></circle>
      <circle cx="47" cy="58" r="4.6" fill="#FFF7D6" fill-opacity="0.44"><animate attributeName="fill-opacity" values="0.3;0.65;0.3" dur="2.3s" repeatCount="indefinite"/></circle>
      <circle cx="70" cy="55" r="4" fill="#FFF7D6" fill-opacity="0.42"><animate attributeName="fill-opacity" values="0.25;0.6;0.25" dur="2.6s" repeatCount="indefinite"/></circle>

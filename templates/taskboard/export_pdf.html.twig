    <linearGradient id="f_wd" x1="108" y1="16" x2="304" y2="74" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#E2E8F0"/><stop offset="38%" stop-color="#A5B4FC"/><stop offset="72%" stop-color="#60A5FA"/><stop offset="100%" stop-color="#22D3EE"/></linearGradient>
    <linearGradient id="f_rl" x1="108" y1="64" x2="240" y2="64" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#FB923C"/><stop offset="100%" stop-color="#22D3EE"/></linearGradient>

            </div>
            <div class="cover-right">
                <div class="cover-label">Prepared for</div>
                <div class="cover-name">{{ user.fullName|default(user.email) }}</div>
                <div class="cover-date">{{ exportDate|date('D, d M Y') }} &nbsp;&middot;&nbsp; {{ exportDate|date('H:i') }}</div>
                <div class="cover-doc-type">Task Board Report</div>
            </div>
        </div>
    </div>

    <!-- ══ PROGRESS BAND ══ -->
    <div class="progress-band">
        <div class="progress-ring-wrap">
            <svg viewBox="0 0 80 80">
                <defs><linearGradient id="rg" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#7b61f1"/><stop offset="100%" stop-color="#38bdd1"/></linearGradient></defs>
                <circle cx="40" cy="40" r="30" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="7"/>
                <circle cx="40" cy="40" r="30" fill="none" stroke="url(#rg)" stroke-width="7" stroke-linecap="round"
                    stroke-dasharray="{{ circum }}" stroke-dashoffset="{{ dashOff }}" transform="rotate(-90 40 40)"/>
            </svg>
            <div class="progress-ring-val" style="color:{% if completionPct >= 75 %}#34d399{% elseif completionPct >= 40 %}#fbbf24{% else %}#f87171{% endif %}">{{ completionPct }}%</div>
        </div>
        <div class="progress-stats">
            <div class="ps-item"><div class="ps-val" style="color:#60a5fa">{{ todoCount }}</div><div class="ps-lbl">To Do</div></div>
            <div class="ps-item"><div class="ps-val" style="color:#fbbf24">{{ inpCount }}</div><div class="ps-lbl">In Progress</div></div>
            <div class="ps-item"><div class="ps-val" style="color:#f87171">{{ blkCount }}</div><div class="ps-lbl">Blocked</div></div>
            <div class="ps-item"><div class="ps-val" style="color:#34d399">{{ doneCount }}</div><div class="ps-lbl">Done</div></div>
        </div>
        <div class="progress-bar-wrap">
            <div class="progress-bar-label">
                <span>Completion</span>
                <span style="color:#f0f4fc;font-weight:700">{{ doneCount }} / {{ totalTasks }} tasks</span>
            </div>
            <div class="progress-bar-track">
                <div class="progress-bar-fill" style="width:{{ completionPct }}%"></div>
            </div>
        </div>
    </div>

    <!-- ══ TASKS BY STATUS ══ -->
    {% set statusGroups = {
        'IN_PROGRESS': { label: 'In Progress', color: '#fbbf24' },
        'TODO':        { label: 'To Do',        color: '#60a5fa' },
        'BLOCKED':     { label: 'Blocked',       color: '#f87171' },
        'DONE':        { label: 'Completed',     color: '#34d399' }
    } %}

    {% for status, meta in statusGroups %}
    {% set groupTasks = tasks|filter(t => t.status == status) %}
    {% if groupTasks|length > 0 %}
        <div class="section-head">
            <div class="section-dot" style="background:{{ meta.color }};box-shadow:0 0 8px {{ meta.color }}55"></div>
            <div class="section-label" style="color:{{ meta.color }}">{{ meta.label }}</div>
            <div class="section-rule"></div>
            <div class="section-count">{{ groupTasks|length }} task{{ groupTasks|length != 1 ? 's' : '' }}</div>
        </div>
        <div class="task-cards">
        {% for task in groupTasks %}
        {% set isOverdue = task.due_date is not null and task.due_date < 'now'|date('Y-m-d') and task.status != 'DONE' %}
        <div class="task-card">
            <div class="task-card-accent" style="background:{{ meta.color }}"></div>
            <div class="task-card-top">
                <div class="task-title">{{ task.title }}</div>
            </div>
            {% if task.description %}
            <div class="task-desc">{{ task.description }}</div>
            {% endif %}
            <div class="task-chips">
                {% if task.priority == 'HIGH' %}
                <span class="chip chip-priority-high">
                    <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 2v5M6 9v1"/></svg>
                    High Priority
                </span>
                {% elseif task.priority == 'MEDIUM' %}
                <span class="chip chip-priority-medium">
                    <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><line x1="1" y1="4" x2="11" y2="4"/><line x1="1" y1="8" x2="11" y2="8"/></svg>
                    Medium
                </span>
                {% elseif task.priority %}
                <span class="chip chip-priority-low">
                    <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 2v8M3 7l3 3 3-3"/></svg>
                    Low
                </span>
                {% endif %}
                {% if task.due_date %}
                <span class="chip {{ isOverdue ? 'chip-overdue' : 'chip-due' }}">
                    <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="1" y="2" width="10" height="9" rx="1.5"/><line x1="1" y1="5" x2="11" y2="5"/><line x1="4" y1="1" x2="4" y2="3"/><line x1="8" y1="1" x2="8" y2="3"/></svg>
                    {{ isOverdue ? 'Overdue · ' : '' }}{{ task.due_date|date('d M Y') }}
                </span>
                {% endif %}
                {% if task.course_title %}
                <span class="chip chip-course">
                    <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="1" y="2" width="10" height="8" rx="1"/><line x1="1" y1="5.5" x2="11" y2="5.5"/><line x1="4" y1="2" x2="4" y2="10"/></svg>
                    {{ task.course_title }}
                </span>
                {% endif %}
            </div>
        </div>
        {% endfor %}
        </div>
    {% endif %}
    {% endfor %}

    {% if totalTasks == 0 %}
    <div class="empty-state">No tasks found in your board.</div>
    {% endif %}

    <!-- ══ SUMMARY ══ -->
    <div class="summary">
        <div class="summary-title">Session Summary</div>
        <div class="summary-grid">
            <div class="sum-card">
                <div class="sum-val" style="background:linear-gradient(135deg,#7b61f1,#38bdd1);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent">{{ totalTasks }}</div>
                <div class="sum-lbl">Total Tasks</div>
            </div>
            <div class="sum-card">
                <div class="sum-val" style="color:#f87171">{{ pomodoroStats.total_sessions|default(0) }}</div>
                <div class="sum-lbl">Pomodoro Sessions</div>
            </div>
            <div class="sum-card">
                <div class="sum-val" style="color:#38bdd1">{{ (pomodoroStats.total_minutes|default(0) / 60)|number_format(1) }}h</div>
                <div class="sum-lbl">Total Focus Time</div>
            </div>
        </div>
    </div>

    <!-- ══ FOOTER ══ -->
    <div class="pdf-footer">
        <div>

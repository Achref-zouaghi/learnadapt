      <rect x="48" y="2" width="6" height="40" rx="3" fill="url(#c_mt)"/>
      <rect x="64" y="2" width="5" height="36" rx="2.5" fill="url(#c_mt)"/>
      <rect x="78" y="2" width="5" height="36" rx="2.5" fill="url(#c_mt)"/>
      <rect x="20" y="2" width="5" height="36" rx="2.5" fill="url(#c_sh)"/>
      <rect x="34" y="2" width="5" height="36" rx="2.5" fill="url(#c_sh)"/>
      <rect x="48" y="2" width="6" height="40" rx="3" fill="url(#c_sh)"/>
      <rect x="64" y="2" width="5" height="36" rx="2.5" fill="url(#c_sh)"/>
      <rect x="78" y="2" width="5" height="36" rx="2.5" fill="url(#c_sh)"/>

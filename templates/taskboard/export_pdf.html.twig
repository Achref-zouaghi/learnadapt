      <rect x="30" y="34" width="13" height="8" rx="3" fill="url(#c_mb)"/>
      <rect x="45" y="38" width="13" height="8" rx="3" fill="url(#c_mb)"/>
      <rect x="60" y="34" width="13" height="8" rx="3" fill="url(#c_mb)"/>
      <rect x="74" y="34" width="13" height="8" rx="3" fill="url(#c_mb)"/>

    <circle cx="51" cy="63" r="14" fill="url(#f_gb)"/>
    <circle cx="74" cy="59" r="12" fill="url(#f_gc)"/>
    <rect x="20" y="2" width="5" height="36" rx="2.5" fill="url(#f_mt)"/>
    <rect x="34" y="2" width="5" height="36" rx="2.5" fill="url(#f_mt)"/>
    <rect x="48" y="2" width="6" height="40" rx="3" fill="url(#f_mt)"/>
    <rect x="64" y="2" width="5" height="36" rx="2.5" fill="url(#f_mt)"/>
    <rect x="78" y="2" width="5" height="36" rx="2.5" fill="url(#f_mt)"/>
    <rect x="16" y="34" width="13" height="8" rx="3" fill="url(#f_mb)"/>
    <rect x="30" y="34" width="13" height="8" rx="3" fill="url(#f_mb)"/>
    <rect x="45" y="38" width="13" height="8" rx="3" fill="url(#f_mb)"/>
    <rect x="60" y="34" width="13" height="8" rx="3" fill="url(#f_mb)"/>
    <rect x="74" y="34" width="13" height="8" rx="3" fill="url(#f_mb)"/>
  </g>
  <text x="108" y="29" fill="#8F9BB2" font-family="Inter,'Segoe UI',sans-serif" font-size="12" font-weight="700" letter-spacing="3.3">ADAPTIVE LEARNING</text>
  <text x="108" y="66" fill="url(#f_wd)" font-family="Inter,'Segoe UI',sans-serif" font-size="38" font-weight="800" letter-spacing="-1.1">LearnAdapt</text>

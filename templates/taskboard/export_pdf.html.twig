<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>LearnAdapt — Task Report</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',system-ui,sans-serif;background:#030810;color:#f0f4fc;min-height:100vh;overflow-x:hidden}

/* ══ INTRO OVERLAY ══ */
.intro{position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:0;background:radial-gradient(ellipse at 40% 30%,#0d1530,#030810 70%);animation:introFade 3.2s cubic-bezier(0.4,0,0.2,1) forwards}
.intro-logo{width:260px;opacity:0;animation:logoAppear .9s cubic-bezier(0.34,1.56,0.64,1) .15s forwards}
.intro-sub{font-size:0.78rem;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:#4a5578;margin-top:20px;opacity:0;animation:fadeUp .6s ease .7s forwards}
.intro-bar-wrap{width:220px;height:3px;background:rgba(255,255,255,0.05);border-radius:3px;margin-top:22px;overflow:hidden;opacity:0;animation:fadeUp .5s ease .9s forwards}
.intro-bar-fill{width:0%;height:100%;border-radius:3px;background:linear-gradient(90deg,#7b61f1,#38bdd1);animation:barFill 2s cubic-bezier(0.4,0,0.2,1) 1s forwards}
@keyframes introFade{0%,75%{opacity:1;pointer-events:all}100%{opacity:0;pointer-events:none}}
@keyframes logoAppear{from{opacity:0;transform:translateY(20px) scale(0.92)}to{opacity:1;transform:none}}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
@keyframes barFill{to{width:100%}}

/* ══ MAIN PAGE ══ */
.page{max-width:860px;margin:0 auto;padding:44px 36px 60px;opacity:0;animation:pageIn .7s ease 3s forwards}
@keyframes pageIn{to{opacity:1}}

/* ══ PRINT BUTTON ══ */
.print-bar{text-align:center;margin-bottom:36px}
.print-btn{display:inline-flex;align-items:center;gap:10px;padding:13px 38px;background:linear-gradient(135deg,#7b61f1,#38bdd1);border:none;border-radius:12px;color:#fff;font-weight:700;font-size:0.88rem;cursor:pointer;font-family:inherit;letter-spacing:0.01em;box-shadow:0 6px 32px rgba(123,97,241,0.35);transition:all .2s;position:relative;overflow:hidden}
.print-btn::after{content:'';position:absolute;inset:0;background:linear-gradient(45deg,transparent 40%,rgba(255,255,255,0.18) 50%,transparent 60%);transform:translateX(-100%);animation:sheen 3s ease-in-out 3.5s infinite}
@keyframes sheen{to{transform:translateX(200%)}}
.print-btn:hover{transform:translateY(-2px);box-shadow:0 10px 44px rgba(123,97,241,0.45)}
.print-btn svg{width:18px;height:18px;flex-shrink:0}

/* ══ COVER HEADER ══ */
.cover{position:relative;border-radius:22px;overflow:hidden;margin-bottom:32px;background:linear-gradient(135deg,#0c1428 0%,#0d1b38 55%,#0a1625 100%);border:1px solid rgba(255,255,255,0.07)}
.cover-bg-mesh{position:absolute;inset:0;background:radial-gradient(ellipse 60% 100% at 80% 50%,rgba(56,189,209,0.08),transparent),radial-gradient(ellipse 50% 80% at 10% 20%,rgba(123,97,241,0.1),transparent);pointer-events:none}
.cover-stripe{position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,#7b61f1,#38bdd1,#34d399,#fb923c,#7b61f1);background-size:400% 100%;animation:stripeMove 6s linear infinite}
@keyframes stripeMove{to{background-position:400% 0}}
.cover-inner{position:relative;padding:38px 40px 34px;display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap}
.cover-logo-wrap{flex:1;min-width:220px}
.cover-logo-wrap svg{max-width:240px;height:auto}
.cover-right{text-align:right;flex-shrink:0}
.cover-label{font-size:0.6rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#38bdd1;margin-bottom:6px}
.cover-name{font-size:1.15rem;font-weight:800;color:#f0f4fc;letter-spacing:-0.02em}
.cover-date{font-size:0.72rem;color:#6474a0;margin-top:5px;font-weight:500}
.cover-doc-type{display:inline-block;margin-top:12px;padding:5px 14px;border-radius:8px;background:rgba(123,97,241,0.12);border:1px solid rgba(123,97,241,0.22);font-size:0.62rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#a78bfa}

/* ══ PROGRESS BAND ══ */
.progress-band{background:rgba(255,255,255,0.018);border:1px solid rgba(255,255,255,0.055);border-radius:16px;padding:22px 28px;margin-bottom:28px;display:flex;align-items:center;gap:32px;flex-wrap:wrap}
.progress-ring-wrap{position:relative;flex-shrink:0}
.progress-ring-wrap svg{width:80px;height:80px}
.progress-ring-val{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:900;letter-spacing:-0.03em}
.progress-stats{display:flex;gap:20px;flex-wrap:wrap;flex:1}
.ps-item{text-align:center;min-width:60px}
.ps-val{font-size:1.45rem;font-weight:900;letter-spacing:-0.03em;line-height:1}
.ps-lbl{font-size:0.6rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#6474a0;margin-top:4px}
.progress-bar-wrap{flex:2;min-width:180px}
.progress-bar-label{display:flex;justify-content:space-between;font-size:0.7rem;font-weight:600;color:#6474a0;margin-bottom:8px}
.progress-bar-track{height:8px;background:rgba(255,255,255,0.05);border-radius:4px;overflow:hidden}
.progress-bar-fill{height:100%;border-radius:4px;background:linear-gradient(90deg,#7b61f1,#38bdd1)}

/* ══ SECTION HEADING ══ */
.section-head{display:flex;align-items:center;gap:12px;margin:36px 0 16px}
.section-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.section-label{font-size:0.72rem;font-weight:800;text-transform:uppercase;letter-spacing:0.12em}
.section-count{margin-left:auto;font-size:0.7rem;font-weight:600;color:#6474a0}
.section-rule{flex:1;height:1px;background:rgba(255,255,255,0.05)}

/* ══ TASK CARDS ══ */
.task-cards{display:flex;flex-direction:column;gap:12px}
.task-card{position:relative;background:rgba(255,255,255,0.022);border:1px solid rgba(255,255,255,0.06);border-radius:14px;padding:18px 20px 18px 24px;overflow:hidden}
.task-card-accent{position:absolute;left:0;top:0;bottom:0;width:4px;border-radius:14px 0 0 14px}
.task-card-top{display:flex;align-items:flex-start;gap:14px;justify-content:space-between;margin-bottom:10px;flex-wrap:wrap}
.task-title{font-size:0.92rem;font-weight:700;color:#f0f4fc;line-height:1.35;flex:1}
.task-desc{font-size:0.76rem;color:#6474a0;line-height:1.5;margin-bottom:12px;max-width:600px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.task-chips{display:flex;flex-wrap:wrap;gap:8px;align-items:center}
.chip{display:inline-flex;align-items:center;gap:5px;padding:4px 11px;border-radius:7px;font-size:0.64rem;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;white-space:nowrap}
.chip-priority-high{background:rgba(239,68,68,0.1);color:#f87171;border:1px solid rgba(239,68,68,0.15)}
.chip-priority-medium{background:rgba(251,146,60,0.1);color:#fb923c;border:1px solid rgba(251,146,60,0.15)}
.chip-priority-low{background:rgba(52,211,153,0.08);color:#34d399;border:1px solid rgba(52,211,153,0.12)}
.chip-due{background:rgba(255,255,255,0.04);color:#8896ab;border:1px solid rgba(255,255,255,0.07)}
.chip-overdue{background:rgba(239,68,68,0.1);color:#f87171;border:1px solid rgba(239,68,68,0.15)}
.chip-course{background:rgba(56,189,209,0.08);color:#38bdd1;border:1px solid rgba(56,189,209,0.12)}
.chip svg{width:11px;height:11px;flex-shrink:0}

/* ══ SUMMARY ══ */
.summary{margin-top:40px;background:rgba(255,255,255,0.018);border:1px solid rgba(255,255,255,0.055);border-radius:18px;padding:28px 32px}
.summary-title{font-size:0.68rem;font-weight:800;text-transform:uppercase;letter-spacing:0.14em;color:#38bdd1;margin-bottom:20px}
.summary-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.sum-card{background:rgba(255,255,255,0.025);border:1px solid rgba(255,255,255,0.06);border-radius:14px;padding:20px;text-align:center}
.sum-val{font-size:1.8rem;font-weight:900;letter-spacing:-0.04em;line-height:1}
.sum-lbl{font-size:0.62rem;font-weight:700;color:#6474a0;text-transform:uppercase;letter-spacing:0.1em;margin-top:5px}

/* ══ FOOTER ══ */
.pdf-footer{margin-top:44px;padding-top:22px;border-top:1px solid rgba(255,255,255,0.055);display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap}
.footer-logo{width:130px;height:auto;opacity:0.55}
.footer-right{text-align:right;font-size:0.66rem;color:#3e4d6a;line-height:1.8}
.footer-conf{display:inline-block;padding:3px 10px;border-radius:6px;background:rgba(239,68,68,0.07);border:1px solid rgba(239,68,68,0.12);color:#f87171;font-size:0.58rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin-top:6px}

/* ══ EMPTY STATE ══ */
.empty-state{text-align:center;padding:48px 24px;color:#3e4d6a;font-size:0.82rem}

/* ══ PRINT ══ */
@media print{
    body{background:#fff!important;color:#111827!important;-webkit-print-color-adjust:exact;print-color-adjust:exact}
    .intro,.print-bar{display:none!important}
    .page{opacity:1!important;animation:none!important;padding:0;max-width:100%}
    .cover{background:#f1f5fb!important;border-color:#dde3ef!important;-webkit-print-color-adjust:exact;print-color-adjust:exact}
    .cover-bg-mesh,.cover-stripe{display:none}
    .cover-name{color:#111827!important}
    .cover-date{color:#6b7280!important}
    .cover-doc-type{background:#ede9fe!important;border-color:#c4b5fd!important;color:#7c3aed!important}
    .progress-band,.summary,.task-card{background:#f8fafc!important;border-color:#e2e8f0!important}
    .progress-bar-track{background:#e5e7eb!important}
    .task-title{color:#111827!important}
    .task-desc{color:#6b7280!important}
    .section-rule{background:#e5e7eb!important}
    .section-label{color:#374151!important}
    .section-count,.ps-lbl,.sum-lbl,.footer-right{color:#6b7280!important}
    .pdf-footer{border-top-color:#e5e7eb!important}
    .footer-logo{opacity:0.8!important}
    .sum-card{background:#f1f5f9!important;border-color:#e2e8f0!important}
    @page{margin:16mm 18mm;size:A4}
}
</style>
</head>
<body>

{# ── Twig counters ── #}
{% set todoCount = 0 %}{% set inpCount = 0 %}{% set doneCount = 0 %}{% set blkCount = 0 %}
{% for t in tasks %}
    {% if t.status == 'TODO' %}{% set todoCount = todoCount + 1 %}
    {% elseif t.status == 'IN_PROGRESS' %}{% set inpCount = inpCount + 1 %}
    {% elseif t.status == 'DONE' %}{% set doneCount = doneCount + 1 %}
    {% elseif t.status == 'BLOCKED' %}{% set blkCount = blkCount + 1 %}
    {% endif %}
{% endfor %}
{% set totalTasks = tasks|length %}
{% set completionPct = totalTasks > 0 ? (doneCount / totalTasks * 100)|round : 0 %}
{% set circum = 188.5 %}
{% set dashOff = circum * (1 - completionPct / 100) %}

<!-- ══ INTRO OVERLAY ══ -->
<div class="intro">
    <div class="intro-logo">

        </div>
        <div class="footer-right">
            Generated {{ exportDate|date('d/m/Y') }} at {{ exportDate|date('H:i') }}<br>
            {{ user.fullName|default(user.email) }} &nbsp;&middot;&nbsp; {{ totalTasks }} task{{ totalTasks != 1 ? 's' : '' }}
            <br><span class="footer-conf">Confidential</span>
        </div>
    </div>

</div>
</body>
</html>
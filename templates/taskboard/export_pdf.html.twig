    <radialGradient id="f_gb" cx="0" cy="0" r="1" gradientUnits="userSpaceOnUse" gradientTransform="translate(51 63) rotate(44.5) scale(26.8)"><stop offset="0%" stop-color="#FFF8E1"/><stop offset="30%" stop-color="#FBBF24"/><stop offset="68%" stop-color="#D97706"/><stop offset="100%" stop-color="#713F12"/></radialGradient>

            <div class="kb-modal-row">
                <div>
                    <label>Status</label>
                    <select name="status">
                        <option value="TODO" selected>{{ 'taskboard.todo'|trans }}</option>
                        <option value="IN_PROGRESS">{{ 'taskboard.in_progress'|trans }}</option>
                        <option value="DONE">{{ 'taskboard.done'|trans }}</option>
                        <option value="BLOCKED">{{ 'taskboard.blocked'|trans }}</option>
                    </select>
                </div>
                <div>
                    <label>Priority</label>
                    <select name="priority">
                        <option value="LOW">LOW</option>
                        <option value="MEDIUM" selected>MEDIUM</option>
                        <option value="HIGH">HIGH</option>
                    </select>
                </div>
                <div>
                    <label>Due date</label>
                    <input type="date" name="due_date" min="{{ 'now'|date('Y-m-d') }}">
                </div>
            </div>
            <div class="kb-modal-foot">
                <button type="button" class="kb-modal-cancel" onclick="document.getElementById('addModal').classList.remove('open')">Cancel</button>
                <button type="submit" class="kb-modal-submit"><i class='bx bx-check' style="vertical-align:middle;margin-right:4px"></i> {{ 'taskboard.add_task'|trans }}</button>

            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
// ── Inline add toggle ──
function toggleInline(btn, status) {
    var f = document.getElementById('inline-' + status);
    f.classList.toggle('open');
    btn.style.display = f.classList.contains('open') ? 'none' : '';
}

// ── Select task for pomodoro from card ──
function selectPomo(id, title) {
    document.getElementById('pomoTask').value = String(id);
    document.querySelector('.kb-pomo').scrollIntoView({ behavior: 'smooth', block: 'center' });
}

// ── Modal backdrop close ──
document.getElementById('addModal').addEventListener('click', function(e) {
    if (e.target === this) this.classList.remove('open');
});
document.getElementById('editModal').addEventListener('click', function(e) {
    if (e.target === this) this.classList.remove('open');
});

// ── Edit modal ──
function openEditModal(id, title, desc, status, priority, dueDate) {
    document.getElementById('editForm').action = '/taskboard/edit/' + id;
    document.getElementById('editTitle').value = title;
    document.getElementById('editDesc').value = desc;
    document.getElementById('editStatus').value = status;
    document.getElementById('editPriority').value = priority;
    document.getElementById('editDueDate').value = (dueDate && dueDate !== '1970-01-01') ? dueDate : '';
    document.getElementById('editModal').classList.add('open');
}

// ── Pomodoro Timer (Premium) ──
function setPreset(w,b,c,btn) {
    document.getElementById('pomoWork').value = w;
    document.getElementById('pomoBreak').value = b;
    document.getElementById('pomoCycles').value = c;
    document.querySelectorAll('.kb-pomo-preset').forEach(function(p){p.classList.remove('active')});
    btn.classList.add('active');
    if (!window._pomoRunning) window._pomoReset();
}

(function() {
    var workEl = document.getElementById('pomoWork');
    var breakEl = document.getElementById('pomoBreak');
    var cyclesEl = document.getElementById('pomoCycles');
    var timeEl = document.getElementById('pomoTime');
    var phaseEl = document.getElementById('pomoPhase');
    var ring = document.getElementById('pomoRing');
    var startBtn = document.getElementById('pomoStart');
    var pauseBtn = document.getElementById('pomoPause');
    var resetBtn = document.getElementById('pomoReset');
    var skipBtn = document.getElementById('pomoSkip');
    var taskSel = document.getElementById('pomoTask');
    var badge = document.getElementById('pomoBadge');
    var badgeText = document.getElementById('pomoBadgeText');
    var dotsEl = document.getElementById('pomoDots');
    var particles = document.getElementById('pomoParticles');

    var C = 2 * Math.PI * 100;
    ring.style.strokeDasharray = C;
    var timer = null, total = 0, remain = 0, running = false, paused = false, onBreak = false, sessId = null;
    var currentCycle = 0, maxCycles = 4;
    var totalWorkSec = 0, totalBreakSec = 0;
    window._pomoRunning = false;

    // Tick sound (Web Audio)
    var audioCtx = null;
    function playTick() {
        try {
            if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            var osc = audioCtx.createOscillator();
            var gain = audioCtx.createGain();
            osc.connect(gain); gain.connect(audioCtx.destination);
            osc.frequency.value = 880; osc.type = 'sine';
            gain.gain.value = 0.05;
            osc.start(); osc.stop(audioCtx.currentTime + 0.05);
        } catch(e){}
    }
    function playDing() {
        try {
            if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            var osc = audioCtx.createOscillator();
            var gain = audioCtx.createGain();
            osc.connect(gain); gain.connect(audioCtx.destination);
            osc.frequency.value = 660; osc.type = 'triangle';
            gain.gain.value = 0.15;
            gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.6);
            osc.start(); osc.stop(audioCtx.currentTime + 0.6);
        } catch(e){}
    }

    function fmt(s) { return String(Math.floor(s/60)).padStart(2,'0') + ':' + String(s%60).padStart(2,'0'); }

    function buildDots() {
        dotsEl.innerHTML = '';
        for (var i = 0; i < maxCycles; i++) {
            var d = document.createElement('div');
            d.className = 'kb-pomo-dot' + (i < currentCycle ? ' done' : '') + (i === currentCycle && running ? ' current' : '');
            dotsEl.appendChild(d);
        }
    }

    function updateSessionStats() {
        document.getElementById('pomoSessWork').textContent = Math.floor(totalWorkSec / 60) + 'm';
        document.getElementById('pomoSessBreak').textContent = Math.floor(totalBreakSec / 60) + 'm';
        document.getElementById('pomoSessCycle').textContent = currentCycle + '/' + maxCycles;
    }

    function setBadge(state) {
        badge.className = 'kb-pomo-badge ' + (state === 'idle' ? 'idle' : 'active');
        if (state === 'focus') { badgeText.textContent = 'FOCUSING'; badge.style.borderColor = 'rgba(248,113,113,0.15)'; badge.style.color = 'var(--red)'; badge.style.background = 'rgba(248,113,113,0.08)'; }
        else if (state === 'break') { badgeText.textContent = 'BREAK'; badge.style.borderColor = ''; badge.style.color = ''; badge.style.background = ''; }
        else if (state === 'paused') { badgeText.textContent = 'PAUSED'; badge.style.borderColor = 'rgba(251,146,60,0.15)'; badge.style.color = '#fb923c'; badge.style.background = 'rgba(251,146,60,0.08)'; }
        else { badgeText.textContent = 'IDLE'; badge.style.borderColor = ''; badge.style.color = ''; badge.style.background = ''; }
    }

    function draw() {
        timeEl.textContent = fmt(remain);
        var p = total > 0 ? 1 - remain / total : 0;
        ring.style.strokeDashoffset = C * (1 - p);
        ring.style.stroke = onBreak ? 'var(--green)' : 'var(--red)';
        startBtn.classList.toggle('break-mode', onBreak);
        // Glow effect intensity
        var glow = Math.max(2, 6 * p);
        ring.parentElement.parentElement.style.filter = 'drop-shadow(0 0 ' + glow + 'px ' + (onBreak ? 'rgba(52,211,153,0.3)' : 'rgba(248,113,113,0.3)') + ')';
        buildDots();
    }

    function reset() {
        clearInterval(timer); timer = null;
        running = paused = onBreak = false; sessId = null;
        window._pomoRunning = false;
        currentCycle = 0; totalWorkSec = 0; totalBreakSec = 0;
        maxCycles = parseInt(cyclesEl.value) || 4;
        total = parseInt(workEl.value) * 60; remain = total;
        startBtn.style.display = ''; pauseBtn.style.display = 'none'; skipBtn.style.display = 'none';
        startBtn.innerHTML = "<i class='bx bx-play'></i> {{ 'taskboard.pomo_start'|trans }}";
        phaseEl.textContent = "{{ 'taskboard.pomo_focus'|trans }}";
        setBadge('idle');
        draw();
        updateSessionStats();
        particles.style.opacity = '0.3';
    }
    window._pomoReset = reset;

    function tick() {
        if (remain <= 0) {
            playDing();
            clearInterval(timer); timer = null;
            if (!onBreak) {
                // Work phase done
                if (sessId) fetch("{{ path('app_taskboard_pomodoro_complete', {id:0}) }}".replace('/0','/'+sessId),{method:'POST'});
                currentCycle++;
                updateSessionStats();
                if (currentCycle >= maxCycles) {
                    // All cycles done
                    running = false; onBreak = false;
                    window._pomoRunning = false;
                    phaseEl.textContent = "{{ 'taskboard.pomo_done'|trans }} 🎉";
                    startBtn.style.display = ''; pauseBtn.style.display = 'none'; skipBtn.style.display = 'none';
                    startBtn.innerHTML = "<i class='bx bx-play'></i> {{ 'taskboard.pomo_start'|trans }}";
                    setBadge('idle');
                    particles.style.opacity = '0.3';
                    if (Notification.permission === 'granted') new Notification('🍅 Pomodoro Complete!', {body: currentCycle + ' cycles done. Great work!'});
                    draw();
                    return;
                }
                onBreak = true;
                total = parseInt(breakEl.value) * 60; remain = total;
                phaseEl.textContent = "{{ 'taskboard.pomo_break_phase'|trans }}";
                setBadge('break');
                draw();
                if (Notification.permission === 'granted') new Notification('☕ Break Time!', {body:"{{ 'taskboard.pomo_break_phase'|trans }}"});
                timer = setInterval(tick, 1000);
            } else {
                // Break done, start next work phase
                onBreak = false;
                total = parseInt(workEl.value) * 60; remain = total;
                phaseEl.textContent = "{{ 'taskboard.pomo_focus'|trans }}";
                setBadge('focus');
                // Start new session for new cycle
                var tid = taskSel.value;
                if (tid) {
                    var fd = new FormData(); fd.append('work_minutes', workEl.value); fd.append('break_minutes', breakEl.value);
                    fetch("{{ path('app_taskboard_pomodoro_start', {taskId:0}) }}".replace('/0','/'+tid),{method:'POST',body:fd})
                    .then(function(r){return r.json()}).then(function(d){if(d.id) sessId=d.id;});
                }
                draw();
                if (Notification.permission === 'granted') new Notification('🍅 Focus Time!', {body:'Cycle ' + (currentCycle + 1) + ' of ' + maxCycles});
                timer = setInterval(tick, 1000);
            }
            return;
        }
        remain--;
        if (onBreak) totalBreakSec++; else totalWorkSec++;
        if (remain % 60 === 0) updateSessionStats();
        // Subtle tick every 30s
        if (remain > 0 && remain % 30 === 0) playTick();
        draw();
    }

    startBtn.addEventListener('click', function() {
        if (running && !paused) return;
        var tid = taskSel.value;
        if (!tid && !onBreak && !paused) { taskSel.style.borderColor='var(--red)'; taskSel.focus(); setTimeout(function(){taskSel.style.borderColor='';},2000); return; }
        if (paused) {
            // Resume
            paused = false;
            timer = setInterval(tick, 1000);
            startBtn.style.display = 'none'; pauseBtn.style.display = ''; skipBtn.style.display = '';
            setBadge(onBreak ? 'break' : 'focus');
            particles.style.opacity = '1';
            return;
        }
        running = true; paused = false;
        window._pomoRunning = true;
        maxCycles = parseInt(cyclesEl.value) || 4;
        if (!onBreak) { total = parseInt(workEl.value)*60; remain = total; phaseEl.textContent = "{{ 'taskboard.pomo_focus'|trans }}"; }
        setBadge(onBreak ? 'break' : 'focus');
        particles.style.opacity = '1';
        draw();
        if ('Notification' in window && Notification.permission === 'default') Notification.requestPermission();
        if (tid && !onBreak) {
            var fd = new FormData(); fd.append('work_minutes', workEl.value); fd.append('break_minutes', breakEl.value);
            fetch("{{ path('app_taskboard_pomodoro_start', {taskId:0}) }}".replace('/0','/'+tid),{method:'POST',body:fd})
            .then(function(r){return r.json()}).then(function(d){if(d.id) sessId=d.id;});
        }
        timer = setInterval(tick, 1000);
        startBtn.style.display = 'none'; pauseBtn.style.display = ''; skipBtn.style.display = '';
    });

    pauseBtn.addEventListener('click', function() {
        if (timer) {
            clearInterval(timer); timer = null; paused = true;
            pauseBtn.style.display = 'none'; startBtn.style.display = '';
            startBtn.innerHTML = "<i class='bx bx-play'></i> {{ 'taskboard.pomo_resume'|trans }}";
            skipBtn.style.display = 'none';
            setBadge('paused');
            particles.style.opacity = '0.3';
        }
    });

    skipBtn.addEventListener('click', function() {
        if (running) { remain = 0; tick(); }
    });

    resetBtn.addEventListener('click', reset);
    reset();

    // Animate title with time
    var origTitle = document.title;
    setInterval(function() {
        if (running && !paused) {
            document.title = (onBreak ? '☕ ' : '🍅 ') + fmt(remain) + ' — ' + origTitle;
        } else {
            document.title = origTitle;
        }
    }, 1000);
})();

// ── Drag & Drop ──
(function() {
    var dragCard = null;
    var placeholder = document.createElement('div');
    placeholder.className = 'kb-drop-placeholder';

    document.querySelectorAll('.kb-card[draggable]').forEach(function(card) {
        card.addEventListener('dragstart', function(e) {
            dragCard = this;
            this.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
            e.dataTransfer.setData('text/plain', this.dataset.taskId);
        });
        card.addEventListener('dragend', function() {
            this.classList.remove('dragging');
            document.querySelectorAll('.kb-col-body.drag-over').forEach(function(z) { z.classList.remove('drag-over'); });
            if (placeholder.parentNode) placeholder.parentNode.removeChild(placeholder);
            dragCard = null;
        });
    });

    document.querySelectorAll('.kb-col-body').forEach(function(zone) {
        zone.addEventListener('dragover', function(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            this.classList.add('drag-over');

            // Position placeholder near mouse
            var afterEl = getDragAfterElement(this, e.clientY);
            if (afterEl) {
                this.insertBefore(placeholder, afterEl);
            } else {
                this.appendChild(placeholder);
            }
        });
        zone.addEventListener('dragleave', function(e) {
            if (!this.contains(e.relatedTarget)) {
                this.classList.remove('drag-over');
                if (placeholder.parentNode === this) this.removeChild(placeholder);
            }
        });
        zone.addEventListener('drop', function(e) {
            e.preventDefault();
            this.classList.remove('drag-over');
            if (placeholder.parentNode) placeholder.parentNode.removeChild(placeholder);
            if (!dragCard) return;

            var taskId = dragCard.dataset.taskId;
            var newStatus = this.dataset.status;
            var isOverdue = dragCard.dataset.overdue === '1';

            // Block overdue → DONE in UI
            if (isOverdue && newStatus === 'DONE') {
                dragCard.style.animation = 'overdueShake 0.4s';
                setTimeout(function() { dragCard.style.animation = ''; }, 400);
                return;
            }

            // Move the card in DOM immediately
            this.appendChild(dragCard);

            // Update column counts
            updateColumnCounts();

            // AJAX call to persist
            var fd = new FormData();
            fd.append('status', newStatus);
            fetch('/taskboard/update-status/' + taskId, {
                method: 'POST',
                body: fd,
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            }).then(function(r) { return r.json(); }).then(function(data) {
                if (!data.ok) {
                    // Revert on error — reload page
                    window.location.reload();
                }
            }).catch(function() {
                window.location.reload();
            });
        });
    });

    function getDragAfterElement(container, y) {
        var els = Array.from(container.querySelectorAll('.kb-card:not(.dragging)'));
        var closest = null, closestOffset = Number.NEGATIVE_INFINITY;
        els.forEach(function(el) {
            var box = el.getBoundingClientRect();
            var offset = y - box.top - box.height / 2;
            if (offset < 0 && offset > closestOffset) {
                closestOffset = offset;
                closest = el;
            }
        });
        return closest;
    }

    function updateColumnCounts() {
        document.querySelectorAll('.kb-col').forEach(function(col) {
            var body = col.querySelector('.kb-col-body');
            var cnt = col.querySelector('.cnt');
            if (body && cnt) {
                cnt.textContent = body.querySelectorAll('.kb-card').length;
            }
        });
    }
})();

// Auto-dismiss flashes
document.querySelectorAll('.kb-flash').forEach(function(el) {
    setTimeout(function() { el.style.opacity='0'; el.style.transform='translateY(-10px)'; setTimeout(function(){el.remove()},400); }, 4000);
});
</script>
{% endblock %}

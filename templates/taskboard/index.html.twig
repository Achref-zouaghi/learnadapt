</div>

{# ══ EDIT TASK MODAL ══ #}
<div class="kb-modal-bg" id="editModal">
    <div class="kb-modal">
        <h2><i class='bx bx-edit-alt' style="color:var(--cyan);vertical-align:middle;margin-right:6px"></i> {{ 'taskboard.edit_task'|trans }}</h2>
        <p class="sub">{{ 'taskboard.edit_task_sub'|trans }}</p>
        <form id="editForm" method="post">

						<div style="width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,rgba(123,97,241,0.15),rgba(56,189,209,0.1));display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:800;color:var(--purple);flex-shrink:0">
							<i class='bx bx-user'></i>

</div>
</div>

<!-- Toast notification -->
<div class="cs-toast" id="toast"></div>

<script>
const courseId = {{ course.id }};
let selectedRating = {{ userRating ? userRating.rating : 0 }};

function showToast(msg) {
	const t = document.getElementById('toast');
	t.textContent = msg;
	t.classList.add('show');
	setTimeout(() => t.classList.remove('show'), 2500);
}

function toggleBookmark() {
	fetch('/courses/'+courseId+'/bookmark', {method:'POST'}).then(r=>r.json()).then(d=>{
		const btn=document.getElementById('bmBtn');
		const ico=document.getElementById('bmIcon');
		const txt=document.getElementById('bmText');
		if(d.bookmarked){
			btn.classList.add('active');
			ico.className='bx bxs-bookmark';
			txt.textContent='Bookmarked';
			showToast('Course bookmarked!');
		} else {
			btn.classList.remove('active');
			ico.className='bx bx-bookmark';
			txt.textContent='Bookmark';
			showToast('Bookmark removed');
		}
	});
}

function shareCourse() {
	navigator.clipboard.writeText(window.location.href).then(()=>showToast('Link copied to clipboard!'));
}

function setRating(val) {
	selectedRating = val;
	document.querySelectorAll('#rateStars i').forEach((s,i)=>{
		s.className = i < val ? 'bx bxs-star' : 'bx bx-star';
	});
}

function submitRating() {
	if(!selectedRating) return showToast('Please select a rating');
	const review = document.getElementById('rateReview').value;
	fetch('/courses/'+courseId+'/rate', {
		method:'POST',
		headers:{'Content-Type':'application/json'},
		body:JSON.stringify({rating:selectedRating,review:review})
	}).then(r=>r.json()).then(d=>{
		showToast('Rating submitted!');
		setTimeout(()=>location.reload(), 800);
	});
}

function saveNote() {
	const content = document.getElementById('noteInput').value.trim();
	if(!content) return;
	fetch('/courses/'+courseId+'/notes', {
		method:'POST',
		headers:{'Content-Type':'application/json'},
		body:JSON.stringify({content:content})
	}).then(r=>r.json()).then(d=>{
		document.getElementById('noteInput').value='';
		const div = document.createElement('div');
		div.className='cs-note';
		div.id='note-'+d.id;
		div.innerHTML='<button class="cs-note-del" onclick="deleteNote('+d.id+')"><i class="bx bx-x"></i></button><div class="cs-note-content">'+escapeHtml(content)+'</div><div class="cs-note-date">Just now</div>';
		document.getElementById('notesList').prepend(div);
		showToast('Note saved!');
	});
}

function deleteNote(id) {
	fetch('/courses/'+courseId+'/notes/'+id, {method:'DELETE'}).then(r=>r.json()).then(()=>{
		document.getElementById('note-'+id)?.remove();
		showToast('Note deleted');
	});
}

function addComment() {
	const content = document.getElementById('commentInput').value.trim();
	if(!content) return;
	fetch('/courses/'+courseId+'/comments', {
		method:'POST',
		headers:{'Content-Type':'application/json'},
		body:JSON.stringify({content:content})
	}).then(r=>r.json()).then(d=>{
		document.getElementById('commentInput').value='';
		document.getElementById('noComments')?.remove();
		const div = document.createElement('div');
		div.className='cs-comment';
		div.id='comment-'+d.id;
		div.innerHTML='<div class="cs-comment-avatar"><i class="bx bx-user"></i></div><div class="cs-comment-body"><div class="cs-comment-head"><span class="cs-comment-name">You</span><span class="cs-comment-time">Just now</span><button class="cs-comment-del" onclick="deleteComment('+d.id+')"><i class="bx bx-trash"></i></button></div><div class="cs-comment-text">'+escapeHtml(content)+'</div></div>';
		document.getElementById('commentsList').prepend(div);
		showToast('Comment posted!');
	});
}

function deleteComment(id) {
	fetch('/courses/'+courseId+'/comments/'+id, {method:'DELETE'}).then(r=>r.json()).then(()=>{
		document.getElementById('comment-'+id)?.remove();
		showToast('Comment deleted');
	});
}

function updateProgress() {
	fetch('/courses/'+courseId+'/progress', {
		method:'POST',
		headers:{'Content-Type':'application/json'},
		body:JSON.stringify({percent:100})
	}).then(r=>r.json()).then(d=>{
		showToast('Course marked as complete! +' + (d.xp_earned||0) + ' XP');
		setTimeout(()=>location.reload(), 1000);
	});
}

function escapeHtml(text) {
	const d = document.createElement('div');
	d.textContent = text;
	return d.innerHTML;
}
</script>
{% endblock %}

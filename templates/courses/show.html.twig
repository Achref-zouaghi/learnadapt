						<div class="cs-mini-card-lvl" style="color:{{ pr.level == 'EASY' ? 'var(--green)' : (pr.level == 'MEDIUM' ? 'var(--yellow)' : 'var(--red)') }}">{{ pr.level }}</div>
					</a>
					{% endfor %}
				</div>

						<div style="flex:1">
							<textarea id="commentInput" class="cs-note-input" placeholder="Ask a question or leave a comment..." style="min-height:60px;margin-bottom:8px"></textarea>
							<button class="cs-btn cs-btn-primary cs-btn-sm" onclick="addComment()"><i class='bx bx-send'></i> Post</button>

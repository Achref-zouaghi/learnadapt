					<div class="cs-mini-card-title">{{ rc.title }}</div>
					<div class="cs-mini-card-lvl" style="color:{{ rc.level == 'EASY' ? 'var(--green)' : (rc.level == 'MEDIUM' ? 'var(--yellow)' : 'var(--red)') }}">{{ rc.level }}</div>
				</a>

				<div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
					<div style="width:40px;height:40px;border-radius:12px;background:rgba(56,189,209,0.1);display:flex;align-items:center;justify-content:center;font-size:1rem">âš¡</div>
					<div>
						<div style="font-size:1.1rem;font-weight:900;color:var(--cyan)">{{ progress.xp_earned }}</div>
						<div style="font-size:0.65rem;color:var(--muted);font-weight:600">XP EARNED</div>
					</div>
				</div>
				{% endif %}
				{% if streak and streak.current_streak > 0 %}
				<div style="display:flex;align-items:center;gap:10px">
					<div style="width:40px;height:40px;border-radius:12px;background:rgba(251,146,60,0.1);display:flex;align-items:center;justify-content:center;font-size:1rem">ðŸ”¥</div>
					<div>
						<div style="font-size:1.1rem;font-weight:900;color:var(--orange)">{{ streak.current_streak }} days</div>

<!-- Shared Footer -->
<footer class="bg-gray-900 text-white py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
            <div class="flex items-center gap-6">
                <a href="{{ path('app_home') }}" class="block shrink-0" aria-label="9rayti+ home">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 295 72" width="200" height="49" role="img" aria-label="9rayti+ logo" style="display:block">
<defs>
<linearGradient id="ft-bk" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#3B82F6"/><stop offset="55%" stop-color="#4F46E5"/><stop offset="100%" stop-color="#7C3AED"/></linearGradient>
<linearGradient id="ft-sp" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#1D4ED8"/><stop offset="100%" stop-color="#4338CA"/></linearGradient>
<linearGradient id="ft-sh" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#fff" stop-opacity="0.3"/><stop offset="100%" stop-color="#fff" stop-opacity="0"/></linearGradient>
<linearGradient id="ft-cp" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#4F46E5"/><stop offset="100%" stop-color="#7C3AED"/></linearGradient>
<linearGradient id="ft-tsl" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#FCD34D"/><stop offset="100%" stop-color="#F59E0B"/></linearGradient>
<linearGradient id="ft-txt" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#3B82F6"/><stop offset="50%" stop-color="#6366F1"/><stop offset="100%" stop-color="#8B5CF6"/></linearGradient>
<linearGradient id="ft-pl" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#F97316"/><stop offset="100%" stop-color="#EF4444"/></linearGradient>
<filter id="ft-glow" x="-20%" y="-20%" width="140%" height="140%"><feGaussianBlur stdDeviation="2" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
<filter id="ft-tg" x="-5%" y="-30%" width="115%" height="160%"><feGaussianBlur stdDeviation="2.5" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
<filter id="ft-sg" x="-100%" y="-100%" width="300%" height="300%"><feGaussianBlur stdDeviation="1.3" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
</defs>
<path d="M6 16 Q6 12 10 12 L40 14 L40 62 L10 60 Q6 60 6 56 Z" fill="url(#ft-bk)" filter="url(#ft-glow)"/>
<path d="M44 14 L74 12 Q78 12 78 16 L78 56 Q78 60 74 60 L44 62 Z" fill="url(#ft-bk)" filter="url(#ft-glow)"/>
<rect x="40" y="14" width="4" height="48" fill="url(#ft-sp)"/>
<path d="M6 16 Q6 12 10 12 L40 14 L40 36 Q24 32 6 34 Z" fill="url(#ft-sh)"/>
<path d="M44 14 L74 12 Q78 12 78 16 L78 36 Q62 32 44 36 Z" fill="url(#ft-sh)"/>
<path d="M23 37 L25 31 L27 37 L33 37 L28 41 L30 47 L25 43 L20 47 L22 41 L17 37 Z" fill="white" opacity="0.9" filter="url(#ft-sg)"><animate attributeName="opacity" values="0.9;0.4;0.9" dur="2.2s" repeatCount="indefinite"/></path>
<path d="M20 14 L42 6 L64 14 L42 22 Z" fill="url(#ft-cp)"/>
<path d="M30 16 Q42 21 54 16 L54 20 Q42 25 30 20 Z" fill="#5B21B6"/>
<line x1="64" y1="14" x2="70" y2="20" stroke="url(#ft-tsl)" stroke-width="2" stroke-linecap="round"/>
<circle cx="70" cy="23" r="3" fill="url(#ft-tsl)"><animate attributeName="cy" values="23;27;23" dur="2s" repeatCount="indefinite" calcMode="spline" keySplines="0.4 0 0.2 1;0.4 0 0.2 1"/></circle>
<g transform="translate(4,5)"><path d="M0-4.5 L1-1 L4.5 0 L1 1 L0 4.5 L-1 1 L-4.5 0 L-1-1 Z" fill="#FBBF24" filter="url(#ft-sg)"><animateTransform attributeName="transform" type="rotate" values="0;360" dur="8s" repeatCount="indefinite"/><animate attributeName="opacity" values="1;0.4;1" dur="2.4s" repeatCount="indefinite"/></path></g>
<g transform="translate(70,4)"><path d="M0-3.5 L0.8-0.8 L3.5 0 L0.8 0.8 L0 3.5 L-0.8 0.8 L-3.5 0 L-0.8-0.8 Z" fill="#38BDD1" filter="url(#ft-sg)"><animateTransform attributeName="transform" type="rotate" values="0;-360" dur="6s" repeatCount="indefinite"/><animate attributeName="opacity" values="0.5;1;0.5" dur="1.8s" repeatCount="indefinite"/></path></g>
<text x="88" y="54" font-family="Nunito,Poppins,sans-serif" font-size="48" font-weight="800" letter-spacing="-0.5" filter="url(#ft-tg)"><tspan fill="url(#ft-txt)">9rayti</tspan><tspan fill="url(#ft-pl)" font-size="50" font-weight="900" dy="1">+</tspan></text>
</svg>
                </a>
                <nav class="flex gap-6 text-sm">
                    <a href="{{ path('app_home') }}" class="text-white/60 hover:text-white transition">{{ 'nav.home'|trans }}</a>
                    <a href="{{ path('app_profile') }}" class="text-white/60 hover:text-white transition">{{ 'nav.profile'|trans }}</a>
                    <a href="{{ path('app_settings') }}" class="text-white/60 hover:text-white transition">{{ 'nav.settings'|trans }}</a>
                </nav>
            </div>
            <div class="flex items-center gap-3">
                <a href="#" class="w-8 h-8 bg-white/10 rounded-full flex items-center justify-center hover:bg-white/20 transition">
                    <span class="material-icons text-sm">public</span>
                </a>
                <a href="#" class="w-8 h-8 bg-white/10 rounded-full flex items-center justify-center hover:bg-white/20 transition">
                    <span class="material-icons text-sm">photo_camera</span>
                </a>
            </div>
        </div>
        <div class="border-t border-white/10 mt-6 pt-5 text-center">
            <p class="text-sm text-white/30">{{ 'footer.copyright'|trans({'%year%': "now"|date("Y")}) }}</p>
        </div>
    </div>
</footer>

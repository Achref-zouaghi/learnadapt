<!-- Shared Navbar -->
{% set currentRoute = app.request.attributes.get('_route') %}
{% if darkPage|default(false) %}
{# ===== HOME-STYLE NAVBAR (dark pages) ===== #}
<style>
	/* ── NAVBAR ── */
	:root { --ease: cubic-bezier(0.22, 1, 0.36, 1); }
	.nav {
		--scroll-progress: 0%;
		position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
		display: flex; align-items: center; justify-content: center; height: 86px; padding: 0 20px;
		backdrop-filter: none; -webkit-backdrop-filter: none;
		background: linear-gradient(180deg, rgba(4,6,14,0.52), rgba(4,6,14,0.12));
		border-bottom: 1px solid transparent;
		transition: transform 0.4s var(--ease), border-color 0.3s ease, background 0.3s ease, height 0.3s ease;
		will-change: transform;
	}
	.nav::after {
		content: '';
		position: absolute; left: 0; bottom: 0; height: 1px;
		width: var(--scroll-progress);
		background: linear-gradient(90deg, rgba(251,146,60,0.88), rgba(249,115,22,0.84));
		box-shadow: 0 0 12px rgba(249,115,22,0.45);
		opacity: 0;
		transition: width 0.18s linear, opacity 0.28s ease;
		pointer-events: none;
	}
	.nav.scrolled { border-bottom-color: transparent; background: transparent; }
	.nav.scrolled::after { opacity: 1; }
	.nav.compact { height: 74px; }
	.nav.is-hidden { transform: translateY(-112%); }
	.nav.is-reveal-bounce .nav-menu-shell {
		animation: navRevealSpring 0.46s cubic-bezier(0.22, 1.2, 0.36, 1);
	}
	@keyframes navRevealSpring {
		0% { transform: translateY(-7px) scale(0.99); }
		58% { transform: translateY(2px) scale(1.001); }
		100% { transform: translateY(0) scale(1); }
	}
	.page-brand {
		position: fixed; top: 20px; left: 32px; z-index: 1001;
		display: inline-flex; align-items: center; gap: 0;
		text-decoration: none; padding: 0; background: transparent; border: 0; box-shadow: none;
		transition: transform 0.2s var(--ease), opacity 0.2s ease;
	}
	.page-brand:hover { transform: translateY(-2px); opacity: 0.95; }
	.page-brand-logo {
		display: block;
		width: min(248px, 38vw);
		height: auto;
		filter: drop-shadow(0 10px 26px rgba(8, 15, 35, 0.4));
	}
	.nav-inner { width: 100%; display: flex; align-items: center; justify-content: center; }
	.nav-menu-shell {
		display: flex; align-items: center; gap: 14px; padding: 9px 13px; border-radius: 12px;
		background: linear-gradient(180deg, rgba(7,11,22,0.56), rgba(6,9,18,0.44));
		border: 1px solid rgba(255,255,255,0.2);
		box-shadow: 0 16px 34px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.2), 0 0 24px rgba(56,189,209,0.08), 0 0 22px rgba(124,58,237,0.08);
		width: min(860px, 100%); justify-content: center; position: relative;
		backdrop-filter: blur(18px) saturate(135%); -webkit-backdrop-filter: blur(18px) saturate(135%);
		transition: transform 0.34s var(--ease), box-shadow 0.34s ease, border-color 0.34s ease, background 0.34s ease;
	}
	.nav.scrolled .nav-menu-shell {
		transform: translateY(-1px) scale(0.992);
		border-color: rgba(255,255,255,0.24);
		background: linear-gradient(180deg, rgba(10,14,26,0.66), rgba(7,10,20,0.54));
		box-shadow: 0 18px 40px rgba(0,0,0,0.48), inset 0 1px 0 rgba(255,255,255,0.22), 0 0 20px rgba(249,115,22,0.14);
	}
	.nav-menu-shell::before {
		content: ''; position: absolute; inset: 0; border-radius: inherit; padding: 1px;
		background: linear-gradient(122deg, rgba(255,255,255,0.4), rgba(255,255,255,0.04) 38%, rgba(56,189,209,0.16) 62%, rgba(249,115,22,0.2));
		mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
		mask-composite: exclude; -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
		-webkit-mask-composite: xor; pointer-events: none; opacity: 0.78;
	}
	.nav-menu-shell::after {
		content: ''; position: absolute; inset: 1px; border-radius: inherit;
		background: radial-gradient(100% 80% at 50% -10%, rgba(255,255,255,0.15), transparent 62%);
		pointer-events: none; opacity: 0.75;
	}
	.nav.compact .nav-menu-shell { padding: 8px 11px; border-radius: 11px; }
	.nav-logo {
		display: inline-flex; align-items: center; gap: 10px;
		font-size: 1.02rem; font-weight: 800; letter-spacing: -0.02em; text-decoration: none;
		background: linear-gradient(135deg, #a78bfa, #22d3ee);
		-webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
		flex-shrink: 0; opacity: 1; transition: opacity 0.35s ease;
	}
	.nav-logo:hover { opacity: 0.7; }
	.nav-logo-mark {
		width: 38px; height: 38px; display: inline-flex; align-items: center; justify-content: center;
		background: transparent; border: 0; box-shadow: none; flex-shrink: 0;
	}
	.learnadapt-mark {
		position: relative; display: flex; align-items: flex-start; justify-content: center;
		gap: 4px; height: 100%; width: 100%; padding-top: 1px;
	}
	.learnadapt-mark .wire {
		position: relative; width: 2px; height: 20px; border-radius: 999px;
		background: linear-gradient(180deg, rgba(241,245,249,0.92), rgba(148,163,184,0.26));
		transform-origin: top center;
	}
	.learnadapt-mark .wire.left { animation: cradleLeft 2.8s cubic-bezier(0.4, 0, 0.2, 1) infinite; }
	.learnadapt-mark .wire.right { animation: cradleRight 2.8s cubic-bezier(0.4, 0, 0.2, 1) infinite; }
	.learnadapt-mark .wire::before {
		content: ''; position: absolute; left: 50%; bottom: -6px; width: 10px; height: 8px;
		transform: translateX(-50%); border-radius: 3px;
		background: linear-gradient(180deg, rgba(100,116,139,0.95), rgba(71,85,105,0.92));
		border: 1px solid rgba(255,255,255,0.12); box-shadow: inset 0 1px 0 rgba(255,255,255,0.14);
	}
	.learnadapt-mark .wire::after {
		content: ''; position: absolute; left: 50%; bottom: -16px; width: 12px; height: 12px;
		transform: translateX(-50%); border-radius: 50%;
		background: radial-gradient(circle at 35% 35%, rgba(255,255,255,0.28), rgba(226,232,240,0.08) 32%, rgba(15,23,42,0.02) 60%, rgba(148,163,184,0.12) 100%);
		border: 1px solid rgba(148,163,184,0.26);
		box-shadow: inset -1px -1px 2px rgba(2,6,23,0.24), inset 1px 1px 2px rgba(255,255,255,0.03);
		transition: box-shadow 0.2s ease, border-color 0.2s ease; opacity: 0.32;
	}
	.learnadapt-mark .wire.is-glow::after,
	.learnadapt-mark .wire.left::after,
	.learnadapt-mark .wire.right::after {
		background: radial-gradient(circle at 35% 35%, rgba(255,255,224,0.98) 0%, rgba(250,204,21,0.96) 26%, rgba(250,204,21,0.78) 54%, rgba(250,204,21,0.12) 100%);
		border-color: rgba(250,204,21,0.52);
	}
	.learnadapt-mark .wire.left::after { animation: glowLeft 2.8s linear infinite; }
	.learnadapt-mark .wire.right::after { animation: glowRight 2.8s linear infinite; }
	.learnadapt-mark .wire.is-glow::after {
		box-shadow: 0 0 10px rgba(250,204,21,0.85), 0 0 18px rgba(250,204,21,0.45); opacity: 0.5;
	}
	.learnadapt-mark .wire.is-glow::before {
		background: linear-gradient(180deg, rgba(120,113,108,0.96), rgba(82,82,91,0.94));
		box-shadow: inset 0 1px 0 rgba(255,255,255,0.18), 0 0 8px rgba(250,204,21,0.18);
	}
	.learnadapt-mark.is-small { transform: scale(0.78); transform-origin: center; }
	.learnadapt-mark.is-large { transform: scale(1.06); transform-origin: center; }
	@keyframes cradleLeft {
		0%, 100% { transform: rotate(0deg); } 10% { transform: rotate(-30deg); }
		26% { transform: rotate(0deg); } 50%, 74% { transform: rotate(0deg); }
	}
	@keyframes cradleRight {
		0%, 42% { transform: rotate(0deg); } 58% { transform: rotate(30deg); }
		74% { transform: rotate(0deg); } 100% { transform: rotate(0deg); }
	}
	@keyframes glowLeft {
		0%, 6%, 30%, 100% { box-shadow: inset -1px -1px 2px rgba(2,6,23,0.24), inset 1px 1px 2px rgba(255,255,255,0.03); border-color: rgba(148,163,184,0.26); opacity: 0.32; }
		12%, 24% { box-shadow: 0 0 10px rgba(250,204,21,0.98), 0 0 18px rgba(250,204,21,0.72), 0 0 30px rgba(250,204,21,0.28); border-color: rgba(250,204,21,0.52); opacity: 1; }
	}
	@keyframes glowRight {
		0%, 48%, 78%, 100% { box-shadow: inset -1px -1px 2px rgba(2,6,23,0.24), inset 1px 1px 2px rgba(255,255,255,0.03); border-color: rgba(148,163,184,0.26); opacity: 0.32; }
		58%, 72% { box-shadow: 0 0 10px rgba(250,204,21,0.98), 0 0 18px rgba(250,204,21,0.72), 0 0 30px rgba(250,204,21,0.28); border-color: rgba(250,204,21,0.52); opacity: 1; }
	}
	.nav-logo-label {
		background: linear-gradient(135deg, #a78bfa, #22d3ee);
		-webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
	}
	.nav-links {
		display: flex; align-items: center; gap: 2px; list-style: none;
		flex: 0 1 auto; padding: 2px; border-radius: 10px;
		background: transparent; border: 0; box-shadow: none; position: relative;
	}
	.nav-active-pill, .nav-active-trail { display: none; }
	.nav-active-pill {
		position: absolute; top: 5px; left: 5px; height: calc(100% - 10px); width: 0;
		border-radius: 999px;
		background: linear-gradient(90deg, rgba(111,79,232,0.96), rgba(56,189,209,0.86));
		border: 1px solid rgba(255,255,255,0.14);
		box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 12px 28px rgba(79,70,229,0.28), 0 0 24px rgba(56,189,209,0.14);
		transform: translateX(0);
		transition: transform 0.44s cubic-bezier(0.2, 1.2, 0.35, 1), width 0.44s cubic-bezier(0.2, 1.2, 0.35, 1), opacity 0.2s ease, filter 0.3s ease;
		pointer-events: none; opacity: 0; z-index: 0;
	}
	.nav-active-pill.is-moving { filter: brightness(1.14) saturate(1.08); }
	.nav-active-trail {
		position: absolute; top: 9px; left: 6px; height: calc(100% - 18px); width: 0;
		border-radius: 999px;
		background: linear-gradient(90deg, rgba(111,79,232,0.3), rgba(56,189,209,0.28));
		filter: blur(10px);
		transform: translateX(0);
		transition: transform 0.56s cubic-bezier(0.2, 1.25, 0.45, 1), width 0.56s cubic-bezier(0.2, 1.25, 0.45, 1), opacity 0.22s ease;
		pointer-events: none; opacity: 0; z-index: 0;
	}
	.nav-links li { position: relative; flex: 0 0 auto; z-index: 1; }
	.nav-links a {
		position: relative; display: inline-flex; align-items: center; justify-content: center;
		width: auto; padding: 7px 10px; border-radius: 7px;
		color: rgba(241,245,249,0.9); text-decoration: none;
		font-size: 0.7rem; font-weight: 600; letter-spacing: 0; text-transform: none;
		transition: color 0.22s ease, background 0.22s ease; white-space: nowrap;
	}
	.nav-links a:hover, .nav-links a.is-active { color: #f8fafc; background: rgba(255,255,255,0.06); }
	.nav-right { display: flex; align-items: center; gap: 8px; position: relative; padding-left: 8px; }
	.nav-right::before { display: none; }
	.nav-search {
		position: relative; display: grid; place-items: center; width: 36px; height: 36px;
		border-radius: 8px; background: rgba(255,255,255,0.02);
		border: 1px solid rgba(255,255,255,0.08); overflow: hidden;
		transition: width 0.45s var(--ease), box-shadow 0.3s ease, border-color 0.3s ease;
		box-shadow: inset 0 1px 0 rgba(255,255,255,0.02); flex-shrink: 0;
	}
	.nav-search:focus-within {
		width: 162px; border-color: rgba(60,197,217,0.28);
		box-shadow: 0 0 0 3px rgba(60,197,217,0.08), inset 0 1px 0 rgba(255,255,255,0.03);
	}
	.nav-search-input {
		width: 100%; height: 100%; padding: 0 40px 0 12px; background: transparent;
		border: 0; outline: 0; color: var(--text); font: inherit; font-size: 0.87rem;
		opacity: 0; pointer-events: none; transition: opacity 0.22s ease;
	}
	.nav-search:focus-within .nav-search-input { opacity: 1; pointer-events: auto; }
	.nav-search-input::placeholder { color: rgba(241,245,249,0.42); }
	.nav-search-btn {
		position: absolute; right: 0; top: 0; width: 40px; height: 40px;
		display: inline-flex; align-items: center; justify-content: center;
		border: 0; background: transparent; color: #93c5fd; cursor: pointer;
		transition: color 0.2s ease, transform 0.2s var(--ease);
	}
	.nav-search-btn:hover { color: #dbeafe; transform: scale(1.03); }
	.nav-search-btn svg { width: 16px; height: 16px; }
	.page-top-actions {
		position: fixed; top: 20px; right: 28px; z-index: 1100;
		display: inline-flex; align-items: center; gap: 10px;
	}
	.top-search-form {
		position: relative; display: inline-flex; align-items: center;
		width: 40px; height: 40px; border-radius: 10px;
		background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1);
		overflow: visible; backdrop-filter: blur(14px);
		transition: width 0.35s var(--ease), border-color 0.2s ease, background 0.2s ease;
	}
	.top-search-form:focus-within {
		width: 280px; border-color: rgba(123,97,241,0.35);
		background: rgba(255,255,255,0.06);
		overflow: visible;
	}
	.top-search-input {
		width: 100%; height: 100%; border: none; outline: none;
		background: transparent; color: #e2e8f0; font-size: 0.8rem;
		padding: 0 36px 0 12px;
		opacity: 0; pointer-events: none;
		transition: opacity 0.2s ease;
	}
	.top-search-form:focus-within .top-search-input { opacity: 1; pointer-events: auto; }
	.top-search-input::placeholder { color: rgba(241,245,249,0.42); }
	.top-search-btn {
		position: absolute; right: 0; top: 0; width: 40px; height: 40px;
		display: flex; align-items: center; justify-content: center;
		background: none; border: none; color: #cbd5e1; cursor: pointer;
		transition: color 0.2s ease;
	}
	.top-search-btn:hover { color: #e2e8f0; }
	.top-search-btn svg { width: 16px; height: 16px; }
	.top-search-dropdown {
		position: absolute; top: calc(100% + 8px); right: 0; width: 340px;
		max-height: 400px; overflow-y: auto;
		border-radius: 12px; z-index: 1200;
		background: linear-gradient(180deg, rgba(17,21,33,0.98), rgba(10,13,23,0.98));
		border: 1px solid rgba(255,255,255,0.12);
		box-shadow: 0 20px 50px rgba(0,0,0,0.6); backdrop-filter: blur(16px);
		opacity: 0; visibility: hidden; transform: translateY(8px);
		transition: opacity 0.2s ease, transform 0.2s var(--ease), visibility 0.2s ease;
	}
	.top-search-dropdown::-webkit-scrollbar { width: 6px; }
	.top-search-dropdown::-webkit-scrollbar-thumb { background: rgba(148,163,184,0.28); border-radius: 999px; }
	.top-search-dropdown::-webkit-scrollbar-track { background: transparent; }
	.top-search-form:focus-within .top-search-dropdown,
	.top-search-dropdown.is-open { opacity: 1; visibility: visible; transform: translateY(0); }
	.top-search-suggestion {
		display: flex; align-items: center; gap: 10px; padding: 10px 14px;
		font-size: 0.8rem; color: #94a3b8; cursor: pointer;
		transition: background 0.15s ease, color 0.15s ease;
	}
	.top-search-suggestion:hover { background: rgba(123,97,241,0.12); color: #f8fafc; }
	.top-search-suggestion svg { width: 14px; height: 14px; color: #64748b; flex-shrink: 0; }
	.page-top-actions .top-action-btn {
		position: relative; display: inline-flex; align-items: center; justify-content: center;
		width: 40px; height: 40px; border-radius: 10px;
		background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1);
		color: #cbd5e1; cursor: pointer; text-decoration: none;
		transition: color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s var(--ease);
		backdrop-filter: blur(14px);
	}
	.page-top-actions .top-action-btn:hover {
		color: #e2e8f0; border-color: rgba(148,163,184,0.3);
		transform: translateY(-1px); background: rgba(255,255,255,0.06);
	}
	.page-top-actions .top-action-btn svg {
		width: 18px; height: 18px; fill: none; stroke: currentColor;
		stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round;
	}

	/* ── Friend Requests Button (matches top-action-btn) ── */
	.nav-friends-btn {
		position: relative; display: inline-flex; align-items: center; justify-content: center;
		width: 40px; height: 40px; border-radius: 10px;
		background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1);
		color: #cbd5e1; cursor: pointer; text-decoration: none;
		transition: color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s var(--ease);
		backdrop-filter: blur(14px);
	}
	.nav-friends-btn:hover {
		color: #e2e8f0; border-color: rgba(148,163,184,0.3);
		transform: translateY(-1px); background: rgba(255,255,255,0.06);
	}
	.nav-friends-btn:active { transform: translateY(0) scale(0.97); }
	.nav-friends-btn svg {
		width: 18px; height: 18px; fill: none; stroke: currentColor;
		stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round;
	}

	/* ── Friend Requests Button & Panel ── */
	.nav-friends-badge {
		position: absolute; top: 6px; right: 6px; min-width: 14px; height: 14px;
		padding: 0 3px; border-radius: 999px;
		display: inline-flex; align-items: center; justify-content: center;
		font-size: 0.6rem; font-weight: 700; line-height: 1; color: #fff;
		background: linear-gradient(135deg, #fbbf24, #f472b6);
		border: 1px solid rgba(255,255,255,0.22);
		box-shadow: 0 0 10px rgba(245,158,11,0.42);
		animation: notifBadgePulse 2.2s ease-in-out infinite;
	}
	.nav-friends-panel {
		position: absolute; top: calc(100% + 10px); right: 0; width: min(92vw, 360px);
		border-radius: 16px; overflow: hidden;
		background: radial-gradient(120% 120% at 100% 0%, rgba(245,158,11,0.08), transparent 38%), linear-gradient(180deg, rgba(17,21,33,0.98), rgba(10,13,23,0.98));
		border: 1px solid rgba(255,255,255,0.12);
		box-shadow: 0 24px 58px rgba(0,0,0,0.6), 0 0 0 1px rgba(245,158,11,0.08), 0 0 28px rgba(245,158,11,0.12);
		backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
		opacity: 0; visibility: hidden; transform: translateY(10px) scale(0.98);
		transform-origin: top right;
		transition: opacity 0.22s ease, transform 0.22s var(--ease), visibility 0.22s ease;
		z-index: 1200;
	}
	.nav-friends-panel.is-open { opacity: 1; visibility: visible; transform: translateY(0) scale(1); }
	.nav-friends-panel::before {
		content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
		background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
		pointer-events: none;
	}
	.nav-friends-head {
		display: flex; align-items: center; justify-content: space-between;
		padding: 14px 14px 10px; border-bottom: 1px solid rgba(255,255,255,0.08);
	}
	.nav-friends-title { font-size: 0.95rem; font-weight: 700; color: #f8fafc; }
	.nav-friends-list { list-style: none; max-height: 340px; overflow-y: auto; margin: 0; padding: 0; }
	.nav-friends-list::-webkit-scrollbar { width: 8px; }
	.nav-friends-list::-webkit-scrollbar-thumb { background: rgba(148,163,184,0.28); border-radius: 999px; }
	.nav-friends-list::-webkit-scrollbar-track { background: transparent; }
	.nav-friends-empty { padding: 24px; text-align: center; color: #64748b; font-size: 0.84rem; }
	.nav-fr-item {
		display: flex; align-items: center; gap: 10px;
		padding: 11px 14px; border-bottom: 1px solid rgba(255,255,255,0.06);
		transition: background 0.2s ease;
	}
	.nav-fr-item:hover { background: rgba(255,255,255,0.04); }
	.nav-fr-item:last-child { border-bottom: 0; }
	.nav-fr-avatar {
		width: 38px; height: 38px; border-radius: 50%; flex-shrink: 0;
		display: inline-flex; align-items: center; justify-content: center;
		font-size: 1rem; font-weight: 700; color: #f8fafc;
		background: linear-gradient(135deg, rgba(123,97,241,0.3), rgba(56,189,209,0.3));
		border: 1px solid rgba(255,255,255,0.14); overflow: hidden;
	}
	.nav-fr-avatar img { width: 100%; height: 100%; object-fit: cover; }
	.nav-fr-info { flex: 1; min-width: 0; }
	.nav-fr-name { font-size: 0.85rem; font-weight: 600; color: #f8fafc; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
	.nav-fr-role {
		display: inline-flex; align-items: center; gap: 3px;
		font-size: 0.68rem; font-weight: 600; padding: 2px 7px; border-radius: 999px; margin-top: 2px;
	}
	.nav-fr-role.role-student { background: rgba(34,211,238,0.15); color: #22d3ee; }
	.nav-fr-role.role-expert { background: rgba(250,204,21,0.15); color: #facc15; }
	.nav-fr-role.role-teacher { background: rgba(168,85,247,0.15); color: #a855f7; }
	.nav-fr-role.role-admin { background: rgba(239,68,68,0.15); color: #ef4444; }

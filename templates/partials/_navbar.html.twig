<!-- Floating Admin Button — Premium -->
<style>
.admin-fab{position:fixed;bottom:32px;left:32px;z-index:9000;text-decoration:none;display:flex;align-items:center;gap:0;cursor:pointer;-webkit-user-select:none;user-select:none;filter:drop-shadow(0 8px 24px rgba(123,97,241,.25))}

/* Outer glow ring */
.admin-fab-ring{position:absolute;inset:-8px;border-radius:24px;border:2px solid transparent;background:conic-gradient(from 0deg,#7b61f1,#38bdd1,#34d399,#fb923c,#f87171,#7b61f1) border-box;-webkit-mask:linear-gradient(#fff 0 0) padding-box,linear-gradient(#fff 0 0);mask:linear-gradient(#fff 0 0) padding-box,linear-gradient(#fff 0 0);-webkit-mask-composite:xor;mask-composite:exclude;animation:adminRingSpin 4s linear infinite;opacity:0;transition:opacity .4s}
.admin-fab:hover .admin-fab-ring{opacity:.7}

/* Core button */
.admin-fab-core{width:60px;height:60px;border-radius:18px;background:linear-gradient(135deg,#7b61f1 0%,#a855f7 30%,#f87171 60%,#fb923c 100%);background-size:300% 300%;animation:adminFabGrad 6s ease infinite;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 32px rgba(123,97,241,.4),0 0 0 1px rgba(255,255,255,.08),inset 0 1px 0 rgba(255,255,255,.2);transition:all .4s cubic-bezier(.4,0,.2,1);position:relative;overflow:visible}

/* Glass reflection */
.admin-fab-core::before{content:'';position:absolute;inset:0;border-radius:18px;background:linear-gradient(135deg,rgba(255,255,255,.25) 0%,rgba(255,255,255,.05) 40%,transparent 60%);pointer-events:none;z-index:2}

/* Hover glow aura */
.admin-fab-core::after{content:'';position:absolute;inset:-12px;border-radius:30px;background:radial-gradient(circle,rgba(123,97,241,.3),rgba(248,113,113,.15),transparent 70%);z-index:-1;opacity:0;transition:opacity .4s;animation:adminAuraPulse 3s ease-in-out infinite}
.admin-fab:hover .admin-fab-core{transform:scale(1.12) rotate(-8deg);box-shadow:0 16px 48px rgba(123,97,241,.5),0 0 30px rgba(248,113,113,.2),0 0 0 1px rgba(255,255,255,.12),inset 0 1px 0 rgba(255,255,255,.3)}
.admin-fab:hover .admin-fab-core::after{opacity:1}

/* Crown icon */
.admin-fab-icon{color:#fff;font-size:1.7rem;filter:drop-shadow(0 2px 6px rgba(0,0,0,.4));transition:all .4s cubic-bezier(.4,0,.2,1);z-index:3;position:relative}
.admin-fab:hover .admin-fab-icon{transform:rotate(20deg) scale(1.2);filter:drop-shadow(0 0 8px rgba(255,255,255,.4)) drop-shadow(0 2px 6px rgba(0,0,0,.4))}

/* Floating crown sparkles */
.admin-fab-sparkle{position:absolute;z-index:4;opacity:0;transition:opacity .3s}
.admin-fab:hover .admin-fab-sparkle{opacity:1}
.admin-fab-sparkle i{position:absolute;color:#fbbf24;font-size:.6rem;animation:sparkleFloat 1.5s ease-in-out infinite}
.admin-fab-sparkle i:nth-child(1){top:-8px;left:8px;animation-delay:0s}
.admin-fab-sparkle i:nth-child(2){top:-4px;right:6px;animation-delay:.3s}
.admin-fab-sparkle i:nth-child(3){top:2px;left:-2px;animation-delay:.6s}

/* Expanding label */
.admin-fab-label{max-width:0;overflow:hidden;white-space:nowrap;font-size:.82rem;font-weight:800;letter-spacing:.03em;color:#fff;background:linear-gradient(135deg,rgba(123,97,241,.92),rgba(168,85,247,.9),rgba(248,113,113,.88));backdrop-filter:blur(16px);padding:12px 0;border-radius:0 14px 14px 0;margin-left:-6px;transition:all .4s cubic-bezier(.25,.46,.45,.94);box-shadow:0 4px 20px rgba(0,0,0,.25),inset 0 1px 0 rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.08);border-left:none}
.admin-fab:hover .admin-fab-label{max-width:160px;padding:12px 20px 12px 16px}

/* Live ping dot */
.admin-fab-ping{position:absolute;top:-3px;right:-3px;width:16px;height:16px;border-radius:50%;z-index:5}
.admin-fab-ping::before{content:'';position:absolute;inset:0;border-radius:50%;background:#34d399;animation:adminPing 2s ease-in-out infinite}
.admin-fab-ping::after{content:'';position:absolute;inset:3px;border-radius:50%;background:#34d399;box-shadow:0 0 8px rgba(52,211,153,.6)}

/* Particle burst */
.admin-fab-particles{position:absolute;inset:-24px;pointer-events:none;z-index:0}
.admin-fab-particles span{position:absolute;width:5px;height:5px;border-radius:50%;opacity:0}
.admin-fab:hover .admin-fab-particles span{animation:adminParticle .8s ease-out forwards}
.admin-fab:hover .admin-fab-particles span:nth-child(1){background:#38bdd1;top:5%;left:15%;animation-delay:0s}
.admin-fab:hover .admin-fab-particles span:nth-child(2){background:#fb923c;top:20%;left:85%;animation-delay:.06s}
.admin-fab:hover .admin-fab-particles span:nth-child(3){background:#34d399;top:75%;left:5%;animation-delay:.12s}
.admin-fab:hover .admin-fab-particles span:nth-child(4){background:#fbbf24;top:85%;left:75%;animation-delay:.18s}
.admin-fab:hover .admin-fab-particles span:nth-child(5){background:#7b61f1;top:45%;left:50%;animation-delay:.08s}
.admin-fab:hover .admin-fab-particles span:nth-child(6){background:#f87171;top:10%;left:60%;animation-delay:.14s}
.admin-fab:hover .admin-fab-particles span:nth-child(7){background:#a855f7;top:60%;left:90%;animation-delay:.1s}
.admin-fab:hover .admin-fab-particles span:nth-child(8){background:#38bdd1;top:90%;left:40%;animation-delay:.2s}

/* Entrance animation */
.admin-fab{animation:adminFabEntrance .8s cubic-bezier(.34,1.56,.64,1) .5s backwards}

@keyframes adminFabEntrance{from{opacity:0;transform:translateY(40px) scale(.5) rotate(30deg)}to{opacity:1;transform:translateY(0) scale(1) rotate(0)}}
@keyframes adminFabGrad{0%,100%{background-position:0% 50%}33%{background-position:100% 0%}66%{background-position:50% 100%}}
@keyframes adminRingSpin{to{transform:rotate(360deg)}}
@keyframes adminPing{0%,100%{transform:scale(1);opacity:.7}50%{transform:scale(2.5);opacity:0}}
@keyframes adminAuraPulse{0%,100%{transform:scale(1);opacity:0}50%{transform:scale(1.08);opacity:.5}}
@keyframes adminParticle{0%{transform:translate(0,0) scale(1);opacity:1}100%{transform:translate(calc(var(--px,20)*1px),calc(var(--py,-30)*1px)) scale(0);opacity:0}}
@keyframes sparkleFloat{0%,100%{transform:translateY(0) scale(1);opacity:.8}50%{transform:translateY(-6px) scale(1.3);opacity:1}}

@media(max-width:768px){.admin-fab{bottom:20px;left:20px}.admin-fab-core{width:52px;height:52px;border-radius:15px}.admin-fab-icon{font-size:1.4rem}.admin-fab-ring{inset:-6px;border-radius:21px}}
</style>

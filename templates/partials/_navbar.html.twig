<!-- ═══════ PRIVATE CHAT WIDGET ═══════ -->
<style>
	/* ── Chat FAB ── */
	.chat-fab {
		position: fixed; bottom: 28px; right: 104px; z-index: 9000;
		width: 56px; height: 56px; border-radius: 50%; border: none; cursor: pointer;
		background: linear-gradient(135deg, #06b6d4 0%, #0891b2 50%, #0e7490 100%);
		box-shadow: 0 8px 32px rgba(6,182,212,0.45), 0 0 0 0 rgba(6,182,212,0.25), inset 0 1px 0 rgba(255,255,255,0.22);
		display: flex; align-items: center; justify-content: center;
		transition: transform 0.4s cubic-bezier(0.22,1,0.36,1), box-shadow 0.4s ease;
		animation: chatFabPulse 3s ease-in-out infinite;
	}
	.chat-fab::before {
		content: ''; position: absolute; inset: -3px; border-radius: 50%; z-index: -1;
		background: conic-gradient(from 0deg, #06b6d4, #8b5cf6, #06b6d4);
		opacity: 0; transition: opacity 0.4s ease;
		animation: chatFabRing 4s linear infinite;
	}
	.chat-fab:hover::before { opacity: 0.6; }
	.chat-fab:hover { transform: scale(1.1); box-shadow: 0 12px 44px rgba(6,182,212,0.6), inset 0 1px 0 rgba(255,255,255,0.22); }
	.chat-fab.is-open { animation: none; transform: rotate(0deg); }
	.chat-fab.is-open::before { display: none; }
	.chat-fab svg { width: 24px; height: 24px; fill: #fff; transition: transform 0.3s ease; filter: drop-shadow(0 1px 2px rgba(0,0,0,0.3)); }
	.chat-fab.is-open .chat-fab-icon { display: none; }
	.chat-fab.is-open .chat-fab-close { display: block; }
	.chat-fab-close { display: none; }
	.chat-fab-badge {
		position: absolute; top: -2px; right: -2px; min-width: 20px; height: 20px;
		padding: 0 5px;
		background: linear-gradient(135deg, #ef4444, #f97316); border-radius: 999px; border: 2px solid #080b14;
		font-size: 0.65rem; font-weight: 800; color: #fff;
		display: none; align-items: center; justify-content: center;
		animation: aiBadgePop 0.4s cubic-bezier(0.22,1,0.36,1);
	}
	.chat-fab-badge.has-unread { display: flex; }
	@keyframes chatFabPulse {
		0%, 100% { box-shadow: 0 8px 32px rgba(6,182,212,0.45), 0 0 0 0 rgba(6,182,212,0.2), inset 0 1px 0 rgba(255,255,255,0.22); }
		50% { box-shadow: 0 8px 32px rgba(6,182,212,0.45), 0 0 0 14px rgba(6,182,212,0), inset 0 1px 0 rgba(255,255,255,0.22); }
	}
	@keyframes chatFabRing { to { transform: rotate(360deg); } }

	/* ── Chat Panel ── */
	.chat-panel {
		position: fixed; bottom: 96px; right: 28px; z-index: 8998;
		width: 480px; height: 580px; max-height: calc(100vh - 120px);
		border-radius: 24px; overflow: hidden;
		background: linear-gradient(180deg, #0e1225 0%, #080b14 100%);
		border: 1px solid rgba(6,182,212,0.15);
		box-shadow: 0 40px 100px rgba(0,0,0,0.7), 0 0 0 1px rgba(6,182,212,0.08), 0 0 60px rgba(6,182,212,0.06);
		display: flex; flex-direction: column;
		opacity: 0; visibility: hidden; transform: translateY(24px) scale(0.92);
		transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.22,1,0.36,1), visibility 0.4s ease;
		backdrop-filter: blur(20px);
	}
	.chat-panel.is-open { opacity: 1; visibility: visible; transform: translateY(0) scale(1); }

	/* ── Chat Header ── */
	.chat-head {
		padding: 16px 18px 12px; display: flex; align-items: center; gap: 12px;
		border-bottom: 1px solid rgba(255,255,255,0.06);
		background: linear-gradient(135deg, rgba(6,182,212,0.08), rgba(139,92,246,0.04));
		position: relative; flex-shrink: 0;
	}
	.chat-head::after {
		content: ''; position: absolute; bottom: 0; left: 18px; right: 18px; height: 1px;
		background: linear-gradient(90deg, transparent, rgba(6,182,212,0.3), transparent);
	}
	.chat-head-icon {
		width: 38px; height: 38px; border-radius: 12px; flex-shrink: 0;
		background: linear-gradient(135deg, #06b6d4, #8b5cf6);
		display: flex; align-items: center; justify-content: center;
		box-shadow: 0 4px 16px rgba(6,182,212,0.3);
	}
	.chat-head-icon svg { width: 20px; height: 20px; fill: #fff; }
	.chat-head-info { flex: 1; }
	.chat-head-info h3 { font-size: 0.92rem; font-weight: 700; color: #fff; margin: 0; }
	.chat-head-info p {
		font-size: 0.7rem; color: #67e8f9; margin: 2px 0 0; font-weight: 500;
		display: flex; align-items: center; gap: 5px;
	}
	.chat-head-info p::before {
		content: ''; width: 6px; height: 6px; border-radius: 50%; background: #34d399;
		box-shadow: 0 0 8px rgba(52,211,153,0.6);
	}
	.chat-head-back {
		width: 32px; height: 32px; border-radius: 8px; border: none; cursor: pointer;
		background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.5);
		display: none; align-items: center; justify-content: center;
		transition: all 0.2s ease;
	}
	.chat-head-back:hover { background: rgba(255,255,255,0.1); color: #fff; }
	.chat-head-back svg { width: 16px; height: 16px; stroke: currentColor; stroke-width: 2; fill: none; }
	.chat-panel.in-conversation .chat-head-back { display: flex; }

	/* ── Contacts view ── */
	.chat-contacts {
		flex: 1; overflow-y: auto; display: flex; flex-direction: column;
		scrollbar-width: thin; scrollbar-color: rgba(6,182,212,0.2) transparent;
	}
	.chat-contacts::-webkit-scrollbar { width: 4px; }
	.chat-contacts::-webkit-scrollbar-thumb { background: rgba(6,182,212,0.25); border-radius: 99px; }
	.chat-panel.in-conversation .chat-contacts { display: none; }
	.chat-panel.in-conversation .chat-search-bar { display: none; }
	.chat-panel.in-conversation .chat-filter-chips { display: none; }
	.chat-section-label {
		padding: 12px 18px 6px; font-size: 0.62rem; font-weight: 700;
		text-transform: uppercase; letter-spacing: 0.1em; color: rgba(103,232,249,0.6);
		display: flex; align-items: center; gap: 8px;
	}
	.chat-section-label::after {
		content: ''; flex: 1; height: 1px;
		background: linear-gradient(90deg, rgba(6,182,212,0.15), transparent);
	}
	.chat-contact {
		display: flex; align-items: center; gap: 11px;
		padding: 10px 18px; cursor: pointer;
		transition: background 0.2s ease;
		border-bottom: 1px solid rgba(255,255,255,0.03);
	}
	.chat-contact:hover { background: rgba(6,182,212,0.06); }
	.chat-contact-avatar {
		width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
		display: flex; align-items: center; justify-content: center;
		font-size: 0.9rem; font-weight: 700; color: #f8fafc;
		background: linear-gradient(135deg, rgba(6,182,212,0.3), rgba(139,92,246,0.3));
		border: 1px solid rgba(255,255,255,0.12);
		position: relative; overflow: hidden;
	}
	.chat-contact-avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
	.chat-contact-online {
		position: absolute; bottom: 0; right: 0; width: 10px; height: 10px;
		border-radius: 50%; background: #34d399; border: 2px solid #0e1225;
	}
	.chat-contact-info { flex: 1; min-width: 0; }
	.chat-contact-name {
		font-size: 0.82rem; font-weight: 600; color: #f8fafc;
		white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
	}
	.chat-contact-role {
		display: inline-flex; align-items: center; gap: 3px;
		font-size: 0.62rem; font-weight: 600; padding: 1px 6px; border-radius: 999px; margin-top: 2px;
	}
	.chat-contact-role.role-teacher { background: rgba(168,85,247,0.15); color: #a855f7; }
	.chat-contact-role.role-expert { background: rgba(250,204,21,0.15); color: #facc15; }
	.chat-contact-role.role-admin { background: rgba(239,68,68,0.15); color: #ef4444; }
	.chat-contact-role.role-student { background: rgba(34,211,238,0.15); color: #22d3ee; }
	.chat-contact-role.role-default { background: rgba(148,163,184,0.15); color: #94a3b8; }
	.chat-contact-preview {
		font-size: 0.72rem; color: #64748b; margin-top: 1px;
		white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
	}
	.chat-contact-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; flex-shrink: 0; }
	.chat-contact-time { font-size: 0.6rem; color: #475569; }
	.chat-contact-unread {
		min-width: 18px; height: 18px; padding: 0 4px; border-radius: 999px;
		background: linear-gradient(135deg, #06b6d4, #8b5cf6);
		font-size: 0.6rem; font-weight: 700; color: #fff;
		display: flex; align-items: center; justify-content: center;
	}
	.chat-contacts-empty {
		padding: 30px; text-align: center; color: #475569; font-size: 0.8rem;
	}

	/* ── Chat Search & Filters ── */
	.chat-search-bar {
		padding: 10px 14px 6px; flex-shrink: 0;
	}
	.chat-search-wrap {
		display: flex; align-items: center; gap: 8px;
		background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
		border-radius: 10px; padding: 0 10px; height: 34px;
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}
	.chat-search-wrap:focus-within {
		border-color: rgba(6,182,212,0.3); box-shadow: 0 0 0 3px rgba(6,182,212,0.06);
	}
	.chat-search-wrap svg { width: 14px; height: 14px; stroke: #64748b; stroke-width: 2; fill: none; flex-shrink: 0; }
	.chat-search-wrap input {
		flex: 1; background: none; border: none; outline: none;
		color: #e2e8f0; font-size: 0.76rem; font-family: inherit;
	}
	.chat-search-wrap input::placeholder { color: rgba(148,163,184,0.4); }
	.chat-filter-chips {
		display: flex; gap: 5px; padding: 6px 14px 8px; flex-shrink: 0; flex-wrap: wrap;
	}
	.chat-filter-chip {
		padding: 4px 10px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.1);
		background: rgba(255,255,255,0.03); color: #94a3b8;
		font-size: 0.65rem; font-weight: 600; cursor: pointer; font-family: inherit;
		transition: all 0.2s ease; white-space: nowrap;
	}
	.chat-filter-chip:hover { background: rgba(255,255,255,0.06); color: #cbd5e1; }
	.chat-filter-chip.is-active {
		background: rgba(6,182,212,0.15); border-color: rgba(6,182,212,0.3); color: #67e8f9;
	}

	/* ── Conversation view ── */
	.chat-conversation {
		flex: 1; display: none; flex-direction: column; min-height: 0;
	}
	.chat-panel.in-conversation .chat-conversation { display: flex; }
	.chat-messages {
		flex: 1; overflow-y: auto; padding: 16px 16px; display: flex; flex-direction: column; gap: 8px;
		scrollbar-width: thin; scrollbar-color: rgba(6,182,212,0.2) transparent;
	}
	.chat-messages::-webkit-scrollbar { width: 4px; }
	.chat-messages::-webkit-scrollbar-thumb { background: rgba(6,182,212,0.25); border-radius: 99px; }
	.chat-msg {
		max-width: 80%; padding: 10px 14px; border-radius: 16px; font-size: 0.82rem; line-height: 1.55;
		animation: chatMsgIn 0.35s cubic-bezier(0.22,1,0.36,1) both;
		position: relative; word-wrap: break-word;
	}
	@keyframes chatMsgIn {
		from { opacity: 0; transform: translateY(10px) scale(0.97); }
		to { opacity: 1; transform: translateY(0) scale(1); }
	}
	.chat-msg.sent {
		align-self: flex-end;
		background: linear-gradient(135deg, #06b6d4, #0891b2);
		color: #fff; border-bottom-right-radius: 4px;
		box-shadow: 0 4px 16px rgba(6,182,212,0.2);
	}
	.chat-msg.received {
		align-self: flex-start; color: rgba(241,245,249,0.9);
		background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.07);
		border-bottom-left-radius: 4px;
	}
	.chat-msg-time {
		font-size: 0.58rem; color: rgba(255,255,255,0.35); margin-top: 4px;
		display: block; text-align: right;
	}
	.chat-msg.received .chat-msg-time { text-align: left; }
	.chat-msg-date-divider {
		text-align: center; font-size: 0.62rem; color: #475569;
		padding: 8px 0; font-weight: 600;
	}

	/* ── Chat Input ── */
	.chat-input-area {
		padding: 12px 14px; border-top: 1px solid rgba(255,255,255,0.06);
		background: rgba(255,255,255,0.02); flex-shrink: 0;
		position: relative;
	}
	.chat-input-area::before {
		content: ''; position: absolute; top: 0; left: 14px; right: 14px; height: 1px;
		background: linear-gradient(90deg, transparent, rgba(6,182,212,0.2), transparent);
	}
	.chat-input-wrap {
		display: flex; align-items: center; gap: 8px;
		background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);
		border-radius: 14px; padding: 4px 6px 4px 14px;
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}
	.chat-input-wrap:focus-within {
		border-color: rgba(6,182,212,0.3);
		box-shadow: 0 0 0 3px rgba(6,182,212,0.08);
	}
	.chat-input-wrap input {
		flex: 1; background: transparent; border: none; outline: none;
		color: #f1f5f9; font-size: 0.82rem; font-family: inherit; padding: 8px 0;
	}
	.chat-input-wrap input::placeholder { color: rgba(148,163,184,0.45); }
	.chat-send-btn {
		width: 34px; height: 34px; border-radius: 10px; border: none; cursor: pointer;
		background: linear-gradient(135deg, #06b6d4, #0891b2);
		display: flex; align-items: center; justify-content: center;
		transition: all 0.25s cubic-bezier(0.22,1,0.36,1); flex-shrink: 0;
		box-shadow: 0 2px 10px rgba(6,182,212,0.3);
	}
	.chat-send-btn:hover { transform: scale(1.08); box-shadow: 0 4px 20px rgba(6,182,212,0.5); }
	.chat-send-btn:active { transform: scale(0.95); }
	.chat-send-btn svg { width: 15px; height: 15px; fill: none; stroke: #fff; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
	.chat-panel.in-conversation .chat-input-area { display: flex; }
	.chat-panel:not(.in-conversation) .chat-input-area { display: none; }

	/* ── Responsive ── */
	@media (max-width: 640px) {
		.chat-panel { width: calc(100vw - 20px); right: 10px; bottom: 88px; height: 520px; border-radius: 20px; }
		.chat-fab { bottom: 20px; right: 80px; width: 50px; height: 50px; }
	}
</style>

<!-- Chat FAB Button -->
<button class="chat-fab" id="chatFab" type="button" aria-label="Open Private Chat">
	<svg class="chat-fab-icon" viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
	<svg class="chat-fab-close" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12" stroke="#fff" stroke-width="2.5" stroke-linecap="round" fill="none"/></svg>
	<span class="chat-fab-badge" id="chatFabBadge">0</span>
</button>

<!-- Chat Panel -->
<div class="chat-panel" id="chatPanel">
	<!-- Header -->
	<div class="chat-head">
		<button class="chat-head-back" id="chatBackBtn" type="button" title="Back to contacts">
			<svg viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
		</button>
		<div class="chat-head-icon" id="chatHeadIcon">
			<svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
		</div>
		<div class="chat-head-info">
			<h3 id="chatHeadTitle">Messages</h3>
			<p id="chatHeadSub">Talk to teachers & experts</p>
		</div>
	</div>

	<!-- Contacts List -->
	<div class="chat-search-bar">
		<div class="chat-search-wrap">
			<svg viewBox="0 0 16 16"><circle cx="7" cy="7" r="4.5"/><path d="M10.5 10.5 14 14" stroke-linecap="round"/></svg>
			<input type="text" id="chatSearchInput" placeholder="Search by name..." autocomplete="off">
		</div>
	</div>
	<div class="chat-filter-chips" id="chatFilterChips">
		<button class="chat-filter-chip is-active" data-role="all" type="button">All</button>
		<button class="chat-filter-chip" data-role="teacher" type="button">👨‍🏫 Teachers</button>
		<button class="chat-filter-chip" data-role="expert" type="button">⭐ Experts</button>
		<button class="chat-filter-chip" data-role="admin" type="button">🛡️ Admins</button>
		<button class="chat-filter-chip" data-role="student" type="button">🎓 Students</button>
		<button class="chat-filter-chip" data-role="friend" type="button">🤝 Friends</button>
	</div>
	<div class="chat-contacts" id="chatContacts">
		<div class="chat-contacts-empty">Loading contacts...</div>
	</div>

	<!-- Conversation View -->
	<div class="chat-conversation">
		<div class="chat-messages" id="chatMessages"></div>
	</div>

	<!-- Input -->
	<div class="chat-input-area">
		<div class="chat-input-wrap">
			<input type="text" id="chatInput" placeholder="Type a message..." autocomplete="off">
			<button class="chat-send-btn" id="chatSendBtn" type="button" aria-label="Send">
				<svg viewBox="0 0 24 24"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
			</button>
		</div>
	</div>
</div>

<script>
(function() {
	var fab = document.getElementById('chatFab');
	var panel = document.getElementById('chatPanel');
	var contactsEl = document.getElementById('chatContacts');
	var messagesEl = document.getElementById('chatMessages');
	var inputEl = document.getElementById('chatInput');
	var sendBtn = document.getElementById('chatSendBtn');
	var backBtn = document.getElementById('chatBackBtn');
	var headTitle = document.getElementById('chatHeadTitle');
	var headSub = document.getElementById('chatHeadSub');
	var headIcon = document.getElementById('chatHeadIcon');
	var badgeEl = document.getElementById('chatFabBadge');
	if (!fab || !panel) return;

	var currentContactId = null;
	var pollTimer = null;
	var sending = false;
	var allContactsData = null;
	var activeFilter = 'all';
	var searchQuery = '';
	var chatSearchInput = document.getElementById('chatSearchInput');
	var chatFilterChips = document.getElementById('chatFilterChips');

	function escapeHtml(t) {
		var d = document.createElement('div'); d.textContent = t; return d.innerHTML;
	}

	function timeAgo(dateStr) {
		var d = new Date(dateStr);
		var now = new Date();
		var diff = Math.floor((now - d) / 1000);
		if (diff < 60) return 'now';
		if (diff < 3600) return Math.floor(diff/60) + 'm';
		if (diff < 86400) return Math.floor(diff/3600) + 'h';
		return Math.floor(diff/86400) + 'd';
	}

	function fmtTime(dateStr) {
		var d = new Date(dateStr);
		return d.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
	}

	function getInitials(name) {
		return name.split(' ').map(function(w){ return w[0]; }).join('').substring(0,2).toUpperCase();
	}

	function getRoleClass(role) {
		if (role === 'teacher') return 'role-teacher';
		if (role === 'expert') return 'role-expert';
		if (role === 'admin') return 'role-admin';
		if (role === 'student') return 'role-student';
		return 'role-default';
	}

	function getRoleLabel(role) {
		if (role === 'teacher') return '👨‍🏫 Teacher';
		if (role === 'expert') return '⭐ Expert';
		if (role === 'admin') return '🛡️ Admin';
		if (role === 'student') return '🎓 Student';
		return role;
	}

	function renderAvatar(c) {
		if (c.avatar_base64) return '<img src="' + escapeHtml(c.avatar_base64) + '" alt="">';
		return getInitials(c.full_name || '?');
	}

	function updateBadge(count) {
		badgeEl.textContent = count;
		if (count > 0) { badgeEl.classList.add('has-unread'); }
		else { badgeEl.classList.remove('has-unread'); }
	}

	/* ── Load contacts ── */
	function loadContacts() {
		fetch('/chat/contacts', {credentials:'same-origin'})
		.then(function(r){ return r.json(); })
		.then(function(data) {
			updateBadge(data.totalUnread || 0);
			allContactsData = data;
			renderContacts();
		})
		.catch(function(){ contactsEl.innerHTML = '<div class="chat-contacts-empty">Could not load contacts</div>'; });
	}

	function matchesFilter(role) {
		if (activeFilter === 'all') return true;
		if (activeFilter === 'friend') return false;
		return role === activeFilter;
	}

	function matchesSearch(name) {
		if (!searchQuery) return true;
		return name.toLowerCase().indexOf(searchQuery.toLowerCase()) !== -1;
	}

	function renderContacts() {
		if (!allContactsData) return;
		var data = allContactsData;
		var html = '';

		// Teachers & Experts section
		var advisors = (data.advisors || []).filter(function(c){ return matchesFilter(c.role) && matchesSearch(c.full_name); });
		if (advisors.length) {
			html += '<div class="chat-section-label">👨‍🏫 Teachers & Experts</div>';
			advisors.forEach(function(c) {
				html += '<div class="chat-contact" data-id="'+c.id+'" data-name="'+escapeHtml(c.full_name)+'" data-role="'+escapeHtml(c.role)+'">' 
					+ '<div class="chat-contact-avatar">'+renderAvatar(c)+'<span class="chat-contact-online"></span></div>'
					+ '<div class="chat-contact-info">'
					+ '<div class="chat-contact-name">'+escapeHtml(c.full_name)+'</div>'
					+ '<span class="chat-contact-role '+getRoleClass(c.role)+'">'+getRoleLabel(c.role)+'</span>'
					+ '</div>'
					+ '</div>';
			});
		}

		// Admins section
		var admins = (data.admins || []).filter(function(c){ return matchesFilter(c.role) && matchesSearch(c.full_name); });
		if (admins.length) {
			html += '<div class="chat-section-label">🛡️ Admins</div>';
			admins.forEach(function(c) {
				html += '<div class="chat-contact" data-id="'+c.id+'" data-name="'+escapeHtml(c.full_name)+'" data-role="'+escapeHtml(c.role)+'">' 
					+ '<div class="chat-contact-avatar">'+renderAvatar(c)+'<span class="chat-contact-online"></span></div>'
					+ '<div class="chat-contact-info">'
					+ '<div class="chat-contact-name">'+escapeHtml(c.full_name)+'</div>'
					+ '<span class="chat-contact-role '+getRoleClass(c.role)+'">'+getRoleLabel(c.role)+'</span>'
					+ '</div>'
					+ '</div>';
			});
		}

		// Students section
		var students = (data.students || []).filter(function(c){ return matchesFilter(c.role) && matchesSearch(c.full_name); });
		if (students.length) {
			html += '<div class="chat-section-label">🎓 Students</div>';
			students.forEach(function(c) {
				html += '<div class="chat-contact" data-id="'+c.id+'" data-name="'+escapeHtml(c.full_name)+'" data-role="'+escapeHtml(c.role)+'">' 
					+ '<div class="chat-contact-avatar">'+renderAvatar(c)+'<span class="chat-contact-online"></span></div>'
					+ '<div class="chat-contact-info">'
					+ '<div class="chat-contact-name">'+escapeHtml(c.full_name)+'</div>'
					+ '<span class="chat-contact-role '+getRoleClass(c.role)+'">'+getRoleLabel(c.role)+'</span>'
					+ '</div>'
					+ '</div>';
			});
		}

		// Friends section
		var friends = (data.friends || []).filter(function(c){ return (activeFilter === 'all' || activeFilter === 'friend') && matchesSearch(c.full_name); });
		if (friends.length) {
			html += '<div class="chat-section-label">🤝 Friends</div>';
			friends.forEach(function(c) {
				html += '<div class="chat-contact" data-id="'+c.id+'" data-name="'+escapeHtml(c.full_name)+'" data-role="'+escapeHtml(c.role)+'">' 
					+ '<div class="chat-contact-avatar">'+renderAvatar(c)+'<span class="chat-contact-online"></span></div>'
					+ '<div class="chat-contact-info">'
					+ '<div class="chat-contact-name">'+escapeHtml(c.full_name)+'</div>'
					+ '<span class="chat-contact-role '+getRoleClass(c.role)+'">'+getRoleLabel(c.role)+' · Friend</span>'
					+ '</div>'
					+ '</div>';
			});
		}

		if (!html) html = '<div class="chat-contacts-empty">No contacts found</div>';
		contactsEl.innerHTML = html;

		// Attach click handlers
		contactsEl.querySelectorAll('.chat-contact').forEach(function(el) {
			el.addEventListener('click', function() {
				openConversation(
					parseInt(el.dataset.id),
					el.dataset.name,
					el.dataset.role
				);
			});
		});
	}

	/* ── Search & Filter ── */
	if (chatSearchInput) {
		chatSearchInput.addEventListener('input', function() {
			searchQuery = this.value;
			renderContacts();
		});
	}
	if (chatFilterChips) {
		chatFilterChips.addEventListener('click', function(e) {
			var chip = e.target.closest('.chat-filter-chip');
			if (!chip) return;
			chatFilterChips.querySelectorAll('.chat-filter-chip').forEach(function(c){ c.classList.remove('is-active'); });
			chip.classList.add('is-active');
			activeFilter = chip.dataset.role;
			renderContacts();
		});
	}

	/* ── Open conversation ── */
	function openConversation(contactId, name, role) {
		currentContactId = contactId;
		panel.classList.add('in-conversation');
		headTitle.textContent = name;
		headSub.innerHTML = '<span class="chat-contact-role '+getRoleClass(role)+'">'+getRoleLabel(role)+'</span>';
		messagesEl.innerHTML = '<div style="text-align:center;padding:20px;color:#475569;font-size:0.75rem;">Loading...</div>';
		inputEl.value = '';
		inputEl.focus();
		loadMessages();
		startPolling();
	}

	/* Expose for notification click */
	window.openChatWithUser = function(userId) {
		/* Open the chat panel if not already open */
		if (!panel.classList.contains('is-open')) {
			panel.classList.add('is-open');
			fab.classList.add('is-open');
		}
		/* Find the contact in our loaded data */
		var found = null;
		if (allContactsData) {
			var allContacts = (allContactsData.advisors||[]).concat(allContactsData.admins||[]).concat(allContactsData.students||[]).concat(allContactsData.friends||[]);
			for (var i = 0; i < allContacts.length; i++) {
				if (allContacts[i].id == userId) { found = allContacts[i]; break; }
			}
		}
		if (found) {
			openConversation(found.id, found.full_name, found.role);
		} else {
			/* Contact not yet loaded — fetch contacts first, then open */
			fetch('/chat/contacts', {credentials:'same-origin'})
			.then(function(r){ return r.json(); })
			.then(function(data) {
				allContactsData = data;
				renderContacts();
				var all2 = (data.advisors||[]).concat(data.admins||[]).concat(data.students||[]).concat(data.friends||[]);
				for (var j = 0; j < all2.length; j++) {
					if (all2[j].id == userId) { found = all2[j]; break; }
				}
				if (found) {
					openConversation(found.id, found.full_name, found.role);
				} else {
					/* fallback: open conversation with minimal info */
					openConversation(userId, 'User', 'student');
				}
			});
		}
	};

	/* ── Load messages ── */
	function loadMessages() {
		if (!currentContactId) return;
		fetch('/chat/messages/' + currentContactId, {credentials:'same-origin'})
		.then(function(r){ return r.json(); })
		.then(function(data) {
			var html = '';
			var lastDate = '';
			(data.messages || []).forEach(function(m) {
				var d = new Date(m.created_at);
				var dateStr = d.toLocaleDateString();
				if (dateStr !== lastDate) {
					html += '<div class="chat-msg-date-divider">'+dateStr+'</div>';
					lastDate = dateStr;
				}
				var cls = (m.sender_id == currentContactId) ? 'received' : 'sent';
				html += '<div class="chat-msg '+cls+'">'
					+ escapeHtml(m.content)
					+ '<span class="chat-msg-time">'+fmtTime(m.created_at)+'</span>'
					+ '</div>';
			});
			if (!html) html = '<div style="text-align:center;padding:40px 20px;color:#475569;font-size:0.8rem;">No messages yet. Say hello! 👋</div>';
			messagesEl.innerHTML = html;
			messagesEl.scrollTop = messagesEl.scrollHeight;
		});
	}

	/* ── Send message ── */
	function sendMessage() {
		var text = inputEl.value.trim();
		if (!text || sending || !currentContactId) return;
		sending = true;

		// Optimistic add
		var div = document.createElement('div');
		div.className = 'chat-msg sent';
		div.innerHTML = escapeHtml(text) + '<span class="chat-msg-time">' + fmtTime(new Date().toISOString()) + '</span>';
		messagesEl.appendChild(div);
		messagesEl.scrollTop = messagesEl.scrollHeight;
		inputEl.value = '';

		fetch('/chat/send', {
			method: 'POST',
			credentials: 'same-origin',
			headers: {'Content-Type':'application/json'},
			body: JSON.stringify({receiver_id: currentContactId, content: text})
		})
		.then(function(r){ return r.json(); })
		.then(function(data) {
			if (data.error) { div.style.opacity = '0.5'; div.title = data.error; }
		})
		.catch(function(){ div.style.opacity = '0.5'; })
		.finally(function(){ sending = false; });
	}

	/* ── Polling ── */
	function startPolling() {
		stopPolling();
		pollTimer = setInterval(function() {
			if (currentContactId && panel.classList.contains('is-open')) loadMessages();
		}, 5000);
	}
	function stopPolling() { if (pollTimer) { clearInterval(pollTimer); pollTimer = null; } }

	/* ── Back to contacts ── */
	backBtn.addEventListener('click', function() {
		panel.classList.remove('in-conversation');
		currentContactId = null;
		headTitle.textContent = 'Messages';
		headSub.textContent = 'Talk to teachers & experts';
		headIcon.innerHTML = '<svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" fill="#fff"/></svg>';
		stopPolling();
		loadContacts();
	});

	/* ── Toggle panel ── */
	fab.addEventListener('click', function() {
		var open = panel.classList.toggle('is-open');
		fab.classList.toggle('is-open', open);
		// Close AI chat if open
		var aiChat = document.getElementById('aiChat');
		var aiFab = document.getElementById('aiFab');
		if (open && aiChat && aiChat.classList.contains('is-open')) {
			aiChat.classList.remove('is-open');
			if (aiFab) aiFab.classList.remove('is-open');
		}
		if (open) {
			if (!panel.classList.contains('in-conversation')) loadContacts();
			else { inputEl.focus(); startPolling(); }
		} else { stopPolling(); }
	});

	/* ── Send events ── */
	sendBtn.addEventListener('click', sendMessage);
	inputEl.addEventListener('keydown', function(e) {
		if (e.key === 'Enter') { e.preventDefault(); sendMessage(); }
	});

	/* ── Close on outside click ── */
	document.addEventListener('click', function(e) {
		if (panel.classList.contains('is-open') && !panel.contains(e.target) && !fab.contains(e.target)) {
			panel.classList.remove('is-open');
			fab.classList.remove('is-open');
			stopPolling();
		}
	});
	document.addEventListener('keydown', function(e) {
		if (e.key === 'Escape' && panel.classList.contains('is-open')) {
			panel.classList.remove('is-open');
			fab.classList.remove('is-open');
			stopPolling();
		}
	});

	/* ── Initial badge check ── */
	fetch('/chat/unread-count', {credentials:'same-origin'})
	.then(function(r){ return r.json(); })
	.then(function(d){ updateBadge(d.count || 0); })
	.catch(function(){});

	/* ── Periodic badge check ── */
	setInterval(function() {
		if (!panel.classList.contains('is-open')) {
			fetch('/chat/unread-count', {credentials:'same-origin'})
			.then(function(r){ return r.json(); })
			.then(function(d){ updateBadge(d.count || 0); })
			.catch(function(){});
		}
	}, 30000);
})();
</script>

<!-- AI ASSISTANT CHAT WIDGET (all pages) -->
<style>
	/* ═══════ AI FAB BUTTON ═══════ */
	.ai-fab {
		position: fixed; bottom: 28px; right: 28px; z-index: 9000;
		width: 64px; height: 64px; border-radius: 50%; border: none; cursor: pointer;
		background: linear-gradient(135deg, #7b61f1 0%, #6d28d9 50%, #2563eb 100%);
		box-shadow: 0 8px 32px rgba(124,58,237,0.5), 0 0 0 0 rgba(124,58,237,0.3), inset 0 1px 0 rgba(255,255,255,0.2);
		display: flex; align-items: center; justify-content: center;
		transition: transform 0.4s cubic-bezier(0.22,1,0.36,1), box-shadow 0.4s ease;
		animation: aiFabPulse 3s ease-in-out infinite;
	}
	.ai-fab::before {
		content: ''; position: absolute; inset: -3px; border-radius: 50%; z-index: -1;
		background: conic-gradient(from 0deg, #7b61f1, #38bdd1, #7b61f1);
		opacity: 0; transition: opacity 0.4s ease;
		animation: aiFabRing 4s linear infinite;
	}
	.ai-fab:hover::before { opacity: 0.6; }
	.ai-fab:hover { transform: scale(1.1); box-shadow: 0 12px 44px rgba(124,58,237,0.65), inset 0 1px 0 rgba(255,255,255,0.2); }
	.ai-fab.is-open { animation: none; transform: rotate(0deg); }
	.ai-fab.is-open::before { display: none; }
	.ai-fab svg { width: 26px; height: 26px; fill: #fff; transition: transform 0.3s ease; filter: drop-shadow(0 1px 2px rgba(0,0,0,0.3)); }
	.ai-fab.is-open .ai-fab-chat { display: none; }
	.ai-fab.is-open .ai-fab-close { display: block; }
	.ai-fab-close { display: none; }
	.ai-fab-badge {
		position: absolute; top: -2px; right: -2px; width: 20px; height: 20px;
		background: #ef4444; border-radius: 50%; border: 2px solid #080b14;
		font-size: 0.65rem; font-weight: 800; color: #fff;
		display: flex; align-items: center; justify-content: center;
		animation: aiBadgePop 0.4s cubic-bezier(0.22,1,0.36,1);
	}
	@keyframes aiFabPulse {
		0%, 100% { box-shadow: 0 8px 32px rgba(124,58,237,0.5), 0 0 0 0 rgba(124,58,237,0.25), inset 0 1px 0 rgba(255,255,255,0.2); }
		50% { box-shadow: 0 8px 32px rgba(124,58,237,0.5), 0 0 0 16px rgba(124,58,237,0), inset 0 1px 0 rgba(255,255,255,0.2); }
	}
	@keyframes aiFabRing { to { transform: rotate(360deg); } }
	@keyframes aiBadgePop { from { transform: scale(0); } to { transform: scale(1); } }

	/* ═══════ CHAT PANEL ═══════ */
	.ai-chat {
		position: fixed; bottom: 104px; right: 28px; z-index: 8999;
		width: 420px; max-height: 620px; border-radius: 24px;
		background: linear-gradient(180deg, #0e1225 0%, #080b14 100%);
		border: 1px solid rgba(139,92,246,0.15);
		box-shadow: 0 40px 100px rgba(0,0,0,0.7), 0 0 0 1px rgba(139,92,246,0.08), 0 0 60px rgba(124,58,237,0.08);
		display: flex; flex-direction: column;
		opacity: 0; visibility: hidden; transform: translateY(24px) scale(0.92);
		transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.22,1,0.36,1), visibility 0.4s ease;
		overflow: hidden;
		backdrop-filter: blur(20px);
	}
	.ai-chat.is-open { opacity: 1; visibility: visible; transform: translateY(0) scale(1); }

	/* ═══════ HEADER ═══════ */
	.ai-chat-head {
		padding: 18px 20px 14px; display: flex; align-items: center; gap: 12px;
		border-bottom: 1px solid rgba(255,255,255,0.06);
		background: linear-gradient(135deg, rgba(124,58,237,0.08) 0%, rgba(56,189,209,0.04) 100%);
		position: relative;
	}
	.ai-chat-head::after {
		content: ''; position: absolute; bottom: 0; left: 20px; right: 20px; height: 1px;
		background: linear-gradient(90deg, transparent, rgba(139,92,246,0.3), transparent);
	}
	.ai-chat-avatar {
		width: 42px; height: 42px; border-radius: 14px; flex-shrink: 0;
		background: linear-gradient(135deg, #7b61f1, #38bdd1);
		display: flex; align-items: center; justify-content: center;
		box-shadow: 0 4px 16px rgba(124,58,237,0.3);
		position: relative; overflow: hidden;
	}
	.ai-chat-avatar::after {
		content: ''; position: absolute; inset: 0;
		background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, transparent 50%);
		border-radius: inherit;
	}
	.ai-chat-avatar svg { width: 22px; height: 22px; fill: #fff; position: relative; z-index: 1; }
	.ai-chat-head-info { flex: 1; }
	.ai-chat-head-info h3 { font-size: 0.95rem; font-weight: 700; color: #fff; margin: 0; letter-spacing: -0.01em; }
	.ai-chat-head-info p {

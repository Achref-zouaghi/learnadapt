<script>
(function() {
	const navbar = document.getElementById('navbar');
	const navNotifBtn = document.getElementById('navNotifBtn');
	const navNotifPanel = document.getElementById('navNotifPanel');
	const navNotifReadAll = document.getElementById('navNotifReadAll');
	const navNotifTabs = [...document.querySelectorAll('.nav-notif-tab[data-tab]')];
	const navNotifItems = [...document.querySelectorAll('.nav-notif-item[data-notif-category]')];
	const navNotifBadge = document.querySelector('.nav-notif-badge');
	const navNotifList = navNotifPanel ? navNotifPanel.querySelector('.nav-notif-list') : null;

	/* Navbar scroll state */
	let lastScrollY = window.scrollY;
	let navTicking = false;
	let navRevealTimer;
	function updateNavState() {
		const y = window.scrollY;
		const maxScroll = Math.max(document.documentElement.scrollHeight - window.innerHeight, 1);
		const scrollProgress = Math.min(100, Math.max(0, (y / maxScroll) * 100));
		navbar.style.setProperty('--scroll-progress', scrollProgress + '%');
		navbar.classList.toggle('scrolled', y > 20);
		navbar.classList.toggle('compact', y > 80);
		const delta = y - lastScrollY;
		if (y < 24) { navbar.classList.remove('is-hidden'); }
		else if (y > 220 && delta > 10) { navbar.classList.add('is-hidden'); }
		else if (delta < -8) {
			const wasHidden = navbar.classList.contains('is-hidden');
			navbar.classList.remove('is-hidden');
			if (wasHidden) {
				navbar.classList.add('is-reveal-bounce');
				clearTimeout(navRevealTimer);
				navRevealTimer = setTimeout(function() { navbar.classList.remove('is-reveal-bounce'); }, 560);
			}
		}
		lastScrollY = y;
		navTicking = false;
	}
	if (navbar) {
		updateNavState();
		window.addEventListener('scroll', function() {
			if (navTicking) return;
			navTicking = true;
			requestAnimationFrame(updateNavState);
		}, { passive: true });
	}

	/* Notification panel */
	if (navNotifBtn && navNotifPanel) {
		const updateNotifBadge = function() {
			if (!navNotifBadge) return;
			const unreadCount = navNotifItems.filter(function(i) { return i.dataset.unread === 'true'; }).length;
			navNotifBadge.textContent = unreadCount > 0 ? String(unreadCount) : '0';
			navNotifBadge.style.opacity = unreadCount > 0 ? '1' : '0.45';
			navNotifBtn.classList.toggle('has-unread', unreadCount > 0);
		};
		const setNotifTab = function(tabName) {
			navNotifTabs.forEach(function(tab) { tab.classList.toggle('is-active', tab.dataset.tab === tabName); });
			if (navNotifList) navNotifList.classList.add('is-switching');
			navNotifItems.forEach(function(item) { item.classList.toggle('is-hidden', item.dataset.notifCategory !== tabName); });
			if (navNotifList) requestAnimationFrame(function() { navNotifList.classList.remove('is-switching'); });
		};
		const closeNotifPanel = function() { navNotifPanel.classList.remove('is-open'); navNotifBtn.setAttribute('aria-expanded', 'false'); };
		const openNotifPanel = function() { navNotifPanel.classList.add('is-open'); navNotifBtn.setAttribute('aria-expanded', 'true'); };
		navNotifBtn.addEventListener('click', function(e) {
			e.stopPropagation();
			navNotifBtn.classList.remove('is-click-burst');
			requestAnimationFrame(function() { navNotifBtn.classList.add('is-click-burst'); });
			setTimeout(function() { navNotifBtn.classList.remove('is-click-burst'); }, 620);
			if (navNotifPanel.classList.contains('is-open')) closeNotifPanel(); else openNotifPanel();
		});
		navNotifTabs.forEach(function(tab) { tab.addEventListener('click', function() { setNotifTab(tab.dataset.tab); }); });
		if (navNotifReadAll) {
			navNotifReadAll.addEventListener('click', function() {
				navNotifItems.forEach(function(item) {
					item.dataset.unread = 'false';
					var dot = item.querySelector('.nav-notif-dot');
					if (dot) dot.classList.add('is-read');
				});
				updateNotifBadge();
			});
		}
		navNotifPanel.addEventListener('click', function(e) { e.stopPropagation(); });
		document.addEventListener('click', closeNotifPanel);
		document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeNotifPanel(); });
		setNotifTab('inbox');

		/* ── Click on PRIVATE_MESSAGE notification → open chat ── */
		navNotifItems.forEach(function(item) {
			var chatUserId = item.dataset.chatUserId;
			if (chatUserId) {
				item.addEventListener('click', function(e) {
					e.preventDefault();
					e.stopPropagation();
					/* Mark as read via the existing link */
					var link = item.querySelector('.nav-notif-link');
					if (link) {
						fetch(link.href, {credentials:'same-origin'}).catch(function(){});
					}
					/* Update UI to mark as read */
					item.dataset.unread = 'false';
					var dot = item.querySelector('.nav-notif-dot');
					if (dot) dot.classList.add('is-read');
					updateNotifBadge();
					closeNotifPanel();
					/* Open chat with sender */
					if (typeof window.openChatWithUser === 'function') {
						window.openChatWithUser(parseInt(chatUserId));
					}
				});
			}
		});
		updateNotifBadge();
	}

	/* ── FRIEND REQUESTS PANEL ── */
	(function() {
		var frBtn = document.getElementById('navFriendsBtn');
		var frPanel = document.getElementById('navFriendsPanel');
		var frList = document.getElementById('navFriendsList');
		var frBadge = document.getElementById('navFriendsBadge');
		if (!frBtn || !frPanel) return;

		function roleClass(role) {
			if (!role) return 'role-default';
			var r = role.toLowerCase();
			if (r === 'student') return 'role-student';
			if (r === 'expert') return 'role-expert';
			if (r === 'teacher') return 'role-teacher';
			if (r === 'admin') return 'role-admin';
			return 'role-default';
		}
		function roleIcon(role) {
			if (!role) return 'person';
			var r = role.toLowerCase();
			if (r === 'student') return 'school';
			if (r === 'expert') return 'workspace_premium';
			if (r === 'teacher') return 'menu_book';
			if (r === 'admin') return 'shield';
			return 'person';
		}
		function avatarHtml(req) {
			if (req.avatar_base64) return '<img src="' + req.avatar_base64 + '" alt="">';
			var name = req.full_name || '?';
			return name.charAt(0).toUpperCase();
		}

		function loadFriendRequests() {
			fetch('{{ path("app_friend_requests") }}')
				.then(function(r) { return r.json(); })
				.then(function(data) {
					var reqs = data.requests || [];
					if (frBadge) {
						if (reqs.length > 0) {
							frBadge.textContent = reqs.length;
							frBadge.style.display = '';
						} else {
							frBadge.style.display = 'none';
						}
					}
					if (reqs.length === 0) {
						frList.innerHTML = '<li class="nav-friends-empty">No pending requests</li>';
						return;
					}
					var html = '';
					reqs.forEach(function(req) {
						html += '<li class="nav-fr-item" data-id="' + req.id + '">'
							+ '<div class="nav-fr-avatar">' + avatarHtml(req) + '</div>'
							+ '<div class="nav-fr-info">'
							+ '<div class="nav-fr-name">' + (req.full_name || 'Unknown') + '</div>'
							+ '<span class="nav-fr-role ' + roleClass(req.role) + '"><span class="material-icons" style="font-size:11px">' + roleIcon(req.role) + '</span> ' + (req.role || 'User') + '</span>'
							+ '</div>'
							+ '<div class="nav-fr-actions">'
							+ '<button class="nav-fr-accept" title="Accept" onclick="friendAction(\'accept\',' + req.id + ',this)"><span class="material-icons" style="font-size:16px">check</span></button>'
							+ '<button class="nav-fr-decline" title="Decline" onclick="friendAction(\'decline\',' + req.id + ',this)"><span class="material-icons" style="font-size:16px">close</span></button>'
							+ '</div></li>';
					});
					frList.innerHTML = html;
				}).catch(function() {});
		}

		window.friendAction = function(action, reqId, btn) {
			var url = action === 'accept' ? '/friends/accept/' + reqId : '/friends/decline/' + reqId;
			fetch(url, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
				.then(function(r) { return r.json(); })
				.then(function(data) {
					if (data.success) {
						var item = btn.closest('.nav-fr-item');
						if (item) {
							item.style.transition = 'opacity 0.3s, transform 0.3s';
							item.style.opacity = '0';
							item.style.transform = 'translateX(' + (action === 'accept' ? '20px' : '-20px') + ')';
							setTimeout(function() {
								item.remove();
								var remaining = frList.querySelectorAll('.nav-fr-item').length;
								if (remaining === 0) {
									frList.innerHTML = '<li class="nav-friends-empty">No pending requests</li>';
								}
								if (frBadge) {
									if (remaining > 0) { frBadge.textContent = remaining; }
									else { frBadge.style.display = 'none'; }
								}
							}, 300);
						}
					}
				}).catch(function() {});
		};

		var closeFrPanel = function() { frPanel.classList.remove('is-open'); frBtn.setAttribute('aria-expanded', 'false'); };
		var openFrPanel = function() { frPanel.classList.add('is-open'); frBtn.setAttribute('aria-expanded', 'true'); loadFriendRequests(); };

		frBtn.addEventListener('click', function(e) {
			e.stopPropagation();
			if (frPanel.classList.contains('is-open')) { closeFrPanel(); } else { openFrPanel(); }
		});
		frPanel.addEventListener('click', function(e) { e.stopPropagation(); });
		document.addEventListener('click', closeFrPanel);
		document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeFrPanel(); });

		// Load badge count on page load
		loadFriendRequests();
	})();

	/* ── N1. MAGNETIC NAV LINKS ── */
	document.querySelectorAll('.nav-links a').forEach(function(link) {
		var ticking = false;
		link.addEventListener('mousemove', function(e) {
			if (ticking) return;
			ticking = true;
			requestAnimationFrame(function() {
				var r = link.getBoundingClientRect();
				var x = (e.clientX - r.left - r.width / 2) * 0.15;
				var y = (e.clientY - r.top - r.height / 2) * 0.15;
				link.style.transform = 'translate(' + x + 'px, ' + y + 'px)';
				ticking = false;
			});
		});
		link.addEventListener('mouseleave', function() { link.style.transform = ''; });
	});

	/* ── N6. PROFILE DROPDOWN ── */
	var profile = document.getElementById('navProfile');
	if (profile) {
		profile.addEventListener('click', function(e) {
			e.stopPropagation();
			profile.classList.toggle('is-open');
			profile.setAttribute('aria-expanded', profile.classList.contains('is-open'));
		});
		document.addEventListener('click', function() { profile.classList.remove('is-open'); });
	}

	/* ── N11. MEGA MENU SMOOTH SCROLL ── */
	document.querySelectorAll('.nav-mega-item').forEach(function(item) {
		item.addEventListener('click', function(e) {
			e.preventDefault();
			var href = item.getAttribute('href');
			var target = document.querySelector(href);
			if (target) target.scrollIntoView({ behavior: 'smooth' });
		});
	});

	/* ── N12. TOP SEARCH — PEOPLE SEARCH ── */
	(function() {
		var searchForm = document.querySelector('.top-search-form');
		if (!searchForm) return;
		var input = document.getElementById('topPeopleSearch');
		var dropdown = document.getElementById('topPeopleResults');
		if (!input || !dropdown) return;
		var timer = null;

		function roleClass(role) {
			if (!role) return 'role-default';
			var r = role.toLowerCase();
			if (r === 'student') return 'role-student';
			if (r === 'expert') return 'role-expert';
			if (r === 'teacher') return 'role-teacher';
			if (r === 'admin') return 'role-admin';
			return 'role-default';
		}
		function roleIcon(role) {
			if (!role) return 'person';
			var r = role.toLowerCase();
			if (r === 'student') return 'school';
			if (r === 'expert') return 'workspace_premium';
			if (r === 'teacher') return 'menu_book';
			if (r === 'admin') return 'shield';
			return 'person';
		}
		function avatarHtml(u) {
			if (u.avatar_base64) return '<img src="' + u.avatar_base64 + '" alt="" style="width:32px;height:32px;border-radius:50%;object-fit:cover;">';
			var name = u.full_name || '?';
			return '<span style="display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,rgba(123,97,241,0.3),rgba(56,189,209,0.3));font-weight:700;font-size:0.85rem;color:#f8fafc;">' + name.charAt(0).toUpperCase() + '</span>';
		}
		function friendBtnHtml(u) {
			if (u.friendship_status === 'accepted') return '<span style="font-size:0.72rem;color:#22c55e;font-weight:600;">✓ Friends</span>';
			if (u.friendship_status === 'pending') return '<span style="font-size:0.72rem;color:#f59e0b;font-weight:600;">⏳ Pending</span>';
			if (u.friendship_status === 'declined') return '<button class="search-add-friend" data-uid="' + u.id + '" style="font-size:0.72rem;padding:3px 10px;border-radius:999px;background:rgba(123,97,241,0.2);color:#a78bfa;border:1px solid rgba(123,97,241,0.3);cursor:pointer;transition:all 0.2s;">Add Friend</button>';
			return '<button class="search-add-friend" data-uid="' + u.id + '" style="font-size:0.72rem;padding:3px 10px;border-radius:999px;background:rgba(123,97,241,0.2);color:#a78bfa;border:1px solid rgba(123,97,241,0.3);cursor:pointer;transition:all 0.2s;">Add Friend</button>';
		}

		searchForm.addEventListener('submit', function(e) { e.preventDefault(); });

		// Keep dropdown open while interacting with it
		dropdown.addEventListener('mousedown', function(e) { e.preventDefault(); });

		input.addEventListener('input', function() {
			clearTimeout(timer);
			var q = input.value.trim();
			if (q.length < 2) {
				dropdown.innerHTML = '<div class="top-search-hint" style="padding:14px;color:#64748b;font-size:0.82rem;text-align:center;">Type a name to search for people</div>';
				return;
			}
			timer = setTimeout(function() {
				fetch('{{ path("app_friend_search") }}?q=' + encodeURIComponent(q))
					.then(function(r) { return r.json(); })
					.then(function(data) {
						var results = data.results || [];
						if (results.length === 0) {
							dropdown.innerHTML = '<div style="padding:14px;color:#64748b;font-size:0.82rem;text-align:center;">No people found</div>';
							return;
						}
						var html = '';
						results.forEach(function(u) {
							html += '<div class="search-person-item" style="display:flex;align-items:center;gap:10px;padding:9px 14px;cursor:pointer;transition:background 0.15s;" onmouseover="this.style.background=\'rgba(123,97,241,0.08)\'" onmouseout="this.style.background=\'transparent\'">'
								+ '<div>' + avatarHtml(u) + '</div>'
								+ '<div style="flex:1;min-width:0;">'
								+ '<div style="font-size:0.84rem;font-weight:600;color:#f8fafc;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + (u.full_name || 'Unknown') + '</div>'
								+ '<span class="nav-fr-role ' + roleClass(u.role) + '" style="display:inline-flex;align-items:center;gap:3px;font-size:0.66rem;font-weight:600;padding:1px 6px;border-radius:999px;margin-top:1px;"><span class="material-icons" style="font-size:10px">' + roleIcon(u.role) + '</span> ' + (u.role || 'User') + '</span>'
								+ '</div>'
								+ '<div>' + friendBtnHtml(u) + '</div>'
								+ '</div>';
						});
						dropdown.innerHTML = html;
						// Bind add friend buttons
						dropdown.querySelectorAll('.search-add-friend').forEach(function(btn) {
							btn.addEventListener('click', function(e) {
								e.stopPropagation();
								var uid = btn.dataset.uid;
								btn.disabled = true;
								btn.textContent = 'Sending...';
								fetch('/friends/send/' + uid, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
									.then(function(r) { return r.json(); })
									.then(function(data) {
										if (data.success) {
											btn.outerHTML = '<span style="font-size:0.72rem;color:#f59e0b;font-weight:600;">⏳ Pending</span>';
										} else if (data.status === 'exists') {
											btn.outerHTML = '<span style="font-size:0.72rem;color:#f59e0b;font-weight:600;">⏳ Pending</span>';
										} else {
											btn.textContent = 'Error';
										}
									}).catch(function() { btn.textContent = 'Error'; });
							});
						});
					}).catch(function() {
						dropdown.innerHTML = '<div style="padding:14px;color:#ef4444;font-size:0.82rem;text-align:center;">Search failed</div>';
					});
			}, 300);
		});
	})();

	/* ── N13. PROGRESS BAR GLOW PARTICLE ── */
	var particle = document.getElementById('progressParticle');
	if (particle && navbar) {
		window.addEventListener('scroll', function() {
			var progress = Math.min(window.scrollY / (document.body.scrollHeight - window.innerHeight), 1);
			particle.style.left = (progress * navbar.offsetWidth) + 'px';
		}, { passive: true });
	}

	/* ── N14. MOBILE HAMBURGER ── */
	var hBtn = document.getElementById('navHamburger');
	var shell = document.querySelector('.nav-menu-shell');
	if (hBtn && shell) {
		hBtn.addEventListener('click', function() {
			hBtn.classList.toggle('is-open');
			shell.classList.toggle('is-mobile-open');
		});
	}

	/* ── N15. BREADCRUMB MODE ── */
	(function() {
		var breadcrumb = document.getElementById('navBreadcrumb');
		var currentEl = document.getElementById('breadcrumbCurrent');
		if (!breadcrumb || !currentEl) return;
		var sections = [
			{ sel: '.hero', name: 'Hero' },
			{ sel: '.dashboard-section', name: 'Dashboard' },
			{ sel: '.steps-section', name: 'Home' },
			{ sel: '.features-section', name: 'Features' },
			{ sel: '.pricing-section', name: 'Pricing' },
			{ sel: '#faq', name: 'FAQ' },
			{ sel: '.cta-section', name: 'Get Started' },
		];
		window.addEventListener('scroll', function() {
			var scrolled = window.scrollY > 300;
			breadcrumb.classList.toggle('is-visible', scrolled);
			if (scrolled) {
				var y = window.scrollY + window.innerHeight / 3;
				var current = 'Hero';
				sections.forEach(function(s) {
					var el = document.querySelector(s.sel);
					if (el && el.offsetTop <= y) current = s.name;
				});
				currentEl.textContent = current;
			}
		}, { passive: true });
	})();

	/* ── N16. NOTIFICATION SOUNDS ── */
	(function() {
		var AudioCtx = window.AudioContext || window.webkitAudioContext;
		if (!AudioCtx) return;
		var ctx = null;
		var muted = false;
		var soundBtn = document.getElementById('soundToggle');
		if (soundBtn) {
			soundBtn.addEventListener('click', function() {
				muted = !muted;
				soundBtn.classList.toggle('is-muted', muted);
				soundBtn.textContent = muted ? '\uD83D\uDD15' : '\uD83D\uDD14';
			});
		}
		function playTone(freq, dur, type) {
			if (muted) return;
			if (!ctx) ctx = new AudioCtx();
			var osc = ctx.createOscillator();
			var gain = ctx.createGain();
			osc.type = type || 'sine';
			osc.frequency.setValueAtTime(freq, ctx.currentTime);
			gain.gain.setValueAtTime(0.06, ctx.currentTime);
			gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + dur);
			osc.connect(gain); gain.connect(ctx.destination);
			osc.start(); osc.stop(ctx.currentTime + dur);
		}
		var bellBtn = document.getElementById('navNotifBtn');
		if (bellBtn) {
			bellBtn.addEventListener('click', function() {
				playTone(880, 0.12, 'sine');
				setTimeout(function() { playTone(1100, 0.1, 'sine'); }, 80);
			});
		}
		var badge = document.querySelector('.nav-notif-badge');
		if (badge) {
			var observer = new MutationObserver(function() {
				playTone(880, 0.08, 'sine');
				setTimeout(function() { playTone(1320, 0.1, 'sine'); }, 60);
			});
			observer.observe(badge, { childList: true, characterData: true, subtree: true });
		}
		window._notifSoundCtx = ctx;
	})();

	/* ── N17. SEASONAL THEME ACCENT ── */
	(function() {
		var month = new Date().getMonth();
		var glow;
		if (month >= 2 && month <= 4) { glow = 'rgba(52,211,153,0.18)'; }
		else if (month >= 5 && month <= 7) { glow = 'rgba(251,191,36,0.18)'; }
		else if (month >= 8 && month <= 10) { glow = 'rgba(249,115,22,0.18)'; }
		else { glow = 'rgba(96,165,250,0.18)'; }
		document.documentElement.style.setProperty('--seasonal-glow', glow);
		var menuShell = document.querySelector('.nav-menu-shell');
		if (menuShell) {
			var st = document.createElement('style');
			st.textContent = '.nav-menu-shell { box-shadow: 0 16px 34px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.2), 0 0 28px ' + glow + ', 0 0 22px rgba(124,58,237,0.08); }';
			document.head.appendChild(st);
		}
	})();

	/* ── N18. TYPEWRITER LOGO ── */
	(function() {
		var brandName = document.querySelector('.page-brand-name');
		if (!brandName) return;
		var fullText = brandName.textContent.trim();
		brandName.textContent = '';
		var cursor = document.createElement('span');
		cursor.className = 'brand-typewriter-cursor';
		brandName.appendChild(cursor);
		var i = 0;
		function type() {
			if (i < fullText.length) {
				brandName.insertBefore(document.createTextNode(fullText[i]), cursor);
				i++;
				setTimeout(type, 70 + Math.random() * 50);
			} else {
				cursor.classList.add('is-done');
			}
		}
		setTimeout(type, 800);
	})();

	/* ── N20. EASTER EGG — LOGO HOVER ── */
	(function() {
		var brand = document.querySelector('.page-brand');
		if (!brand) return;
		var timeout;
		brand.addEventListener('mouseenter', function() {
			timeout = setTimeout(function() {
				var wires = brand.querySelectorAll('.wire.left, .wire.right');
				wires.forEach(function(w) { w.style.animationDuration = '0.6s'; });
				setTimeout(function() { wires.forEach(function(w) { w.style.animationDuration = ''; }); }, 4000);
			}, 3000);
		});
		brand.addEventListener('mouseleave', function() { clearTimeout(timeout); });
	})();
})();
</script>


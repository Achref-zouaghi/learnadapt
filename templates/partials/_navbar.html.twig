	/* ── NAVBAR ENHANCEMENTS ── */
	.nav-links a { transition: color 0.22s ease, background 0.22s ease, transform 0.25s var(--ease); }
	.nav-link-underline {
		position: absolute; bottom: -2px; left: 0; right: 0; height: 2px;
		border-radius: 999px; pointer-events: none; z-index: 2;
		background: linear-gradient(90deg, #7b61f1, #38bdd1);
		transform: scaleX(0); transform-origin: left;
		transition: transform 0.35s var(--ease), left 0.35s var(--ease), width 0.35s var(--ease);
	}
	.nav-links a:hover .nav-link-underline,
	.nav-links a.is-active .nav-link-underline { transform: scaleX(1); }
	.nav-links li {
		opacity: 0; transform: translateY(-10px);
		animation: navLinkStagger 0.5s var(--ease) forwards;
	}
	.nav-links li:nth-child(3) { animation-delay: 0.08s; }
	.nav-links li:nth-child(4) { animation-delay: 0.16s; }
	.nav-links li:nth-child(5) { animation-delay: 0.24s; }
	.nav-links li:nth-child(6) { animation-delay: 0.32s; }
	.nav-links li:nth-child(7) { animation-delay: 0.40s; }
	.nav-links li:nth-child(8) { animation-delay: 0.48s; }
	@keyframes navLinkStagger { to { opacity: 1; transform: translateY(0); } }
	.nav-right { opacity: 0; animation: navRightFade 0.55s var(--ease) 0.3s forwards; }
	@keyframes navRightFade { to { opacity: 1; } }
	@keyframes shellBreath {

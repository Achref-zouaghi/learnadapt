<script>
(function() {
	var fab = document.getElementById('aiFab');
	var chat = document.getElementById('aiChat');
	var body = document.getElementById('aiChatBody');
	var input = document.getElementById('aiChatInput');
	var sendBtn = document.getElementById('aiChatSend');
	var micBtn  = document.getElementById('aiMicBtn');
	var suggestions = document.getElementById('aiSuggestions');
	var clearBtn = document.getElementById('aiClearBtn');
	if (!fab || !chat) return;

	var history = [];
	var sending = false;
	var msgCount = 0;

	function getTime() {
		var d = new Date();
		return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
	}

	/* Fallback knowledge base (used when API key not configured) */
	var kb = {
		courses: "LearnAdapt offers **200+ courses** across tech, business, design, and sciences. Popular topics include Machine Learning, React, Python, Data Science, UX Design, and Cloud Architecture. New courses are added weekly by industry experts.",
		adaptive: "Our AI engine analyzes thousands of micro-interactions — pause times, concept revisits, focus patterns — to build a unique learning profile for you. It adjusts difficulty in real-time and predicts topics you'll find challenging. Learners master content **3.2× faster** than traditional methods.",
		pricing: "We offer three plans:\n\n• **Starter** — $29/mo: 5 courses, adaptive paths, analytics, AI assistant (50 queries/mo), 2 certificates.\n• **Pro** — $79/mo: Unlimited everything + priority support. Most popular!\n• **Teams** — Custom pricing: Everything in Pro + team analytics, SSO & SCIM, dedicated manager.\n\nAll plans include a **14-day free trial**. Annual billing saves 20%.",
		certificates: "Every completed course earns a **blockchain-verified certificate**. Share to LinkedIn or your portfolio with one click. Pro/Teams = unlimited certificates.",
		started: "Getting started is easy! Click **'Start Learning Free'** → take a 5-minute AI assessment → receive your personalized learning path. No credit card required.",
		community: "LearnAdapt connects **140+ countries** of learners. Join study groups, live discussions, and real-world projects. AI matches you with ideal study partners.",
		support: "Pro users get **< 2h response time**. Reach us via chat, email (support@learnadapt.io), or help center. Teams get a dedicated success manager.",
		progress: "Track skills, streaks, and milestones with beautiful dashboards — completion rates, time spent, XP, and skill-level breakdowns all in one place.",
		mobile: "LearnAdapt works seamlessly across **desktop, tablet, and mobile**. Progress syncs automatically. Learn anywhere, anytime.",
		ai_assistant: "I'm LearnAdapt's AI assistant! I can explain concepts, quiz you, suggest what to learn next, and keep you on track. Pro users get **unlimited queries**. Available 24/7."
	};

	function matchFallback(q) {
		var ql = q.toLowerCase();
		if (/course|subject|topic|class|learn what|what.*offer|catalog/i.test(ql)) return kb.courses;
		if (/adaptive|adapt|personali|how.*work|ai.*learn|algorithm/i.test(ql)) return kb.adaptive;
		if (/pric|cost|plan|pay|subscription|free|trial|money|\$/i.test(ql)) return kb.pricing;
		if (/certif|credential|badge|diploma|verify|blockchain|linkedin/i.test(ql)) return kb.certificates;
		if (/start|begin|sign.?up|register|account|join|get.?started/i.test(ql)) return kb.started;
		if (/communit|group|collab|peer|team|study.*group|connect/i.test(ql)) return kb.community;
		if (/support|help|contact|email|issue|problem/i.test(ql)) return kb.support;
		if (/progress|track|analytic|dashboard|stats|streak|xp/i.test(ql)) return kb.progress;
		if (/mobile|phone|tablet|app|device|sync/i.test(ql)) return kb.mobile;
		if (/assistant|ai.*help|you.*do|what.*can/i.test(ql)) return kb.ai_assistant;
		if (/hi|hello|hey|good\s(morning|afternoon|evening)/i.test(ql)) return "Hello! 👋 How can I help you with LearnAdapt today?";
		if (/thank|thx|thanks/i.test(ql)) return "You're welcome! 😊 Happy learning!";
		return "Great question! I can help with:\n\n• 📚 Courses & topics\n• 🧠 Adaptive learning\n• 💰 Pricing & plans\n• 🏆 Certificates\n• 📊 Progress tracking\n• 🤝 Community\n\nTry asking about any of these!";
	}

	function parseActions(text) {
		/* Extract [OPEN:type:id:title] tags and return { clean, actions } */
		var actions = [];
		var clean = text.replace(/\[OPEN:([a-z]+):(\d*):([^\]]+)\]/g, function(_, type, id, title) {
			actions.push({ type: type, id: id, title: title.trim() });
			return '';
		}).trim();
		return { clean: clean, actions: actions };
	}

	function actionIcon(type) {
		var icons = { course: '📚', quiz: '🧠', exercise: '💪', exercises: '💪', quizzes: '🧠', courses: '📚' };
		return icons[type] || '▶️';
	}

	function actionUrl(type, id) {
		var base = window.location.origin;
		if (type === 'course' && id)    return base + '/courses/' + id;
		if (type === 'quiz' && id)      return base + '/quizzes';
		if (type === 'exercise' && id)  return base + '/exercises';
		if (type === 'exercises')       return base + '/exercises';
		if (type === 'quizzes')         return base + '/quizzes';
		if (type === 'courses')         return base + '/courses';
		return base + '/' + type + (id ? '/' + id : '');
	}

	function actionLabel(type) {
		var labels = { course: 'Open Course', quiz: 'Start Quiz', exercise: 'Open Exercise', exercises: 'Browse Exercises', quizzes: 'Browse Quizzes', courses: 'Browse Courses' };
		return labels[type] || 'Open';
	}

	function formatMsg(text) {
		return text
			.replace(/```(\w*)\n([\s\S]*?)```/g, '<pre><code>$2</code></pre>')
			.replace(/`([^`]+)`/g, '<code style="background:rgba(139,92,246,0.15);padding:2px 6px;border-radius:4px;font-size:0.8em">$1</code>')
			.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
			.replace(/\*(.+?)\*/g, '<em>$1</em>')
			.replace(/^• /gm, '&bull; ')
			.replace(/^- /gm, '&bull; ')
			.replace(/^(\d+)\. /gm, '<strong>$1.</strong> ')
			.replace(/^> (.+)/gm, '<div style="border-left:3px solid rgba(139,92,246,0.4);padding-left:10px;margin:4px 0;color:rgba(255,255,255,0.7)">$1</div>')
			.replace(/█/g, '<span style="color:#8b5cf6">█</span>')
			.replace(/░/g, '<span style="color:rgba(255,255,255,0.15)">░</span>')
			.replace(/\n/g, '<br>');
	}

	function addMsg(text, type) {
		var div = document.createElement('div');
		div.className = 'ai-msg ' + type;
		div.style.animationDelay = '0.05s';
		if (type === 'bot') {
			var label = document.createElement('div');
			label.className = 'ai-msg-label';
			label.textContent = 'LearnAdapt AI';
			div.appendChild(label);

			var parsed = parseActions(text);
			var span = document.createElement('span');
			span.innerHTML = formatMsg(parsed.clean);
			div.appendChild(span);

			/* Render action cards */
			if (parsed.actions.length > 0) {
				parsed.actions.forEach(function(action) {
					var card = document.createElement('a');
					card.className = 'ai-action-card';
					card.href = actionUrl(action.type, action.id);
					card.innerHTML =
						'<span class="ai-action-card-icon">' + actionIcon(action.type) + '</span>' +
						'<span class="ai-action-card-text">' +
							'<strong>' + (action.title || actionLabel(action.type)) + '</strong>' +
							'<span>' + actionLabel(action.type) + '</span>' +
						'</span>' +
						'<span class="ai-action-card-arrow">→</span>';
					div.appendChild(card);
				});
			}
		} else {
			div.textContent = text;
		}
		var time = document.createElement('span');
		time.className = 'ai-msg-time';
		time.textContent = getTime();
		div.appendChild(time);
		body.appendChild(div);
		body.scrollTop = body.scrollHeight;
		msgCount++;
		return div;
	}

	function showTyping() {
		var div = document.createElement('div');
		div.className = 'ai-typing';
		div.id = 'aiTyping';
		div.innerHTML = '<span></span><span></span><span></span>';
		body.appendChild(div);
		body.scrollTop = body.scrollHeight;
	}
	function hideTyping() {
		var t = document.getElementById('aiTyping');
		if (t) t.remove();
	}

	function setInputEnabled(enabled) {
		input.disabled = !enabled;
		sendBtn.disabled = !enabled;
		sendBtn.style.opacity = enabled ? '1' : '0.5';
	}

	async function sendMessage(text) {
		text = text.trim();
		if (!text || sending) return;
		sending = true;
		setInputEnabled(false);

		if (suggestions) suggestions.style.display = 'none';
		addMsg(text, 'user');
		input.value = '';
		history.push({ role: 'user', content: text });
		showTyping();

		try {
			var res = await fetch('{{ path("api_ai_chat") }}', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ messages: history })
			});

			hideTyping();

			if (res.ok) {
				var data = await res.json();
				var reply = data.reply || matchFallback(text);
				history.push({ role: 'assistant', content: reply });
				addMsg(reply, 'bot');
				speakReply(reply);
			} else {
				/* API unavailable or no key — use fallback */
				var reply = matchFallback(text);
				history.push({ role: 'assistant', content: reply });
				addMsg(reply, 'bot');
				speakReply(reply);
			}
		} catch (e) {
			hideTyping();
			var reply = matchFallback(text);
			history.push({ role: 'assistant', content: reply });
			addMsg(reply, 'bot');
			speakReply(reply);
		}

		sending = false;
		setInputEnabled(true);
		input.focus();
	}

	/* voice handled globally via aiVoiceToggle() */

	/* ── TEXT-TO-SPEECH (speak AI replies) ── */
	var ttsEnabled = false; /* off by default — user can enable via the TTS toggle */
	function speakReply(text) {
		if (!ttsEnabled || !window.speechSynthesis) return;
		window.speechSynthesis.cancel();
		var plain = text.replace(/<[^>]+>/g, '').replace(/[*_`#]/g, '').trim();
		var utt = new SpeechSynthesisUtterance(plain);
		utt.lang = 'en-US'; utt.rate = 1.05; utt.pitch = 1;
		window.speechSynthesis.speak(utt);
	}

	/* ── TOGGLE TTS button in header ── */
	var ttsBtn = document.getElementById('aiTtsBtn');
	if (ttsBtn) {
		if (!window.speechSynthesis) { ttsBtn.style.display = 'none'; }
		ttsBtn.addEventListener('click', function() {
			ttsEnabled = !ttsEnabled;
			ttsBtn.title = ttsEnabled ? 'Mute AI voice' : 'Enable AI voice';
			ttsBtn.style.color = ttsEnabled ? '#a78bfa' : '';
			ttsBtn.style.background = ttsEnabled ? 'rgba(139,92,246,0.15)' : '';
			if (!ttsEnabled) window.speechSynthesis.cancel();
		});
	}

	/* Toggle */
	fab.addEventListener('click', function() {
		var open = chat.classList.toggle('is-open');
		fab.classList.toggle('is-open', open);
		if (open) { setTimeout(function() { input.focus(); }, 350); }
	});

	/* Send */
	sendBtn.addEventListener('click', function() { sendMessage(input.value); });
	input.addEventListener('keydown', function(e) {
		if (e.key === 'Enter') { e.preventDefault(); sendMessage(input.value); }
	});

	/* Suggestions */
	if (suggestions) {
		suggestions.addEventListener('click', function(e) {
			var btn = e.target.closest('.ai-suggest-btn');
			if (btn) { sendMessage(btn.dataset.q); }
		});
	}

	/* Close on outside click */
	document.addEventListener('click', function(e) {
		if (chat.classList.contains('is-open') && !chat.contains(e.target) && !fab.contains(e.target)) {
			chat.classList.remove('is-open');
			fab.classList.remove('is-open');
		}
	});

	/* Close on Escape */
	document.addEventListener('keydown', function(e) {
		if (e.key === 'Escape' && chat.classList.contains('is-open')) {
			chat.classList.remove('is-open');
			fab.classList.remove('is-open');
		}
	});

	/* New conversation */
	if (clearBtn) {
		clearBtn.addEventListener('click', function() {
			history = [];
			msgCount = 0;
			body.innerHTML = '';
			/* Re-add welcome card */
			body.innerHTML = '<div class="ai-welcome"><div class="ai-welcome-icon"><svg viewBox="0 0 24 24"><path fill="#fff" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg></div><h4>How can I help you?</h4><p>I can show your progress, recommend courses, quiz you, explain concepts, create study plans, and more — all offline!</p></div><div class="ai-suggestions" id="aiSuggestions"><button class="ai-suggest-btn" data-q="Show me my progress and stats"><span class="ai-suggest-icon">📊</span> My progress</button><button class="ai-suggest-btn" data-q="Show me my current courses"><span class="ai-suggest-icon">📚</span> My courses</button><button class="ai-suggest-btn" data-q="Recommend courses for me"><span class="ai-suggest-icon">🎯</span> Recommend</button><button class="ai-suggest-btn" data-q="Give me study tips to stay focused"><span class="ai-suggest-icon">🧠</span> Study tips</button><button class="ai-suggest-btn" data-q="Help me create a study plan"><span class="ai-suggest-icon">📅</span> Study plan</button><button class="ai-suggest-btn" data-q="Quiz me to test my knowledge"><span class="ai-suggest-icon">❓</span> Quiz me</button><button class="ai-suggest-btn" data-q="Show me the leaderboard"><span class="ai-suggest-icon">🏆</span> Leaderboard</button><button class="ai-suggest-btn" data-q="Motivate me to keep learning"><span class="ai-suggest-icon">💪</span> Motivate me</button></div>';
			suggestions = document.getElementById('aiSuggestions');
			suggestions.addEventListener('click', function(e) {
				var btn = e.target.closest('.ai-suggest-btn');
				if (btn) sendMessage(btn.dataset.q);
			});
			input.focus();
		});
	}
})();

/* ── GLOBAL VOICE FUNCTION (outside IIFE so onclick always works) ── */
(function() {
	var SR = window.SpeechRecognition || window.webkitSpeechRecognition;
	var isRecording = false;

	function addBotMsg(text) {
		var body = document.getElementById('aiChatBody');
		if (!body) return;
		var div = document.createElement('div');
		div.className = 'ai-msg bot';
		var label = document.createElement('div');
		label.className = 'ai-msg-label';
		label.textContent = 'LearnAdapt AI';
		div.appendChild(label);
		var span = document.createElement('span');
		span.textContent = text;
		div.appendChild(span);
		body.appendChild(div);
		body.scrollTop = body.scrollHeight;
	}

	window.aiVoiceToggle = function() {
		var micBtn = document.getElementById('aiMicBtn');
		var input  = document.getElementById('aiChatInput');

		if (!SR) {
			addBotMsg('⚠️ Voice input is not supported in this browser. Please use Chrome or Edge.');
			return;
		}

		if (isRecording) {
			isRecording = false;
			if (micBtn) { micBtn.classList.remove('recording'); micBtn.title = 'Speak your message'; }
			if (input)  { input.placeholder = 'Ask me anything...'; }
			return;
		}

		var recognition = new SR();
		recognition.continuous = false;
		recognition.interimResults = true;
		recognition.lang = navigator.language || 'en-US';

		recognition.onstart = function() {
			isRecording = true;
			if (micBtn) { micBtn.classList.add('recording'); micBtn.title = 'Listening… click to stop'; }
			if (input)  { input.placeholder = '🎤 Listening…'; }
		};

		recognition.onresult = function(e) {
			if (!input) return;
			var interim = '', final = '';
			for (var i = e.resultIndex; i < e.results.length; i++) {
				var t = e.results[i][0].transcript;
				if (e.results[i].isFinal) final += t; else interim += t;
			}
			input.value = final || interim;
		};

		var hadError = false;

		recognition.onerror = function(e) {
			hadError = true;
			isRecording = false;
			if (micBtn) { micBtn.classList.remove('recording'); micBtn.title = 'Speak your message'; }
			if (input)  { input.placeholder = 'Ask me anything...'; }
			if (e.error === 'not-allowed' || e.error === 'permission-denied') {
				addBotMsg('⚠️ Microphone access denied. Click the 🔒 lock icon in the address bar → allow Microphone → refresh the page.');
			} else if (e.error !== 'no-speech' && e.error !== 'aborted') {
				addBotMsg('⚠️ Voice error: ' + e.error + '. Make sure your microphone is connected.');
			}
		};

		recognition.onend = function() {
			isRecording = false;
			if (micBtn) { micBtn.classList.remove('recording'); micBtn.title = 'Speak your message'; }
			if (input)  { input.placeholder = 'Ask me anything...'; }
			if (!hadError && input && input.value.trim()) {
				var event = new KeyboardEvent('keydown', { key: 'Enter', bubbles: true });
				input.dispatchEvent(event);
			}
		};

		try {
			recognition.start();
		} catch (err) {
			isRecording = false;
			if (micBtn) { micBtn.classList.remove('recording'); }
			if (input)  { input.placeholder = 'Ask me anything...'; }
			addBotMsg('⚠️ Could not start microphone: ' + err.message);
		}
	};
})();
</script>


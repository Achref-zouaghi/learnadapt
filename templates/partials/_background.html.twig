{# ═══ Premium Animated Background – LearnAdapt ═══ #}
<div class="la-bg" aria-hidden="true">
	<canvas id="laBgCanvas"></canvas>
</div>
<style>
.la-bg{position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden}
#laBgCanvas{position:absolute;inset:0;width:100%;height:100%}
@media(prefers-reduced-motion:reduce){ #laBgCanvas{display:none}.la-bg{background:#04060e}}
</style>
<script>
(function(){
var c=document.getElementById('laBgCanvas');if(!c)return;
var ctx=c.getContext('2d');
var W,H,dpr=Math.min(window.devicePixelRatio||1,2);

function resize(){
	W=window.innerWidth;H=window.innerHeight;
	c.width=W*dpr;c.height=H*dpr;
	c.style.width=W+'px';c.style.height=H+'px';
	ctx.setTransform(dpr,0,0,dpr,0,0);
	drawNebula();
}
resize();
window.addEventListener('resize',resize);

/* ═══ NEBULA (painted once, cached) ═══ */
var nebImg=null;
function drawNebula(){
	var off=document.createElement('canvas');
	off.width=W;off.height=H;
	var ox=off.getContext('2d');

	/* deep midnight base with subtle warmth */
	var bg=ox.createRadialGradient(W*0.5,H*0.4,0,W*0.5,H*0.5,Math.max(W,H)*0.9);
	bg.addColorStop(0,'#0a0e1a');
	bg.addColorStop(0.3,'#070b15');
	bg.addColorStop(0.6,'#050810');
	bg.addColorStop(1,'#03050c');
	ox.fillStyle=bg;
	ox.fillRect(0,0,W,H);

	/* ── purple nebula cloud (upper-left area) ── */
	var purpleClouds=[
		{x:W*0.22,y:H*0.18,r:W*0.32,a:0.10},
		{x:W*0.30,y:H*0.28,r:W*0.22,a:0.08},
		{x:W*0.15,y:H*0.12,r:W*0.18,a:0.06},
		{x:W*0.35,y:H*0.40,r:W*0.25,a:0.04},
	];
	for(var i=0;i<purpleClouds.length;i++){
		var cl=purpleClouds[i];
		var g=ox.createRadialGradient(cl.x,cl.y,0,cl.x,cl.y,cl.r);
		g.addColorStop(0,'rgba(123,97,241,'+cl.a+')');
		g.addColorStop(0.3,'rgba(110,80,220,'+(cl.a*0.6)+')');
		g.addColorStop(0.6,'rgba(90,60,180,'+(cl.a*0.2)+')');
		g.addColorStop(1,'transparent');
		ox.fillStyle=g;
		ox.fillRect(0,0,W,H);
	}

	/* ── cyan nebula cloud (upper-right area) ── */
	var cyanClouds=[
		{x:W*0.75,y:H*0.14,r:W*0.30,a:0.10},
		{x:W*0.70,y:H*0.25,r:W*0.22,a:0.08},
		{x:W*0.82,y:H*0.08,r:W*0.16,a:0.07},
		{x:W*0.65,y:H*0.35,r:W*0.20,a:0.04},
	];
	for(var i=0;i<cyanClouds.length;i++){
		var cl=cyanClouds[i];
		var g=ox.createRadialGradient(cl.x,cl.y,0,cl.x,cl.y,cl.r);
		g.addColorStop(0,'rgba(56,189,209,'+cl.a+')');
		g.addColorStop(0.3,'rgba(34,211,238,'+(cl.a*0.5)+')');
		g.addColorStop(0.6,'rgba(20,160,190,'+(cl.a*0.15)+')');
		g.addColorStop(1,'transparent');
		ox.fillStyle=g;
		ox.fillRect(0,0,W,H);
	}

	/* ── blended center area where purple meets cyan ── */
	var blend=ox.createRadialGradient(W*0.48,H*0.22,0,W*0.48,H*0.22,W*0.20);
	blend.addColorStop(0,'rgba(100,120,220,0.05)');
	blend.addColorStop(0.5,'rgba(80,140,200,0.03)');
	blend.addColorStop(1,'transparent');
	ox.fillStyle=blend;
	ox.fillRect(0,0,W,H);

	/* ── bottom subtle purple bloom ── */
	var btm=ox.createRadialGradient(W*0.55,H*0.88,0,W*0.55,H*0.88,W*0.35);
	btm.addColorStop(0,'rgba(123,97,241,0.04)');
	btm.addColorStop(0.5,'rgba(90,60,180,0.02)');
	btm.addColorStop(1,'transparent');
	ox.fillStyle=btm;
	ox.fillRect(0,0,W,H);

	/* ── soft vignette ── */
	var vig=ox.createRadialGradient(W*0.5,H*0.5,W*0.25,W*0.5,H*0.5,Math.max(W,H)*0.75);
	vig.addColorStop(0,'transparent');
	vig.addColorStop(0.7,'rgba(3,5,12,0.15)');
	vig.addColorStop(1,'rgba(3,5,12,0.5)');
	ox.fillStyle=vig;
	ox.fillRect(0,0,W,H);

	nebImg=off;
}

/* ═══ STARS ═══ */
var stars=[];
function initStars(){
	stars=[];
	var count=280;
	for(var i=0;i<count;i++){
		var b=Math.random();
		stars.push({
			x:Math.random()*W,y:Math.random()*H,
			r:b<0.8?(Math.random()*0.8+0.2):(Math.random()*1.4+0.7),
			a:b<0.8?(Math.random()*0.4+0.1):(Math.random()*0.4+0.5),
			tw:Math.random()*Math.PI*2,
			ts:0.004+Math.random()*0.016,
			/* star colors: white, warm, cyan, purple */
			t:b<0.5?0:(b<0.7?1:(b<0.85?2:3)),
			big:b>=0.8
		});
	}
}
initStars();

/* ═══ PARTICLES (floating glowing orbs) ═══ */
var particles=[];
var PCOUNT=70;
function Particle(){
	this.x=Math.random()*W;
	this.y=Math.random()*H;
	this.vx=(Math.random()-0.5)*0.08;
	this.vy=(Math.random()-0.5)*0.06-0.02;
	this.r=Math.random()*2.2+0.4;
	this.glow=this.r*5+Math.random()*8;
	this.alpha=Math.random()*0.45+0.15;
	this.pulse=Math.random()*Math.PI*2;
	this.ps=0.005+Math.random()*0.015;
	/* color palette matching brand: purple, cyan, white-blue */
	var roll=Math.random();
	if(roll<0.35){
		/* purple family */
		this.cr=100+Math.random()*50;this.cg=70+Math.random()*40;this.cb=220+Math.random()*35;
	}else if(roll<0.65){
		/* cyan family */
		this.cr=20+Math.random()*30;this.cg=180+Math.random()*60;this.cb=200+Math.random()*55;
	}else if(roll<0.85){
		/* blended blue-purple */
		this.cr=80+Math.random()*60;this.cg=120+Math.random()*60;this.cb=230+Math.random()*25;
	}else{
		/* white-blue accent */
		this.cr=180+Math.random()*40;this.cg=200+Math.random()*40;this.cb=255;
	}
}
Particle.prototype.update=function(){
	this.pulse+=this.ps;
	this.x+=this.vx;this.y+=this.vy;
	if(this.y<-30){this.y=H+30;this.x=Math.random()*W;}
	if(this.y>H+30){this.y=-30;this.x=Math.random()*W;}
	if(this.x<-30)this.x=W+30;
	if(this.x>W+30)this.x=-30;
};
Particle.prototype.draw=function(){
	var p=0.5+0.5*Math.sin(this.pulse);
	var a=this.alpha*(0.3+0.7*p);
	var s=this.r*(0.7+0.3*p);
	var gl=this.glow*(0.8+0.2*p);

	/* soft outer glow */
	ctx.beginPath();ctx.arc(this.x,this.y,gl,0,Math.PI*2);
	var g=ctx.createRadialGradient(this.x,this.y,0,this.x,this.y,gl);
	g.addColorStop(0,'rgba('+this.cr+','+this.cg+','+this.cb+','+(a*0.22)+')');
	g.addColorStop(0.35,'rgba('+this.cr+','+this.cg+','+this.cb+','+(a*0.08)+')');
	g.addColorStop(0.7,'rgba('+this.cr+','+this.cg+','+this.cb+','+(a*0.02)+')');
	g.addColorStop(1,'transparent');
	ctx.fillStyle=g;ctx.fill();

	/* core dot */
	ctx.beginPath();ctx.arc(this.x,this.y,s,0,Math.PI*2);
	ctx.fillStyle='rgba('+this.cr+','+this.cg+','+this.cb+','+a+')';
	ctx.fill();

	/* hot center for larger */
	if(this.r>1.3){
		ctx.beginPath();ctx.arc(this.x,this.y,s*0.3,0,Math.PI*2);
		ctx.fillStyle='rgba(220,230,255,'+(a*0.85)+')';
		ctx.fill();
	}
};
function initParticles(){particles=[];for(var i=0;i<PCOUNT;i++)particles.push(new Particle());}
initParticles();

/* ═══ NEBULA DRIFT ═══ */
var neb={x:0,y:0,vx:0.04,vy:0.02};

/* ═══ RENDER ═══ */
var rafId;
var STAR_COLORS=[
	function(a){return'rgba(210,220,240,'+a+')';},   /* white */
	function(a){return'rgba(240,220,200,'+a+')';},   /* warm */
	function(a){return'rgba(120,210,240,'+a+')';},   /* cyan */
	function(a){return'rgba(170,140,255,'+a+')';},   /* purple */
];

function animate(){
	ctx.clearRect(0,0,W,H);

	/* nebula */
	if(nebImg){
		neb.x+=neb.vx;neb.y+=neb.vy;
		if(Math.abs(neb.x)>40)neb.vx*=-1;
		if(Math.abs(neb.y)>25)neb.vy*=-1;
		ctx.drawImage(nebImg,neb.x,neb.y,W,H);
	}

	/* stars */
	for(var i=0;i<stars.length;i++){
		var s=stars[i];
		s.tw+=s.ts;
		var ta=s.a*(0.15+0.85*Math.abs(Math.sin(s.tw)));
		var col=STAR_COLORS[s.t];

		/* glow halo for bright stars */
		if(s.big){
			ctx.beginPath();ctx.arc(s.x,s.y,s.r*3.5,0,Math.PI*2);
			var sg=ctx.createRadialGradient(s.x,s.y,0,s.x,s.y,s.r*3.5);
			sg.addColorStop(0,col(ta*0.18));
			sg.addColorStop(1,'transparent');
			ctx.fillStyle=sg;ctx.fill();
		}

		ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);
		ctx.fillStyle=col(ta);
		ctx.fill();
	}

	/* particles */
	for(var i=0;i<particles.length;i++){
		particles[i].update();
		particles[i].draw();
	}

	rafId=requestAnimationFrame(animate);
}

/* visibility */
var obs=new IntersectionObserver(function(e){
	if(e[0].isIntersecting){if(!rafId)animate();}
	else{cancelAnimationFrame(rafId);rafId=null;}
},{threshold:0});
obs.observe(c);

window.addEventListener('resize',function(){initStars();initParticles();});

if(window.matchMedia('(prefers-reduced-motion:reduce)').matches){
	cancelAnimationFrame(rafId);rafId=null;
}
})();
</script>

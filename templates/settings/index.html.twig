                .pm-card-chip.amex      { background:linear-gradient(135deg,#007bc1,#00a9e0); }
                .pm-card-chip.discover  { background:linear-gradient(135deg,#e65c00,#f9d423); }
                .pm-card-chip.other     { background:linear-gradient(135deg,#374151,#6b7280); }
                .pm-card-num  { font-size:0.95rem; font-weight:700; color:var(--text); letter-spacing:0.05em; }

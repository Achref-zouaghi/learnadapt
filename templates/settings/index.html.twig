{% block javascripts %}
<script>
// Auto-dismiss flashes after 5 seconds
document.querySelectorAll('.s-flash').forEach(function(el) {
    setTimeout(function() {
        el.classList.add('fade-out');
        setTimeout(function() { el.remove(); }, 500);
    }, 5000);
});

// Avatar upload auto-submit
var avatarInput = document.getElementById('settingsAvatarInput');
if (avatarInput) {
    avatarInput.addEventListener('change', function() {
        if (this.files.length > 0) this.closest('form').submit();
    });
}

// Close modal on backdrop click
var deleteModal = document.getElementById('deleteModal');
if (deleteModal) {
    deleteModal.addEventListener('click', function(e) {
        if (e.target === this) this.classList.remove('open');
    });
}

// Theme: instant switch on click + auto-submit
document.querySelectorAll('input[name="theme"]').forEach(function(radio) {
    var tile = radio.closest('.s-tile');
    if (tile) {
        tile.addEventListener('click', function(e) {
            e.preventDefault();
            radio.checked = true;
            // Instant visual preview
            document.documentElement.setAttribute('data-theme', radio.value);
            // Highlight selected card, un-highlight other
            document.querySelectorAll('input[name="theme"]').forEach(function(r) {
                var t = r.closest('.s-tile');
                if (t) t.style.borderColor = r.checked ? 'rgba(123,97,241,0.5)' : '';
            });
            // Auto-submit the form to save to DB
            radio.closest('form').submit();
        });
    }
});
</script>

{% if section == 'security' %}
<script>
/* ── Settings: Face ID / WebAuthn ── */
(async function skInit() {
    if (!window.PublicKeyCredential) {
        skSetStatus('Your browser does not support passkeys / Face ID.', 'error');
        return;
    }
    if (location.hostname === '127.0.0.1') {
        skSetStatus('Open the app via http://localhost:8000 (not 127.0.0.1) to use Face ID / Passkey — browsers require a real domain name.', 'error');
        document.getElementById('skRegisterBtn').style.display = 'none';
        return;
    }
    try {
        const res  = await fetch('/auth/webauthn/status');
        const data = await res.json();
        if (data.registered) {
            skSetStatus('✓ A passkey is registered on this device.', 'ok');
            document.getElementById('skDeleteBtn').style.display = 'inline-flex';
        } else {
            skSetStatus('No passkey registered yet. Add one to enable biometric sign-in.', 'none');
            document.getElementById('skRegisterBtn').style.display = 'inline-flex';
        }
    } catch(e) {
        skSetStatus('Could not check passkey status.', 'error');
    }
})();

async function skRegisterPasskey() {
    const btn  = document.getElementById('skRegisterBtn');
    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="bx bx-loader-alt" style="animation:sk-spin 0.8s linear infinite;"></i> Waiting for biometric…';

    try {
        const optRes  = await fetch('/auth/webauthn/register-options');
        const optData = await optRes.json();
        if (!optRes.ok) throw new Error(optData.error || 'Could not get options');

        const publicKey = skPrepareCreate(optData.publicKey);
        const cred      = await navigator.credentials.create({ publicKey });

        const vRes  = await fetch('/auth/webauthn/register', {
            method:  'POST',
            headers: {'Content-Type': 'application/json'},
            body:    JSON.stringify({
                clientDataJSON:    skBufToB64(cred.response.clientDataJSON),
                attestationObject: skBufToB64(cred.response.attestationObject),
            })
        });
        const vData = await vRes.json();
        if (!vRes.ok) throw new Error(vData.error || 'Registration failed');

        skSetStatus('✓ Passkey registered successfully!', 'ok');
        skFeedback('Passkey added. You can now sign in with Face ID.', 'success');
        btn.style.display = 'none';
        document.getElementById('skDeleteBtn').style.display = 'inline-flex';
    } catch(e) {
        btn.disabled = false;
        btn.innerHTML = orig;
        if (e.name !== 'NotAllowedError') skFeedback('Error: ' + e.message, 'error');
    }
}

async function skDeletePasskey() {
    if (!confirm('Remove your registered passkey? You will need to sign in with your password.')) return;
    const res = await fetch('/auth/webauthn/delete', { method: 'POST' });
    if (res.ok) {
        skSetStatus('No passkey registered yet. Add one to enable biometric sign-in.', 'none');
        skFeedback('Passkey removed.', 'neutral');
        document.getElementById('skDeleteBtn').style.display = 'none';
        document.getElementById('skRegisterBtn').style.display = 'inline-flex';
    }
}

function skPrepareCreate(opts) {
    opts.challenge = skB64ToBuf(opts.challenge);
    opts.user.id  = skB64ToBuf(opts.user.id);
    if (opts.excludeCredentials) {
        opts.excludeCredentials = opts.excludeCredentials.map(c => ({ ...c, id: skB64ToBuf(c.id) }));
    }
    return opts;
}
function skB64ToBuf(b64) {
    b64 = b64.replace(/-/g,'+').replace(/_/g,'/');
    while (b64.length % 4) b64 += '=';
    const bin = atob(b64);
    const buf = new Uint8Array(bin.length);
    for (let i = 0; i < bin.length; i++) buf[i] = bin.charCodeAt(i);
    return buf.buffer;
}
function skBufToB64(buf) {
    return btoa(String.fromCharCode(...new Uint8Array(buf)));
}
function skSetStatus(msg, type) {
    const el = document.getElementById('skPasskeyStatus');
    el.textContent = msg;
    if (type === 'ok')    { el.style.color='#34d399'; el.style.borderColor='rgba(52,211,153,0.2)'; el.style.background='rgba(52,211,153,0.06)'; }
    else if (type==='error') { el.style.color='#f87171'; el.style.borderColor='rgba(248,113,113,0.2)'; el.style.background='rgba(248,113,113,0.06)'; }
    else                  { el.style.color=''; el.style.borderColor=''; el.style.background=''; }
}
function skFeedback(msg, type) {
    const el = document.getElementById('skFeedback');
    el.textContent = msg;
    el.style.display = 'block';
    if (type === 'success') { el.style.color='#aef7ff'; el.style.borderColor='rgba(56,189,209,0.3)'; el.style.background='rgba(56,189,209,0.08)'; }
    else { el.style.color='#ffd7e1'; el.style.borderColor='rgba(248,113,113,0.25)'; el.style.background='rgba(248,113,113,0.08)'; }
    setTimeout(() => { el.style.display = 'none'; }, 5000);
}
const _skStyle = document.createElement('style');
_skStyle.textContent = '@keyframes sk-spin { to { transform: rotate(360deg); } } #skRegisterBtn, #skDeleteBtn { display: inline-flex; align-items: center; gap: 8px; }';
document.head.appendChild(_skStyle);
</script>
{% endif %}
{% endblock %}

                {# ═══════════ PAYMENT ═══════════ #}

                {% elseif section == 'payment' %}

                <style>
                .pm-flash-ok  { display:flex; align-items:center; gap:10px; padding:13px 16px; border-radius:12px; background:rgba(34,197,94,0.08); border:1px solid rgba(34,197,94,0.22); color:#22c55e; font-size:0.86rem; margin-bottom:20px; }
                .pm-flash-err { display:flex; align-items:center; gap:10px; padding:13px 16px; border-radius:12px; background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.22); color:#ef4444; font-size:0.86rem; margin-bottom:20px; }
                .pm-flash-ok i, .pm-flash-err i { font-size:1.1rem; flex-shrink:0; }

                .pm-section-title { font-size:0.7rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted); margin-bottom:12px; }

                /* Card rows */
                .pm-card-row {
                    display:flex; align-items:center; gap:16px;
                    padding:16px 18px; border-radius:14px;
                    border:1px solid var(--border); background:rgba(255,255,255,0.02);

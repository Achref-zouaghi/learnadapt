{% block javascripts %}
<script>
// Auto-dismiss flashes after 5 seconds
document.querySelectorAll('.s-flash').forEach(function(el) {
    setTimeout(function() {
        el.classList.add('fade-out');
        setTimeout(function() { el.remove(); }, 500);
    }, 5000);
});

// Avatar upload auto-submit
var avatarInput = document.getElementById('settingsAvatarInput');
if (avatarInput) {
    avatarInput.addEventListener('change', function() {
        if (this.files.length > 0) this.closest('form').submit();
    });
}

// Close modal on backdrop click
var deleteModal = document.getElementById('deleteModal');
if (deleteModal) {
    deleteModal.addEventListener('click', function(e) {
        if (e.target === this) this.classList.remove('open');
    });
}

// Theme: instant switch on click + auto-submit
document.querySelectorAll('input[name="theme"]').forEach(function(radio) {
    var tile = radio.closest('.s-tile');
    if (tile) {
        tile.addEventListener('click', function(e) {
            e.preventDefault();
            radio.checked = true;
            // Instant visual preview
            document.documentElement.setAttribute('data-theme', radio.value);
            // Highlight selected card, un-highlight other
            document.querySelectorAll('input[name="theme"]').forEach(function(r) {
                var t = r.closest('.s-tile');
                if (t) t.style.borderColor = r.checked ? 'rgba(123,97,241,0.5)' : '';
            });
            // Auto-submit the form to save to DB
            radio.closest('form').submit();
        });
    }
});
</script>
{% endblock %}

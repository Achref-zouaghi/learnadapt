                .pm-btn-danger {
                    padding:6px 11px; border-radius:9px; font-size:0.8rem;
                    border:1px solid rgba(239,68,68,0.25); background:transparent; color:#ef4444;
                    cursor:pointer; font-family:inherit; transition:background 0.15s, border-color 0.15s;
                    display:flex; align-items:center; gap:4px;
                }
                .pm-btn-danger:hover { background:rgba(239,68,68,0.08); border-color:rgba(239,68,68,0.45); }

                /* Empty state */
                .pm-empty { display:flex; flex-direction:column; align-items:center; justify-content:center; padding:32px 20px; border-radius:14px; border:1px dashed rgba(255,255,255,0.1); background:rgba(255,255,255,0.01); text-align:center; margin-bottom:20px; }
                .pm-empty i { font-size:2rem; color:var(--muted); margin-bottom:10px; }
                .pm-empty p { font-size:0.85rem; color:var(--muted); }

                /* Add card form */
                .pm-form-wrap { border-radius:16px; border:1px solid var(--border); background:rgba(255,255,255,0.02); padding:24px; margin-bottom:20px; }
                .pm-form-header { display:flex; align-items:center; gap:10px; margin-bottom:22px; padding-bottom:16px; border-bottom:1px solid var(--border); }
                .pm-form-header-icon { width:36px; height:36px; border-radius:10px; background:rgba(123,97,241,0.12); display:flex; align-items:center; justify-content:center; }
                .pm-form-header-icon i { color:#a78bfa; font-size:1rem; }
                .pm-form-header span { font-size:0.95rem; font-weight:700; color:var(--text); }
                .pm-input-wrap { position:relative; }
                .pm-brand-badge { position:absolute; right:14px; top:50%; transform:translateY(-50%); font-size:0.65rem; font-weight:800; letter-spacing:0.05em; color:var(--muted); pointer-events:none; }
                .pm-err-msg { color:#ef4444; font-size:0.74rem; margin-top:5px; display:none; }
                .pm-field { margin-bottom:16px; }
                .pm-field label { display:block; font-size:0.77rem; font-weight:600; color:var(--muted); margin-bottom:6px; letter-spacing:0.02em; text-transform:uppercase; }
                .pm-grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:14px; }

                .pm-submit-row { display:flex; align-items:center; justify-content:space-between; margin-top:20px; padding-top:18px; border-top:1px solid var(--border); }
                .pm-secure-note { display:flex; align-items:center; gap:6px; font-size:0.75rem; color:var(--muted); }
                .pm-secure-note i { color:#22c55e; }
                .pm-btn-submit {
                    display:inline-flex; align-items:center; gap:8px;
                    padding:11px 22px; border-radius:12px; border:none;
                    background:linear-gradient(135deg,#7856ed,#3cc5d9); color:#fff;
                    font-size:0.86rem; font-weight:700; cursor:pointer; font-family:inherit;
                    transition:opacity 0.2s, transform 0.15s;
                }
                .pm-btn-submit:hover { opacity:0.88; transform:scale(0.98); }

                /* Accepted brands footer */
                .pm-brands { display:flex; align-items:center; gap:8px; padding:14px 18px; border-radius:12px; background:rgba(255,255,255,0.02); border:1px solid var(--border); }
                .pm-brand-chip { padding:5px 12px; border-radius:6px; font-size:0.62rem; font-weight:800; letter-spacing:0.06em; color:#fff; }
                .pm-brands-label { font-size:0.76rem; color:var(--muted); margin-right:4px; }
                </style>

                <div class="s-label">{{ 'settings.payment.label'|trans }}</div>
                <h2>{{ 'settings.payment.title'|trans }}</h2>
                <p class="sub" style="margin-top:4px; margin-bottom:26px;">{{ 'settings.payment.subtitle'|trans }}</p>

                {# Flash messages #}
                {% for msg in app.flashes('success') %}
                    <div class="pm-flash-ok"><i class='bx bx-check-circle'></i> {{ msg|trans }}</div>
                {% endfor %}
                {% for msg in app.flashes('error') %}
                    <div class="pm-flash-err"><i class='bx bx-error-circle'></i> {{ msg|trans }}</div>
                {% endfor %}

                {# ── Saved cards ── #}
                {% if paymentMethods is defined and paymentMethods|length > 0 %}
                    <div class="pm-section-title"><i class='bx bx-wallet-alt' style="margin-right:5px;"></i>Saved cards</div>
                    <div style="margin-bottom:24px;">
                        {% for card in paymentMethods %}
                        {% set brand_class = card.card_brand == 'Visa' ? 'visa' : (card.card_brand == 'Mastercard' ? 'mastercard' : (card.card_brand == 'Amex' ? 'amex' : (card.card_brand == 'Discover' ? 'discover' : 'other'))) %}
                        <div class="pm-card-row {{ card.is_default ? 'is-default' : '' }}">
                            <div class="pm-card-chip {{ brand_class }}">{{ card.card_brand|upper }}</div>
                            <div>
                                <div class="pm-card-num">•••• •••• •••• {{ card.card_last4 }}</div>
                                <div class="pm-card-meta">
                                    {{ card.card_holder }} &nbsp;·&nbsp; Expires {{ card.expiry_month }}/{{ card.expiry_year }}
                                    {% if card.is_default %}
                                    &nbsp;<span class="pm-default-pill"><i class='bx bx-check' style="font-size:0.7rem;"></i> Default</span>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="pm-card-actions">
                                {% if not card.is_default %}
                                <form method="POST" action="{{ path('app_settings_payment_default', {id: card.id}) }}">
                                    <button type="submit" class="pm-btn-ghost">Set default</button>
                                </form>
                                {% endif %}
                                <form method="POST" action="{{ path('app_settings_payment_remove', {id: card.id}) }}" onsubmit="return confirm('Remove this card from your account?')">
                                    <button type="submit" class="pm-btn-danger"><i class='bx bx-trash'></i> Remove</button>
                                </form>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="pm-empty">
                        <i class='bx bx-credit-card'></i>
                        <p>No payment methods saved yet.<br>Add a card below to get started.</p>
                    </div>
                {% endif %}

                {# ── Add card form ── #}
                <div class="pm-form-wrap">
                    <div class="pm-form-header">
                        <div class="pm-form-header-icon"><i class='bx bx-plus'></i></div>
                        <span>Add a new card</span>
                    </div>

                    <form method="POST" action="{{ path('app_settings_payment_add') }}" id="paymentForm">
                        <div class="pm-field">
                            <label>Cardholder name</label>
                            <input type="text" name="card_holder" class="s-input" placeholder="Name as it appears on card" required autocomplete="cc-name">
                        </div>

                        <div class="pm-field">
                            <label>Card number</label>
                            <div class="pm-input-wrap">
                                <input type="text" id="cardNumber" name="card_number" class="s-input" placeholder="1234  5678  9012  3456" maxlength="19" required autocomplete="cc-number" inputmode="numeric" style="padding-right:56px; letter-spacing:0.05em;">
                                <span id="cardBrandBadge" class="pm-brand-badge"></span>
                            </div>
                            <div id="cardError" class="pm-err-msg"></div>
                        </div>

                        <div class="pm-grid-2">
                            <div class="pm-field">
                                <label>Expiry date</label>
                                <input type="text" id="expiryInput" class="s-input" placeholder="MM / YY" maxlength="7" required autocomplete="cc-exp" inputmode="numeric">
                                <input type="hidden" name="expiry_month" id="expiryMonth">
                                <input type="hidden" name="expiry_year"  id="expiryYear">
                            </div>
                            <div class="pm-field">
                                <label>Security code (CVV)</label>
                                <input type="password" name="cvv" class="s-input" placeholder="•••" maxlength="4" required autocomplete="cc-csc" inputmode="numeric">
                            </div>
                        </div>

                        <div class="pm-submit-row">
                            <span class="pm-secure-note"><i class='bx bxs-lock-alt'></i> 256-bit SSL encrypted</span>
                            <button type="submit" class="pm-btn-submit" id="submitCard">
                                <i class='bx bx-lock-alt'></i> Add card
                            </button>
                        </div>
                    </form>
                </div>

                {# ── Accepted brands ── #}
                <div class="pm-brands">
                    <span class="pm-brands-label">Accepted:</span>
                    <span class="pm-brand-chip" style="background:linear-gradient(135deg,#1a1f71,#2d5dab);">VISA</span>
                    <span class="pm-brand-chip" style="background:linear-gradient(135deg,#1a1433,#c8102e);">MC</span>
                    <span class="pm-brand-chip" style="background:linear-gradient(135deg,#007bc1,#00a9e0);">AMEX</span>
                    <span class="pm-brand-chip" style="background:linear-gradient(135deg,#e65c00,#f9d423);">DISC</span>
                    <span style="margin-left:auto; font-size:0.74rem; color:var(--muted); display:flex; align-items:center; gap:5px;"><i class='bx bx-shield-alt-2' style="color:#22c55e;"></i> Secure &amp; encrypted</span>
                </div>

                <script>
                (() => {
                    const cardInput  = document.getElementById('cardNumber');
                    const brandBadge = document.getElementById('cardBrandBadge');
                    const cardError  = document.getElementById('cardError');
                    const expiryInput = document.getElementById('expiryInput');

                    const brandColors = { VISA:'#4f7dc9', MC:'#c8102e', AMEX:'#00a9e0', DISC:'#e65c00' };

                    function detectBrand(n) {
                        if (/^4/.test(n))          return 'VISA';
                        if (/^5[1-5]/.test(n))     return 'MC';
                        if (/^3[47]/.test(n))       return 'AMEX';
                        if (/^6(?:011|5)/.test(n))  return 'DISC';
                        return '';
                    }

                    function luhn(n) {
                        let s = 0, l = n.length, p = l % 2;
                        for (let i = 0; i < l; i++) {
                            let d = +n[i];
                            if (i % 2 === p) { d *= 2; if (d > 9) d -= 9; }
                            s += d;
                        }
                        return s % 10 === 0;
                    }

                    cardInput.addEventListener('input', function () {
                        let raw = this.value.replace(/\D/g, '').slice(0, 16);
                        this.value = raw.replace(/(.{4})/g, '$1 ').trim();
                        const brand = detectBrand(raw);
                        brandBadge.textContent = brand;
                        brandBadge.style.color = brandColors[brand] || 'var(--muted)';
                        if (raw.length >= 13) {
                            if (!luhn(raw)) {
                                cardError.textContent = 'Card number is invalid'; cardError.style.display = 'block';
                            } else { cardError.style.display = 'none'; }
                        } else { cardError.style.display = 'none'; }
                    });

                    expiryInput.addEventListener('input', function () {
                        let raw = this.value.replace(/\D/g, '').slice(0, 4);
                        if (raw.length >= 3) raw = raw.slice(0,2) + ' / ' + raw.slice(2);
                        this.value = raw;
                    });

                    document.getElementById('paymentForm').addEventListener('submit', function () {
                        const parts = expiryInput.value.replace(/\s/g,'').split('/');
                        document.getElementById('expiryMonth').value = parts[0] || '';
                        document.getElementById('expiryYear').value  = parts[1] || '';
                    });
                })();
                </script>



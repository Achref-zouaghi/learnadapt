{% extends 'base.html.twig' %}
{% set darkPage = true %}
{% block title %}Exercises — LearnAdapt{% endblock %}

{% block stylesheets %}
<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

:root{--bg:#04060e;--purple:#7b61f1;--cyan:#38bdd1;--green:#34d399;--red:#f87171;--orange:#fb923c;--yellow:#fbbf24;--text:#f6f8fc;--muted:#8896ab;--glass:rgba(255,255,255,0.035);--glass-b:rgba(255,255,255,0.06);--card:rgba(255,255,255,0.025);--card-h:rgba(255,255,255,0.05);--border:rgba(255,255,255,0.06);--shadow:0 4px 24px rgba(0,0,0,0.3);--ease:cubic-bezier(0.4,0,0.2,1)}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body,body.dark-page{font-family:'Inter',sans-serif!important;background:#020a10!important;color:var(--text)}
footer{display:none!important}

/* ═══ AMBIENT BACKGROUND ═══ */
.ex-page{min-height:100vh;padding:100px 0 80px;display:flex;justify-content:center;background:transparent;position:relative;z-index:1;overflow:hidden}
.ex-bg-orb{position:fixed;border-radius:50%;filter:blur(120px);opacity:0.12;pointer-events:none;z-index:0}
.ex-bg-orb--1{width:600px;height:600px;background:radial-gradient(circle,var(--cyan),transparent 70%);top:-10%;left:-5%;animation:orbFloat1 18s ease-in-out infinite}
.ex-bg-orb--2{width:500px;height:500px;background:radial-gradient(circle,var(--purple),transparent 70%);bottom:5%;right:-8%;animation:orbFloat2 22s ease-in-out infinite}
.ex-bg-orb--3{width:350px;height:350px;background:radial-gradient(circle,var(--green),transparent 70%);top:40%;left:50%;animation:orbFloat3 15s ease-in-out infinite}
@keyframes orbFloat1{0%,100%{transform:translate(0,0)}50%{transform:translate(60px,40px)}}
@keyframes orbFloat2{0%,100%{transform:translate(0,0)}50%{transform:translate(-50px,-30px)}}
@keyframes orbFloat3{0%,100%{transform:translate(0,0)}50%{transform:translate(-30px,50px)}}

.ex-wrap{width:100%;max-width:1360px;margin:0 auto;padding:0 32px;position:relative;z-index:2}

/* ═══ HERO HEADER ═══ */
@keyframes bannerShimmer{0%{background-position:-200% center}100%{background-position:200% center}}
@keyframes floatOrb{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-12px) scale(1.04)}}
@keyframes heroIn{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:none}}
.ex-hero{margin-bottom:40px;position:relative;padding:48px 48px 40px;background:linear-gradient(135deg,rgba(56,189,209,0.10) 0%,rgba(16,185,129,0.06) 50%,rgba(6,182,212,0.03) 100%);border:1px solid rgba(56,189,209,0.18);border-radius:28px;backdrop-filter:blur(24px);overflow:hidden;animation:heroIn .7s var(--ease) backwards}
.ex-hero::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,transparent,#06b6d4,#10b981,#06b6d4,transparent);background-size:200% 100%;animation:bannerShimmer 3s linear infinite}
.ex-hero::after{content:'';display:none}
.ex-hero-watermark{position:absolute;right:-20px;bottom:-30px;font-size:14rem;opacity:0.04;background:linear-gradient(135deg,#06b6d4,#10b981);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;pointer-events:none;user-select:none;line-height:1}
.ex-hero-orb1{position:absolute;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(56,189,209,0.13),transparent 70%);top:-70px;right:140px;animation:floatOrb 6s ease-in-out infinite;pointer-events:none}
.ex-hero-orb2{position:absolute;width:130px;height:130px;border-radius:50%;background:radial-gradient(circle,rgba(16,185,129,0.10),transparent 70%);bottom:-50px;left:80px;animation:floatOrb 8s ease-in-out infinite reverse;pointer-events:none}
.ex-hero-badge{display:inline-flex;align-items:center;gap:6px;padding:4px 14px;background:linear-gradient(135deg,rgba(56,189,209,0.15),rgba(16,185,129,0.10));border:1px solid rgba(56,189,209,0.22);border-radius:20px;font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#06b6d4;margin-bottom:12px}
.ex-hero-row{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:20px}
.ex-hero h1{font-size:2.4rem;font-weight:900;letter-spacing:-0.04em;line-height:1.1}
.ex-hero h1 span.t1{background:linear-gradient(135deg,var(--cyan),#6ee7b7);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
.ex-hero h1 span.t2{color:var(--text);-webkit-text-fill-color:var(--text)}
.ex-hero-sub{color:var(--muted);font-size:0.9rem;margin-top:8px;max-width:500px;line-height:1.6}
.ex-hero-icon{width:80px;height:80px;border-radius:24px;background:linear-gradient(135deg,rgba(56,189,209,0.20),rgba(16,185,129,0.12));border:1px solid rgba(56,189,209,0.22);box-shadow:0 0 40px rgba(56,189,209,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ex-hero-icon i{font-size:2.2rem;background:linear-gradient(135deg,var(--cyan),var(--purple));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}

/* ═══ STAT CARDS ═══ */
.ex-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:28px}
@media(max-width:800px){.ex-stats{grid-template-columns:repeat(2,1fr)}}
@media(max-width:480px){.ex-stats{grid-template-columns:1fr}}
.ex-st{position:relative;background:var(--card);border:1px solid var(--border);border-radius:16px;padding:20px 22px;backdrop-filter:blur(14px);transition:all .3s var(--ease);cursor:pointer;text-decoration:none;color:inherit;overflow:hidden;animation:stIn .5s var(--ease) backwards}
.ex-st:nth-child(1){animation-delay:0s}.ex-st:nth-child(2){animation-delay:.06s}.ex-st:nth-child(3){animation-delay:.12s}.ex-st:nth-child(4){animation-delay:.18s}
@keyframes stIn{from{opacity:0;transform:translateY(12px) scale(0.97)}to{opacity:1;transform:none}}
.ex-st::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;border-radius:2px 2px 0 0;opacity:0;transition:opacity .3s}
.ex-st:nth-child(1)::before{background:linear-gradient(90deg,var(--cyan),var(--purple))}
.ex-st:nth-child(2)::before{background:linear-gradient(90deg,#22c55e,var(--green))}
.ex-st:nth-child(3)::before{background:linear-gradient(90deg,var(--orange),var(--yellow))}
.ex-st:nth-child(4)::before{background:linear-gradient(90deg,#ef4444,var(--red))}
.ex-st:hover,.ex-st.is-active{background:var(--card-h);transform:translateY(-3px);border-color:rgba(255,255,255,0.1)}
.ex-st:hover::before,.ex-st.is-active::before{opacity:1}
.ex-st.is-active{box-shadow:0 8px 32px rgba(0,0,0,0.2)}
.ex-st-row{display:flex;align-items:center;gap:14px}
.ex-st-icon{width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1.15rem}
.ex-st:nth-child(1) .ex-st-icon{background:linear-gradient(135deg,rgba(56,189,209,0.15),rgba(123,97,241,0.1));color:var(--cyan)}
.ex-st:nth-child(2) .ex-st-icon{background:rgba(52,211,153,0.12);color:var(--green)}
.ex-st:nth-child(3) .ex-st-icon{background:rgba(251,191,36,0.12);color:var(--yellow)}
.ex-st:nth-child(4) .ex-st-icon{background:rgba(248,113,113,0.12);color:var(--red)}
.ex-st-v{font-size:1.65rem;font-weight:900;letter-spacing:-0.03em;line-height:1}
.ex-st-l{font-size:0.68rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;margin-top:3px}

/* ═══ MODULE FILTER ═══ */
.ex-filters-section{margin-bottom:28px;animation:fadeUp .5s var(--ease) .2s backwards}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
.ex-filters-label{font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);margin-bottom:10px;display:flex;align-items:center;gap:6px}
.ex-filters-label i{font-size:0.85rem;opacity:0.6}
.ex-modules{display:flex;gap:8px;flex-wrap:wrap}
.ex-mod-chip{display:inline-flex;align-items:center;gap:7px;padding:9px 18px;background:var(--glass);border:1px solid var(--border);border-radius:12px;color:var(--muted);font-size:0.78rem;font-weight:600;text-decoration:none;transition:all .25s var(--ease);cursor:pointer;font-family:inherit;position:relative;overflow:hidden}
.ex-mod-chip::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(56,189,209,0.08),rgba(123,97,241,0.05));opacity:0;transition:opacity .25s}
.ex-mod-chip:hover{background:var(--glass-b);color:var(--text);border-color:rgba(56,189,209,0.18);transform:translateY(-1px)}
.ex-mod-chip:hover::before{opacity:1}
.ex-mod-chip.is-active{background:rgba(56,189,209,0.08);border-color:rgba(56,189,209,0.3);color:var(--cyan);box-shadow:0 0 20px rgba(56,189,209,0.08)}
.ex-mod-chip.is-active::before{opacity:1}
.ex-mod-chip i{font-size:0.9rem;position:relative;z-index:1}
.ex-mod-chip span{position:relative;z-index:1}
.ex-mod-count{background:rgba(255,255,255,0.06);padding:2px 8px;border-radius:6px;font-size:0.68rem;font-weight:800;margin-left:2px}
.ex-mod-chip.is-active .ex-mod-count{background:rgba(56,189,209,0.15)}

/* ═══ SEARCH BAR ═══ */
.ex-search-bar{display:flex;gap:16px;margin-bottom:32px;animation:fadeUp .5s var(--ease) .25s backwards;align-items:stretch}
.ex-search{flex:1;width:100%;background:var(--glass);border:1px solid var(--border);border-radius:16px;padding:18px 22px 18px 52px;color:var(--text);font-size:1rem;font-family:inherit;outline:none;transition:all .3s var(--ease)}
.ex-search:focus{border-color:rgba(56,189,209,0.3);box-shadow:0 0 24px rgba(56,189,209,0.06);background:rgba(255,255,255,0.04)}
.ex-search::placeholder{color:var(--muted)}
.ex-search-wrap{flex:1;position:relative}
.ex-search-wrap i{position:absolute;left:20px;top:50%;transform:translateY(-50%);font-size:1.25rem;color:var(--muted);pointer-events:none;z-index:2}
.ex-search-btn{background:linear-gradient(135deg,var(--cyan),#2dd4bf);border:none;border-radius:16px;padding:18px 42px;color:#fff;font-weight:800;font-size:1rem;cursor:pointer;font-family:inherit;transition:all .25s var(--ease);position:relative;overflow:hidden;white-space:nowrap;letter-spacing:0.01em}
.ex-search-btn::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,0.15),transparent);opacity:0;transition:opacity .25s}
.ex-search-btn:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(56,189,209,0.35)}
.ex-search-btn:hover::before{opacity:1}

/* ═══ RESULTS COUNT ═══ */
.ex-results{font-size:0.78rem;color:var(--muted);margin-bottom:20px;display:flex;align-items:center;gap:8px;animation:fadeUp .5s var(--ease) .3s backwards}
.ex-results strong{color:var(--text);font-weight:700}

/* ═══ GRID ═══ */
.ex-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(360px,1fr));gap:20px;margin-bottom:50px}
@media(max-width:640px){.ex-grid{grid-template-columns:1fr}}

/* ═══ PREMIUM CARD ═══ */
.ex-card{position:relative;background:linear-gradient(145deg,rgba(255,255,255,0.03),rgba(255,255,255,0.01));border:1px solid var(--border);border-radius:20px;padding:0;backdrop-filter:blur(16px);transition:all .35s var(--ease);overflow:hidden;animation:exCardIn .6s var(--ease) backwards}
.ex-card:hover{border-color:rgba(56,189,209,0.12);transform:translateY(-4px);box-shadow:0 20px 60px rgba(0,0,0,0.25),0 0 40px rgba(56,189,209,0.04)}
@keyframes exCardIn{from{opacity:0;transform:translateY(20px) scale(0.98)}to{opacity:1;transform:none}}

/* Card shimmer effect on hover */
.ex-card::before{content:'';position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.03),transparent);transition:left .6s var(--ease);z-index:1;pointer-events:none}
.ex-card:hover::before{left:120%}

/* Level accent bar at top */
.ex-card::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;z-index:2}
.ex-card[data-level="EASY"]::after{background:linear-gradient(90deg,var(--green),#6ee7b7)}
.ex-card[data-level="MEDIUM"]::after{background:linear-gradient(90deg,var(--orange),var(--yellow))}
.ex-card[data-level="HARD"]::after{background:linear-gradient(90deg,#ef4444,var(--red))}

.ex-card-body{padding:26px 26px 22px;position:relative;z-index:1}
.ex-card-top{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:12px}
.ex-card-title{font-size:1.08rem;font-weight:800;letter-spacing:-0.02em;line-height:1.3;transition:color .2s}
.ex-card:hover .ex-card-title{color:var(--cyan)}

/* Premium badge */
.ex-badge{display:inline-flex;align-items:center;gap:5px;padding:5px 12px;border-radius:10px;font-size:0.68rem;font-weight:800;text-transform:uppercase;letter-spacing:0.06em;white-space:nowrap;position:relative}
.ex-badge i{font-size:0.75rem}
.ex-badge.easy{background:rgba(52,211,153,0.1);color:var(--green);border:1px solid rgba(52,211,153,0.12)}
.ex-badge.medium{background:rgba(251,191,36,0.1);color:var(--yellow);border:1px solid rgba(251,191,36,0.12)}
.ex-badge.hard{background:rgba(248,113,113,0.1);color:var(--red);border:1px solid rgba(248,113,113,0.12)}

.ex-card-desc{font-size:0.82rem;color:var(--muted);line-height:1.65;margin-bottom:18px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}

/* Module tag */
.ex-card-module{display:inline-flex;align-items:center;gap:5px;padding:4px 12px;background:rgba(123,97,241,0.08);border:1px solid rgba(123,97,241,0.1);border-radius:8px;font-size:0.72rem;font-weight:600;color:var(--purple);margin-bottom:14px}
.ex-card-module i{font-size:0.8rem}

.ex-card-meta{display:flex;flex-wrap:wrap;gap:14px;font-size:0.72rem;color:var(--muted);margin-bottom:18px;padding-top:14px;border-top:1px solid var(--border)}
.ex-card-meta span{display:flex;align-items:center;gap:5px}
.ex-card-meta i{font-size:0.85rem;opacity:0.5}

/* Card footer */
.ex-card-foot{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:14px 26px;background:rgba(255,255,255,0.015);border-top:1px solid var(--border)}
.ex-dl-btn{display:inline-flex;align-items:center;gap:8px;padding:10px 22px;background:linear-gradient(135deg,var(--cyan),#2dd4bf);border:none;border-radius:12px;color:#fff;font-weight:700;font-size:0.78rem;cursor:pointer;text-decoration:none;font-family:inherit;transition:all .25s var(--ease);position:relative;overflow:hidden}
.ex-dl-btn::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,0.18),transparent);opacity:0;transition:opacity .25s}
.ex-dl-btn:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(56,189,209,0.35)}
.ex-dl-btn:hover::before{opacity:1}
.ex-dl-btn i{font-size:1rem}
.ex-view-btn{display:inline-flex;align-items:center;gap:6px;padding:10px 18px;background:var(--glass);border:1px solid var(--border);border-radius:12px;color:var(--muted);font-size:0.78rem;font-weight:600;text-decoration:none;transition:all .25s var(--ease);cursor:pointer;font-family:inherit}
.ex-view-btn:hover{background:var(--glass-b);color:var(--text);border-color:rgba(255,255,255,0.12)}
.ex-view-btn i{font-size:0.95rem}
.ex-no-file{display:inline-flex;align-items:center;gap:6px;padding:10px 18px;background:var(--glass);border:1px solid var(--border);border-radius:12px;color:var(--muted);font-size:0.78rem;font-family:inherit;opacity:0.7}
.ex-file-size{font-size:0.7rem;color:var(--muted);font-weight:600;display:flex;align-items:center;gap:4px}
.ex-file-size i{font-size:0.85rem;opacity:0.5}

/* ═══ EMPTY STATE ═══ */
.ex-empty{text-align:center;padding:100px 20px;color:var(--muted);animation:fadeUp .6s var(--ease)}
.ex-empty-icon{width:80px;height:80px;border-radius:24px;background:linear-gradient(135deg,rgba(56,189,209,0.08),rgba(123,97,241,0.05));border:1px solid rgba(56,189,209,0.08);display:flex;align-items:center;justify-content:center;margin:0 auto 20px}
.ex-empty-icon i{font-size:2.2rem;color:var(--cyan);opacity:0.5}
.ex-empty h3{font-size:1.1rem;font-weight:700;margin-bottom:6px;color:var(--text)}
.ex-empty p{font-size:0.85rem;max-width:340px;margin:0 auto;line-height:1.6}

/* ═══ RESPONSIVE ═══ */
@media(max-width:768px){
	.ex-hero{padding:28px 24px}
	.ex-hero h1{font-size:1.6rem}
	.ex-card-body{padding:20px}
	.ex-card-foot{padding:12px 20px}
	.ex-wrap{padding:0 16px}
}
</style>
{% endblock %}

{% block body %}
<!-- Ambient orbs -->
<div class="ex-bg-orb ex-bg-orb--1"></div>
<div class="ex-bg-orb ex-bg-orb--2"></div>
<div class="ex-bg-orb ex-bg-orb--3"></div>

<div class="ex-page">
<div class="ex-wrap">

	<!-- Hero Header -->
	<div class="ex-hero">
		<div class="ex-hero-watermark"><i class='bx bx-dumbbell'></i></div>
		<div class="ex-hero-orb1"></div>
		<div class="ex-hero-orb2"></div>
		<div class="ex-hero-row">
			<div>
				<div class="ex-hero-badge"><i class='bx bx-run'></i> Practice Zone</div>
				<h1><span class="t1">{{ 'exercises.title'|trans }}</span> <span class="t2">Library</span></h1>
				<p class="ex-hero-sub">{{ 'exercises.subtitle'|trans }}</p>
			</div>
			<div class="ex-hero-icon">
				<i class='bx bx-book-open'></i>
			</div>
		</div>
	</div>

	<!-- Level Stats -->
	<div class="ex-stats">
		<a href="{{ path('app_exercises', currentModule ? {module: currentModule} : {}) }}" class="ex-st {{ currentLevel == '' ? 'is-active' : '' }}">
			<div class="ex-st-row">
				<div class="ex-st-icon"><i class='bx bx-collection'></i></div>
				<div>
					<div class="ex-st-v">{{ counts.total|default(0) }}</div>
					<div class="ex-st-l">{{ 'exercises.all'|trans }}</div>
				</div>
			</div>
		</a>
		<a href="{{ path('app_exercises', {level: 'EASY'}|merge(currentModule ? {module: currentModule} : {})) }}" class="ex-st {{ currentLevel == 'EASY' ? 'is-active' : '' }}">
			<div class="ex-st-row">
				<div class="ex-st-icon"><i class='bx bx-leaf'></i></div>
				<div>
					<div class="ex-st-v" style="color:var(--green)">{{ counts.easy|default(0) }}</div>
					<div class="ex-st-l">{{ 'exercises.easy'|trans }}</div>
				</div>
			</div>
		</a>
		<a href="{{ path('app_exercises', {level: 'MEDIUM'}|merge(currentModule ? {module: currentModule} : {})) }}" class="ex-st {{ currentLevel == 'MEDIUM' ? 'is-active' : '' }}">
			<div class="ex-st-row">
				<div class="ex-st-icon"><i class='bx bx-trending-up'></i></div>
				<div>
					<div class="ex-st-v" style="color:var(--yellow)">{{ counts.medium|default(0) }}</div>
					<div class="ex-st-l">{{ 'exercises.medium'|trans }}</div>
				</div>
			</div>
		</a>
		<a href="{{ path('app_exercises', {level: 'HARD'}|merge(currentModule ? {module: currentModule} : {})) }}" class="ex-st {{ currentLevel == 'HARD' ? 'is-active' : '' }}">
			<div class="ex-st-row">
				<div class="ex-st-icon"><i class='bx bx-trophy'></i></div>
				<div>
					<div class="ex-st-v" style="color:var(--red)">{{ counts.hard|default(0) }}</div>
					<div class="ex-st-l">{{ 'exercises.hard'|trans }}</div>
				</div>
			</div>
		</a>
	</div>

	<!-- Module Filter -->
	{% if modules|length > 0 %}
	<div class="ex-filters-section">
		<div class="ex-filters-label"><i class='bx bx-filter-alt'></i> {{ 'exercises.all_modules'|trans }}</div>
		<div class="ex-modules">
			<a href="{{ path('app_exercises', currentLevel ? {level: currentLevel} : {}) }}" class="ex-mod-chip {{ currentModule == '' ? 'is-active' : '' }}">
				<i class='bx bx-grid-alt'></i> <span>All</span>
			</a>
			{% for mod in modules %}
			<a href="{{ path('app_exercises', {module: mod.id}|merge(currentLevel ? {level: currentLevel} : {})) }}" class="ex-mod-chip {{ currentModule == mod.id ? 'is-active' : '' }}">
				<i class='bx bx-book'></i> <span>{{ mod.name }}</span> <span class="ex-mod-count">{{ mod.exercise_count }}</span>
			</a>
			{% endfor %}
		</div>
	</div>
	{% endif %}

	<!-- Search -->
	<form class="ex-search-bar" method="get" action="{{ path('app_exercises') }}">
		{% if currentLevel %}<input type="hidden" name="level" value="{{ currentLevel }}">{% endif %}
		{% if currentModule %}<input type="hidden" name="module" value="{{ currentModule }}">{% endif %}
		<div class="ex-search-wrap">
			<i class='bx bx-search'></i>
			<input class="ex-search" type="text" name="q" value="{{ searchQuery }}" placeholder="{{ 'exercises.search_placeholder'|trans }}">
		</div>
		<button class="ex-search-btn" type="submit">{{ 'exercises.search'|trans }}</button>
	</form>

	<!-- Results count -->
	<div class="ex-results">
		<i class='bx bx-list-ul'></i>
		Showing <strong>{{ exercises|length }}</strong> exercise{{ exercises|length != 1 ? 's' : '' }}
		{% if currentLevel %} &middot; Level: <strong>{{ currentLevel }}</strong>{% endif %}
		{% if searchQuery %} &middot; Search: <strong>"{{ searchQuery }}"</strong>{% endif %}
	</div>

	<!-- Grid -->
	{% if exercises|length > 0 %}
	<div class="ex-grid">
		{% for ex in exercises %}
		<div class="ex-card" data-level="{{ ex.level }}" style="animation-delay:{{ loop.index0 * 0.07 }}s">
			<div class="ex-card-body">
				<div class="ex-card-top">
					<div class="ex-card-title">{{ ex.title }}</div>
					<span class="ex-badge {{ ex.level|lower }}">
						{% if ex.level == 'EASY' %}<i class='bx bx-leaf'></i>{% elseif ex.level == 'MEDIUM' %}<i class='bx bx-trending-up'></i>{% else %}<i class='bx bx-trophy'></i>{% endif %}
						{{ ex.level }}
					</span>
				</div>
				{% if ex.description %}
						<div class="ex-card-desc">{{ ex.description|u.truncate(120, '\u2026', true) }}</div>
				{% endif %}
				{% if ex.module_name %}
					<div class="ex-card-module"><i class='bx bx-category'></i> {{ ex.module_name }}</div>
				{% endif %}
				<div class="ex-card-meta">
					{% if ex.teacher_name %}
						<span><i class='bx bx-user'></i> {{ ex.teacher_name }}</span>
					{% endif %}
					<span><i class='bx bx-calendar'></i> {{ ex.created_at|date('M d, Y') }}</span>
				</div>
			</div>
			<div class="ex-card-foot">
				<a href="{{ path('app_exercise_view', {id: ex.id}) }}" class="ex-dl-btn" style="background:linear-gradient(135deg,var(--purple),var(--cyan))"><i class='bx bx-play-circle'></i> Open Exercise</a>
				{% if ex.pdf_path %}
					{% if ex.pdf_size_bytes %}
						<span class="ex-file-size"><i class='bx bx-file-pdf'></i> {{ (ex.pdf_size_bytes / 1024)|round(0) }} KB</span>
					{% else %}
						<span class="ex-file-size"><i class='bx bx-file-pdf'></i> PDF</span>
					{% endif %}
				{% else %}
					<span class="ex-no-file" style="font-size:0.7rem"><i class='bx bx-camera'></i> AI Monitor</span>
				{% endif %}
			</div>
		</div>
		{% endfor %}
	</div>
	{% else %}
	<div class="ex-empty">
		<div class="ex-empty-icon"><i class='bx bx-search-alt'></i></div>
		<h3>No exercises found</h3>
		<p>{{ 'exercises.empty'|trans }}</p>
	</div>
	{% endif %}

</div>
</div>
{% endblock %}

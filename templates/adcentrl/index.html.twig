					modal.innerHTML = `<svg width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="2" opacity="0.3"/><path d="M19 15l14 9-14 9V15z" fill="currentColor"/></svg><p style="font-size:0.9rem;opacity:0.7;">${name}'s Story — Coming Soon</p>`;
					overlay.appendChild(modal);

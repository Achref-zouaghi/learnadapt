				'Maria completed Machine Learning Basics 🎉',
				'Team at Shopify enrolled 12 members',
				'James from London earned a certificate!',
				'Sara just hit a 30-day streak 🔥',
				'David from Berlin upgraded to Pro',
				'Priya finished her AI Fundamentals path',
				'Acme Corp signed up for Enterprise'
			];
			let idx = 0, showing = false;
			function show() {
				if (showing) return;
				showing = true;
				textEl.textContent = proofs[idx % proofs.length];
				idx++;
				toast.classList.add('is-visible');
				setTimeout(hide, 5000);

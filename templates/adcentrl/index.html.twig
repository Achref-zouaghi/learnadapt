			let idx = 0, lastTime = 0;
			document.addEventListener('mousemove', e => {
				const now = performance.now();
				if (now - lastTime < 60) return; /* ~16 particles/sec max */
				lastTime = now;
				const p = pool[idx % MAX];
				/* Reset: place at cursor, full opacity */
				p.style.transition = 'none';
				p.style.opacity = '0.5';
				p.style.transform = 'translate3d(0,0,0) scale(1)';

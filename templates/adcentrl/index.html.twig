		/* ── N19. NAV BLUR TRANSITION — handled by CSS ── */

		/* ── N20. EASTER EGG — LOGO HOVER 3s SPEEDS UP CRADLE ── */
		(() => {
			const brand = document.querySelector('.page-brand');
			if (!brand) return;

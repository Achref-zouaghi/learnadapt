		.why-header .section-tag { display: inline-block; padding: 6px 16px; border-radius: 999px; background: rgba(139,92,246,0.12); border: 1px solid rgba(139,92,246,0.22); font-size: 0.72rem; font-weight: 700; color: #a78bfa; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 20px; }
		.why-header h2 { font-size: clamp(1.8rem,3.2vw,2.6rem); font-weight: 800; letter-spacing: -0.03em; line-height: 1.2; margin-bottom: 18px; }
		.why-header p { font-size: 1.05rem; color: var(--muted); line-height: 1.7; }
		.why-row {

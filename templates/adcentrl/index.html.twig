		.pricing-card.featured { background: linear-gradient(#0c0d1e,#0c0d1e) padding-box, linear-gradient(155deg, #9f7aea, #67e8f9) border-box; border: 2px solid transparent; padding: 42px 30px; margin-top: -16px; box-shadow: 0 24px 62px rgba(0,0,0,0.5), 0 0 26px rgba(124,58,237,0.14); }

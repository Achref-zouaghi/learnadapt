		.pricing-btn.outline { background: transparent; color: var(--text); border: 1px solid rgba(255,255,255,0.15); }
		.pricing-btn.outline:hover { border-color: rgba(255,255,255,0.35); background: rgba(255,255,255,0.04); }

		/* ── FINAL CTA ── */
		.cta-section { padding: 0 56px 130px; }
		.cta-inner {
			max-width: 860px; margin: 0 auto; border-radius: 28px; padding: 90px 64px; text-align: center;
			background: linear-gradient(135deg, rgba(124,58,237,0.26) 0%, rgba(37,99,235,0.2) 50%, rgba(34,211,238,0.14) 100%);
			border: 1px solid rgba(139,92,246,0.34); position: relative; overflow: hidden;
			box-shadow: 0 22px 64px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.06);
		}
		.cta-inner::before { content: ''; position: absolute; width: 600px; height: 600px; background: radial-gradient(circle, rgba(124,58,237,0.22), transparent 70%); top: 50%; left: 50%; transform: translate(-50%,-50%); pointer-events: none; }
		.cta-tag { position: relative; z-index: 1; font-size: 0.72rem; font-weight: 700; color: #a78bfa; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 14px; display: block; }
		.cta-title { position: relative; z-index: 1; font-size: clamp(28px,4vw,48px); font-weight: 800; letter-spacing: -0.03em; line-height: 1.15; margin-bottom: 16px; }
		.cta-sub { position: relative; z-index: 1; font-size: 1.0625rem; color: var(--muted); max-width: 460px; margin: 0 auto 36px; line-height: 1.68; }
		.cta-actions { position: relative; z-index: 1; display: flex; align-items: center; justify-content: center; gap: 12px; flex-wrap: wrap; width: 100%; }
		.cta-note { position: relative; z-index: 1; font-size: 0.8rem; color: rgba(148,163,184,0.5); margin-top: 16px; }

		/* ── NOTIFICATIONS SECTION ── */
		.notifications-section { padding: 0 56px 120px; }
		.notifications-inner {
			max-width: 860px;
			margin: 0 auto;
			border-radius: 24px;
			padding: 34px 30px;
			background: linear-gradient(165deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
			border: 1px solid rgba(255,255,255,0.11);
			box-shadow: 0 20px 54px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.04);
		}
		.notifications-head { display: flex; align-items: center; justify-content: space-between; gap: 14px; margin-bottom: 18px; }

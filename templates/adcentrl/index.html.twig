				ticking = false;
			}
			window.addEventListener('scroll', () => {
				if (!ticking) { ticking = true; requestAnimationFrame(update); }
			}, { passive: true });
		})();

		/* ── B14. HERO TEXT SCRAMBLE ── */
		(() => {
			const title = document.querySelector('.hero-title');
			if (!title) return;
			const finalText = title.textContent;
			const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%';
			let iter = 0;
			const maxIter = 8;
			function scramble() {
				title.textContent = finalText.split('').map((ch, i) => {
					if (ch === ' ' || ch === '\n') return ch;
					if (i < iter) return finalText[i];
					return chars[Math.floor(Math.random() * chars.length)];
				}).join('');
				iter += 1;
				if (iter <= finalText.length) requestAnimationFrame(() => setTimeout(scramble, 25));
			}
			setTimeout(scramble, 600);
		})();

		/* ── B15. STAR RATING FILL ── */
		(() => {
			document.querySelectorAll('.testimonial-card').forEach(card => {
				const starsWrap = card.querySelector('.testimonial-stars');
				if (!starsWrap) return;
				const stars = starsWrap.querySelectorAll('span, svg');
				const io = new IntersectionObserver(entries => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							stars.forEach((s, i) => {
								s.style.opacity = '0';
								s.style.transform = 'scale(0)';
								s.style.transition = `opacity 0.3s ease ${i * 0.12}s, transform 0.4s cubic-bezier(0.34,1.56,0.64,1) ${i * 0.12}s`;
								requestAnimationFrame(() => { s.style.opacity = '1'; s.style.transform = 'scale(1)'; });
							});
							io.unobserve(entry.target);
						}
					});
				}, { threshold: 0.5 });

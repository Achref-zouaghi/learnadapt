	<!-- COMMUNITY COMMENTS -->
	<section class="section-wrap" id="community-comments">
		<div class="comments-section">
			<div class="comments-header" data-anim="fade-up">
				<span class="section-tag">Community</span>
				<h2>What our learners say</h2>
				<p>Real reviews from real students — share your experience!</p>
			</div>

			{% if user %}
			<div class="comment-composer" data-anim="fade-up">
				<div class="comment-composer-top">
					{% if user.avatarBase64 %}
						<img class="comment-composer-avatar" src="{{ user.avatarBase64 }}" alt="">
					{% else %}
						<div class="comment-composer-avatar" style="background:linear-gradient(135deg,var(--purple),var(--cyan));display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.9rem;color:#fff">{{ user.fullName|first|upper }}</div>
					{% endif %}
					<div>
						<div class="comment-composer-name">{{ user.fullName }}</div>
						<div class="comment-composer-hint">Share your experience with LearnAdapt</div>
					</div>
				</div>
				<div class="comment-stars-input" id="commentStarsInput">
					<button type="button" data-star="1" aria-label="1 star">★</button>
					<button type="button" data-star="2" aria-label="2 stars">★</button>
					<button type="button" data-star="3" aria-label="3 stars">★</button>
					<button type="button" data-star="4" aria-label="4 stars">★</button>
					<button type="button" data-star="5" aria-label="5 stars">★</button>
				</div>
				<div class="comment-media-btns">
					<button type="button" class="comment-media-btn" id="commentPhotoBtn">
						<svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
						Photos
					</button>
					<button type="button" class="comment-media-btn" id="commentVideoBtn">
						<svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
						Videos
					</button>
					<input type="file" id="commentPhotoInput" accept="image/jpeg,image/png,image/gif,image/webp" style="display:none" multiple>
					<input type="file" id="commentVideoInput" accept="video/mp4,video/webm,video/ogg" style="display:none" multiple>
				</div>
				<div class="comment-media-preview" id="commentMediaPreview" style="display:none;gap:6px;flex-wrap:wrap">
					<button type="button" class="comment-media-remove" id="commentMediaRemove">×</button>
				</div>
				<textarea class="comment-textarea" id="commentTextarea" placeholder="Write your review..." maxlength="1000"></textarea>
				<div class="comment-composer-actions">
					<span class="comment-char-count"><span id="commentCharCount">0</span>/1000</span>
					<button class="comment-submit-btn" id="commentSubmitBtn" disabled>
						<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						Post Review
					</button>
				</div>
			</div>
			{% else %}
			<div class="comment-login-prompt" data-anim="fade-up">
				<p>Sign in to share your experience with the community</p>
				<a href="{{ path('app_login') }}" class="comment-login-btn">
					<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4M10 17l5-5-5-5M15 12H3"/></svg>
					Sign In
				</a>
			</div>
			{% endif %}

			<div class="comments-list" id="commentsList">
				{% if comments is empty %}
				<div class="comments-empty" id="commentsEmpty">
					<div class="comments-empty-icon">💬</div>
					<p>No reviews yet — be the first to share your thoughts!</p>
				</div>
				{% else %}
					{% for c in comments %}
					<div class="comment-card" data-comment-id="{{ c.id }}" data-anim="fade-up">
						<div class="comment-card-head">
							{% if c.author_avatar %}
								<img class="comment-card-avatar" src="{{ c.author_avatar }}" alt="">
							{% else %}
								<div class="comment-card-avatar" style="background:linear-gradient(135deg,var(--purple),var(--cyan));display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.82rem;color:#fff">{{ c.author_name|first|upper }}</div>
							{% endif %}
							<div>
								<span class="comment-card-name">{{ c.author_name }}</span>
								<span class="comment-card-role">{{ c.author_role }}</span>
							</div>
							<span class="comment-card-time">{{ c.created_at|date('M d, Y') }}</span>
						</div>
						<div class="comment-card-stars">{% for i in 1..5 %}{{ i <= c.rating ? '★' : '☆' }}{% endfor %}</div>
						{% set _cMedia = [] %}
						{% if c.media_files is defined and c.media_files %}
							{% set _cMedia = c.media_files|json_decode %}
						{% elseif c.media_path %}
							{% set _cMedia = [{type: c.media_type, path: c.media_path}] %}
						{% endif %}
						{% if _cMedia|length > 0 %}
						<div class="comment-card-media" style="{% if _cMedia|length > 1 %}display:grid;grid-template-columns:repeat(2,1fr);gap:6px{% endif %}">
							{% for m in _cMedia %}
								{% if m.type == 'image' %}
									<img src="{{ m.path }}" alt="" style="border-radius:14px;max-height:{{ _cMedia|length > 1 ? '200' : '400' }}px;object-fit:cover;width:100%">
								{% elseif m.type == 'video' %}
									<video controls playsinline preload="auto" style="border-radius:14px;max-height:{{ _cMedia|length > 1 ? '200' : '400' }}px;width:100%;background:#000"><source src="{{ m.path }}">Your browser does not support video.</video>
								{% endif %}
							{% endfor %}
						</div>
						{% endif %}
						{% if c.comment %}<div class="comment-card-text">{{ c.comment }}</div>{% endif %}
						{% if (c.like_count|default(0)) > 0 %}
						<div class="comment-reaction-summary">
							<div class="comment-reaction-icons"><span class="r-like">👍</span><span class="r-love">❤️</span><span class="r-clap">👏</span></div>
							<span class="reaction-count">{{ c.like_count }}</span>
						</div>
						{% endif %}
						<div class="comment-actions">
							<button type="button" class="comment-action {% if c.user_reaction is defined and c.user_reaction == 'like' %}liked{% endif %}" data-comment-id="{{ c.id }}" onclick="reactToComment(this)">
								<i class='bx {% if c.user_reaction is defined and c.user_reaction == "like" %}bxs-like{% else %}bx-like{% endif %}'></i> J'aime
							</button>
							<button type="button" class="comment-action"><i class='bx bx-message-rounded'></i> Commenter</button>
							<button type="button" class="comment-action"><i class='bx bx-repost'></i> Republier</button>
							<button type="button" class="comment-action"><i class='bx bx-send'></i> Envoyer</button>
						</div>
						{% if user and user.id == c.user_id %}
						<button class="comment-card-delete" data-delete-id="{{ c.id }}">Delete</button>
						{% endif %}
					</div>
					{% endfor %}
				{% endif %}
			</div>
		</div>

		<div class="comment-media-lightbox" id="commentLightbox" onclick="this.classList.remove('active')">
			<img src="" alt="" id="commentLightboxImg">
		</div>
	</section>


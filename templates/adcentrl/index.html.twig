	<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
	<script>
		/* ── Toast system ── */
		(function(){
			var container = document.createElement('div');
			container.className = 'toast-container';
			document.body.appendChild(container);
			window.showToast = function(msg, type) {
				type = type || 'error';
				var icons = {error:'<i class="bx bx-error-circle"></i>',success:'<i class="bx bx-check-circle"></i>',warn:'<i class="bx bx-shield-x"></i>'};
				var titles = {error:'Error',success:'Success',warn:'Warning'};
				var toast = document.createElement('div');
				toast.className = 'toast';
				toast.style.position = 'relative';
				toast.style.overflow = 'hidden';
				toast.innerHTML = '<div class="toast-icon '+type+'">'+icons[type]+'</div>'+
					'<div class="toast-body"><div class="toast-title '+type+'">'+titles[type]+'</div><div class="toast-msg">'+msg+'</div></div>'+
					'<button class="toast-close"><i class="bx bx-x"></i></button>'+
					'<div class="toast-progress" style="width:100%"></div>';
				container.appendChild(toast);
				var progress = toast.querySelector('.toast-progress');
				var duration = 5000;
				setTimeout(function(){ toast.classList.add('show'); }, 10);
				progress.style.transitionDuration = duration + 'ms';
				setTimeout(function(){ progress.style.width = '0%'; }, 50);
				var autoClose = setTimeout(function(){ dismissToast(toast); }, duration);
				toast.querySelector('.toast-close').addEventListener('click', function(){ clearTimeout(autoClose); dismissToast(toast); });
				function dismissToast(t){ t.classList.remove('show'); t.classList.add('hide'); setTimeout(function(){ t.remove(); }, 400); }
			};
		})();

		document.getElementById('footerYear').textContent = new Date().getFullYear();

		const navbar = document.getElementById('navbar');
		const navLinksWrap = document.querySelector('.nav-links');
		const navActivePill = document.getElementById('navActivePill');
		const navActiveTrail = document.getElementById('navActiveTrail');
		const navLinks = [...document.querySelectorAll('.nav-links a[href^="#"]:not([href="#"])')];
		const centerNotifTabs = [...document.querySelectorAll('.notifications-tab[data-tab]')];
		const centerNotifItems = [...document.querySelectorAll('.notifications-item[data-notif-category]')];
		const centerNotifGrid = document.querySelector('.notifications-grid');
		const notificationsUnreadSummary = document.getElementById('notificationsUnreadSummary');
		const notificationsSection = document.getElementById('notifications');

		/* ── Active nav pill tracking (home page only) ── */
		let navPillMoveTimer;
		function moveNavPillTo(link) {
			if (!navLinksWrap || !navActivePill || !link) return;
			const wrapBox = navLinksWrap.getBoundingClientRect();
			const linkBox = link.getBoundingClientRect();
			navActivePill.style.width = `${linkBox.width}px`;
			navActivePill.style.transform = `translateX(${linkBox.left - wrapBox.left}px)`;
			navActivePill.style.opacity = '1';
			navActivePill.classList.add('is-moving');
			clearTimeout(navPillMoveTimer);
			navPillMoveTimer = setTimeout(() => navActivePill.classList.remove('is-moving'), 420);
			if (navActiveTrail) {
				navActiveTrail.style.width = `${Math.max(linkBox.width - 10, 14)}px`;
				navActiveTrail.style.transform = `translateX(${linkBox.left - wrapBox.left + 5}px)`;
				navActiveTrail.style.opacity = '0.75';
			}
		}
		function setActiveNavLink(id) {
			let activeLink = null;
			navLinks.forEach(link => {
				const isActive = link.getAttribute('href') === `#${id}`;
				link.classList.toggle('is-active', isActive);
				if (isActive) activeLink = link;
			});
			if (activeLink) moveNavPillTo(activeLink);
		}

		window.addEventListener('resize', () => {
			const active = navLinks.find(link => link.classList.contains('is-active'));
			if (active) moveNavPillTo(active);
		});
		navLinks.forEach(link => {
			link.addEventListener('click', () => moveNavPillTo(link));
		});
		const firstActive = navLinks.find(link => link.classList.contains('is-active'));
		if (firstActive) moveNavPillTo(firstActive);

		/* ── Center notification tab sync (home page only) ── */
		if (centerNotifTabs.length) {
			centerNotifTabs.forEach(tab => {
				tab.addEventListener('click', () => {
					const tabName = tab.dataset.tab;
					centerNotifTabs.forEach(t => t.classList.toggle('is-active', t.dataset.tab === tabName));
					document.querySelectorAll('.nav-notif-tab[data-tab]').forEach(t => t.classList.toggle('is-active', t.dataset.tab === tabName));
					if (centerNotifGrid) centerNotifGrid.classList.add('is-switching');
					centerNotifItems.forEach(item => item.classList.toggle('is-hidden', item.dataset.notifCategory !== tabName));
					document.querySelectorAll('.nav-notif-item[data-notif-category]').forEach(item => item.classList.toggle('is-hidden', item.dataset.notifCategory !== tabName));
					if (centerNotifGrid) requestAnimationFrame(() => centerNotifGrid.classList.remove('is-switching'));
				});
			});
		}

		/* ── Section intersection observer ── */
		const navSections = navLinks
			.map(link => document.querySelector(link.getAttribute('href')))
			.filter(Boolean);
		if (navSections.length) {
			const sectionObserver = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						setActiveNavLink(entry.target.id);
					}
				});
			}, {
				rootMargin: '-42% 0px -42% 0px',
				threshold: 0
			});
			navSections.forEach(section => sectionObserver.observe(section));
		}

		const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		/* ── Twinkling star particles ── */
		if (!prefersReduced) {
			const pc = document.getElementById('particles');
			const st = document.createElement('style');
				st.textContent = '@keyframes twinkle{0%,100%{opacity:.04}50%{opacity:.28;transform:scale(1.22)}}';
			document.head.appendChild(st);
				for (let i = 0; i < 34; i++) {
				const d = document.createElement('div');
				const s = Math.random() * 2 + 1;
					d.style.cssText = `position:absolute;width:${s}px;height:${s}px;border-radius:50%;background:rgba(255,255,255,.62);top:${Math.random()*100}%;left:${Math.random()*100}%;animation:twinkle ${Math.random()*5+4}s ease-in-out infinite;animation-delay:${Math.random()*7}s;will-change:transform,opacity;`;
				pc.appendChild(d);
			}
		}

		if (prefersReduced) {
			document.querySelectorAll('[data-feature],[data-pricing],[data-testimonial],[data-showcase]')
				.forEach(el => el.classList.add('visible'));
			document.querySelectorAll('[data-reveal]').forEach(el => {
				el.style.opacity = '1'; el.style.transform = 'none';
			});
			document.querySelectorAll('.stat-number').forEach(el => {
				const t = parseFloat(el.dataset.count), d = parseInt(el.dataset.decimals || 0);
				const pre = el.dataset.prefix || '', suf = el.dataset.suffix || '';
				const comma = el.dataset.comma === 'true';
				el.textContent = pre + (comma ? t.toLocaleString() : t.toFixed(d)) + suf;
			});
		} else {

			/* GSAP dashboard scrub */
			window.addEventListener('load', () => {
				if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
				gsap.registerPlugin(ScrollTrigger);
				gsap.fromTo('#browserWindow',
					{ scale: 0.76, opacity: 0.22, y: 50 },
					{
						scale: 1, opacity: 1, y: 0, ease: 'none',
						scrollTrigger: {
							trigger: '#dashboardSection',
							start: 'top top', end: 'bottom bottom',
							scrub: 1.25, pin: '#dashboardPin', anticipatePin: 1,
						}
					}
				);
			});

			/* Generic [data-reveal] */
			document.querySelectorAll('[data-reveal]').forEach(el => {
				el.style.cssText += ';opacity:0;transform:translateY(32px);transition:opacity 0.82s cubic-bezier(0.22,1,0.36,1),transform 0.82s cubic-bezier(0.22,1,0.36,1)';
				new IntersectionObserver((ents, obs) => {
					ents.forEach(e => {
						if (!e.isIntersecting) return;
						e.target.style.opacity = '1'; e.target.style.transform = 'translateY(0)';
						obs.unobserve(e.target);
					});
				}, { threshold: 0.15 }).observe(el);
			});

			/* Feature stagger */
			const fcards = [...document.querySelectorAll('[data-feature]')];
			fcards.forEach(c => new IntersectionObserver((ents, obs) => {
				ents.forEach(e => {
					if (!e.isIntersecting) return;
					e.target.style.transitionDelay = `${fcards.indexOf(e.target) * 0.1}s`;
					e.target.classList.add('visible');
					obs.unobserve(e.target);
				});
			}, { threshold: 0.12, rootMargin: '0px 0px -30px 0px' }).observe(c));

			/* Pricing stagger */
			const pcards = [...document.querySelectorAll('[data-pricing]')];
			pcards.forEach(c => new IntersectionObserver((ents, obs) => {
				ents.forEach(e => {
					if (!e.isIntersecting) return;
					e.target.style.transitionDelay = `${pcards.indexOf(e.target) * 0.12}s`;
					e.target.classList.add('visible');
					obs.unobserve(e.target);
				});
			}, { threshold: 0.1 }).observe(c));

			/* Testimonial stagger */
			const tcards = [...document.querySelectorAll('[data-testimonial]')];
			tcards.forEach(c => new IntersectionObserver((ents, obs) => {
				ents.forEach(e => {
					if (!e.isIntersecting) return;
					e.target.style.transitionDelay = `${tcards.indexOf(e.target) * 0.13}s`;
					e.target.classList.add('visible');
					obs.unobserve(e.target);
				});
			}, { threshold: 0.1 }).observe(c));

			/* Showcase stagger */
			const scards = [...document.querySelectorAll('[data-showcase]')];
			scards.forEach(c => new IntersectionObserver((ents, obs) => {
				ents.forEach(e => {
					if (!e.isIntersecting) return;
					e.target.style.transitionDelay = `${scards.indexOf(e.target) * 0.12}s`;
					e.target.classList.add('visible');
					obs.unobserve(e.target);
				});
			}, { threshold: 0.1 }).observe(c));

			/* Count-up */
			function easeOut(t) { return 1 - Math.pow(1 - t, 4); }
			function countUp(el) {
				const target = parseFloat(el.dataset.count);
				const decimals = parseInt(el.dataset.decimals || 0);
				const prefix = el.dataset.prefix || '', suffix = el.dataset.suffix || '';
				const comma = el.dataset.comma === 'true';
				const dur = 2000, t0 = performance.now();
				const fmt = v => { const n = v.toFixed(decimals); return comma ? parseFloat(n).toLocaleString() : n; };
				(function tick(now) {
					const p = Math.min((now - t0) / dur, 1);
					el.textContent = prefix + fmt(target * easeOut(p)) + (p === 1 ? suffix : '');
					if (p < 1) requestAnimationFrame(tick);
					else {
						el.textContent = prefix + fmt(target) + suffix;
						el.classList.add('glow-done'); /* Stats glow (#10) */
					}
				})(t0);
			}
			let statsRan = false;
			new IntersectionObserver(ents => {
				if (!ents[0].isIntersecting || statsRan) return;
				statsRan = true;
				document.querySelectorAll('.stat-number').forEach(countUp);
			}, { threshold: 0.4 }).observe(document.getElementById('statsBar'));
		}

		/* ═══════════════════════════════════════════
		   PREMIUM ENHANCEMENTS - ALL 25 FEATURES
		   ═══════════════════════════════════════════ */

		/* ── 1. CUSTOM CURSOR (GPU-accelerated, no rAF loop) ── */
		(() => {
			const dot = document.getElementById('cursorDot');
			const ring = document.getElementById('cursorRing');
			if (!dot || !ring || window.matchMedia('(pointer: coarse)').matches) return;
			document.body.style.cursor = 'none';
			/* Ring offset = half its current size; recalc on hover */
			let ringOff = 16;
			const updateRingOff = () => { ringOff = ring.offsetWidth / 2; };
			document.addEventListener('mousemove', e => {
				const x = e.clientX, y = e.clientY;
				dot.style.transform = `translate3d(${x - 3}px, ${y - 3}px, 0)`;
				ring.style.transform = `translate3d(${x - ringOff}px, ${y - ringOff}px, 0)`;
			}, { passive: true });
			document.addEventListener('mousedown', () => ring.classList.add('is-click'));
			document.addEventListener('mouseup', () => ring.classList.remove('is-click'));
			const interactives = 'a, button, input, [role="button"], .pricing-card, .feature-card, .testimonial-card, .step-card';
			document.addEventListener('mouseover', e => { if (e.target.closest(interactives)) { ring.classList.add('is-hover'); updateRingOff(); } });
			document.addEventListener('mouseout',  e => { if (e.target.closest(interactives)) { ring.classList.remove('is-hover'); updateRingOff(); } });
		})();

		/* ── 2. MAGNETIC BUTTONS (perf: rAF throttled) ── */
		(() => {
			const magnetics = document.querySelectorAll('.btn-primary, .btn-ghost, .nav-cta, .pricing-btn');
			magnetics.forEach(btn => {
				let ticking = false;
				btn.addEventListener('mousemove', e => {
					if (ticking) return;
					ticking = true;
					requestAnimationFrame(() => {
						const r = btn.getBoundingClientRect();
						const cx = r.left + r.width / 2, cy = r.top + r.height / 2;
						const pull = 0.28;
						btn.style.transform = `translate(${(e.clientX - cx) * pull}px, ${(e.clientY - cy) * pull}px)`;
						ticking = false;
					});
				});
				btn.addEventListener('mouseleave', () => {
					btn.style.transform = '';
					btn.style.transition = 'transform 0.4s cubic-bezier(0.22,1,0.36,1)';
					setTimeout(() => btn.style.transition = '', 400);
				});
			});
		})();

		/* ── 3. HERO TEXT REVEAL ── */
		(() => {
			const ht = document.querySelector('.hero-text');
			if (!ht) return;
			setTimeout(() => ht.classList.add('is-revealed'), 600);
		})();

		/* ── 4. PARALLAX MOUSE BLOBS (perf: rAF throttled) ── */
		(() => {

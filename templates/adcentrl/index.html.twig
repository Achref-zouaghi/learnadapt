			background: rgba(255,255,255,0.07);
			color: rgba(241,245,249,0.75);
		}
		.nav-notif-tab.is-active { color: #f8fafc; border-bottom-color: rgba(123,97,241,0.9); }
		.nav-notif-tab.is-active::after {
			background: linear-gradient(135deg, rgba(123,97,241,0.28), rgba(56,189,209,0.22));
			color: #e2e8f0;
		}
		.nav-notif-list { list-style: none; max-height: 320px; overflow: auto; }
		.nav-notif-item.is-hidden { display: none; }
		.nav-notif-list.is-switching .nav-notif-item {
			opacity: 0;
			transform: translateY(6px);
		}
		.nav-notif-item {
			display: grid;
			grid-template-columns: 34px 1fr auto;
			gap: 10px;
			align-items: start;
			padding: 11px 14px;
			border-bottom: 1px solid rgba(255,255,255,0.06);
			transition: background 0.2s ease, opacity 0.24s ease, transform 0.24s ease;
		}
		.nav-notif-item:hover { background: rgba(255,255,255,0.04); }
		.nav-notif-item:last-child { border-bottom: 0; }
		.nav-notif-avatar {
			position: relative;
			width: 34px;
			height: 34px;
			border-radius: 50%;
			display: inline-flex;
			align-items: center;
			justify-content: center;
			font-size: 0.88rem;
			background: rgba(255,255,255,0.07);
			border: 1px solid rgba(255,255,255,0.14);
			overflow: hidden;
		}
		.nav-notif-avatar::after {
			content: '';
			position: absolute;
			right: 1px;
			bottom: 1px;
			width: 9px;
			height: 9px;
			border-radius: 50%;
			border: 2px solid rgba(10,13,23,0.95);
			opacity: 0;
		}
		.nav-notif-avatar[data-status="online"]::after {
			opacity: 1;
			background: #22c55e;
			box-shadow: 0 0 10px rgba(34,197,94,0.6);
		}
		.nav-notif-avatar[data-status="away"]::after {
			opacity: 1;
			background: #f59e0b;
			box-shadow: 0 0 10px rgba(245,158,11,0.5);
		}
		.nav-notif-avatar[data-status="offline"]::after {
			opacity: 1;
			background: #64748b;
		}
		.nav-notif-text strong { color: #f8fafc; font-weight: 700; }
		.nav-notif-text p { font-size: 0.82rem; line-height: 1.35; color: #cbd5e1; }
		.nav-notif-meta { font-size: 0.74rem; color: #94a3b8; margin-top: 2px; }
		.nav-notif-dot {
			width: 8px;
			height: 8px;
			border-radius: 50%;
			margin-top: 5px;
			background: linear-gradient(135deg, #7b61f1, #38bdd1);
			box-shadow: 0 0 12px rgba(123,97,241,0.6);
			transition: opacity 0.2s ease, box-shadow 0.2s ease;
		}
		.nav-notif-dot.is-read { opacity: 0; box-shadow: none; }
		.nav-notif-list::-webkit-scrollbar { width: 8px; }
		.nav-notif-list::-webkit-scrollbar-thumb { background: rgba(148,163,184,0.28); border-radius: 999px; }
		.nav-notif-list::-webkit-scrollbar-track { background: transparent; }
		.nav-notif-footer {
			padding: 10px 14px 12px;
			border-top: 1px solid rgba(255,255,255,0.06);
			background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0));
		}
		.nav-notif-footer a {
			display: inline-flex;
			align-items: center;
			gap: 8px;
			font-size: 0.8rem;
			font-weight: 600;
			text-decoration: none;
			color: #cbd5e1;
			transition: color 0.2s ease, transform 0.2s ease;
		}
		.nav-notif-footer a::after {
			content: '->';
			font-size: 0.78rem;
			opacity: 0.8;
		}
		.nav-notif-footer a:hover {
			color: #f8fafc;
			transform: translateX(2px);
		}
		.nav-cta {
			position: relative;
			display: inline-flex; align-items: center; justify-content: center;
			height: 32px; min-width: 96px; padding: 0 13px; border-radius: 999px;
			background: linear-gradient(180deg, #ffffff, #f4f4f5);
			color: #0f172a; font-size: 0.68rem; font-weight: 700; text-decoration: none;
			border: 1px solid rgba(255,255,255,0.74);
			box-shadow: 0 3px 10px rgba(15,23,42,0.22);
			overflow: hidden;
			isolation: isolate;
			transition: box-shadow 0.24s ease, transform 0.24s var(--ease), border-color 0.24s ease, filter 0.24s ease;
			will-change: transform; white-space: nowrap;
		}
		.nav-cta::before {
			content: '';
			position: absolute;
			inset: -1px;
			border-radius: inherit;
			background: conic-gradient(from 120deg, rgba(249,115,22,0.28), rgba(255,255,255,0.04), rgba(249,115,22,0.34), rgba(255,255,255,0.04));
			opacity: 0;
			filter: blur(8px);
			z-index: -1;
			transform: scale(0.9);
			transition: opacity 0.24s ease, transform 0.24s ease;
		}
		.nav-cta::after {
			content: '';
			position: absolute;
			top: 0;
			left: -130%;
			width: 60%;
			height: 100%;
			background: linear-gradient(110deg, transparent, rgba(255,255,255,0.72), transparent);
			transform: skewX(-22deg);
			opacity: 0;
		}
		.nav-cta:hover {
			border-color: rgba(255,255,255,0.94);
			box-shadow: 0 6px 18px rgba(15,23,42,0.32), 0 0 14px rgba(249,115,22,0.24);
			transform: scale(1.02) translateY(-1px);
			filter: brightness(1.02);
		}
		.nav-cta:hover::before { opacity: 0.42; transform: scale(1.06); }
		.nav-cta:hover::after { opacity: 1; animation: navCtaShimmer 0.9s linear 1; }
		.nav-cta:active { transform: translateY(0) scale(0.985); }
		.nav.scrolled .nav-cta {
			min-width: 92px;
			height: 31px;
			padding: 0 12px;
			border-radius: 999px;
			box-shadow: 0 4px 12px rgba(15,23,42,0.28);
		}
		.nav.compact .nav-cta {
			min-width: 88px;
			height: 30px;
			padding: 0 11px;
			font-size: 0.64rem;
			border-radius: 999px;
			background: linear-gradient(180deg, #ffffff, #f4f4f5);
			border-color: rgba(255,255,255,0.7);
		}
		.nav.compact .nav-cta:hover {
			box-shadow: 0 5px 12px rgba(15,23,42,0.3), 0 0 10px rgba(249,115,22,0.2);
			transform: scale(1.02) translateY(-1px);
		}
		@keyframes navCtaShimmer {
			0% { left: -130%; }
			100% { left: 160%; }
		}

		/* ── HERO ── */
		.hero {
			position: relative; min-height: 100vh; display: flex; align-items: center;
			padding: 110px 56px 80px; overflow: hidden;
		}
		.hero::after {
			content: ''; position: absolute; inset: 0;
			background-image: radial-gradient(rgba(255,255,255,0.065) 1px, transparent 1px);
			background-size: 34px 34px; pointer-events: none; z-index: 0;
			mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 20%, transparent 100%);
			-webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 20%, transparent 100%);
		}
		.hero-bg { position: absolute; inset: 0; overflow: hidden; z-index: 0; pointer-events: none; }
		.blob { position: absolute; border-radius: 50%; filter: blur(100px); will-change: transform; }
		.blob-1 { width: 700px; height: 700px; background: radial-gradient(circle, rgba(124,58,237,0.23), transparent 70%); top: -200px; left: -150px; animation: blobMove 10s ease-in-out infinite; }
		.blob-2 { width: 580px; height: 580px; background: radial-gradient(circle, rgba(34,211,238,0.16), transparent 70%); top: 80px; right: -80px; animation: blobMove 13s ease-in-out infinite reverse; }
		.blob-3 { width: 480px; height: 480px; background: radial-gradient(circle, rgba(167,139,250,0.12), transparent 70%); bottom: -80px; left: 38%; animation: blobMove 9s ease-in-out infinite; animation-delay: -3s; }
		@keyframes blobMove { 0%,100% { transform: translate(0,0); } 33% { transform: translate(28px,-32px); } 66% { transform: translate(-22px,14px); } }

		.hero-inner {
			position: relative; z-index: 1;
			display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center;
			max-width: 1200px; margin: 0 auto; width: 100%;
		}
		.hero-text { display: flex; flex-direction: column; align-items: flex-start; gap: 26px; }
		.hero-badge {
			display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px; border-radius: 999px;
			border: 1px solid rgba(139,92,246,0.5); background: rgba(139,92,246,0.1);
			font-size: 0.8125rem; font-weight: 500; color: rgba(241,245,249,0.9);
		}
		.badge-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--purple); animation: pulse 2s ease-in-out infinite; }
		@keyframes pulse { 0%,100% { opacity:1; transform:scale(1); } 50% { opacity:0.45; transform:scale(0.7); } }
		.hero-title { font-size: clamp(44px, 5.8vw, 80px); font-weight: 800; line-height: 1.03; letter-spacing: -0.046em; }
		.gradient-text {
			background: linear-gradient(90deg, #b29cfb 0%, #50cbdc 50%, #b29cfb 100%);
			background-size: 200% auto;
			-webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
			animation: gradShift 4s linear infinite;
		}
		@keyframes gradShift { 0% { background-position: 0% center; } 100% { background-position: 200% center; } }
		.hero-sub { font-size: 1.0625rem; color: var(--muted); max-width: 460px; line-height: 1.72; }
		.hero-actions { display: flex; align-items: center; justify-content: center; gap: 12px; flex-wrap: wrap; width: 100%; }
		.btn-primary {
			display: inline-flex; align-items: center; gap: var(--btn-gap);
			height: var(--btn-h); padding: 0 var(--btn-px); border-radius: var(--btn-radius);
			background: linear-gradient(135deg, var(--purple-d), #2563eb); color: #fff;
			font-size: 0.9375rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer;
			box-shadow: 0 0 30px rgba(124,58,237,0.45), 0 4px 16px rgba(0,0,0,0.5);
			transition: transform 0.2s var(--ease), box-shadow 0.2s ease; will-change: transform; font-family: inherit;
		}
		.btn-primary:hover { transform: var(--btn-hover-transform); box-shadow: 0 0 55px rgba(124,58,237,0.7), 0 8px 28px rgba(0,0,0,0.5); }
		.btn-ghost {
			display: inline-flex; align-items: center; gap: var(--btn-gap);
			height: var(--btn-h); padding: 0 var(--btn-px); border-radius: var(--btn-radius);
			background: rgba(255,255,255,0.05); color: var(--text);
			font-size: 0.9375rem; font-weight: 600; text-decoration: none;
			border: 1px solid rgba(255,255,255,0.13); cursor: pointer;
			transition: transform 0.2s var(--ease), background 0.2s ease, border-color 0.2s ease; will-change: transform; font-family: inherit;
		}
		.btn-ghost:hover { transform: var(--btn-hover-transform); background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.28); }
		.hero-actions .btn-primary,
		.hero-actions .btn-ghost,
		.cta-actions .btn-primary,
		.cta-actions .btn-ghost {
			min-width: 220px;
			justify-content: center;
			text-align: center;
		}
		.hero-meta { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
		.hero-meta-item { display: flex; align-items: center; gap: 6px; font-size: 0.8125rem; color: var(--muted); }
		.hero-meta-item svg { color: var(--green); flex-shrink: 0; }

		/* Hero visual */
		.hero-visual { position: relative; display: flex; align-items: center; justify-content: center; }
		.hero-img-wrap { position: relative; width: 100%; max-width: 540px; }
		.hero-img-card {
			border-radius: 20px; overflow: hidden;
			border: 1px solid rgba(255,255,255,0.12);
			box-shadow: 0 50px 120px rgba(0,0,0,0.85), 0 0 0 1px rgba(255,255,255,0.05), 0 0 60px rgba(124,58,237,0.12);
			animation: floatCard 7s ease-in-out infinite; will-change: transform;
			transform: perspective(1000px) rotateY(-8deg) rotateX(3deg);
		}
		@keyframes floatCard { 0%,100% { transform: perspective(1000px) rotateY(-8deg) rotateX(3deg) translateY(0); } 50% { transform: perspective(1000px) rotateY(-8deg) rotateX(3deg) translateY(-14px); } }
		.hero-img-card img { width: 100%; display: block; object-fit: cover; aspect-ratio: 4/3; }
		.img-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(124,58,237,0.18), rgba(34,211,238,0.08)); mix-blend-mode: overlay; pointer-events: none; }
		.float-chip {
			position: absolute; z-index: 10;
			background: rgba(12,13,26,0.88); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
			border: 1px solid rgba(255,255,255,0.13); border-radius: 14px;
			padding: 10px 16px; display: flex; align-items: center; gap: 10px;
			font-size: 0.8125rem; font-weight: 600; color: var(--text);
			box-shadow: 0 16px 50px rgba(0,0,0,0.65); white-space: nowrap; will-change: transform;
		}
		.chip-1 { top: -22px; left: -28px; animation: floatCard 8s ease-in-out infinite; animation-delay: -2s; }
		.chip-2 { bottom: -20px; right: -28px; animation: floatCard 9s ease-in-out infinite; animation-delay: -5s; }
		.chip-icon { width: 30px; height: 30px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 0.875rem; flex-shrink: 0; }
		.chip-icon.purple { background: rgba(139,92,246,0.22); }
		.chip-icon.green { background: rgba(52,211,153,0.2); }
		.chip-text-sm { font-size: 0.7rem; font-weight: 400; color: var(--muted); margin-top: 1px; }

		/* ── LOGOS STRIP ── */
		.logos-strip { padding: 40px 56px; border-top: 1px solid rgba(255,255,255,0.05); border-bottom: 1px solid rgba(255,255,255,0.05); text-align: center; }
		.logos-label { font-size: 0.72rem; font-weight: 600; color: rgba(148,163,184,0.45); text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 22px; }
		.logos-row { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 48px; }
		.logo-item { font-size: 1rem; font-weight: 700; letter-spacing: -0.02em; color: rgba(148,163,184,0.3); transition: color 0.25s ease; cursor: default; }
		.logo-item:hover { color: rgba(148,163,184,0.65); }

		/* ── DASHBOARD SECTION ── */
		.dashboard-section { height: 150vh; position: relative; }
		.dashboard-pin { height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 80px 40px 32px; gap: 16px; }
		.dashboard-eyebrow { font-size: 0.75rem; font-weight: 700; color: var(--purple); letter-spacing: 0.1em; text-transform: uppercase; }

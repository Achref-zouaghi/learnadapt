		.stat-number { font-size: clamp(28px,3.5vw,40px); font-weight: 800; color: #fff; letter-spacing: -0.025em; display: block; line-height: 1; }
		.stat-desc { font-size: 0.875rem; color: var(--muted); margin-top: 8px; }

		/* ── TESTIMONIALS ── */

			brand.addEventListener('mouseenter', () => {
				timeout = setTimeout(() => {
					const wires = brand.querySelectorAll('.wire.left, .wire.right');
					wires.forEach(w => {
						w.style.animationDuration = '0.6s';
					});
					setTimeout(() => wires.forEach(w => w.style.animationDuration = ''), 4000);

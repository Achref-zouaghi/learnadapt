		/* ── COMMUNITY COMMENTS ── */
		function openCommentLightbox(src) {
			const lb = document.getElementById('commentLightbox');
			document.getElementById('commentLightboxImg').src = src;
			lb.classList.add('active');
		}

		(function() {
			const starsWrap = document.getElementById('commentStarsInput');
			const textarea = document.getElementById('commentTextarea');
			const submitBtn = document.getElementById('commentSubmitBtn');
			const charCount = document.getElementById('commentCharCount');
			const commentsList = document.getElementById('commentsList');
			const photoBtn = document.getElementById('commentPhotoBtn');
			const videoBtn = document.getElementById('commentVideoBtn');
			const photoInput = document.getElementById('commentPhotoInput');
			const videoInput = document.getElementById('commentVideoInput');
			const mediaPreview = document.getElementById('commentMediaPreview');
			const mediaRemove = document.getElementById('commentMediaRemove');
			let selectedRating = 0;

			if (!starsWrap) return; // not logged in

			const starBtns = starsWrap.querySelectorAll('button');
			function setStars(n) {
				selectedRating = n;
				starBtns.forEach(b => b.classList.toggle('active', +b.dataset.star <= n));
				checkReady();
			}
			starBtns.forEach(b => {
				b.addEventListener('click', () => setStars(+b.dataset.star));
				b.addEventListener('mouseenter', () => {
					starBtns.forEach(s => s.classList.toggle('active', +s.dataset.star <= +b.dataset.star));
				});
				b.addEventListener('mouseleave', () => {
					starBtns.forEach(s => s.classList.toggle('active', +s.dataset.star <= selectedRating));
				});
			});

			textarea.addEventListener('input', () => {
				charCount.textContent = textarea.value.length;
				checkReady();
			});

			function checkReady() {
				submitBtn.disabled = !(selectedRating > 0 && (textarea.value.trim().length > 0 || selectedPhotos.length > 0 || selectedVideos.length > 0));
			}

			var selectedPhotos = [];
			var selectedVideos = [];

			// Media upload handlers
			photoBtn.addEventListener('click', () => photoInput.click());
			videoBtn.addEventListener('click', () => videoInput.click());

			photoInput.addEventListener('change', () => {
				for (const f of photoInput.files) {
					if (f.size > 20 * 1024 * 1024) { showToast('File too large (max 20MB): ' + f.name); continue; }
					if (selectedPhotos.length + selectedVideos.length >= 10) { showToast('Max 10 files allowed.'); break; }
					selectedPhotos.push(f);
				}
				photoInput.value = '';
				showAllPreviews();
				checkReady();
			});
			videoInput.addEventListener('change', () => {
				for (const f of videoInput.files) {
					if (f.size > 20 * 1024 * 1024) { showToast('File too large (max 20MB): ' + f.name); continue; }
					if (selectedPhotos.length + selectedVideos.length >= 10) { showToast('Max 10 files allowed.'); break; }
					selectedVideos.push(f);
				}
				videoInput.value = '';
				showAllPreviews();
				checkReady();
			});

			function showAllPreviews() {
				mediaPreview.querySelectorAll('img, video').forEach(el => { URL.revokeObjectURL(el.src); el.remove(); });
				const allFiles = [...selectedPhotos.map(f => ({file: f, type: 'image'})), ...selectedVideos.map(f => ({file: f, type: 'video'}))];
				if (allFiles.length === 0) { mediaPreview.style.display = 'none'; return; }
				allFiles.forEach(item => {
					const url = URL.createObjectURL(item.file);
					if (item.type === 'image') {
						const img = document.createElement('img');
						img.src = url;
						img.style.maxHeight = '120px';
						img.style.borderRadius = '10px';
						img.style.objectFit = 'cover';
						mediaPreview.insertBefore(img, mediaRemove);
					} else {
						const vid = document.createElement('video');
						vid.src = url;
						vid.controls = true;
						vid.style.maxHeight = '120px';
						vid.style.borderRadius = '10px';
						mediaPreview.insertBefore(vid, mediaRemove);
					}
				});
				mediaPreview.style.display = 'flex';
			}

			function clearMedia() {
				selectedPhotos = [];
				selectedVideos = [];
				photoInput.value = '';
				videoInput.value = '';
				mediaPreview.querySelectorAll('img, video').forEach(el => { URL.revokeObjectURL(el.src); el.remove(); });
				mediaPreview.style.display = 'none';
				checkReady();
			}
			mediaRemove.addEventListener('click', clearMedia);

			submitBtn.addEventListener('click', async () => {
				if (submitBtn.disabled) return;
				submitBtn.disabled = true;
				submitBtn.textContent = 'Posting…';
				try {
					const fd = new FormData();
					fd.append('rating', selectedRating);
					fd.append('comment', textarea.value.trim());
					selectedPhotos.forEach(f => fd.append('photos[]', f));
					selectedVideos.forEach(f => fd.append('videos[]', f));
					const res = await fetch('/home/comment', { method: 'POST', body: fd });
					const data = await res.json();
					if (data.success) {
						const empty = document.getElementById('commentsEmpty');
						if (empty) empty.remove();
						const stars = '★'.repeat(data.comment.rating) + '☆'.repeat(5 - data.comment.rating);
						const initial = data.comment.author_name.charAt(0).toUpperCase();
						const avatarHtml = data.comment.author_avatar
							? `<img class="comment-card-avatar" src="${data.comment.author_avatar}" alt="">`
							: `<div class="comment-card-avatar" style="background:linear-gradient(135deg,var(--purple),var(--cyan));display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.82rem;color:#fff">${initial}</div>`;
						let mediaHtml = '';
						const mediaFiles = data.comment.media_files || [];
						if (mediaFiles.length > 0) {
							const gridStyle = mediaFiles.length > 1 ? 'display:grid;grid-template-columns:repeat(2,1fr);gap:6px' : '';
							const maxH = mediaFiles.length > 1 ? '200' : '400';
							mediaHtml = `<div class="comment-card-media" style="${gridStyle}">`;
							mediaFiles.forEach(m => {
								if (m.type === 'image') {
									mediaHtml += `<img src="${m.path}" alt="" style="border-radius:14px;max-height:${maxH}px;object-fit:cover;width:100%">`;
								} else if (m.type === 'video') {
									mediaHtml += `<video controls playsinline preload="auto" style="border-radius:14px;max-height:${maxH}px;width:100%;background:#000"><source src="${m.path}">Your browser does not support video.</video>`;
								}
							});
							mediaHtml += `</div>`;
						} else if (data.comment.media_path) {
							if (data.comment.media_type === 'image') {
								mediaHtml = `<div class="comment-card-media"><img src="${data.comment.media_path}" alt=""></div>`;
							} else if (data.comment.media_type === 'video') {
								mediaHtml = `<div class="comment-card-media"><video controls playsinline preload="auto"><source src="${data.comment.media_path}">Your browser does not support video.</video></div>`;
							}
						}
						const commentText = data.comment.comment
							? `<div class="comment-card-text">${data.comment.comment.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</div>`
							: '';
						const card = document.createElement('div');
						card.className = 'comment-card';
						card.dataset.commentId = data.comment.id;
						card.innerHTML = `
							<div class="comment-card-head">
								${avatarHtml}
								<div>
									<span class="comment-card-name">${data.comment.author_name}</span>
									<span class="comment-card-role">${data.comment.author_role}</span>
								</div>
								<span class="comment-card-time">${data.comment.created_at}</span>
							</div>
							<div class="comment-card-stars">${stars}</div>
							${mediaHtml}
							${commentText}
							<div class="comment-actions">
								<button type="button" class="comment-action" data-comment-id="${data.comment.id}" onclick="reactToComment(this)"><i class='bx bx-like'></i> J'aime</button>
								<button type="button" class="comment-action"><i class='bx bx-message-rounded'></i> Commenter</button>
								<button type="button" class="comment-action"><i class='bx bx-repost'></i> Republier</button>
								<button type="button" class="comment-action"><i class='bx bx-send'></i> Envoyer</button>
							</div>
							<button class="comment-card-delete" data-delete-id="${data.comment.id}">Delete</button>
						`;
						commentsList.prepend(card);
						textarea.value = '';
						charCount.textContent = '0';
						setStars(0);
						clearMedia();
					} else {
						showToast(data.error || 'Failed to post comment', 'warn');
					}
				} catch (e) {
					showToast('Network error. Please try again.');
				}
				submitBtn.innerHTML = '<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg> Post Review';
				checkReady();
			});

			document.addEventListener('click', async (e) => {
				const btn = e.target.closest('.comment-card-delete');
				if (!btn) return;
				if (!confirm('Delete this review?')) return;
				const id = btn.dataset.deleteId;
				btn.disabled = true;
				try {
					const res = await fetch(`/home/comment/${id}`, { method: 'DELETE' });
					const data = await res.json();
					if (data.success) {
						const card = btn.closest('.comment-card');
						card.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
						card.style.opacity = '0';
						card.style.transform = 'translateY(-10px)';
						setTimeout(() => card.remove(), 300);
					} else {
						showToast(data.error || 'Failed to delete');
						btn.disabled = false;
					}
				} catch (e) {
					showToast('Network error');
					btn.disabled = false;
				}
			});
		})();

		function reactToComment(btn) {
			const id = btn.dataset.commentId;
			fetch('/home/comment/' + id + '/react', {
				method: 'POST',
				headers: {'Content-Type': 'application/json'},
				body: JSON.stringify({type: 'like'})
			})
			.then(r => r.json())
			.then(data => {
				if (data.error) return;
				btn.classList.toggle('liked', data.userReaction === 'like');
				btn.querySelector('i').className = data.userReaction === 'like' ? 'bx bxs-like' : 'bx bx-like';

				const card = btn.closest('.comment-card');
				let summary = card.querySelector('.comment-reaction-summary');
				if (data.likes > 0) {
					if (!summary) {
						summary = document.createElement('div');
						summary.className = 'comment-reaction-summary';
						const actions = card.querySelector('.comment-actions');
						actions.parentNode.insertBefore(summary, actions);
					}
					summary.innerHTML = '<div class="comment-reaction-icons"><span class="r-like">👍</span><span class="r-love">❤️</span><span class="r-clap">👏</span></div><span class="reaction-count">' + data.likes + '</span>';
				} else if (summary) {
					summary.remove();
				}
			});
		}

	</script>
{% endblock %}


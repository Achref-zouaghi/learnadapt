			else if (month >= 5 && month <= 7) { glow = 'rgba(251,191,36,0.18)'; accent = '#fbbf24'; } // Summer
			else if (month >= 8 && month <= 10) { glow = 'rgba(249,115,22,0.18)'; accent = '#f97316'; } // Fall
			else { glow = 'rgba(96,165,250,0.18)'; accent = '#60a5fa'; } // Winter

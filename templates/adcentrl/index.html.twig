		.feature-title { font-size: 0.9375rem; font-weight: 700; margin-bottom: 8px; }
		.feature-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.68; }

		/* ── STATS BAR ── */
		.stats-bar {
			background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
			border-top: 1px solid rgba(255,255,255,0.1);

		}
		.step-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--grad); opacity: 0; transition: opacity 0.3s ease; }
		.step-card:hover { border-color: rgba(139,92,246,0.28); box-shadow: 0 22px 56px rgba(0,0,0,0.44), 0 0 0 1px rgba(139,92,246,0.12); transform: translateY(-3px); }
		.step-card:hover::before { opacity: 1; }
		.step-number { font-size: 2.8rem; font-weight: 900; letter-spacing: -0.04em; background: linear-gradient(135deg, rgba(139,92,246,0.55), rgba(34,211,238,0.35)); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 16px; line-height: 1; }
		.step-title { font-size: 1.0625rem; font-weight: 700; margin-bottom: 10px; }
		.step-desc { font-size: 0.875rem; color: var(--muted); line-height: 1.68; }

		/* ── FEATURES ── */
		.features-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 18px; }
		.feature-card {
			background: linear-gradient(165deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
			border: 1px solid rgba(255,255,255,0.1);

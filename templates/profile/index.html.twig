{% extends 'base.html.twig' %}

{% set darkPage = true %}

{% block title %}{{ user.full_name }} - LearnAdapt{% endblock %}

{% block stylesheets %}
<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

    :root {
        --bg: #04060e;
        --purple: #7b61f1;
        --purple-soft: #a78bfa;
        --cyan: #38bdd1;
        --green: #34d399;
        --red: #f87171;
        --orange: #fb923c;
        --yellow: #fbbf24;
        --text: #f6f8fc;
        --muted: #8896ab;
        --glass: rgba(255,255,255,0.035);
        --glass-border: rgba(255,255,255,0.06);
        --card: rgba(255,255,255,0.025);
        --card-h: rgba(255,255,255,0.05);
        --border: rgba(255,255,255,0.06);
        --shadow: 0 4px 24px rgba(0,0,0,0.3);
        --ease: cubic-bezier(0.22,1,0.36,1);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: 'Inter', sans-serif !important;
        background: #020a10 !important;
        color: var(--text);
    }

    footer { display: none !important; }

    .pr-scene { min-height: 100vh; position: relative; z-index: 1; }

    /* â”€â”€ Animations â”€â”€ */
    @keyframes prSlideUp { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes prFadeIn { from { opacity: 0; transform: translateY(6px) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
    @keyframes prPulse { 0%,100% { opacity: 0.5; } 50% { opacity: 1; } }

    /* â”€â”€ Banner â”€â”€ */
    .pr-banner {
        margin-top: 82px; height: 260px; position: relative; overflow: hidden;
        background: linear-gradient(135deg, rgba(123,97,241,0.08) 0%, rgba(10,14,26,0.9) 40%, rgba(56,189,209,0.06) 100%);
        border-bottom: 1px solid var(--border);
        animation: prSlideUp .4s var(--ease);
    }
    .pr-banner-img { width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; }
    .pr-banner::after {
        content: ''; position: absolute; inset: 0;
        background: linear-gradient(180deg, rgba(4,6,14,0.05) 0%, rgba(4,6,14,0.7) 100%);
        pointer-events: none;
    }
    .pr-banner-mesh {
        position: absolute; inset: 0; pointer-events: none;
        background:
            radial-gradient(ellipse 500px 250px at 30% 60%, rgba(123,97,241,0.12), transparent 60%),
            radial-gradient(ellipse 400px 200px at 75% 40%, rgba(56,189,209,0.08), transparent 55%);
    }
    .pr-banner-btn {
        position: absolute; bottom: 16px; right: 16px; z-index: 5;
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 16px; border-radius: 10px; cursor: pointer;
        background: rgba(255,255,255,0.06); backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,0.1);
        color: rgba(255,255,255,0.6); font-size: 0.74rem; font-weight: 600;
        transition: all 0.25s; font-family: inherit;
    }
    .pr-banner-btn:hover { background: rgba(123,97,241,0.15); border-color: rgba(123,97,241,0.25); color: #fff; }
    .pr-banner-btn i { font-size: 0.95rem; }

    /* â”€â”€ Top Header (full-width) â”€â”€ */
    .pr-top-wrap { max-width: 1280px; margin: 0 auto; padding: 0 28px; }
    .pr-head {
        display: flex; gap: 24px; align-items: flex-end;
        margin-top: -50px; position: relative; z-index: 3; flex-wrap: wrap;
        animation: prSlideUp .5s var(--ease);
    }
    .pr-avatar-wrap { position: relative; width: 130px; height: 130px; flex-shrink: 0; }
    .pr-avatar {
        width: 130px; height: 130px; border-radius: 22px;
        border: 3px solid rgba(123,97,241,0.2);
        box-shadow: 0 14px 44px rgba(0,0,0,0.5), 0 0 32px rgba(123,97,241,0.08);
        object-fit: cover; background: rgba(255,255,255,0.03); display: block;
    }
    .pr-avatar-btn {
        position: absolute; inset: 3px; border-radius: 22px;
        display: flex; align-items: center; justify-content: center;
        background: rgba(0,0,0,0.55); backdrop-filter: blur(4px);
        opacity: 0; cursor: pointer; transition: opacity 0.25s;
        border: none; color: #fff; font-size: 1.5rem;
    }
    .pr-avatar-wrap:hover .pr-avatar-btn { opacity: 1; }

    .pr-head-info { flex: 1; min-width: 220px; padding-bottom: 6px; }
    .pr-name {
        font-size: 1.9rem; font-weight: 900; letter-spacing: -0.04em; line-height: 1.15;
        background: linear-gradient(135deg, #fff 30%, var(--purple-soft));
        -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
        display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    }
    .pr-role-badge {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 4px 12px; border-radius: 999px;
        background: linear-gradient(135deg, rgba(124,92,252,0.15), rgba(34,211,238,0.08));
        border: 1px solid rgba(124,92,252,0.22);
        color: var(--purple-soft); font-size: 0.66rem; font-weight: 700;
        letter-spacing: 0.04em; text-transform: uppercase;
        -webkit-text-fill-color: initial;
    }
    .pr-role-badge i { font-size: 0.8rem; }
    .pr-head-bio {
        margin-top: 6px; color: var(--muted); font-size: 0.84rem; line-height: 1.6;
        max-width: 480px;
    }
    .pr-edit-bio-btn {
        display: inline-flex; align-items: center; gap: 5px;
        margin-top: 8px; padding: 6px 14px; border-radius: 9px;
        background: rgba(124,92,252,0.1); border: 1px solid rgba(124,92,252,0.18);
        color: var(--purple-soft); font-size: 0.74rem; font-weight: 600;
        cursor: pointer; transition: all 0.25s; font-family: inherit;
    }
    .pr-edit-bio-btn:hover { background: rgba(124,92,252,0.18); border-color: rgba(124,92,252,0.3); }
    .pr-edit-bio-btn i { font-size: 0.85rem; }

    .pr-head-stats {
        display: flex; gap: 8px; margin-left: auto; align-self: flex-end; padding-bottom: 6px; flex-wrap: wrap;
    }
    .pr-hstat {
        padding: 12px 18px; border-radius: 12px;
        border: 1px solid var(--border); background: var(--card);
        backdrop-filter: blur(12px); text-align: center; min-width: 88px;
        transition: all .2s ease;
    }
    .pr-hstat:hover { background: var(--card-h); border-color: rgba(123,97,241,0.15); transform: translateY(-1px); }
    .pr-hstat strong { display: block; font-size: 1.3rem; font-weight: 900; letter-spacing: -0.02em; }
    .pr-hstat span { display: block; margin-top: 1px; font-size: 0.62rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }

    /* â”€â”€ Glow separator â”€â”€ */
    .pr-glow-line {
        height: 1px; margin-top: 14px;
        background: linear-gradient(90deg, transparent, rgba(123,97,241,0.18), rgba(56,189,209,0.12), transparent);
    }

    /* â”€â”€ 3-Column Layout â”€â”€ */
    .pr-layout {
        max-width: 1280px; margin: 18px auto 0; padding: 0 28px 80px;
        display: grid;
        grid-template-columns: 300px 1fr 300px;
        gap: 20px;
        align-items: start;
    }
    .pr-left  { position: sticky; top: 100px; display: flex; flex-direction: column; gap: 16px; }
    .pr-center { display: flex; flex-direction: column; gap: 16px; min-width: 0; }
    .pr-right  { position: sticky; top: 100px; display: flex; flex-direction: column; gap: 16px; }

    /* â”€â”€ Sidebar Card â”€â”€ */
    .pr-scard {
        border-radius: 18px; border: 1px solid var(--border);
        background: var(--glass); backdrop-filter: blur(14px);
        padding: 20px; box-shadow: var(--shadow); overflow: hidden;
        transition: border-color 0.3s, transform 0.25s;
        position: relative;
        animation: prFadeIn .5s var(--ease) backwards;
    }
    .pr-scard::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; z-index: 2;
        background: linear-gradient(90deg, var(--purple), var(--cyan));
    }
    .pr-scard:hover { border-color: rgba(123,97,241,0.12); }
    .pr-scard-label {
        font-size: 0.62rem; letter-spacing: 0.08em; text-transform: uppercase;
        color: var(--muted); font-weight: 800;
    }
    .pr-scard h3 {
        font-size: 0.95rem; font-weight: 800; letter-spacing: -0.02em; margin-top: 6px;
        background: linear-gradient(135deg, var(--purple), var(--cyan));
        -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
        display: inline-block;
    }

    /* â”€â”€ Feed Card (center column) â”€â”€ */
    .pr-fcard {
        border-radius: 20px; border: 1px solid var(--border);
        background: var(--glass); backdrop-filter: blur(14px);
        padding: 24px 26px; box-shadow: var(--shadow); overflow: hidden;
        transition: border-color 0.3s, transform 0.25s;
        position: relative;
        animation: prSlideUp .5s var(--ease) backwards;
    }
    .pr-fcard::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; z-index: 2;
        background: linear-gradient(90deg, var(--purple), var(--cyan)); opacity: 0;
        transition: opacity 0.3s;
    }
    .pr-fcard:hover { border-color: rgba(123,97,241,0.15); }
    .pr-fcard:hover::before { opacity: 1; }
    .pr-fcard-label {
        font-size: 0.62rem; letter-spacing: 0.08em; text-transform: uppercase;
        color: var(--muted); font-weight: 800;
    }
    .pr-fcard h2 {
        font-size: 1.05rem; font-weight: 800; letter-spacing: -0.02em; margin-top: 6px;
        background: linear-gradient(135deg, var(--purple), var(--cyan));
        -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
        display: inline-block;
    }

    /* â”€â”€ About Info â”€â”€ */
    .pr-about-row {
        display: flex; align-items: center; gap: 10px;
        padding: 8px 0; font-size: 0.8rem;
    }
    .pr-about-row + .pr-about-row { border-top: 1px solid rgba(255,255,255,0.04); }
    .pr-about-row i { font-size: 1rem; color: var(--muted); width: 20px; text-align: center; flex-shrink: 0; }
    .pr-about-label { color: var(--muted); font-weight: 500; }
    .pr-about-val { color: rgba(255,255,255,0.85); font-weight: 600; margin-left: auto; text-align: right; max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    /* â”€â”€ Level ring (compact) â”€â”€ */
    .pr-level-compact { display: flex; align-items: center; gap: 14px; margin-top: 12px; }
    .pr-level-ring-sm { position: relative; width: 64px; height: 64px; flex-shrink: 0; }
    .pr-level-ring-sm svg { width: 100%; height: 100%; }
    .pr-level-center-sm {
        position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
        font-size: 0.9rem; font-weight: 900; color: #fff;
    }
    .pr-level-info-sm h4 { font-weight: 800; color: #fff; font-size: 0.88rem; }
    .pr-level-info-sm p { color: var(--muted); font-size: 0.72rem; margin-top: 2px; }

    /* â”€â”€ Badge (compact) â”€â”€ */
    .pr-badge-sm {
        display: flex; gap: 10px; align-items: center;
        padding: 10px 12px; border-radius: 12px;
        border: 1px solid var(--border);
        background: var(--card); transition: all .2s;
    }
    .pr-badge-sm:hover { background: var(--card-h); border-color: rgba(123,97,241,0.15); }
    .pr-badge-sm + .pr-badge-sm { margin-top: 8px; }
    .pr-badge-icon-sm {
        width: 36px; height: 36px; border-radius: 10px;
        background: linear-gradient(135deg, rgba(124,92,252,0.14), rgba(34,211,238,0.08));
        border: 1px solid rgba(124,92,252,0.18);
        display: flex; align-items: center; justify-content: center;
        color: var(--purple-soft); flex-shrink: 0;
    }
    .pr-badge-icon-sm svg { width: 16px; height: 16px; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
    .pr-badge-name { font-weight: 700; color: #fff; font-size: 0.78rem; }
    .pr-badge-desc { color: var(--muted); font-size: 0.66rem; margin-top: 1px; }

    /* â”€â”€ Mini stat cards (right sidebar) â”€â”€ */
    .pr-mini-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 10px; }
    .pr-mini-stat {
        padding: 14px 12px; border-radius: 12px;
        border: 1px solid var(--border); background: var(--card);
        transition: all .2s; text-align: center;
    }
    .pr-mini-stat:hover { background: var(--card-h); border-color: rgba(123,97,241,0.12); transform: translateY(-1px); }
    .pr-mini-stat-val { font-size: 1.25rem; font-weight: 900; color: #fff; }
    .pr-mini-stat-label { font-size: 0.58rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); font-weight: 700; margin-top: 2px; }
    .pr-mini-stat-bar { height: 2px; border-radius: 2px; background: rgba(255,255,255,0.06); margin-top: 8px; overflow: hidden; }
    .pr-mini-stat-fill { height: 100%; border-radius: 2px; }
    .pr-mini-stat.purple .pr-mini-stat-fill { background: linear-gradient(90deg, var(--purple), var(--purple-soft)); }
    .pr-mini-stat.cyan .pr-mini-stat-fill { background: linear-gradient(90deg, #0891b2, var(--cyan)); }
    .pr-mini-stat.green .pr-mini-stat-fill { background: linear-gradient(90deg, #059669, var(--green)); }
    .pr-mini-stat.orange .pr-mini-stat-fill { background: linear-gradient(90deg, #ea580c, var(--orange)); }

    /* â”€â”€ Quiz rows (compact) â”€â”€ */
    .pr-quiz-sm {
        display: flex; align-items: center; gap: 10px;
        padding: 10px 12px; border-radius: 10px;
        border: 1px solid var(--border); background: var(--card);
        transition: all .2s;
    }
    .pr-quiz-sm + .pr-quiz-sm { margin-top: 6px; }
    .pr-quiz-sm:hover { background: var(--card-h); border-color: rgba(123,97,241,0.12); }
    .pr-quiz-sm-icon { font-size: 1rem; flex-shrink: 0; width: 24px; text-align: center; }
    .pr-quiz-sm-info { flex: 1; min-width: 0; }
    .pr-quiz-sm-title { font-weight: 600; color: #fff; font-size: 0.76rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .pr-quiz-sm-meta { color: var(--muted); font-size: 0.64rem; margin-top: 1px; }
    .pr-quiz-sm-score { font-weight: 800; font-size: 0.78rem; flex-shrink: 0; }
    .pr-quiz-sm-score.gold { color: #fbbf24; }
    .pr-quiz-sm-score.cyan { color: var(--cyan); }
    .pr-quiz-sm-score.muted { color: var(--muted); }

    /* â”€â”€ Timeline (compact) â”€â”€ */
    .pr-tl { margin-top: 12px; position: relative; padding-left: 18px; }
    .pr-tl::before {
        content: ''; position: absolute; left: 5px; top: 6px; bottom: 6px; width: 2px;
        background: linear-gradient(180deg, rgba(124,92,252,0.2), rgba(255,255,255,0.04));
    }
    .pr-tl-item { position: relative; padding-bottom: 14px; }
    .pr-tl-item:last-child { padding-bottom: 0; }
    .pr-tl-dot { position: absolute; left: -16px; top: 4px; width: 8px; height: 8px; border-radius: 50%; }
    .pr-tl-dot.quiz { background: var(--purple); box-shadow: 0 0 6px rgba(124,92,252,0.4); }
    .pr-tl-dot.post { background: var(--cyan); box-shadow: 0 0 6px rgba(34,211,238,0.4); }
    .pr-tl-dot.task { background: var(--green); box-shadow: 0 0 6px rgba(52,211,153,0.4); }
    .pr-tl-label { font-size: 0.64rem; color: var(--muted); font-weight: 600; }
    .pr-tl-title { font-weight: 600; color: #fff; font-size: 0.76rem; margin-top: 2px; }
    .pr-tl-time { font-size: 0.6rem; color: rgba(148,163,184,0.4); margin-top: 2px; }

    /* â”€â”€ Notification rows (compact) â”€â”€ */
    .pr-notif-sm {
        display: flex; gap: 10px; align-items: flex-start;
        padding: 10px 12px; border-radius: 10px;
        border: 1px solid var(--border); background: var(--card);
        transition: all .2s;
    }
    .pr-notif-sm + .pr-notif-sm { margin-top: 6px; }
    .pr-notif-sm:hover { background: var(--card-h); }
    .pr-notif-dot-sm {
        width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; margin-top: 5px;
        background: var(--purple); box-shadow: 0 0 5px rgba(124,92,252,0.4);
    }
    .pr-notif-title { font-weight: 600; color: #fff; font-size: 0.76rem; }
    .pr-notif-msg { color: var(--muted); font-size: 0.66rem; margin-top: 2px; line-height: 1.4; }
    .pr-notif-time { color: rgba(148,163,184,0.35); font-size: 0.6rem; margin-top: 3px; }
    .pr-notif-count-sm {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 18px; height: 18px; border-radius: 6px; padding: 0 5px;
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: #fff; font-size: 0.6rem; font-weight: 800; margin-left: 6px; vertical-align: middle;
    }

    /* â”€â”€ Forum Posts (center feed) â”€â”€ */
    .pr-post {
        padding: 20px 22px; border-radius: 16px;
        border: 1px solid var(--border); background: var(--card);
        transition: all .22s ease; position: relative; overflow: hidden;
        animation: prFadeIn .4s var(--ease) backwards;
    }
    .pr-post::after {
        content: ''; position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.02), transparent);
        transition: left .5s ease; pointer-events: none;
    }
    .pr-post:hover { background: var(--card-h); border-color: rgba(123,97,241,0.18); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,0,0,0.15); }
    .pr-post:hover::after { left: 100%; }
    .pr-post-head { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
    .pr-post-av { width: 38px; height: 38px; border-radius: 11px; object-fit: cover; border: 1px solid rgba(255,255,255,0.06); }
    .pr-post-author { font-weight: 700; color: #fff; font-size: 0.84rem; }
    .pr-post-time { font-size: 0.68rem; color: rgba(148,163,184,0.5); margin-top: 1px; }
    .pr-post-cat {
        display: inline-flex; padding: 3px 9px; border-radius: 7px;
        font-size: 0.58rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
        background: rgba(124,92,252,0.1); color: var(--purple-soft); border: 1px solid rgba(124,92,252,0.12);
        margin-left: auto;
    }
    .pr-post-cat.HELP { background: rgba(251,191,36,0.1); color: #fbbf24; border-color: rgba(251,191,36,0.12); }
    .pr-post-cat.RESOURCE { background: rgba(52,211,153,0.1); color: var(--green); border-color: rgba(52,211,153,0.12); }
    .pr-post-cat.QUESTION { background: rgba(34,211,238,0.1); color: var(--cyan); border-color: rgba(34,211,238,0.12); }
    .pr-post-cat.PROJECT { background: rgba(249,115,22,0.1); color: #fb923c; border-color: rgba(249,115,22,0.12); }
    .pr-post-title {
        font-weight: 800; color: #fff; font-size: 0.95rem; line-height: 1.4;
        text-decoration: none; display: block; transition: color 0.2s;
    }
    .pr-post-title:hover { color: var(--purple-soft); }
    .pr-post-body { color: rgba(241,245,249,0.55); font-size: 0.84rem; line-height: 1.65; margin-top: 6px; word-break: break-word; }
    .pr-post-media { margin-top: 10px; display: grid; gap: 6px; border-radius: 14px; overflow: hidden; }
    .pr-post-media img { width: 100%; border-radius: 14px; max-height: 300px; object-fit: cover; display: block; }
    .pr-post-media video { width: 100%; border-radius: 14px; max-height: 300px; background: #000; display: block; }
    .pr-post-stats {
        display: flex; align-items: center; gap: 14px; margin-top: 12px; padding-top: 10px;
        border-top: 1px solid rgba(255,255,255,0.05);
        font-size: 0.74rem; color: var(--muted); font-weight: 600;
    }
    .pr-post-stats i { font-size: 0.85rem; vertical-align: -1px; margin-right: 3px; }
    .pr-post-stats .likes { color: var(--purple-soft); }
    .pr-post-stats .replies { color: var(--cyan); }

    /* â”€â”€ Courses grid (center) â”€â”€ */
    .pr-courses-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; margin-top: 14px; }
    .pr-course-card {
        padding: 16px 18px; border-radius: 14px;
        border: 1px solid var(--border); background: var(--card);
        transition: all .22s ease; position: relative; overflow: hidden;
    }
    .pr-course-card:hover { background: var(--card-h); border-color: rgba(123,97,241,0.18); transform: translateY(-2px); }
    .pr-course-level {
        display: inline-block; padding: 3px 8px; border-radius: 6px;
        font-size: 0.56rem; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; border: 1px solid;
    }
    .pr-course-level.beginner { background: rgba(52,211,153,0.1); color: var(--green); border-color: rgba(52,211,153,0.08); }
    .pr-course-level.intermediate { background: rgba(34,211,238,0.1); color: var(--cyan); border-color: rgba(34,211,238,0.08); }
    .pr-course-level.advanced { background: rgba(251,191,36,0.1); color: #fbbf24; border-color: rgba(251,191,36,0.08); }
    .pr-course-title { font-weight: 800; color: #fff; font-size: 0.88rem; margin-top: 10px; }
    .pr-course-module { color: var(--muted); font-size: 0.72rem; margin-top: 4px; display: flex; align-items: center; gap: 4px; }
    .pr-course-footer {
        display: flex; justify-content: space-between; margin-top: 12px; padding-top: 10px;
        border-top: 1px solid rgba(255,255,255,0.05);
        font-size: 0.66rem; color: rgba(148,163,184,0.5); font-weight: 600;
    }
    .pr-course-footer span { display: flex; align-items: center; gap: 3px; }

    /* â”€â”€ QR section (compact in sidebar) â”€â”€ */
    .pr-qr-compact { text-align: center; margin-top: 10px; }
    .pr-qr-compact canvas {
        width: 180px; height: 180px; border-radius: 16px;
        display: block; margin: 0 auto; background: #fff;
        box-shadow: 0 12px 32px rgba(0,0,0,0.3);
    }
    .pr-qr-actions-sm { display: flex; gap: 6px; justify-content: center; margin-top: 12px; }
    .pr-qr-btn-sm {
        padding: 7px 14px; border-radius: 9px; font-size: 0.72rem; font-weight: 700;
        cursor: pointer; border: none; transition: all 0.25s; font-family: inherit;
        display: inline-flex; align-items: center; gap: 4px;
    }
    .pr-qr-btn-sm.primary {
        background: linear-gradient(135deg, var(--orange), var(--yellow));
        color: #fff; box-shadow: 0 4px 14px rgba(251,146,60,0.25);
    }
    .pr-qr-btn-sm.primary:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(251,146,60,0.35); }
    .pr-qr-btn-sm.ghost {
        background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.7); border: 1px solid rgba(255,255,255,0.08);
    }
    .pr-qr-btn-sm.ghost:hover { background: rgba(255,255,255,0.1); color: #fff; }
    .pr-qr-btn-sm i { font-size: 0.85rem; }

    /* â”€â”€ Empty state â”€â”€ */
    .pr-empty { text-align: center; padding: 32px 0; }
    .pr-empty i { font-size: 2.5rem; color: rgba(255,255,255,0.08); }
    .pr-empty p { color: var(--muted); margin-top: 10px; font-size: 0.8rem; }

    /* â”€â”€ Modal â”€â”€ */
    .pr-modal-bg {
        display: none; position: fixed; inset: 0; z-index: 200;
        background: rgba(0,0,0,0.6); backdrop-filter: blur(6px);
        align-items: center; justify-content: center;
    }
    .pr-modal-bg.open { display: flex; }
    .pr-modal {
        width: min(480px, calc(100vw - 40px)); border-radius: 20px;
        border: 1px solid var(--border); background: rgba(10,14,26,0.95);
        backdrop-filter: blur(20px); padding: 28px;
        box-shadow: 0 40px 100px rgba(0,0,0,0.5);
    }
    .pr-modal h3 { font-size: 1.15rem; font-weight: 800; color: #fff; margin-bottom: 6px; }
    .pr-modal p { color: var(--muted); font-size: 0.8rem; margin-bottom: 16px; }
    .pr-modal textarea {
        width: 100%; min-height: 110px; padding: 12px 14px;
        border-radius: 12px; border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.04); color: #fff;
        font-family: 'Inter', sans-serif; font-size: 0.86rem;
        line-height: 1.6; resize: vertical; outline: none; transition: border-color 0.25s;
    }
    .pr-modal textarea:focus { border-color: rgba(124,92,252,0.4); }
    .pr-modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 14px; }
    .pr-btn {
        padding: 9px 20px; border-radius: 10px; font-size: 0.8rem;
        font-weight: 700; cursor: pointer; border: none; transition: all 0.25s; font-family: inherit;
    }
    .pr-btn-ghost { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.7); border: 1px solid rgba(255,255,255,0.08); }
    .pr-btn-ghost:hover { background: rgba(255,255,255,0.1); color: #fff; }
    .pr-btn-primary { background: linear-gradient(135deg, var(--purple), #6344e0); color: #fff; box-shadow: 0 4px 16px rgba(124,92,252,0.3); }
    .pr-btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 24px rgba(124,92,252,0.4); }

    /* â”€â”€ Toast â”€â”€ */
    .pr-toast-container {
        position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 9999;
        display: flex; flex-direction: column; gap: 10px; align-items: center;
    }
    .pr-flash {
        padding: 12px 22px; border-radius: 12px;
        font-size: 0.82rem; font-weight: 600; backdrop-filter: blur(16px);
        box-shadow: 0 8px 32px rgba(0,0,0,0.4); display: flex; align-items: center;
        animation: prSlideUp 0.4s var(--ease);
    }
    .pr-flash.success { background: rgba(52,211,153,0.15); border: 1px solid rgba(52,211,153,0.3); color: #34d399; }
    .pr-flash.error { background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.3); color: #ef4444; }
    .pr-flash.fade-out { opacity: 0; transform: translateX(40px); transition: opacity 0.5s, transform 0.5s; }

    .pr-qr-toast {
        position: fixed; bottom: 40px; left: 50%; transform: translateX(-50%) translateY(80px);
        background: rgba(15,18,28,0.95); border: 1px solid rgba(251,146,60,0.2);
        border-radius: 12px; padding: 12px 24px; display: flex; align-items: center; gap: 8px;
        font-size: 0.82rem; font-weight: 600; color: var(--orange); backdrop-filter: blur(20px);
        box-shadow: 0 8px 32px rgba(0,0,0,0.4); z-index: 10000;
        opacity: 0; transition: all .4s cubic-bezier(0.4, 0, 0.2, 1); pointer-events: none;
    }
    .pr-qr-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
    .pr-qr-toast i { font-size: 1.1rem; }

    .pr-file-hidden { display: none; }
    .pr-qr-source { display: none !important; }

    /* â”€â”€ CTA Button â”€â”€ */
    .pr-cta-btn {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 8px 18px; border-radius: 10px;
        background: linear-gradient(135deg, var(--purple), #6344e0);
        color: #fff; font-size: 0.78rem; font-weight: 700;
        text-decoration: none; box-shadow: 0 4px 14px rgba(124,92,252,0.25);
        transition: all 0.25s; border: none; cursor: pointer; font-family: inherit;
    }
    .pr-cta-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(124,92,252,0.35); }

    .pr-link-btn {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 5px 12px; border-radius: 8px;
        background: rgba(124,92,252,0.1); border: 1px solid rgba(124,92,252,0.15);
        color: var(--purple-soft); font-size: 0.7rem; font-weight: 600;
        text-decoration: none; transition: all 0.25s;
    }
    .pr-link-btn:hover { background: rgba(124,92,252,0.18); }
    .pr-link-btn i { font-size: 0.8rem; }

    /* â”€â”€ Responsive â”€â”€ */
    @media (max-width: 1100px) {
        .pr-layout { grid-template-columns: 280px 1fr; }
        .pr-right { position: static; }
        .pr-layout > .pr-right { grid-column: 1 / -1; display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    }
    @media (max-width: 860px) {
        .pr-layout { grid-template-columns: 1fr; padding: 0 16px 60px; }
        .pr-left { position: static; }
        .pr-layout > .pr-right { grid-template-columns: 1fr; }
        .pr-head { flex-direction: column; align-items: flex-start; gap: 14px; }
        .pr-head-stats { margin-left: 0; width: 100%; }
        .pr-name { font-size: 1.5rem; }
        .pr-top-wrap { padding: 0 16px; }
        .pr-banner { height: 180px; }
    }
    @media (max-width: 560px) {
        .pr-head-stats { gap: 6px; }
        .pr-hstat { min-width: 72px; padding: 10px 12px; }
        .pr-hstat strong { font-size: 1.1rem; }
        .pr-mini-stats { grid-template-columns: 1fr 1fr; gap: 6px; }
    }
</style>
{% endblock %}

{% block body %}
{% include 'partials/_background.html.twig' %}
<div class="pr-scene">

    {# â”€â”€ Hidden upload forms â”€â”€ #}
    <form id="avatarForm" action="{{ path('app_profile_upload_avatar') }}" method="post" enctype="multipart/form-data" style="display:none;">
        <input type="file" id="avatarInput" name="avatar" accept="image/jpeg,image/png,image/gif,image/webp">
    </form>
    <form id="bannerForm" action="{{ path('app_profile_upload_banner') }}" method="post" enctype="multipart/form-data" style="display:none;">
        <input type="file" id="bannerInput" name="banner" accept="image/jpeg,image/png,image/gif,image/webp">
    </form>

    {# â”€â”€ Banner â”€â”€ #}
    <div class="pr-banner">
        {% if user.banner_base64 %}
            <img src="{{ user.banner_base64 }}" alt="Banner" class="pr-banner-img">
        {% endif %}
        <div class="pr-banner-mesh"></div>
        <button type="button" class="pr-banner-btn" onclick="document.getElementById('bannerInput').click()">
            <i class='bx bx-image-add'></i> {{ 'profile.change_banner'|trans }}
        </button>
    </div>

    {# â”€â”€ Toast Notifications â”€â”€ #}
    <div class="pr-toast-container">
        {% for message in app.flashes('success') %}
            <div class="pr-flash success"><i class='bx bx-check-circle' style="margin-right:6px;"></i>{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="pr-flash error"><i class='bx bx-error-circle' style="margin-right:6px;"></i>{{ message }}</div>
        {% endfor %}
    </div>

    {# â”€â”€ Top Header â”€â”€ #}
    <div class="pr-top-wrap">
        <div class="pr-head">
            <div class="pr-avatar-wrap">
                <img src="{{ user.avatar_base64 ?: 'https://ui-avatars.com/api/?name=' ~ user.full_name|url_encode ~ '&size=260&background=7c5cfc&color=fff&bold=true&format=svg' }}" alt="{{ user.full_name }}" class="pr-avatar">
                <button type="button" class="pr-avatar-btn" onclick="document.getElementById('avatarInput').click()">
                    <i class='bx bx-camera'></i>
                </button>
            </div>
            <div class="pr-head-info">
                <h1 class="pr-name">{{ user.full_name }} <span class="pr-role-badge"><i class='bx bx-shield-quarter'></i> {{ user.role|lower|title }}</span></h1>
                {% if user.bio %}
                    <p class="pr-head-bio">{{ user.bio }}</p>
                {% else %}
                    <p class="pr-head-bio" style="color: rgba(255,255,255,0.25); font-style: italic;">{{ 'profile.no_bio'|trans }}</p>
                {% endif %}
                <button type="button" class="pr-edit-bio-btn" onclick="document.getElementById('bioModal').classList.add('open')">
                    <i class='bx bx-edit-alt'></i> {{ 'profile.edit_bio'|trans }}
                </button>
            </div>
            <div class="pr-head-stats">
                <div class="pr-hstat"><strong>{{ courses|length }}</strong><span>{{ 'profile.courses'|trans }}</span></div>
                <div class="pr-hstat"><strong>{{ tasksCompleted }}</strong><span>{{ 'profile.tasks_done'|trans }}</span></div>
                <div class="pr-hstat"><strong>{{ forumPostsCount }}</strong><span>{{ 'profile.posts'|trans }}</span></div>
                <div class="pr-hstat"><strong>{{ user.created_at|date('Y') }}</strong><span>{{ 'profile.joined'|trans }}</span></div>
            </div>
        </div>
        <div class="pr-glow-line"></div>
    </div>

    {# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• #}
    {# â•â•  3-COLUMN LAYOUT: Left | Center Feed | Right          â•â• #}
    {# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• #}
    <div class="pr-layout">

        {# â”â”â”â”â”â”â”â”â”â”â”â”â”â”â”â”â”â” LEFT SIDEBAR â”â”â”â”â”â”â”â”â”â”â”â”â”â”â”â”â”â” #}
        <aside class="pr-left">

            {# About #}
            <div class="pr-scard">
                <div class="pr-scard-label">{{ 'profile.profile_overview'|trans }}</div>
                <h3>{{ 'profile.about'|trans|default('About') }}</h3>
                <div style="margin-top: 12px;">
                    <div class="pr-about-row">
                        <i class='bx bx-envelope'></i>
                        <span class="pr-about-label">{{ 'profile.email'|trans }}</span>
                        <span class="pr-about-val">{{ user.email }}</span>
                    </div>
                    {% if user.phone %}
                    <div class="pr-about-row">
                        <i class='bx bx-phone'></i>
                        <span class="pr-about-label">{{ 'profile.phone'|trans }}</span>
                        <span class="pr-about-val">{{ user.phone }}</span>
                    </div>
                    {% endif %}
                    {% if user.location %}
                    <div class="pr-about-row">
                        <i class='bx bx-map'></i>
                        <span class="pr-about-label">{{ 'profile.location'|trans }}</span>
                        <span class="pr-about-val">{{ user.location }}</span>
                    </div>
                    {% endif %}
                    <div class="pr-about-row">
                        <i class='bx bx-user-check'></i>
                        <span class="pr-about-label">{{ 'profile.role'|trans }}</span>
                        <span class="pr-about-val">{{ user.role|lower|title }}</span>
                    </div>
                    <div class="pr-about-row">
                        <i class='bx bx-calendar'></i>
                        <span class="pr-about-label">{{ 'profile.joined_date'|trans }}</span>
                        <span class="pr-about-val">{{ user.created_at|date('M d, Y') }}</span>
                    </div>
                    {% if user.last_login %}
                    <div class="pr-about-row">
                        <i class='bx bx-log-in'></i>
                        <span class="pr-about-label">{{ 'profile.last_login'|trans }}</span>
                        <span class="pr-about-val">{{ user.last_login|date('M d, H:i') }}</span>
                    </div>
                    {% endif %}
                </div>
            </div>

            {# Level #}
            <div class="pr-scard" style="animation-delay: .08s;">
                <div class="pr-scard-label">{{ 'profile.your_level'|trans }}</div>
                {% if currentLevel %}
                    <div class="pr-level-compact">
                        <div class="pr-level-ring-sm">
                            <svg viewBox="0 0 64 64">
                                <circle cx="32" cy="32" r="28" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="5"/>
                                <circle cx="32" cy="32" r="28" fill="none" stroke="url(#lvlG)" stroke-width="5" stroke-linecap="round"
                                    stroke-dasharray="{{ (currentLevel.last_score_percent|default(0)) * 1.76 }} 176"
                                    transform="rotate(-90 32 32)"/>
                                <defs><linearGradient id="lvlG" x1="0%" y1="0%" x2="100%" y2="100%">
                                    <stop offset="0%" stop-color="var(--purple)"/>
                                    <stop offset="100%" stop-color="var(--cyan)"/>
                                </linearGradient></defs>
                            </svg>
                            <div class="pr-level-center-sm">{{ currentLevel.last_score_percent|default(0)|round }}%</div>
                        </div>
                        <div class="pr-level-info-sm">
                            <h4>{{ currentLevel.current_level|title }}</h4>
                            <p>{{ 'profile.level_based_on'|trans }}</p>
                        </div>
                    </div>
                {% else %}
                    <div class="pr-empty" style="padding: 20px 0;">
                        <i class='bx bx-trophy'></i>
                        <p>{{ 'profile.take_quiz'|trans }}</p>
                    </div>
                {% endif %}
            </div>

            {# Badges #}
            <div class="pr-scard" style="animation-delay: .16s;">
                <div class="pr-scard-label">{{ 'profile.recognition'|trans }}</div>
                <h3>{{ 'profile.badges_status'|trans }}</h3>
                <div style="margin-top: 12px;">
                    <div class="pr-badge-sm">
                        <div class="pr-badge-icon-sm">
                            <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        </div>
                        <div>
                            <div class="pr-badge-name">{{ 'profile.verified_account'|trans }}</div>
                            <div class="pr-badge-desc">{{ 'profile.identity_confirmed'|trans }}</div>
                        </div>
                    </div>
                    <div class="pr-badge-sm">
                        <div class="pr-badge-icon-sm">
                            <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
                        </div>
                        <div>
                            <div class="pr-badge-name">{{ 'profile.early_adopter'|trans }}</div>
                            <div class="pr-badge-desc">{{ 'profile.joined_launch'|trans }}</div>
                        </div>
                    </div>
                    {% if forumPostsCount >= 5 %}
                    <div class="pr-badge-sm">
                        <div class="pr-badge-icon-sm" style="background: linear-gradient(135deg, rgba(34,211,238,0.14), rgba(52,211,153,0.08)); border-color: rgba(34,211,238,0.2); color: var(--cyan);">
                            <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        </div>
                        <div>
                            <div class="pr-badge-name">{{ 'profile.active_contributor'|trans }}</div>
                            <div class="pr-badge-desc">{{ forumPostsCount }} posts</div>
                        </div>
                    </div>
                    {% endif %}
                    {% if tasksCompleted >= 10 %}
                    <div class="pr-badge-sm">
                        <div class="pr-badge-icon-sm" style="background: linear-gradient(135deg, rgba(251,191,36,0.14), rgba(249,115,22,0.08)); border-color: rgba(251,191,36,0.2); color: #fbbf24;">
                            <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                        </div>
                        <div>
                            <div class="pr-badge-name">{{ 'profile.task_master'|trans }}</div>
                            <div class="pr-badge-desc">{{ tasksCompleted }} tasks done</div>
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>

            {# QR Code #}
            <div class="pr-scard" style="animation-delay: .24s;">
                <div class="pr-scard-label" style="color: var(--orange);">{{ 'profile.share_profile'|trans }}</div>
                <h3>{{ 'profile.your_qr_code'|trans }}</h3>
                <div class="pr-qr-compact">
                    <canvas id="qrCanvas" width="180" height="180"></canvas>
                    <img id="qrImageSource" class="pr-qr-source" src="{{ path('app_profile_qr', { size: 520 }) }}" alt="">
                    <div class="pr-qr-actions-sm">
                        <button class="pr-qr-btn-sm primary" onclick="downloadQR()"><i class='bx bx-download'></i> PNG</button>
                        <button class="pr-qr-btn-sm ghost" onclick="copyProfileLink()"><i class='bx bx-link'></i> Copy</button>
                    </div>
                </div>
            </div>

        </aside>

        {# â”â”â”â”â”â”â”â”â”â”â”â”â”â”â”â”â”â” CENTER FEED â”â”â”â”â”â”â”â”â”â”â”â”â”â”â”â”â”â” #}
        <main class="pr-center">

            {# Forum Posts Feed #}
            <div class="pr-fcard">
                <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px;">
                    <div>
                        <div class="pr-fcard-label">{{ 'profile.community'|trans }}</div>
                        <h2>{{ 'profile.my_forum_posts'|trans }}</h2>
                    </div>
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <span style="color: var(--muted); font-size: 0.68rem; opacity: 0.6;">{{ forumTopics|length }} {{ forumTopics|length == 1 ? 'post' : 'posts' }}</span>
                        <a href="{{ path('app_forum') }}" class="pr-link-btn"><i class='bx bx-message-square-dots'></i> {{ 'profile.view_forum'|trans }}</a>
                    </div>
                </div>
                {% if forumTopics|length > 0 %}
                    <div style="display: flex; flex-direction: column; gap: 12px; margin-top: 16px;">
                        {% for topic in forumTopics %}
                            <div class="pr-post" style="animation-delay: {{ loop.index0 * 0.05 }}s;">
                                <div class="pr-post-head">
                                    <img class="pr-post-av" src="{{ user.avatarBase64 ?: 'https://ui-avatars.com/api/?name=' ~ user.fullName|url_encode ~ '&size=88&background=e2e8f0&color=0f172a&bold=true&format=svg' }}" alt="">
                                    <div>
                                        <div class="pr-post-author">{{ user.fullName }}</div>
                                        <div class="pr-post-time">{{ topic.created_at|date('M d, Y Â· H:i') }}</div>
                                    </div>
                                    <span class="pr-post-cat {{ topic.category }}">{{ topic.category|replace({'_': ' '}) }}</span>
                                </div>
                                <a href="{{ path('app_forum_topic', {id: topic.id}) }}" class="pr-post-title">{{ topic.title }}</a>
                                {% if topic.first_post_content %}
                                    <div class="pr-post-body">{{ topic.first_post_content|length > 280 ? topic.first_post_content|slice(0, 280) ~ 'â€¦' : topic.first_post_content }}</div>
                                {% endif %}
                                {% set _media = [] %}
                                {% if topic.first_post_media_files %}
                                    {% set _media = topic.first_post_media_files|json_decode %}
                                {% elseif topic.first_post_media_path %}
                                    {% set _media = [{type: topic.first_post_media_type, path: topic.first_post_media_path}] %}
                                {% endif %}
                                {% if _media|length > 0 %}
                                    <div class="pr-post-media" style="{% if _media|length > 1 %}grid-template-columns: repeat(2, 1fr){% endif %}">
                                        {% for m in _media|slice(0, 4) %}
                                            {% if m.type == 'image' %}
                                                <img src="{{ m.path }}" alt="" loading="lazy">
                                            {% elseif m.type == 'video' %}
                                                <video controls playsinline preload="none"><source src="{{ m.path }}"></video>
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                <div class="pr-post-stats">
                                    {% if topic.like_count > 0 %}
                                        <span class="likes"><i class='bx bxs-like'></i> {{ topic.like_count }}</span>
                                    {% endif %}
                                    {% if topic.reply_count > 0 %}
                                        <span class="replies"><i class='bx bx-message-rounded'></i> {{ topic.reply_count }}</span>
                                    {% endif %}
                                    {% if topic.is_closed %}<span style="color: var(--red);"><i class='bx bx-lock-alt'></i> Closed</span>{% endif %}
                                    {% if topic.like_count == 0 and topic.reply_count == 0 %}
                                        <span style="color: rgba(148,163,184,0.35); font-size: 0.7rem;">No interactions yet</span>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="pr-empty" style="padding: 40px 0;">
                        <i class='bx bx-message-square-dots'></i>
                        <p>{{ 'profile.no_forum_posts'|trans }}</p>
                        <a href="{{ path('app_forum') }}" class="pr-cta-btn" style="margin-top: 14px;">
                            <i class='bx bx-plus'></i> {{ 'profile.create_first_post'|trans }}
                        </a>
                    </div>
                {% endif %}
            </div>

            {# Courses #}
            <div class="pr-fcard" style="animation-delay: .1s;">
                <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px;">
                    <div>
                        <div class="pr-fcard-label">{{ 'profile.learning'|trans }}</div>
                        <h2>{{ 'profile.my_courses'|trans }}</h2>
                    </div>
                    <span style="color: var(--muted); font-size: 0.68rem; opacity: 0.6;">{{ courses|length }} total</span>
                </div>
                {% if courses|length > 0 %}
                    <div class="pr-courses-grid">
                        {% for course in courses %}
                            <div class="pr-course-card">
                                <div class="pr-course-level {{ course.level|lower }}">{{ course.level|upper }}</div>
                                <h3 class="pr-course-title">{{ course.title }}</h3>
                                {% if course.module_name %}
                                    <div class="pr-course-module"><i class='bx bx-layer'></i> {{ course.module_name }}</div>
                                {% endif %}
                                <div class="pr-course-footer">
                                    <span><i class='bx bx-file'></i> {{ course.exercise_count }} {{ 'profile.exercises'|trans }}</span>
                                    <span>{{ course.created_at|date('M Y') }}</span>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="pr-empty">
                        <i class='bx bx-book-open'></i>
                        <p>{{ 'profile.no_courses'|trans }}</p>
                    </div>
                {% endif %}
            </div>

        </main>

        {# â”â”â”â”â”â”â”â”â”â”â”â”â”â”â”â”â”â” RIGHT SIDEBAR â”â”â”â”â”â”â”â”â”â”â”â”â”â”â”â”â”â” #}
        <aside class="pr-right">

            {# Learning Stats #}
            <div class="pr-scard">
                <div class="pr-scard-label">{{ 'profile.learning_stats'|trans|default('Learning Stats') }}</div>
                <h3>{{ 'profile.dashboard'|trans|default('Dashboard') }}</h3>
                <div class="pr-mini-stats">
                    <div class="pr-mini-stat purple">
                        <div class="pr-mini-stat-val">{{ totalPomodoroMinutes }}</div>
                        <div class="pr-mini-stat-label">{{ 'profile.study_time'|trans }}</div>
                        <div class="pr-mini-stat-bar"><div class="pr-mini-stat-fill" style="width: {{ min(totalPomodoroMinutes / 10, 100) }}%"></div></div>
                    </div>
                    <div class="pr-mini-stat cyan">
                        <div class="pr-mini-stat-val">{{ tasksCompleted }}</div>
                        <div class="pr-mini-stat-label">{{ 'profile.tasks_done'|trans }}</div>
                        <div class="pr-mini-stat-bar"><div class="pr-mini-stat-fill" style="width: {{ min(tasksCompleted * 10, 100) }}%"></div></div>
                    </div>
                    <div class="pr-mini-stat green">
                        <div class="pr-mini-stat-val">{{ quizAvgScore }}%</div>
                        <div class="pr-mini-stat-label">{{ 'profile.quiz_average'|trans }}</div>
                        <div class="pr-mini-stat-bar"><div class="pr-mini-stat-fill" style="width: {{ quizAvgScore }}%"></div></div>
                    </div>
                    <div class="pr-mini-stat orange">
                        <div class="pr-mini-stat-val">{{ forumPostsCount }}</div>
                        <div class="pr-mini-stat-label">{{ 'profile.forum_posts'|trans }}</div>
                        <div class="pr-mini-stat-bar"><div class="pr-mini-stat-fill" style="width: {{ min(forumPostsCount * 5, 100) }}%"></div></div>
                    </div>
                </div>
            </div>

            {# Quiz Performance #}
            <div class="pr-scard" style="animation-delay: .06s;">
                <div class="pr-scard-label">{{ 'profile.quiz_history'|trans }}</div>
                <h3>{{ 'profile.performance'|trans }}</h3>
                {% if quizAttempts|length > 0 %}
                    <div style="margin-top: 12px;">
                        {% for attempt in quizAttempts|slice(0, 6) %}
                            <div class="pr-quiz-sm">
                                <div class="pr-quiz-sm-icon">
                                    {% if attempt.score_percent >= 80 %}
                                        <i class='bx bxs-star' style="color: #fbbf24;"></i>
                                    {% elseif attempt.score_percent >= 50 %}
                                        <i class='bx bxs-bolt' style="color: var(--cyan);"></i>
                                    {% else %}
                                        <i class='bx bx-target-lock' style="color: var(--muted);"></i>
                                    {% endif %}
                                </div>
                                <div class="pr-quiz-sm-info">
                                    <div class="pr-quiz-sm-title">{{ attempt.quiz_title|default('Quiz') }}</div>
                                    <div class="pr-quiz-sm-meta">{{ attempt.started_at|date('M d') }} Â· {{ attempt.earned_points }}/{{ attempt.total_points }}pts</div>
                                </div>
                                <div class="pr-quiz-sm-score {% if attempt.score_percent >= 80 %}gold{% elseif attempt.score_percent >= 50 %}cyan{% else %}muted{% endif %}">
                                    {{ attempt.score_percent|round }}%
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="pr-empty" style="padding: 20px 0;">
                        <i class='bx bx-notepad'></i>
                        <p>{{ 'profile.no_quiz_attempts'|trans }}</p>
                    </div>
                {% endif %}
            </div>

            {# Activity Timeline #}
            <div class="pr-scard" style="animation-delay: .12s;">
                <div class="pr-scard-label">{{ 'profile.timeline'|trans }}</div>
                <h3>{{ 'profile.recent_activity'|trans }}</h3>
                {% if recentActivity|length > 0 %}
                    <div class="pr-tl">
                        {% for item in recentActivity %}
                            <div class="pr-tl-item">
                                <div class="pr-tl-dot {{ item.type }}"></div>
                                <div>
                                    <div class="pr-tl-label">
                                        {% if item.type == 'quiz' %}
                                            <i class='bx bx-brain' style="font-size: 0.7rem;"></i> {{ 'profile.completed_quiz'|trans }}
                                        {% elseif item.type == 'post' %}
                                            <i class='bx bx-message-detail' style="font-size: 0.7rem;"></i> {{ 'profile.forum_post'|trans }}
                                        {% else %}
                                            <i class='bx bx-check-circle' style="font-size: 0.7rem;"></i> {{ 'profile.task_done'|trans }}
                                        {% endif %}
                                    </div>
                                    <div class="pr-tl-title">{{ item.title|default('Untitled') }}</div>
                                    <div class="pr-tl-time">{{ item.created_at|date('M d Â· H:i') }}</div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="pr-empty" style="padding: 20px 0;">
                        <i class='bx bx-history'></i>
                        <p>{{ 'profile.no_activity'|trans }}</p>
                    </div>
                {% endif %}
            </div>

            {# Notifications #}
            <div class="pr-scard" style="animation-delay: .18s;">
                <div class="pr-scard-label">{{ 'profile.inbox'|trans }}</div>
                <h3>{{ 'profile.notifications'|trans }} {% if unreadCount > 0 %}<span class="pr-notif-count-sm">{{ unreadCount }}</span>{% endif %}</h3>
                {% if unreadNotifications|length > 0 %}
                    <div style="margin-top: 12px;">
                        {% for notif in unreadNotifications|slice(0, 6) %}
                            <div class="pr-notif-sm">
                                <div class="pr-notif-dot-sm"></div>
                                <div>
                                    <div class="pr-notif-title">{{ notif.title }}</div>
                                    <div class="pr-notif-msg">{{ notif.message|length > 60 ? notif.message|slice(0, 60) ~ 'â€¦' : notif.message }}</div>
                                    <div class="pr-notif-time">{{ notif.created_at|date('M d Â· H:i') }}</div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="pr-empty" style="padding: 20px 0;">
                        <i class='bx bx-bell'></i>
                        <p>{{ 'profile.all_caught_up'|trans }}</p>
                    </div>
                {% endif %}
            </div>

        </aside>
    </div>

    {# QR Code Toast #}
    <div class="pr-qr-toast" id="qrToast">
        <i class='bx bx-check-circle'></i>
        <span id="qrToastMsg">Link copied!</span>
    </div>

    {# â”€â”€ Bio Edit Modal â”€â”€ #}
    <div class="pr-modal-bg" id="bioModal">
        <div class="pr-modal">
            <h3>{{ 'profile.edit_bio_title'|trans }}</h3>
            <p>{{ 'profile.edit_bio_desc'|trans }}</p>
            <form method="post" action="{{ path('app_profile_update_bio') }}">
                <textarea name="bio" maxlength="500" placeholder="{{ 'profile.bio_placeholder'|trans }}">{{ user.bio }}</textarea>
                <div class="pr-modal-actions">
                    <button type="button" class="pr-btn pr-btn-ghost" onclick="document.getElementById('bioModal').classList.remove('open')">{{ 'profile.cancel'|trans }}</button>
                    <button type="submit" class="pr-btn pr-btn-primary">{{ 'profile.save_bio'|trans }}</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
document.getElementById('avatarInput').addEventListener('change', function() {
    if (this.files.length > 0) document.getElementById('avatarForm').submit();
});
document.getElementById('bannerInput').addEventListener('change', function() {
    if (this.files.length > 0) document.getElementById('bannerForm').submit();
});
document.getElementById('bioModal').addEventListener('click', function(e) {
    if (e.target === this) this.classList.remove('open');
});
document.querySelectorAll('.pr-flash').forEach(function(el) {
    setTimeout(function() {
        el.classList.add('fade-out');
        setTimeout(function() { el.remove(); }, 500);
    }, 5000);
});

// â”€â”€ QR Code â”€â”€
(function() {
    var profileUrl = '{{ profileShareUrl|e('js') }}';
    var qrCanvas = document.getElementById('qrCanvas');
    var qrImageSource = document.getElementById('qrImageSource');
    var qrDownloadSourceUrl = '{{ path('app_profile_qr', { size: 800 }) }}';

    function roundedRectPath(ctx, x, y, w, h, r) {
        r = Math.min(r, w / 2, h / 2);
        ctx.beginPath();
        ctx.moveTo(x + r, y);
        ctx.arcTo(x + w, y, x + w, y + h, r);
        ctx.arcTo(x + w, y + h, x, y + h, r);
        ctx.arcTo(x, y + h, x, y, r);
        ctx.arcTo(x, y, x + w, y, r);
        ctx.closePath();
    }

    function renderPreview() {
        if (!qrImageSource.complete || !qrImageSource.naturalWidth) return;
        var ctx = qrCanvas.getContext('2d');
        var s = qrCanvas.width;
        ctx.clearRect(0, 0, s, s);
        roundedRectPath(ctx, 0, 0, s, s, 24);
        ctx.fillStyle = '#ffffff';
        ctx.fill();
        ctx.save();
        roundedRectPath(ctx, 2, 2, s - 4, s - 4, 22);
        ctx.clip();
        ctx.drawImage(qrImageSource, 14, 14, s - 28, s - 28);
        ctx.restore();
    }

    if (qrImageSource.complete) {
        renderPreview();
    } else {
        qrImageSource.addEventListener('load', renderPreview, { once: true });
    }

    qrImageSource.addEventListener('error', function() {
        var ctx = qrCanvas.getContext('2d');
        ctx.clearRect(0, 0, qrCanvas.width, qrCanvas.height);
        roundedRectPath(ctx, 0, 0, qrCanvas.width, qrCanvas.height, 24);
        ctx.fillStyle = '#111827';
        ctx.fill();
        ctx.fillStyle = '#fff';
        ctx.font = '700 13px Arial';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('QR unavailable', qrCanvas.width / 2, qrCanvas.height / 2);
    }, { once: true });

    function loadQrImage(url) {
        return new Promise(function(resolve, reject) {
            var img = new Image();
            img.onload = function() { resolve(img); };
            img.onerror = reject;
            img.src = url + (url.indexOf('?') === -1 ? '?' : '&') + 'v=' + Date.now();
        });
    }

    window.downloadQR = function() {
        loadQrImage(qrDownloadSourceUrl).then(function(img) {
            var c = document.createElement('canvas');
            c.width = 800; c.height = 800;
            var ctx = c.getContext('2d');
            roundedRectPath(ctx, 0, 0, 800, 800, 40);
            ctx.fillStyle = '#fff';
            ctx.fill();
            ctx.drawImage(img, 40, 40, 720, 720);
            var link = document.createElement('a');
            link.download = 'learnadapt-profile-qr.png';
            link.href = c.toDataURL('image/png');
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            showQRToast('QR downloaded!');
        }).catch(function() {
            showQRToast('Unable to generate QR right now.');
        });
    };

    window.copyProfileLink = function() {
        navigator.clipboard.writeText(profileUrl).then(function() {
            showQRToast('Profile link copied!');
        }).catch(function() {
            var ta = document.createElement('textarea');
            ta.value = profileUrl;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            document.body.removeChild(ta);
            showQRToast('Profile link copied!');
        });
    };

    window.showQRToast = function(msg) {
        var toast = document.getElementById('qrToast');
        document.getElementById('qrToastMsg').textContent = msg;
        toast.classList.add('show');
        setTimeout(function() { toast.classList.remove('show'); }, 2500);
    };
})();
</script>
{% endblock %}

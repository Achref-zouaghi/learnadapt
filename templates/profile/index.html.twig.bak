{% extends 'base.html.twig' %}

{% set darkPage = true %}

{% block title %}{{ user.full_name }} - LearnAdapt{% endblock %}

{% block stylesheets %}
<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

    :root {
        --bg: #04060e;
        --purple: #7b61f1;
        --purple-soft: #a78bfa;
        --cyan: #38bdd1;
        --green: #34d399;
        --red: #f87171;
        --orange: #fb923c;
        --text: #f6f8fc;
        --muted: #8896ab;
        --glass: rgba(255,255,255,0.035);
        --glass-border: rgba(255,255,255,0.06);
        --card: rgba(255,255,255,0.025);
        --card-h: rgba(255,255,255,0.05);
        --border: rgba(255,255,255,0.06);
        --shadow: 0 4px 24px rgba(0,0,0,0.3);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: 'Inter', sans-serif !important;
        background: #020a10 !important;
        color: var(--text);
    }

    footer { display: none !important; }

    .pr-scene {
        min-height: 100vh;
        background: transparent !important;
        position: relative;
        z-index: 1;
    }

    .pr-container { max-width: 1120px; margin: 0 auto; padding: 0 32px; }

    /* ── Entrance Animations (matching taskboard) ── */
    @keyframes prSlideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes prCardFadeIn { from { opacity: 0; transform: translateY(8px) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }

    .pr-banner {
        margin-top: 82px; height: 280px; position: relative; overflow: hidden;
        border-radius: 0 0 24px 24px;
        background: linear-gradient(135deg, rgba(123,97,241,0.08) 0%, rgba(10,14,26,0.9) 40%, rgba(56,189,209,0.06) 100%);
        border: 1px solid var(--border); border-top: none;
        animation: prSlideUp .4s ease-out;
    }
    .pr-banner-img { width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; }
    .pr-banner::after {
        content: ''; position: absolute; inset: 0;
        background: linear-gradient(180deg, rgba(4,6,14,0.05) 0%, rgba(4,6,14,0.65) 100%);
        pointer-events: none;
    }
    .pr-banner-mesh {
        position: absolute; inset: 0; pointer-events: none;
        background:
            radial-gradient(ellipse 500px 250px at 30% 60%, rgba(123,97,241,0.12), transparent 60%),
            radial-gradient(ellipse 400px 200px at 75% 40%, rgba(56,189,209,0.08), transparent 55%);
    }
    .pr-banner-btn {
        position: absolute; bottom: 18px; right: 18px; z-index: 5;
        display: inline-flex; align-items: center; gap: 7px;
        padding: 9px 18px; border-radius: 12px; cursor: pointer;
        background: rgba(255,255,255,0.04); backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,0.08);
        color: rgba(255,255,255,0.6); font-size: 0.76rem; font-weight: 600;
        transition: all 0.25s; font-family: inherit;
    }
    .pr-banner-btn:hover { background: rgba(123,97,241,0.15); border-color: rgba(123,97,241,0.25); color: #fff; }
    .pr-banner-btn i { font-size: 1rem; }

    .pr-head {
        display: flex; gap: 28px; align-items: flex-end;
        margin-top: -56px; position: relative; z-index: 3; flex-wrap: wrap;
        animation: prSlideUp .5s ease-out;
    }
    .pr-avatar-wrap { position: relative; width: 140px; height: 140px; flex-shrink: 0; }
    .pr-avatar {
        width: 140px; height: 140px; border-radius: 24px;
        border: 3px solid rgba(123,97,241,0.2);
        box-shadow: 0 16px 48px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.06), 0 0 40px rgba(123,97,241,0.08);
        object-fit: cover; background: rgba(255,255,255,0.03); display: block;
    }
    .pr-avatar-btn {
        position: absolute; inset: 4px; border-radius: 24px;
        display: flex; align-items: center; justify-content: center;
        background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);
        opacity: 0; cursor: pointer; transition: opacity 0.25s;
        border: none; color: #fff; font-size: 1.6rem;
    }
    .pr-avatar-wrap:hover .pr-avatar-btn { opacity: 1; }

    .pr-info { flex: 1; min-width: 220px; padding-bottom: 8px; }
    .pr-role-badge {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 5px 14px; border-radius: 999px;
        background: linear-gradient(135deg, rgba(124,92,252,0.15), rgba(34,211,238,0.08));
        border: 1px solid rgba(124,92,252,0.22);
        color: var(--purple-soft); font-size: 0.7rem; font-weight: 700;
        letter-spacing: 0.04em; text-transform: uppercase;
    }
    .pr-role-badge i { font-size: 0.85rem; }
    .pr-name {
        font-size: 2.2rem; font-weight: 900; letter-spacing: -0.04em;
        margin-top: 6px;
        background: linear-gradient(135deg, #fff 30%, var(--purple-soft));
        -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
        display: flex; align-items: center; gap: 14px;
    }
    .pr-name .pr-role-badge { -webkit-text-fill-color: initial; }
    .pr-bio-text {
        margin-top: 8px; color: var(--muted); font-size: 0.88rem;
        line-height: 1.7; max-width: 480px;
    }

    .pr-stats {
        display: flex; gap: 10px; margin-left: auto;
        align-self: flex-end; padding-bottom: 8px; flex-wrap: wrap;
    }
    .pr-stat {
        padding: 16px 22px; border-radius: 14px;
        border: 1px solid var(--border);
        background: var(--card);
        backdrop-filter: blur(12px); text-align: center; min-width: 100px;
        transition: all .2s ease;
    }
    .pr-stat:hover { background: var(--card-h); border-color: rgba(123,97,241,0.15); transform: translateY(-1px); }
    .pr-stat strong {
        display: block; font-size: 1.5rem; font-weight: 900; letter-spacing: -0.02em;
    }
    .pr-stat span {
        display: block; margin-top: 2px; font-size: 0.68rem;
        font-weight: 600; color: var(--muted); text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .pr-card {
        border-radius: 22px; border: 1px solid var(--border);
        background: var(--glass);
        backdrop-filter: blur(14px); padding: 28px 30px;
        box-shadow: var(--shadow); overflow: hidden;
        transition: border-color 0.3s, transform 0.25s;
        position: relative;
        animation: prSlideUp .6s ease-out backwards;
    }
    .pr-card::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; z-index: 2;
        background: linear-gradient(90deg, var(--purple), var(--cyan));
    }
    .pr-card::after {
        content: ''; position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.02), transparent);
        transition: left 0.6s ease; pointer-events: none;
    }
    .pr-card:hover { border-color: rgba(123,97,241,0.12); transform: translateY(-2px); }
    .pr-card:hover::after { left: 100%; }
    .pr-card-label {
        font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;
        color: var(--muted); font-weight: 800;
    }
    .pr-card h2 {
        font-size: 1.15rem; font-weight: 900; letter-spacing: -0.03em; margin-top: 8px;
        background: linear-gradient(135deg, var(--purple), var(--cyan));
        -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
        display: inline-block;
    }
    .pr-card p { color: rgba(255,255,255,0.5); line-height: 1.75; font-size: 0.88rem; margin-top: 10px; }

    .pr-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 22px; }
    .pr-info-tile {
        padding: 20px 22px; border-radius: 14px;
        border: 1px solid var(--border);
        background: var(--card); transition: background 0.25s, border-color 0.25s;
    }
    .pr-info-tile:hover { background: var(--card-h); border-color: rgba(123,97,241,0.1); }
    .pr-info-tile .pr-card-label { margin-bottom: 12px; }
    .pr-info-tile p { font-size: 0.84rem; color: rgba(255,255,255,0.72); margin-top: 0; }
    .pr-info-tile .detail { color: var(--muted); font-size: 0.82rem; margin-top: 3px; }

    .pr-modal-bg {
        display: none; position: fixed; inset: 0; z-index: 200;
        background: rgba(0,0,0,0.6); backdrop-filter: blur(6px);
        align-items: center; justify-content: center;
    }
    .pr-modal-bg.open { display: flex; }
    .pr-modal {
        width: min(480px, calc(100vw - 40px)); border-radius: 22px;
        border: 1px solid var(--border);
        background: rgba(10,14,26,0.95);
        backdrop-filter: blur(20px);
        padding: 32px;
        box-shadow: 0 40px 100px rgba(0,0,0,0.5), 0 0 40px rgba(123,97,241,0.06);
    }
    .pr-modal h3 { font-size: 1.2rem; font-weight: 800; color: #fff; margin-bottom: 6px; }
    .pr-modal p { color: var(--muted); font-size: 0.82rem; margin-bottom: 18px; }
    .pr-modal textarea {
        width: 100%; min-height: 120px; padding: 14px 16px;
        border-radius: 14px; border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.04); color: #fff;
        font-family: 'Inter', sans-serif; font-size: 0.88rem;
        line-height: 1.6; resize: vertical; outline: none; transition: border-color 0.25s;
    }
    .pr-modal textarea:focus { border-color: rgba(124,92,252,0.4); }
    .pr-modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 16px; }
    .pr-btn {
        padding: 10px 22px; border-radius: 12px; font-size: 0.82rem;
        font-weight: 700; cursor: pointer; border: none; transition: all 0.25s; font-family: inherit;
    }
    .pr-btn-ghost {
        background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.7);
        border: 1px solid rgba(255,255,255,0.08);
    }
    .pr-btn-ghost:hover { background: rgba(255,255,255,0.1); color: #fff; }
    .pr-btn-primary {
        background: linear-gradient(135deg, var(--purple), #6344e0);
        color: #fff; box-shadow: 0 4px 20px rgba(124,92,252,0.3);
    }
    .pr-btn-primary:hover { transform: translateY(-1px); box-shadow: 0 8px 28px rgba(124,92,252,0.4); }

    .pr-edit-bio-btn {
        display: inline-flex; align-items: center; gap: 6px;
        margin-top: 12px; padding: 8px 16px; border-radius: 10px;
        background: rgba(124,92,252,0.1); border: 1px solid rgba(124,92,252,0.18);
        color: var(--purple-soft); font-size: 0.78rem; font-weight: 600;
        cursor: pointer; transition: all 0.25s; font-family: inherit;
    }
    .pr-edit-bio-btn:hover { background: rgba(124,92,252,0.18); border-color: rgba(124,92,252,0.3); }
    .pr-edit-bio-btn i { font-size: 0.9rem; }

    .pr-badge-row {
        display: flex; gap: 16px; align-items: center;
        padding: 18px 20px; border-radius: 14px;
        border: 1px solid var(--border);
        background: var(--card); transition: all .22s ease;
        animation: prCardFadeIn .4s ease-out backwards;
    }
    .pr-badge-row:hover { background: var(--card-h); border-color: rgba(123,97,241,0.18); transform: translateY(-1px); }
    .pr-badge-icon {
        width: 50px; height: 50px; border-radius: 15px;
        background: linear-gradient(135deg, rgba(124,92,252,0.14), rgba(34,211,238,0.08));
        border: 1px solid rgba(124,92,252,0.2);
        display: flex; align-items: center; justify-content: center;
        color: var(--purple-soft); flex-shrink: 0;
    }
    .pr-badge-icon svg {
        width: 22px; height: 22px; fill: none; stroke: currentColor;
        stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;
    }

    .pr-toast-container {
        position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 9999;
        display: flex; flex-direction: column; gap: 10px; align-items: center;
    }
    .pr-flash {
        padding: 14px 24px; border-radius: 14px;
        font-size: 0.84rem; font-weight: 600; backdrop-filter: blur(16px);
        box-shadow: 0 8px 32px rgba(0,0,0,0.4);
        display: flex; align-items: center;
        animation: pr-toast-in 0.4s cubic-bezier(0.22,1,0.36,1);
    }
    @keyframes pr-toast-in {
        from { opacity: 0; transform: translateX(40px); }
        to { opacity: 1; transform: translateX(0); }
    }
    .pr-flash.success { background: rgba(52,211,153,0.15); border: 1px solid rgba(52,211,153,0.3); color: #34d399; }
    .pr-flash.error { background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.3); color: #ef4444; }
    .pr-flash.fade-out { opacity: 0; transform: translateX(40px); transition: opacity 0.5s, transform 0.5s; }

    .pr-rank-row {
        display: grid; grid-template-columns: 52px 1fr auto; gap: 14px;
        align-items: center; padding: 16px 20px; border-radius: 14px;
        border: 1px solid var(--border);
        background: var(--card); transition: background 0.25s, border-color 0.25s;
    }
    .pr-rank-row:hover { background: var(--card-h); border-color: rgba(123,97,241,0.1); }
    .pr-rank-num {
        width: 44px; height: 44px; border-radius: 13px;
        background: linear-gradient(135deg, rgba(124,92,252,0.12), rgba(34,211,238,0.08));
        border: 1px solid rgba(124,92,252,0.18);
        display: flex; align-items: center; justify-content: center;
        color: #e0d4ff; font-weight: 800; font-size: 0.85rem;
    }
    .pr-rank-name { font-weight: 600; color: #fff; font-size: 0.88rem; }
    .pr-rank-sub { color: rgba(255,255,255,0.4); font-size: 0.76rem; margin-top: 3px; }
    .pr-rank-tag { font-weight: 700; font-size: 0.78rem; color: var(--purple-soft); }

    .pr-glow-line {
        height: 1px; border: none; margin: 28px 0;
        background: linear-gradient(90deg, transparent, rgba(123,97,241,0.15), rgba(56,189,209,0.08), transparent);
    }

    /* ── Stats Dashboard ── */
    .pr-stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; animation: prSlideUp .5s ease-out backwards; animation-delay: .1s; }
    .pr-stat-card {
        padding: 24px 22px; border-radius: 18px;
        border: 1px solid var(--border);
        background: var(--glass);
        backdrop-filter: blur(14px); position: relative; overflow: hidden;
        transition: border-color 0.3s, transform 0.3s;
        animation: prCardFadeIn .4s ease-out backwards;
    }
    .pr-stat-card:nth-child(1) { animation-delay: 0s; }
    .pr-stat-card:nth-child(2) { animation-delay: .08s; }
    .pr-stat-card:nth-child(3) { animation-delay: .16s; }
    .pr-stat-card:nth-child(4) { animation-delay: .24s; }
    .pr-stat-card::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; z-index: 2;
    }
    .pr-stat-purple::before { background: linear-gradient(90deg, var(--purple), var(--purple-soft)); }
    .pr-stat-cyan::before { background: linear-gradient(90deg, #0891b2, var(--cyan)); }
    .pr-stat-green::before { background: linear-gradient(90deg, #059669, var(--green)); }
    .pr-stat-orange::before { background: linear-gradient(90deg, #ea580c, var(--orange)); }
    .pr-stat-card:hover { transform: translateY(-3px); }
    .pr-stat-card.pr-stat-purple:hover { border-color: rgba(124,92,252,0.3); }
    .pr-stat-card.pr-stat-cyan:hover { border-color: rgba(34,211,238,0.3); }
    .pr-stat-card.pr-stat-green:hover { border-color: rgba(52,211,153,0.3); }
    .pr-stat-card.pr-stat-orange:hover { border-color: rgba(249,115,22,0.3); }
    .pr-stat-card-icon {
        width: 42px; height: 42px; border-radius: 12px; display: flex;
        align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 16px;
    }
    .pr-stat-purple .pr-stat-card-icon { background: rgba(124,92,252,0.12); color: var(--purple-soft); }
    .pr-stat-cyan .pr-stat-card-icon { background: rgba(34,211,238,0.12); color: var(--cyan); }
    .pr-stat-green .pr-stat-card-icon { background: rgba(52,211,153,0.12); color: var(--green); }
    .pr-stat-orange .pr-stat-card-icon { background: rgba(249,115,22,0.12); color: #fb923c; }
    .pr-stat-card-val {
        font-size: 2rem; font-weight: 900; color: #fff; letter-spacing: -0.03em;
    }
    .pr-stat-unit { font-size: 0.9rem; font-weight: 600; color: var(--muted); margin-left: 2px; }
    .pr-stat-card-label {
        font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.1em;
        color: rgba(148,163,184,0.5); font-weight: 700; margin-top: 4px;
    }
    .pr-stat-card-bar {
        height: 3px; border-radius: 3px; background: rgba(255,255,255,0.06); margin-top: 16px; overflow: hidden;
    }
    .pr-stat-card-fill { height: 100%; border-radius: 3px; transition: width 1s ease; }
    .pr-stat-purple .pr-stat-card-fill { background: linear-gradient(90deg, var(--purple), var(--purple-soft)); }
    .pr-stat-cyan .pr-stat-card-fill { background: linear-gradient(90deg, #0891b2, var(--cyan)); }
    .pr-stat-green .pr-stat-card-fill { background: linear-gradient(90deg, #059669, var(--green)); }
    .pr-stat-orange .pr-stat-card-fill { background: linear-gradient(90deg, #ea580c, #fb923c); }

    /* ── Level display ── */
    .pr-level-display { display: flex; gap: 28px; align-items: center; margin-top: 20px; }
    .pr-level-ring { position: relative; width: 120px; height: 120px; flex-shrink: 0; }
    .pr-level-ring svg { width: 100%; height: 100%; }
    .pr-level-center {
        position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
    }
    .pr-level-score { font-size: 1.5rem; font-weight: 900; color: #fff; }
    .pr-level-name { font-size: 1.4rem; font-weight: 900; color: #fff; margin: 0; letter-spacing: -0.02em; }
    .pr-level-tag {
        display: inline-flex; align-items: center; gap: 6px; margin-top: 12px;
        padding: 6px 14px; border-radius: 10px;
        background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);
        font-size: 0.78rem; font-weight: 600; color: var(--muted);
    }

    /* ── Quiz rows ── */
    .pr-quiz-row {
        display: grid; grid-template-columns: 40px 1fr 100px; gap: 14px;
        align-items: center; padding: 14px 18px; border-radius: 14px;
        border: 1px solid var(--border);
        background: var(--card); transition: all .22s ease;
        animation: prCardFadeIn .4s ease-out backwards;
    }
    .pr-quiz-row:hover { background: var(--card-h); border-color: rgba(123,97,241,0.18); transform: translateY(-1px); }
    .pr-quiz-icon { font-size: 1.3rem; text-align: center; }
    .pr-quiz-title { font-weight: 600; color: #fff; font-size: 0.84rem; }
    .pr-quiz-meta { color: var(--muted); font-size: 0.72rem; margin-top: 3px; }
    .pr-quiz-score-wrap { text-align: right; }
    .pr-quiz-score { font-weight: 800; font-size: 0.9rem; }
    .pr-quiz-score.gold { color: #fbbf24; }
    .pr-quiz-score.cyan { color: var(--cyan); }
    .pr-quiz-score.muted { color: var(--muted); }
    .pr-quiz-bar { height: 3px; border-radius: 3px; background: rgba(255,255,255,0.06); margin-top: 6px; }
    .pr-quiz-bar-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, var(--purple), var(--cyan)); }

    /* ── Timeline ── */
    .pr-timeline { margin-top: 20px; position: relative; padding-left: 24px; }
    .pr-timeline::before {
        content: ''; position: absolute; left: 7px; top: 8px; bottom: 8px; width: 2px;
        background: linear-gradient(180deg, rgba(124,92,252,0.2), rgba(255,255,255,0.04));
    }
    .pr-timeline-item { position: relative; padding-bottom: 22px; }
    .pr-timeline-item:last-child { padding-bottom: 0; }
    .pr-timeline-dot {
        position: absolute; left: -20px; top: 6px; width: 10px; height: 10px; border-radius: 50%;
    }
    .pr-timeline-dot.quiz { background: var(--purple); box-shadow: 0 0 8px rgba(124,92,252,0.4); }
    .pr-timeline-dot.post { background: var(--cyan); box-shadow: 0 0 8px rgba(34,211,238,0.4); }
    .pr-timeline-dot.task { background: var(--green); box-shadow: 0 0 8px rgba(52,211,153,0.4); }
    .pr-timeline-label { font-size: 0.72rem; color: var(--muted); font-weight: 600; display: flex; align-items: center; gap: 5px; }
    .pr-timeline-title { font-weight: 600; color: #fff; font-size: 0.84rem; margin-top: 4px; }
    .pr-timeline-detail { font-size: 0.76rem; color: var(--purple-soft); margin-top: 2px; }
    .pr-timeline-time { font-size: 0.68rem; color: rgba(148,163,184,0.4); margin-top: 4px; }

    /* ── Courses grid ── */
    .pr-courses-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 14px; margin-top: 20px; }
    .pr-course-card {
        padding: 18px 20px; border-radius: 16px;
        border: 1px solid var(--border);
        background: var(--card); transition: all .22s ease; position: relative; overflow: hidden;
        animation: prCardFadeIn .4s ease-out backwards;
    }
    .pr-course-card::after {
        content: ''; position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.03), transparent);
        transition: left .5s ease; pointer-events: none;
    }
    .pr-course-card:hover { background: var(--card-h); border-color: rgba(123,97,241,0.18); transform: translateY(-3px); box-shadow: 0 8px 28px rgba(0,0,0,0.15); }
    .pr-course-card:hover::after { left: 100%; }
    .pr-course-level {
        display: inline-block; padding: 4px 10px; border-radius: 8px;
        font-size: 0.6rem; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase;
        border: 1px solid;
    }
    .pr-course-level.beginner { background: rgba(52,211,153,0.1); color: var(--green); border-color: rgba(52,211,153,0.08); }
    .pr-course-level.intermediate { background: rgba(34,211,238,0.1); color: var(--cyan); border-color: rgba(34,211,238,0.08); }
    .pr-course-level.advanced { background: rgba(251,191,36,0.1); color: #fbbf24; border-color: rgba(251,191,36,0.08); }
    .pr-course-title { font-weight: 800; color: #fff; font-size: 0.95rem; margin-top: 12px; }
    .pr-course-module { color: var(--muted); font-size: 0.78rem; margin-top: 6px; display: flex; align-items: center; gap: 5px; }
    .pr-course-footer {
        display: flex; justify-content: space-between; margin-top: 14px; padding-top: 12px;
        border-top: 1px solid rgba(255,255,255,0.05);
        font-size: 0.72rem; color: rgba(148,163,184,0.5); font-weight: 600;
    }
    .pr-course-footer span { display: flex; align-items: center; gap: 4px; }

    /* ── Forum Posts (Facebook-style) ── */
    .pr-forum-feed { display: flex; flex-direction: column; gap: 14px; margin-top: 20px; }
    .pr-forum-post {
        padding: 20px 22px; border-radius: 16px;
        border: 1px solid var(--border);
        background: var(--card); transition: all .22s ease; position: relative; overflow: hidden;
        animation: prCardFadeIn .4s ease-out backwards;
    }
    .pr-forum-post::after {
        content: ''; position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.03), transparent);
        transition: left .5s ease; pointer-events: none;
    }
    .pr-forum-post:hover { background: var(--card-h); border-color: rgba(123,97,241,0.18); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,0,0,0.15); }
    .pr-forum-post:hover::after { left: 100%; }
    .pr-forum-post-head { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
    .pr-forum-post-avatar { width: 40px; height: 40px; border-radius: 12px; object-fit: cover; border: 1px solid rgba(255,255,255,0.06); }
    .pr-forum-post-author { font-weight: 700; color: #fff; font-size: 0.88rem; }
    .pr-forum-post-time { font-size: 0.72rem; color: rgba(148,163,184,0.5); margin-top: 2px; }
    .pr-forum-post-cat {
        display: inline-flex; padding: 3px 10px; border-radius: 8px;
        font-size: 0.62rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
        background: rgba(124,92,252,0.1); color: var(--purple-soft); border: 1px solid rgba(124,92,252,0.12);
        margin-left: auto;
    }
    .pr-forum-post-cat.HELP { background: rgba(251,191,36,0.1); color: #fbbf24; border-color: rgba(251,191,36,0.12); }
    .pr-forum-post-cat.RESOURCE { background: rgba(52,211,153,0.1); color: var(--green); border-color: rgba(52,211,153,0.12); }
    .pr-forum-post-cat.QUESTION { background: rgba(34,211,238,0.1); color: var(--cyan); border-color: rgba(34,211,238,0.12); }
    .pr-forum-post-cat.PROJECT { background: rgba(249,115,22,0.1); color: #fb923c; border-color: rgba(249,115,22,0.12); }
    .pr-forum-post-title {
        font-weight: 800; color: #fff; font-size: 0.95rem; line-height: 1.4;
        text-decoration: none; display: block; transition: color 0.2s;
    }
    .pr-forum-post-title:hover { color: var(--purple-soft); }
    .pr-forum-post-body { color: rgba(241,245,249,0.55); font-size: 0.84rem; line-height: 1.65; margin-top: 8px; word-break: break-word; }
    .pr-forum-post-media {
        margin-top: 12px; display: grid; gap: 6px; border-radius: 14px; overflow: hidden;
    }
    .pr-forum-post-media img { width: 100%; border-radius: 14px; max-height: 280px; object-fit: cover; display: block; }
    .pr-forum-post-media video { width: 100%; border-radius: 14px; max-height: 280px; background: #000; display: block; }
    .pr-forum-post-stats {
        display: flex; align-items: center; gap: 16px; margin-top: 14px; padding-top: 12px;
        border-top: 1px solid rgba(255,255,255,0.05);
        font-size: 0.76rem; color: var(--muted); font-weight: 600;
    }
    .pr-forum-post-stats i { font-size: 0.9rem; vertical-align: -1px; margin-right: 4px; }
    .pr-forum-post-stats .likes { color: var(--purple-soft); }
    .pr-forum-post-stats .replies { color: var(--cyan); }

    /* ── Notifications ── */
    .pr-notif-count {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 22px; height: 22px; border-radius: 8px; padding: 0 6px;
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: #fff; font-size: 0.7rem; font-weight: 800; margin-left: 8px;
        vertical-align: middle;
    }
    .pr-notif-row {
        display: flex; gap: 14px; align-items: flex-start;
        padding: 14px 16px; border-radius: 12px;
        border: 1px solid var(--border);
        background: var(--card); transition: all .22s ease;
    }
    .pr-notif-row:hover { background: var(--card-h); border-color: rgba(123,97,241,0.18); transform: translateY(-1px); }
    .pr-notif-dot {
        width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; margin-top: 6px;
        background: var(--purple); box-shadow: 0 0 6px rgba(124,92,252,0.4);
    }

    .pr-file-hidden { display: none; }

    /* ── Floating Side Decorations ── */
    .pr-floaters {
        position: fixed !important;
        top: 0; left: 0; width: 100vw; height: 100vh;
        pointer-events: none; z-index: 50; overflow: hidden;
        transform: none !important;
        will-change: auto;
    }
    .pr-side-col {
        position: absolute; top: 100px; bottom: 40px;
        width: calc((100vw - 1120px) / 2 - 10px);
        display: flex; flex-direction: column; align-items: center;
        justify-content: center; gap: 50px;
    }
    .pr-side-left { left: 12px; }
    .pr-side-right { right: 12px; }

    .pr-float {
        position: relative; opacity: 0;
        animation-timing-function: ease-in-out; animation-iteration-count: infinite;
        animation-fill-mode: forwards;
    }
    .pr-float svg {
        filter: drop-shadow(0 4px 24px rgba(124,92,252,0.25));
    }

    /* Left icons */
    .pr-float-1 { width: 72px; height: 72px; animation: prFloat1 5.5s infinite 0.2s; }
    .pr-float-2 { width: 56px; height: 56px; animation: prFloat2 6.8s infinite 0.6s; }
    .pr-float-3 { width: 64px; height: 64px; animation: prFloat3 7.2s infinite 1s; }
    .pr-float-4 { width: 48px; height: 48px; animation: prFloat4 6s infinite 0.4s; }

    /* Right icons */
    .pr-float-5 { width: 68px; height: 68px; animation: prFloat5 6.2s infinite 0.3s; }
    .pr-float-6 { width: 52px; height: 52px; animation: prFloat6 7s infinite 0.8s; }
    .pr-float-7 { width: 60px; height: 60px; animation: prFloat7 5.8s infinite 0.5s; }
    .pr-float-8 { width: 50px; height: 50px; animation: prFloat8 6.5s infinite 1.1s; }

    @keyframes prFloat1 {
        0%, 100% { transform: translateY(0) rotate(-3deg); opacity: 0.45; }
        50% { transform: translateY(-14px) rotate(3deg); opacity: 0.6; }
    }
    @keyframes prFloat2 {
        0%, 100% { transform: translateY(0) rotate(2deg); opacity: 0.38; }
        50% { transform: translateY(-18px) rotate(-4deg); opacity: 0.55; }
    }
    @keyframes prFloat3 {
        0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.35; }
        50% { transform: translateY(-12px) rotate(5deg); opacity: 0.5; }
    }
    @keyframes prFloat4 {
        0%, 100% { transform: translateY(0) rotate(-2deg); opacity: 0.4; }
        50% { transform: translateY(-16px) rotate(3deg); opacity: 0.55; }
    }
    @keyframes prFloat5 {
        0%, 100% { transform: translateY(0) rotate(3deg); opacity: 0.42; }
        50% { transform: translateY(-15px) rotate(-4deg); opacity: 0.58; }
    }
    @keyframes prFloat6 {
        0%, 100% { transform: translateY(0) rotate(-1deg); opacity: 0.36; }
        50% { transform: translateY(-20px) rotate(3deg); opacity: 0.52; }
    }
    @keyframes prFloat7 {
        0%, 100% { transform: translateY(0) rotate(2deg); opacity: 0.4; }
        50% { transform: translateY(-13px) rotate(-5deg); opacity: 0.55; }
    }
    @keyframes prFloat8 {
        0%, 100% { transform: translateY(0) rotate(-3deg); opacity: 0.35; }
        50% { transform: translateY(-17px) rotate(4deg); opacity: 0.5; }
    }

    @media (max-width: 1400px) {
        .pr-floaters { display: none; }
    }

    @media (max-width: 768px) {
        .pr-head { flex-direction: column; align-items: flex-start; gap: 18px; }
        .pr-stats { margin-left: 0; width: 100%; }
        .pr-info-grid { grid-template-columns: 1fr; }
        .pr-name { font-size: 1.6rem; }
        .pr-stats-grid { grid-template-columns: repeat(2, 1fr); }
    }

    /* ═══ QR CODE PREMIUM SECTION ═══ */
    @property --qr-border-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }

    .pr-qr-card {
        position: relative;
        background: linear-gradient(145deg, rgba(251,146,60,0.04), rgba(251,191,36,0.02), rgba(255,255,255,0.015));
        border: 1px solid rgba(251,146,60,0.1) !important;
        overflow: hidden;
    }
    .pr-qr-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(251,146,60,0.4), rgba(251,191,36,0.3), transparent);
    }
    .pr-qr-card:hover {
        border-color: rgba(251,146,60,0.18) !important;
        box-shadow: 0 12px 50px rgba(251,146,60,0.06);
    }

    .pr-qr-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 40px;
        flex-wrap: wrap;
    }
    .pr-qr-left { flex: 1; min-width: 280px; }
    .pr-qr-right { flex-shrink: 0; display: flex; flex-direction: column; align-items: center; gap: 12px; }

    .pr-qr-desc {
        color: var(--muted);
        font-size: 0.84rem;
        line-height: 1.7;
        margin-top: 10px;
        max-width: 440px;
    }

    .pr-qr-signals {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 18px;
    }
    .pr-qr-signal {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 9px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        color: #d8dee9;
        font-size: 0.74rem;
        font-weight: 600;
        letter-spacing: 0.01em;
    }
    .pr-qr-signal i {
        color: var(--orange);
        font-size: 0.95rem;
    }

    .pr-qr-user-info {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-top: 22px;
        padding: 16px 20px;
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 14px;
    }
    .pr-qr-avatar { width: 44px; height: 44px; border-radius: 12px; overflow: hidden; flex-shrink: 0; }
    .pr-qr-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .pr-qr-avatar-placeholder {
        width: 100%; height: 100%;
        background: linear-gradient(135deg, rgba(251,146,60,0.15), rgba(251,191,36,0.1));
        display: flex; align-items: center; justify-content: center;
        color: var(--orange); font-size: 1.3rem;
    }
    .pr-qr-name { font-weight: 700; font-size: 0.88rem; color: #fff; }
    .pr-qr-email { font-size: 0.76rem; color: var(--muted); margin-top: 2px; }

    .pr-qr-actions {
        display: flex;
        gap: 10px;
        margin-top: 20px;
        flex-wrap: wrap;
    }
    .pr-qr-download-btn {
        background: linear-gradient(135deg, var(--orange), var(--yellow)) !important;
        border: none !important;
        color: #fff !important;
    }
    .pr-qr-download-btn:hover {
        box-shadow: 0 8px 28px rgba(251,146,60,0.35);
        transform: translateY(-2px);
    }
    .pr-qr-copy-btn i, .pr-qr-download-btn i {
        font-size: 1rem;
        margin-right: 2px;
    }

    /* QR Frame */
    .pr-qr-frame {
        position: relative;
        width: min(290px, 100%);
        min-height: 344px;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        gap: 14px;
        overflow: hidden;
        background: linear-gradient(180deg, rgba(13,17,28,0.96), rgba(6,9,16,0.94));
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 22px;
        padding: 16px;
        box-shadow: 0 24px 60px rgba(0,0,0,0.38), inset 0 1px 0 rgba(255,255,255,0.04);
    }

    /* Spinning border */
    .pr-qr-frame::after {
        content: '';
        position: absolute;
        inset: -2px;
        border-radius: 23px;
        padding: 2px;
        background: conic-gradient(from var(--qr-border-angle), transparent 30%, var(--orange) 50%, transparent 70%);
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        opacity: 0;
        transition: opacity .4s;
        z-index: 0;
    }
    .pr-qr-card:hover .pr-qr-frame::after {
        opacity: 1;
        animation: qrBorderSpin 3s linear infinite;
    }
    @keyframes qrBorderSpin { to { --qr-border-angle: 360deg; } }

    /* Corner brackets */
    .pr-qr-frame-corner {
        position: absolute;
        width: 20px; height: 20px;
        z-index: 3;
    }
    .pr-qr-fc-tl { top: 8px; left: 8px; border-top: 3px solid var(--orange); border-left: 3px solid var(--orange); border-radius: 6px 0 0 0; }
    .pr-qr-fc-tr { top: 8px; right: 8px; border-top: 3px solid var(--yellow); border-right: 3px solid var(--yellow); border-radius: 0 6px 0 0; }
    .pr-qr-fc-bl { bottom: 8px; left: 8px; border-bottom: 3px solid var(--yellow); border-left: 3px solid var(--yellow); border-radius: 0 0 0 6px; }
    .pr-qr-fc-br { bottom: 8px; right: 8px; border-bottom: 3px solid var(--orange); border-right: 3px solid var(--orange); border-radius: 0 0 6px 0; }

    /* Glow behind QR */
    .pr-qr-glow {
        position: absolute;
        inset: 92px 18% auto 18%;
        height: 140px;
        background: radial-gradient(circle, rgba(251,146,60,0.16), rgba(56,189,248,0.06) 45%, transparent 72%);
        border-radius: 50%;
        filter: blur(8px);
        z-index: 1;
        pointer-events: none;
        animation: qrGlowPulse 3s ease-in-out infinite;
    }
    @keyframes qrGlowPulse {
        0%, 100% { opacity: 0.5; transform: scale(1); }
        50% { opacity: 1; transform: scale(1.1); }
    }

    .pr-qr-preview-head,
    .pr-qr-preview-foot {
        position: relative;
        z-index: 2;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }
    .pr-qr-preview-foot {
        margin-top: 2px;
    }
    .pr-qr-premium-pill,
    .pr-qr-live-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        backdrop-filter: blur(12px);
    }
    .pr-qr-premium-pill {
        color: #fff5d6;
        background: linear-gradient(135deg, rgba(251,146,60,0.22), rgba(251,191,36,0.15));
        border: 1px solid rgba(251,191,36,0.2);
    }
    .pr-qr-live-pill {
        color: #d8fbe6;
        background: rgba(52,211,153,0.08);
        border: 1px solid rgba(52,211,153,0.16);
    }
    .pr-qr-live-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #34d399;
        box-shadow: 0 0 0 6px rgba(52,211,153,0.12);
    }
    .pr-qr-frame canvas {
        width: 220px;
        height: 220px;
        border-radius: 18px;
        position: relative;
        z-index: 2;
        display: block;
        background: #fff;
        box-shadow: 0 20px 35px rgba(0,0,0,0.3);
    }
    .pr-qr-preview-copy {
        min-width: 0;
        flex: 1;
    }
    .pr-qr-preview-title {
        color: #fff;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.02em;
    }
    .pr-qr-preview-url {
        margin-top: 4px;
        color: rgba(216,222,233,0.58);
        font-size: 0.68rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 180px;
    }
    .pr-qr-preview-mark {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 0.9rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        color: #fff;
        background: linear-gradient(135deg, rgba(251,146,60,0.92), rgba(251,191,36,0.88));
        box-shadow: 0 12px 28px rgba(251,146,60,0.22);
    }
    .pr-qr-label {
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }
    .pr-qr-source {
        display: none !important;
    }

    /* Toast */
    .pr-qr-toast {
        position: fixed;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%) translateY(80px);
        background: rgba(15,18,28,0.95);
        border: 1px solid rgba(251,146,60,0.2);
        border-radius: 14px;
        padding: 14px 28px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--orange);
        backdrop-filter: blur(20px);
        box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 0 20px rgba(251,146,60,0.08);
        z-index: 10000;
        opacity: 0;
        transition: all .4s cubic-bezier(0.4, 0, 0.2, 1);
        pointer-events: none;
    }
    .pr-qr-toast.show {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
    }
    .pr-qr-toast i { font-size: 1.2rem; }

    @media (max-width: 640px) {
        .pr-qr-inner { flex-direction: column; align-items: stretch; gap: 24px; }
        .pr-qr-right { align-items: center; }
    }
</style>
{% endblock %}

{% block body %}
{% include 'partials/_background.html.twig' %}
<div class="pr-scene" style="position:relative;z-index:1">

    {# ── Hidden upload forms (outside banner/avatar so clicks work) ── #}
    <form id="avatarForm" action="{{ path('app_profile_upload_avatar') }}" method="post" enctype="multipart/form-data" style="display:none;">
        <input type="file" id="avatarInput" name="avatar" accept="image/jpeg,image/png,image/gif,image/webp">
    </form>
    <form id="bannerForm" action="{{ path('app_profile_upload_banner') }}" method="post" enctype="multipart/form-data" style="display:none;">
        <input type="file" id="bannerInput" name="banner" accept="image/jpeg,image/png,image/gif,image/webp">
    </form>

    {# ── Banner ── #}
    <div class="pr-banner">
        {% if user.banner_base64 %}
            <img src="{{ user.banner_base64 }}" alt="Banner" class="pr-banner-img">
        {% endif %}
        <div class="pr-banner-mesh"></div>
        <button type="button" class="pr-banner-btn" onclick="document.getElementById('bannerInput').click()">
            <i class='bx bx-image-add'></i> {{ 'profile.change_banner'|trans }}
        </button>
    </div>

    {# ── Toast Notifications ── #}
    <div class="pr-toast-container">
        {% for message in app.flashes('success') %}
            <div class="pr-flash success"><i class='bx bx-check-circle' style="margin-right:6px;"></i>{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="pr-flash error"><i class='bx bx-error-circle' style="margin-right:6px;"></i>{{ message }}</div>
        {% endfor %}
    </div>

    {# ── Main Content ── #}
    <div class="pr-container" style="padding-top: 18px; padding-bottom: 80px;">

        {# ── Header ── #}
        <div class="pr-head">
            <div class="pr-avatar-wrap">
                <img src="{{ user.avatar_base64 ?: 'https://ui-avatars.com/api/?name=' ~ user.full_name|url_encode ~ '&size=260&background=7c5cfc&color=fff&bold=true&format=svg' }}" alt="{{ user.full_name }}" class="pr-avatar">
                <button type="button" class="pr-avatar-btn" onclick="document.getElementById('avatarInput').click()">
                    <i class='bx bx-camera'></i>
                </button>
            </div>
            <div class="pr-info">
                <h1 class="pr-name">{{ user.full_name }} <span class="pr-role-badge"><i class='bx bx-shield-quarter'></i> {{ user.role|lower|title }}</span></h1>
                {% if user.bio %}
                    <p class="pr-bio-text">{{ user.bio }}</p>
                {% else %}
                    <p class="pr-bio-text" style="color: rgba(255,255,255,0.25); font-style: italic;">{{ 'profile.no_bio'|trans }}</p>
                {% endif %}
                <button type="button" class="pr-edit-bio-btn" onclick="document.getElementById('bioModal').classList.add('open')">
                    <i class='bx bx-edit-alt'></i> {{ 'profile.edit_bio'|trans }}
                </button>
            </div>
            <div class="pr-stats">
                <div class="pr-stat"><strong>{{ courses|length }}</strong><span>{{ 'profile.courses'|trans }}</span></div>
                <div class="pr-stat"><strong>{{ tasksCompleted }}</strong><span>{{ 'profile.tasks_done'|trans }}</span></div>
                <div class="pr-stat"><strong>{{ forumPostsCount }}</strong><span>{{ 'profile.posts'|trans }}</span></div>
                <div class="pr-stat"><strong>{{ user.created_at|date('Y') }}</strong><span>{{ 'profile.joined'|trans }}</span></div>
            </div>
        </div>

        <hr class="pr-glow-line">

        {# ── 1. Learning Stats Dashboard ── #}
        <div class="pr-stats-grid">
            <div class="pr-stat-card pr-stat-purple">
                <div class="pr-stat-card-icon"><i class='bx bx-time-five'></i></div>
                <div class="pr-stat-card-val">{{ totalPomodoroMinutes }}<span class="pr-stat-unit">min</span></div>
                <div class="pr-stat-card-label">{{ 'profile.study_time'|trans }}</div>
                <div class="pr-stat-card-bar"><div class="pr-stat-card-fill" style="width: {{ min(totalPomodoroMinutes / 10, 100) }}%"></div></div>
            </div>
            <div class="pr-stat-card pr-stat-cyan">
                <div class="pr-stat-card-icon"><i class='bx bx-check-double'></i></div>
                <div class="pr-stat-card-val">{{ tasksCompleted }}</div>
                <div class="pr-stat-card-label">{{ 'profile.tasks_done'|trans }}</div>
                <div class="pr-stat-card-bar"><div class="pr-stat-card-fill" style="width: {{ min(tasksCompleted * 10, 100) }}%"></div></div>
            </div>
            <div class="pr-stat-card pr-stat-green">
                <div class="pr-stat-card-icon"><i class='bx bx-bar-chart-alt-2'></i></div>
                <div class="pr-stat-card-val">{{ quizAvgScore }}<span class="pr-stat-unit">%</span></div>
                <div class="pr-stat-card-label">{{ 'profile.quiz_average'|trans }}</div>
                <div class="pr-stat-card-bar"><div class="pr-stat-card-fill" style="width: {{ quizAvgScore }}%"></div></div>
            </div>
            <div class="pr-stat-card pr-stat-orange">
                <div class="pr-stat-card-icon"><i class='bx bx-conversation'></i></div>
                <div class="pr-stat-card-val">{{ forumPostsCount }}</div>
                <div class="pr-stat-card-label">{{ 'profile.forum_posts'|trans }}</div>
                <div class="pr-stat-card-bar"><div class="pr-stat-card-fill" style="width: {{ min(forumPostsCount * 5, 100) }}%"></div></div>
            </div>
        </div>

        {# ── 2. Current Level + Profile Overview ── #}
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-top: 18px;">

            {# Level Card #}
            <div class="pr-card">
                <div class="pr-card-label">{{ 'profile.your_level'|trans }}</div>
                {% if currentLevel %}
                    <div class="pr-level-display">
                        <div class="pr-level-ring">
                            <svg viewBox="0 0 120 120">
                                <circle cx="60" cy="60" r="52" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="8"/>
                                <circle cx="60" cy="60" r="52" fill="none" stroke="url(#levelGrad)" stroke-width="8" stroke-linecap="round"
                                    stroke-dasharray="{{ (currentLevel.last_score_percent|default(0)) * 3.27 }} 327"
                                    transform="rotate(-90 60 60)"/>
                                <defs><linearGradient id="levelGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                    <stop offset="0%" stop-color="var(--purple)"/>
                                    <stop offset="100%" stop-color="var(--cyan)"/>
                                </linearGradient></defs>
                            </svg>
                            <div class="pr-level-center">
                                <span class="pr-level-score">{{ currentLevel.last_score_percent|default(0)|round }}%</span>
                            </div>
                        </div>
                        <div class="pr-level-info">
                            <h2 class="pr-level-name">{{ currentLevel.current_level|title }}</h2>
                            <p style="color: var(--muted); font-size: 0.82rem; margin-top: 6px;">{{ 'profile.level_based_on'|trans }}</p>
                            <div class="pr-level-tag">
                                {% if currentLevel.current_level == 'advanced' %}
                                    <i class='bx bxs-crown' style="color: #fbbf24;"></i> {{ 'profile.top_tier'|trans }}
                                {% elseif currentLevel.current_level == 'intermediate' %}
                                    <i class='bx bxs-bolt' style="color: var(--cyan);"></i> {{ 'profile.making_progress'|trans }}
                                {% else %}
                                    <i class='bx bxs-leaf' style="color: var(--green);"></i> {{ 'profile.getting_started'|trans }}
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div style="text-align: center; padding: 40px 0;">
                        <i class='bx bx-trophy' style="font-size: 3rem; color: rgba(255,255,255,0.1);"></i>
                        <p style="color: var(--muted); margin-top: 12px; font-size: 0.84rem;">{{ 'profile.take_quiz'|trans }}</p>
                    </div>
                {% endif %}
            </div>

            {# Profile Overview #}
            <div class="pr-card">
                <div class="pr-card-label">{{ 'profile.profile_overview'|trans }}</div>
                <h2>{{ user.full_name }}</h2>
                {% if user.bio %}
                    <p>{{ user.bio }}</p>
                {% else %}
                    <p style="color: rgba(255,255,255,0.25); font-style: italic;">{{ 'profile.no_bio_short'|trans }}</p>
                {% endif %}
                <div class="pr-info-grid">
                    <div class="pr-info-tile">
                        <div class="pr-card-label">{{ 'profile.contact'|trans }}</div>
                        <p><strong>{{ 'profile.email'|trans }}</strong> {{ user.email }}</p>
                        {% if user.phone %}
                            <p class="detail"><strong>{{ 'profile.phone'|trans }}</strong> {{ user.phone }}</p>
                        {% endif %}
                        {% if user.location %}
                            <p class="detail"><strong>{{ 'profile.location'|trans }}</strong> {{ user.location }}</p>
                        {% endif %}
                    </div>
                    <div class="pr-info-tile">
                        <div class="pr-card-label">{{ 'profile.account'|trans }}</div>
                        <p><strong>{{ 'profile.role'|trans }}</strong> {{ user.role|lower|title }}</p>
                        <p class="detail"><strong>{{ 'profile.joined_date'|trans }}</strong> {{ user.created_at|date('M d, Y') }}</p>
                        {% if user.last_login %}
                            <p class="detail"><strong>{{ 'profile.last_login'|trans }}</strong> {{ user.last_login|date('M d, Y H:i') }}</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        {# ── 3. Quiz Performance + Activity Timeline ── #}
        <div style="display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 18px; margin-top: 18px;">

            {# Quiz Performance #}
            <div class="pr-card">
                <div class="pr-card-label">{{ 'profile.quiz_history'|trans }}</div>
                <h2>{{ 'profile.performance'|trans }}</h2>
                {% if quizAttempts|length > 0 %}
                    <div style="display: grid; gap: 10px; margin-top: 20px;">
                        {% for attempt in quizAttempts %}
                            <div class="pr-quiz-row">
                                <div class="pr-quiz-icon">
                                    {% if attempt.score_percent >= 80 %}
                                        <i class='bx bxs-star' style="color: #fbbf24;"></i>
                                    {% elseif attempt.score_percent >= 50 %}
                                        <i class='bx bxs-bolt' style="color: var(--cyan);"></i>
                                    {% else %}
                                        <i class='bx bx-target-lock' style="color: var(--muted);"></i>
                                    {% endif %}
                                </div>
                                <div class="pr-quiz-info">
                                    <div class="pr-quiz-title">{{ attempt.quiz_title|default('Quiz') }}</div>
                                    <div class="pr-quiz-meta">{{ attempt.earned_points }}/{{ attempt.total_points }} pts · {{ attempt.started_at|date('M d, Y') }}</div>
                                </div>
                                <div class="pr-quiz-score-wrap">
                                    <div class="pr-quiz-score {% if attempt.score_percent >= 80 %}gold{% elseif attempt.score_percent >= 50 %}cyan{% else %}muted{% endif %}">
                                        {{ attempt.score_percent|round }}%
                                    </div>
                                    <div class="pr-quiz-bar"><div class="pr-quiz-bar-fill" style="width: {{ attempt.score_percent }}%"></div></div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div style="text-align: center; padding: 40px 0;">
                        <i class='bx bx-notepad' style="font-size: 3rem; color: rgba(255,255,255,0.1);"></i>
                        <p style="color: var(--muted); margin-top: 12px; font-size: 0.84rem;">{{ 'profile.no_quiz_attempts'|trans }}</p>
                    </div>
                {% endif %}
            </div>

            {# Activity Timeline #}
            <div class="pr-card">
                <div class="pr-card-label">{{ 'profile.timeline'|trans }}</div>
                <h2>{{ 'profile.recent_activity'|trans }}</h2>
                {% if recentActivity|length > 0 %}
                    <div class="pr-timeline">
                        {% for item in recentActivity %}
                            <div class="pr-timeline-item">
                                <div class="pr-timeline-dot {{ item.type }}"></div>
                                <div class="pr-timeline-content">
                                    <div class="pr-timeline-label">
                                        {% if item.type == 'quiz' %}
                                            <i class='bx bx-brain'></i> {{ 'profile.completed_quiz'|trans }}
                                        {% elseif item.type == 'post' %}
                                            <i class='bx bx-message-detail'></i> {{ 'profile.forum_post'|trans }}
                                        {% else %}
                                            <i class='bx bx-check-circle'></i> {{ 'profile.task_done'|trans }}
                                        {% endif %}
                                    </div>
                                    <div class="pr-timeline-title">{{ item.title|default('Untitled') }}</div>
                                    {% if item.type == 'quiz' and item.detail %}
                                        <div class="pr-timeline-detail">Score: {{ item.detail|round }}%</div>
                                    {% endif %}
                                    <div class="pr-timeline-time">{{ item.created_at|date('M d · H:i') }}</div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div style="text-align: center; padding: 40px 0;">
                        <i class='bx bx-history' style="font-size: 3rem; color: rgba(255,255,255,0.1);"></i>
                        <p style="color: var(--muted); margin-top: 12px; font-size: 0.84rem;">{{ 'profile.no_activity'|trans }}</p>
                    </div>
                {% endif %}
            </div>
        </div>

        {# ── 4. My Courses ── #}
        <div class="pr-card" style="margin-top: 18px;">
            <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px;">
                <div>
                    <div class="pr-card-label">{{ 'profile.learning'|trans }}</div>
                    <h2>{{ 'profile.my_courses'|trans }}</h2>
                </div>
                <span style="color: var(--muted); font-size: 0.72rem; opacity: 0.6;">{{ courses|length }} total</span>
            </div>
            {% if courses|length > 0 %}
                <div class="pr-courses-grid">
                    {% for course in courses %}
                        <div class="pr-course-card">
                            <div class="pr-course-level {{ course.level|lower }}">{{ course.level|upper }}</div>
                            <h3 class="pr-course-title">{{ course.title }}</h3>
                            {% if course.module_name %}
                                <div class="pr-course-module"><i class='bx bx-layer'></i> {{ course.module_name }}</div>
                            {% endif %}
                            <div class="pr-course-footer">
                                <span><i class='bx bx-file'></i> {{ course.exercise_count }} {{ 'profile.exercises'|trans }}</span>
                                <span>{{ course.created_at|date('M Y') }}</span>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div style="text-align: center; padding: 40px 0;">
                    <i class='bx bx-book-open' style="font-size: 3rem; color: rgba(255,255,255,0.1);"></i>
                    <p style="color: var(--muted); margin-top: 12px; font-size: 0.84rem;">{{ 'profile.no_courses'|trans }}</p>
                </div>
            {% endif %}
        </div>

        {# ── 4b. My Forum Posts (Facebook-style) ── #}
        <div class="pr-card" style="margin-top: 18px;">
            <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px;">
                <div>
                    <div class="pr-card-label">{{ 'profile.community'|trans|default('Community') }}</div>
                    <h2>{{ 'profile.my_forum_posts'|trans|default('My Forum Posts') }}</h2>
                </div>
                <div style="display: flex; align-items: center; gap: 10px;">
                    <span style="color: var(--muted); font-size: 0.72rem; opacity: 0.6;">{{ forumTopics|length }} {{ forumTopics|length == 1 ? 'post' : 'posts' }}</span>
                    <a href="{{ path('app_forum') }}" style="display: inline-flex; align-items: center; gap: 5px; padding: 6px 14px; border-radius: 10px; background: rgba(124,92,252,0.1); border: 1px solid rgba(124,92,252,0.15); color: var(--purple-soft); font-size: 0.74rem; font-weight: 600; text-decoration: none; transition: all 0.25s;">
                        <i class='bx bx-message-square-dots' style="font-size: 0.85rem;"></i> {{ 'profile.view_forum'|trans|default('View Forum') }}
                    </a>
                </div>
            </div>
            {% if forumTopics|length > 0 %}
                <div class="pr-forum-feed">
                    {% for topic in forumTopics %}
                        <div class="pr-forum-post" style="animation-delay: {{ loop.index0 * 0.06 }}s;">
                            <div class="pr-forum-post-head">
                                <img class="pr-forum-post-avatar" src="{{ user.avatarBase64 ?: 'https://ui-avatars.com/api/?name=' ~ user.fullName|url_encode ~ '&size=88&background=e2e8f0&color=0f172a&bold=true&format=svg' }}" alt="">
                                <div>
                                    <div class="pr-forum-post-author">{{ user.fullName }}</div>
                                    <div class="pr-forum-post-time">{{ topic.created_at|date('M d, Y · H:i') }}</div>
                                </div>
                                <span class="pr-forum-post-cat {{ topic.category }}">{{ topic.category|replace({'_': ' '}) }}</span>
                            </div>
                            <a href="{{ path('app_forum_topic', {id: topic.id}) }}" class="pr-forum-post-title">{{ topic.title }}</a>
                            {% if topic.first_post_content %}
                                <div class="pr-forum-post-body">{{ topic.first_post_content|length > 250 ? topic.first_post_content|slice(0, 250) ~ '…' : topic.first_post_content }}</div>
                            {% endif %}
                            {% set _media = [] %}
                            {% if topic.first_post_media_files %}
                                {% set _media = topic.first_post_media_files|json_decode %}
                            {% elseif topic.first_post_media_path %}
                                {% set _media = [{type: topic.first_post_media_type, path: topic.first_post_media_path}] %}
                            {% endif %}
                            {% if _media|length > 0 %}
                                <div class="pr-forum-post-media" style="{% if _media|length > 1 %}grid-template-columns: repeat(2, 1fr){% endif %}">
                                    {% for m in _media|slice(0, 4) %}
                                        {% if m.type == 'image' %}
                                            <img src="{{ m.path }}" alt="" loading="lazy">
                                        {% elseif m.type == 'video' %}
                                            <video controls playsinline preload="none"><source src="{{ m.path }}"></video>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            {% endif %}
                            <div class="pr-forum-post-stats">
                                {% if topic.like_count > 0 %}
                                    <span class="likes"><i class='bx bxs-like'></i> {{ topic.like_count }} {{ topic.like_count == 1 ? 'like' : 'likes' }}</span>
                                {% endif %}
                                {% if topic.reply_count > 0 %}
                                    <span class="replies"><i class='bx bx-message-rounded'></i> {{ topic.reply_count }} {{ topic.reply_count == 1 ? 'reply' : 'replies' }}</span>
                                {% endif %}
                                {% if topic.is_closed %}<span style="color: var(--red);"><i class='bx bx-lock-alt'></i> Closed</span>{% endif %}
                                {% if topic.like_count == 0 and topic.reply_count == 0 %}
                                    <span style="color: rgba(148,163,184,0.4);">No interactions yet</span>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div style="text-align: center; padding: 48px 0;">
                    <i class='bx bx-message-square-dots' style="font-size: 3rem; color: rgba(255,255,255,0.08);"></i>
                    <p style="color: var(--muted); margin-top: 14px; font-size: 0.84rem;">{{ 'profile.no_forum_posts'|trans|default('You haven\'t posted in the forum yet.') }}</p>
                    <a href="{{ path('app_forum') }}" style="display: inline-flex; align-items: center; gap: 6px; margin-top: 14px; padding: 9px 20px; border-radius: 12px; background: linear-gradient(135deg, var(--purple), #6344e0); color: #fff; font-size: 0.8rem; font-weight: 700; text-decoration: none; box-shadow: 0 4px 16px rgba(124,92,252,0.25); transition: all 0.25s;">
                        <i class='bx bx-plus'></i> {{ 'profile.create_first_post'|trans|default('Create Your First Post') }}
                    </a>
                </div>
            {% endif %}
        </div>

        {# ── 5. Badges ── #}
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-top: 18px;">
            <div class="pr-card">
                <div class="pr-card-label">{{ 'profile.recognition'|trans }}</div>
                <h2>{{ 'profile.badges_status'|trans }}</h2>
                <div style="display: grid; gap: 12px; margin-top: 20px;">
                    <div class="pr-badge-row">
                        <div class="pr-badge-icon">
                            <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        </div>
                        <div>
                            <div style="font-weight: 700; color: #fff; font-size: 0.88rem;">{{ 'profile.verified_account'|trans }}</div>
                            <div style="color: var(--muted); font-size: 0.78rem; margin-top: 3px;">{{ 'profile.identity_confirmed'|trans }}</div>
                        </div>
                    </div>
                    <div class="pr-badge-row">
                        <div class="pr-badge-icon">
                            <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
                        </div>
                        <div>
                            <div style="font-weight: 700; color: #fff; font-size: 0.88rem;">{{ 'profile.early_adopter'|trans }}</div>
                            <div style="color: var(--muted); font-size: 0.78rem; margin-top: 3px;">{{ 'profile.joined_launch'|trans }}</div>
                        </div>
                    </div>
                    {% if forumPostsCount >= 5 %}
                    <div class="pr-badge-row">
                        <div class="pr-badge-icon" style="background: linear-gradient(135deg, rgba(34,211,238,0.14), rgba(52,211,153,0.08)); border-color: rgba(34,211,238,0.2); color: var(--cyan);">
                            <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        </div>
                        <div>
                            <div style="font-weight: 700; color: #fff; font-size: 0.88rem;">{{ 'profile.active_contributor'|trans }}</div>
                            <div style="color: var(--muted); font-size: 0.78rem; margin-top: 3px;">{{ forumPostsCount }} forum posts and counting!</div>
                        </div>
                    </div>
                    {% endif %}
                    {% if tasksCompleted >= 10 %}
                    <div class="pr-badge-row">
                        <div class="pr-badge-icon" style="background: linear-gradient(135deg, rgba(251,191,36,0.14), rgba(249,115,22,0.08)); border-color: rgba(251,191,36,0.2); color: #fbbf24;">
                            <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                        </div>
                        <div>
                            <div style="font-weight: 700; color: #fff; font-size: 0.88rem;">{{ 'profile.task_master'|trans }}</div>
                            <div style="color: var(--muted); font-size: 0.78rem; margin-top: 3px;">Completed {{ tasksCompleted }} tasks!</div>
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>

            {# Notifications Card #}
            <div class="pr-card">
                <div style="display: flex; align-items: center; justify-content: space-between;">
                    <div>
                        <div class="pr-card-label">{{ 'profile.inbox'|trans }}</div>
                        <h2>{{ 'profile.notifications'|trans }} {% if unreadCount > 0 %}<span class="pr-notif-count">{{ unreadCount }}</span>{% endif %}</h2>
                    </div>
                </div>
                {% if unreadNotifications|length > 0 %}
                    <div style="display: grid; gap: 10px; margin-top: 20px;">
                        {% for notif in unreadNotifications %}
                            <div class="pr-notif-row">
                                <div class="pr-notif-dot"></div>
                                <div>
                                    <div style="font-weight: 600; color: #fff; font-size: 0.84rem;">{{ notif.title }}</div>
                                    <div style="color: var(--muted); font-size: 0.76rem; margin-top: 3px; line-height: 1.5;">{{ notif.message|length > 80 ? notif.message|slice(0, 80) ~ '…' : notif.message }}</div>
                                    <div style="color: rgba(148,163,184,0.4); font-size: 0.7rem; margin-top: 5px;">{{ notif.created_at|date('M d · H:i') }}</div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div style="text-align: center; padding: 40px 0;">
                        <i class='bx bx-bell' style="font-size: 3rem; color: rgba(255,255,255,0.1);"></i>
                        <p style="color: var(--muted); margin-top: 12px; font-size: 0.84rem;">{{ 'profile.all_caught_up'|trans }}</p>
                    </div>
                {% endif %}
            </div>
        </div>

        {# ── 6. QR Code Card ── #}
        <div class="pr-card pr-qr-card" style="margin-top: 18px;">
            <div class="pr-qr-inner">
                <div class="pr-qr-left">
                    <div class="pr-card-label" style="color: var(--orange);">{{ 'profile.share_profile'|trans }}</div>
                    <h2 style="font-size: 1.35rem;">{{ 'profile.your_qr_code'|trans }}</h2>
                    <p class="pr-qr-desc">{{ 'profile.qr_desc'|trans }}</p>
                    <div class="pr-qr-signals">
                        <div class="pr-qr-signal"><i class='bx bx-diamond'></i> {{ 'profile.premium_finish'|trans }}</div>
                        <div class="pr-qr-signal"><i class='bx bx-shield-quarter'></i> {{ 'profile.high_contrast'|trans }}</div>
                        <div class="pr-qr-signal"><i class='bx bx-scan'></i> {{ 'profile.fast_scan'|trans }}</div>
                    </div>
                    <div class="pr-qr-user-info">
                        <div class="pr-qr-avatar">
                            {% if user.avatarBase64 %}
                                <img src="{{ user.avatarBase64 starts with 'data:' ? user.avatarBase64 : 'data:image/jpeg;base64,' ~ user.avatarBase64 }}" alt="">
                            {% else %}
                                <div class="pr-qr-avatar-placeholder"><i class='bx bx-user'></i></div>
                            {% endif %}
                        </div>
                        <div>
                            <div class="pr-qr-name">{{ user.fullName }}</div>
                            <div class="pr-qr-email">{{ user.email }}</div>
                        </div>
                    </div>
                    <div class="pr-qr-actions">
                        <button class="pr-btn pr-btn-primary pr-qr-download-btn" onclick="downloadQR()">
                            <i class='bx bx-download'></i> {{ 'profile.download_png'|trans }}
                        </button>
                        <button class="pr-btn pr-btn-ghost pr-qr-copy-btn" onclick="copyProfileLink()">
                            <i class='bx bx-link'></i> {{ 'profile.copy_link'|trans }}
                        </button>
                    </div>
                </div>
                <div class="pr-qr-right">
                    <div class="pr-qr-frame">
                        <div class="pr-qr-frame-corner pr-qr-fc-tl"></div>
                        <div class="pr-qr-frame-corner pr-qr-fc-tr"></div>
                        <div class="pr-qr-frame-corner pr-qr-fc-bl"></div>
                        <div class="pr-qr-frame-corner pr-qr-fc-br"></div>
                        <div class="pr-qr-glow"></div>
                        <div class="pr-qr-preview-head">
                            <div class="pr-qr-premium-pill"><i class='bx bx-diamond'></i> Premium Share</div>
                            <div class="pr-qr-live-pill"><span class="pr-qr-live-dot"></span> Ready</div>
                        </div>
                        <canvas id="qrCanvas" width="220" height="220"></canvas>
                        <div class="pr-qr-preview-foot">
                            <div class="pr-qr-preview-copy">
                                <div class="pr-qr-preview-title">{{ 'profile.learnadapt_identity'|trans }}</div>
                                <div class="pr-qr-preview-url">{{ profileShareUrl|replace({'https://': '', 'http://': ''}) }}</div>
                            </div>
                            <div class="pr-qr-preview-mark">LA</div>
                        </div>
                        <img id="qrImageSource" class="pr-qr-source" src="{{ path('app_profile_qr', { size: 520 }) }}" alt="">
                    </div>
                    <div class="pr-qr-label">{{ 'profile.scan_camera'|trans }}</div>
                </div>
            </div>
        </div>

        {# QR Code Toast #}
        <div class="pr-qr-toast" id="qrToast">
            <i class='bx bx-check-circle'></i>
            <span id="qrToastMsg">Link copied!</span>
        </div>

    </div>

    {# ── Bio Edit Modal ── #}
    <div class="pr-modal-bg" id="bioModal">
        <div class="pr-modal">
            <h3>{{ 'profile.edit_bio_title'|trans }}</h3>
            <p>{{ 'profile.edit_bio_desc'|trans }}</p>
            <form method="post" action="{{ path('app_profile_update_bio') }}">
                <textarea name="bio" maxlength="500" placeholder="{{ 'profile.bio_placeholder'|trans }}">{{ user.bio }}</textarea>
                <div class="pr-modal-actions">
                    <button type="button" class="pr-btn pr-btn-ghost" onclick="document.getElementById('bioModal').classList.remove('open')">{{ 'profile.cancel'|trans }}</button>
                    <button type="submit" class="pr-btn pr-btn-primary">{{ 'profile.save_bio'|trans }}</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
document.getElementById('avatarInput').addEventListener('change', function() {
    if (this.files.length > 0) document.getElementById('avatarForm').submit();
});
document.getElementById('bannerInput').addEventListener('change', function() {
    if (this.files.length > 0) document.getElementById('bannerForm').submit();
});
document.getElementById('bioModal').addEventListener('click', function(e) {
    if (e.target === this) this.classList.remove('open');
});
document.querySelectorAll('.pr-flash').forEach(function(el) {
    setTimeout(function() {
        el.classList.add('fade-out');
        setTimeout(function() { el.remove(); }, 500);
    }, 5000);
});

// ── QR Code Actions ──
(function() {
    var profileUrl = '{{ profileShareUrl|e('js') }}';
    var qrCanvas = document.getElementById('qrCanvas');
    var qrImageSource = document.getElementById('qrImageSource');
    var qrDownloadSourceUrl = '{{ path('app_profile_qr', { size: 800 }) }}';
    var userName = '{{ user.fullName|e('js') }}';
    var userEmail = '{{ user.email|e('js') }}';

    function roundedRectPath(ctx, x, y, width, height, radius) {
        var r = Math.min(radius, width / 2, height / 2);
        ctx.beginPath();
        ctx.moveTo(x + r, y);
        ctx.arcTo(x + width, y, x + width, y + height, r);
        ctx.arcTo(x + width, y + height, x, y + height, r);
        ctx.arcTo(x, y + height, x, y, r);
        ctx.arcTo(x, y, x + width, y, r);
        ctx.closePath();
    }

    function drawBackdropPattern(ctx, size) {
        ctx.save();
        ctx.strokeStyle = 'rgba(255,255,255,0.045)';
        ctx.lineWidth = Math.max(1, size / 260);

        for (var i = -size; i < size * 2; i += size / 7.5) {
            ctx.beginPath();
            ctx.moveTo(i, 0);
            ctx.lineTo(i - size, size);
            ctx.stroke();
        }

        ctx.restore();
    }

    function drawPreviewQr(canvas, qrImage) {
        var ctx = canvas.getContext('2d');
        var size = canvas.width;
        var scale = size / 220;
        var tileX = 18 * scale;
        var tileY = 18 * scale;
        var tileSize = size - (36 * scale);
        var qrPadding = 12 * scale;
        var accent = ctx.createLinearGradient(0, 0, size, size);
        var panel = ctx.createLinearGradient(0, 0, size, size);

        panel.addColorStop(0, '#111827');
        panel.addColorStop(0.58, '#0b1020');
        panel.addColorStop(1, '#05070d');

        ctx.clearRect(0, 0, size, size);
        roundedRectPath(ctx, 0, 0, size, size, 30 * scale);
        ctx.fillStyle = panel;
        ctx.fill();

        ctx.save();
        ctx.globalCompositeOperation = 'screen';

        var orbA = ctx.createRadialGradient(42 * scale, 38 * scale, 0, 42 * scale, 38 * scale, 96 * scale);
        orbA.addColorStop(0, 'rgba(251,146,60,0.36)');
        orbA.addColorStop(1, 'rgba(251,146,60,0)');
        ctx.fillStyle = orbA;
        ctx.fillRect(0, 0, size, size);

        var orbB = ctx.createRadialGradient(size - (36 * scale), size - (34 * scale), 0, size - (36 * scale), size - (34 * scale), 90 * scale);
        orbB.addColorStop(0, 'rgba(56,189,248,0.18)');
        orbB.addColorStop(1, 'rgba(56,189,248,0)');
        ctx.fillStyle = orbB;
        ctx.fillRect(0, 0, size, size);
        ctx.restore();

        drawBackdropPattern(ctx, size);

        accent.addColorStop(0, 'rgba(251,146,60,0)');
        accent.addColorStop(0.35, 'rgba(251,146,60,0.9)');
        accent.addColorStop(0.68, 'rgba(251,191,36,0.8)');
        accent.addColorStop(1, 'rgba(251,191,36,0)');
        ctx.fillStyle = accent;
        ctx.fillRect(16 * scale, 10 * scale, size - (32 * scale), 4 * scale);

        ctx.save();
        ctx.shadowColor = 'rgba(0,0,0,0.35)';
        ctx.shadowBlur = 28 * scale;
        ctx.shadowOffsetY = 18 * scale;
        roundedRectPath(ctx, tileX, tileY, tileSize, tileSize, 24 * scale);
        ctx.fillStyle = '#ffffff';
        ctx.fill();
        ctx.restore();

        ctx.save();
        roundedRectPath(ctx, tileX + (1.5 * scale), tileY + (1.5 * scale), tileSize - (3 * scale), tileSize - (3 * scale), 22 * scale);
        ctx.clip();
        ctx.drawImage(qrImage, tileX + qrPadding, tileY + qrPadding, tileSize - (qrPadding * 2), tileSize - (qrPadding * 2));
        ctx.restore();

        ctx.lineWidth = 3 * scale;
        ctx.strokeStyle = 'rgba(255,255,255,0.08)';
        roundedRectPath(ctx, tileX, tileY, tileSize, tileSize, 24 * scale);
        ctx.stroke();

        var cornerLength = 18 * scale;
        var cornerInset = 6 * scale;
        ctx.lineWidth = 3 * scale;
        ctx.lineCap = 'round';

        ctx.strokeStyle = '#fb923c';
        ctx.beginPath();
        ctx.moveTo(tileX - cornerInset, tileY + cornerLength);
        ctx.lineTo(tileX - cornerInset, tileY - cornerInset);
        ctx.lineTo(tileX + cornerLength, tileY - cornerInset);
        ctx.stroke();

        ctx.strokeStyle = '#fbbf24';
        ctx.beginPath();
        ctx.moveTo(tileX + tileSize - cornerLength, tileY - cornerInset);
        ctx.lineTo(tileX + tileSize + cornerInset, tileY - cornerInset);
        ctx.lineTo(tileX + tileSize + cornerInset, tileY + cornerLength);
        ctx.stroke();

        ctx.strokeStyle = '#38bdf8';
        ctx.beginPath();
        ctx.moveTo(tileX - cornerInset, tileY + tileSize - cornerLength);
        ctx.lineTo(tileX - cornerInset, tileY + tileSize + cornerInset);
        ctx.lineTo(tileX + cornerLength, tileY + tileSize + cornerInset);
        ctx.stroke();

        ctx.strokeStyle = '#fb923c';
        ctx.beginPath();
        ctx.moveTo(tileX + tileSize - cornerLength, tileY + tileSize + cornerInset);
        ctx.lineTo(tileX + tileSize + cornerInset, tileY + tileSize + cornerInset);
        ctx.lineTo(tileX + tileSize + cornerInset, tileY + tileSize - cornerLength);
        ctx.stroke();
    }

    function drawDownloadCard(canvas, qrImage) {
        var ctx = canvas.getContext('2d');
        var width = canvas.width;
        var height = canvas.height;
        var cardX = 80;
        var cardY = 80;
        var cardWidth = width - 160;
        var cardHeight = height - 160;
        var qrTileSize = 780;
        var qrTileX = (width - qrTileSize) / 2;
        var qrTileY = 320;
        var qrPadding = 56;
        var background = ctx.createLinearGradient(0, 0, width, height);
        var accent = ctx.createLinearGradient(cardX, cardY, cardX + cardWidth, cardY);

        background.addColorStop(0, '#070b13');
        background.addColorStop(0.5, '#0b1120');
        background.addColorStop(1, '#05070c');
        ctx.fillStyle = background;
        ctx.fillRect(0, 0, width, height);

        ctx.save();
        ctx.globalCompositeOperation = 'screen';
        var glowA = ctx.createRadialGradient(140, 150, 0, 140, 150, 360);
        glowA.addColorStop(0, 'rgba(251,146,60,0.28)');
        glowA.addColorStop(1, 'rgba(251,146,60,0)');
        ctx.fillStyle = glowA;
        ctx.fillRect(0, 0, width, height);

        var glowB = ctx.createRadialGradient(width - 120, height - 180, 0, width - 120, height - 180, 320);
        glowB.addColorStop(0, 'rgba(56,189,248,0.18)');
        glowB.addColorStop(1, 'rgba(56,189,248,0)');
        ctx.fillStyle = glowB;
        ctx.fillRect(0, 0, width, height);
        ctx.restore();

        roundedRectPath(ctx, cardX, cardY, cardWidth, cardHeight, 42);
        ctx.fillStyle = 'rgba(11,15,24,0.92)';
        ctx.fill();

        accent.addColorStop(0, 'rgba(251,146,60,0)');
        accent.addColorStop(0.3, 'rgba(251,146,60,0.96)');
        accent.addColorStop(0.7, 'rgba(251,191,36,0.92)');
        accent.addColorStop(1, 'rgba(251,191,36,0)');
        ctx.fillStyle = accent;
        ctx.fillRect(cardX + 44, cardY + 18, cardWidth - 88, 6);

        ctx.strokeStyle = 'rgba(255,255,255,0.06)';
        ctx.lineWidth = 2;
        roundedRectPath(ctx, cardX, cardY, cardWidth, cardHeight, 42);
        ctx.stroke();

        ctx.fillStyle = '#fb923c';
        ctx.font = '700 30px Arial, sans-serif';
        ctx.fillText('PREMIUM SHARE QR', cardX + 70, cardY + 96);

        ctx.fillStyle = '#ffffff';
        ctx.font = '700 72px Arial, sans-serif';
        ctx.fillText(userName, cardX + 70, cardY + 188);

        ctx.fillStyle = 'rgba(216,222,233,0.75)';
        ctx.font = '400 32px Arial, sans-serif';
        ctx.fillText('Scan to open this LearnAdapt profile instantly.', cardX + 70, cardY + 240);

        ctx.save();
        ctx.shadowColor = 'rgba(0,0,0,0.38)';
        ctx.shadowBlur = 48;
        ctx.shadowOffsetY = 24;
        roundedRectPath(ctx, qrTileX, qrTileY, qrTileSize, qrTileSize, 54);
        ctx.fillStyle = '#ffffff';
        ctx.fill();
        ctx.restore();

        ctx.save();
        roundedRectPath(ctx, qrTileX + 4, qrTileY + 4, qrTileSize - 8, qrTileSize - 8, 50);
        ctx.clip();
        ctx.drawImage(qrImage, qrTileX + qrPadding, qrTileY + qrPadding, qrTileSize - (qrPadding * 2), qrTileSize - (qrPadding * 2));
        ctx.restore();

        ctx.lineWidth = 8;
        ctx.strokeStyle = 'rgba(255,255,255,0.08)';
        roundedRectPath(ctx, qrTileX, qrTileY, qrTileSize, qrTileSize, 54);
        ctx.stroke();

        ctx.fillStyle = '#ffffff';
        ctx.font = '700 40px Arial, sans-serif';
        ctx.fillText('LearnAdapt Identity', cardX + 70, height - 290);

        ctx.fillStyle = 'rgba(216,222,233,0.72)';
        ctx.font = '400 28px Arial, sans-serif';
        ctx.fillText(userEmail, cardX + 70, height - 232);
        ctx.fillText(profileUrl, cardX + 70, height - 186);

        roundedRectPath(ctx, width - 220, height - 260, 108, 108, 28);
        ctx.fillStyle = '#fb923c';
        ctx.fill();
        ctx.fillStyle = '#ffffff';
        ctx.font = '800 42px Arial, sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('LA', width - 166, height - 206);

        ctx.textAlign = 'left';
        ctx.textBaseline = 'alphabetic';
    }

    function renderPreview() {
        if (!qrImageSource.complete || !qrImageSource.naturalWidth) {
            return;
        }

        drawPreviewQr(qrCanvas, qrImageSource);
    }

    function loadQrImage(url) {
        return new Promise(function(resolve, reject) {
            var image = new Image();
            image.onload = function() { resolve(image); };
            image.onerror = reject;
            image.src = url + (url.indexOf('?') === -1 ? '?' : '&') + 'v=' + Date.now();
        });
    }

    if (qrImageSource.complete) {
        renderPreview();
    } else {
        qrImageSource.addEventListener('load', renderPreview, { once: true });
    }

    qrImageSource.addEventListener('error', function() {
        var ctx = qrCanvas.getContext('2d');
        ctx.clearRect(0, 0, qrCanvas.width, qrCanvas.height);
        roundedRectPath(ctx, 0, 0, qrCanvas.width, qrCanvas.height, 30);
        ctx.fillStyle = '#111827';
        ctx.fill();
        ctx.fillStyle = '#ffffff';
        ctx.font = '700 16px Arial, sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('QR unavailable', qrCanvas.width / 2, qrCanvas.height / 2);
    }, { once: true });

    // Download
    window.downloadQR = function() {
        loadQrImage(qrDownloadSourceUrl).then(function(downloadQrImage) {
            var downloadCanvas = document.createElement('canvas');
            var link = document.createElement('a');

            downloadCanvas.width = 1400;
            downloadCanvas.height = 1680;
            drawDownloadCard(downloadCanvas, downloadQrImage);

            link.download = 'learnadapt-premium-profile-qr.png';
            link.href = downloadCanvas.toDataURL('image/png');
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);

            showQRToast('Premium QR downloaded!');
        }).catch(function() {
            showQRToast('Unable to build the premium QR right now.');
        });
    };

    // Copy link
    window.copyProfileLink = function() {
        navigator.clipboard.writeText(profileUrl).then(function() {
            showQRToast('Profile link copied!');
        }).catch(function() {
            // Fallback
            var ta = document.createElement('textarea');
            ta.value = profileUrl;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            document.body.removeChild(ta);
            showQRToast('Profile link copied!');
        });
    };

    window.showQRToast = function(msg) {
        var toast = document.getElementById('qrToast');
        document.getElementById('qrToastMsg').textContent = msg;
        toast.classList.add('show');
        setTimeout(function() { toast.classList.remove('show'); }, 2500);
    };
})();

// ── Inject floaters directly on <html> so no ancestor can break position:fixed ──
(function() {
    var f = document.createElement('div');
    f.className = 'pr-floaters';
    f.style.cssText = 'position:fixed;top:0;left:0;width:100vw;height:100vh;pointer-events:none;z-index:50;overflow:hidden;';

    var leftSVGs = [
        '<svg viewBox="0 0 80 80" fill="none"><path d="M40 16L8 32l32 16 32-16L40 16z" fill="#a78bfa"/><path d="M16 38v16l24 14 24-14V38" stroke="#7c5cfc" stroke-width="2.5" fill="none" opacity="0.6"/><line x1="64" y1="32" x2="64" y2="58" stroke="#fbbf24" stroke-width="2"/><circle cx="64" cy="60" r="3" fill="#fbbf24"/></svg>',
        '<svg viewBox="0 0 70 70" fill="none"><path d="M35 18C28 14 18 14 10 16v36c8-2 18-2 25 2 7-4 17-4 25-2V16c-8-2-18-2-25 2z" fill="#6366f1" opacity="0.5"/><path d="M35 18v38" stroke="#fff" stroke-width="1.5" opacity="0.4"/></svg>',
        '<svg viewBox="0 0 70 70" fill="none"><circle cx="35" cy="30" r="16" fill="#fbbf24" opacity="0.5"/><path d="M28 42h14v4c0 3-3 5-7 5s-7-2-7-5v-4z" fill="#94a3b8" opacity="0.5"/><polyline points="30,28 35,22 40,28" stroke="#fff" stroke-width="2" fill="none" opacity="0.6" stroke-linecap="round"/></svg>',
        '<svg viewBox="0 0 60 60" fill="none"><ellipse cx="30" cy="30" rx="22" ry="8" stroke="#22d3ee" stroke-width="1.5" opacity="0.5"/><ellipse cx="30" cy="30" rx="22" ry="8" stroke="#a78bfa" stroke-width="1.5" opacity="0.5" transform="rotate(60 30 30)"/><ellipse cx="30" cy="30" rx="22" ry="8" stroke="#34d399" stroke-width="1.5" opacity="0.5" transform="rotate(120 30 30)"/><circle cx="30" cy="30" r="4" fill="#7c5cfc" opacity="0.7"/></svg>'
    ];
    var rightSVGs = [
        '<svg viewBox="0 0 70 70" fill="none"><rect x="14" y="8" width="42" height="54" rx="6" fill="#34d399" opacity="0.35"/><rect x="18" y="12" width="34" height="46" rx="4" fill="#030711" opacity="0.5"/><polyline points="24,28 28,32 36,24" stroke="#34d399" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.8"/><line x1="40" y1="28" x2="48" y2="28" stroke="#fff" stroke-width="1.5" opacity="0.3"/></svg>',
        '<svg viewBox="0 0 70 70" fill="none"><rect x="8" y="18" width="34" height="24" rx="8" fill="#3b82f6" opacity="0.5"/><circle cx="18" cy="30" r="2" fill="#fff" opacity="0.5"/><circle cx="25" cy="30" r="2" fill="#fff" opacity="0.5"/><circle cx="32" cy="30" r="2" fill="#fff" opacity="0.5"/></svg>',
        '<svg viewBox="0 0 70 70" fill="none"><path d="M22 16h26v18c0 9-6 14-13 14s-13-5-13-14V16z" fill="#fbbf24" opacity="0.45"/><rect x="30" y="48" width="10" height="6" rx="1" fill="#fbbf24" opacity="0.4"/><rect x="26" y="54" width="18" height="4" rx="2" fill="#fbbf24" opacity="0.35"/><path d="M31 26l2 4 4.5.5-3.2 3 .8 4.5L31 35.5 27 38l.8-4.5-3.2-3L29 30l2-4z" fill="#fff" opacity="0.5"/></svg>',
        '<svg viewBox="0 0 60 60" fill="none"><circle cx="30" cy="30" r="22" stroke="#ef4444" stroke-width="2" opacity="0.3"/><circle cx="30" cy="30" r="15" stroke="#f97316" stroke-width="2" opacity="0.35"/><circle cx="30" cy="30" r="8" stroke="#fbbf24" stroke-width="2" opacity="0.4"/><circle cx="30" cy="30" r="3" fill="#fbbf24" opacity="0.6"/></svg>'
    ];

    var sizes = [72, 56, 64, 48, 68, 52, 60, 50];
    var anims = [
        'prFloat1 5.5s infinite 0.2s ease-in-out',
        'prFloat2 6.8s infinite 0.6s ease-in-out',
        'prFloat3 7.2s infinite 1s ease-in-out',
        'prFloat4 6s infinite 0.4s ease-in-out',
        'prFloat5 6.2s infinite 0.3s ease-in-out',
        'prFloat6 7s infinite 0.8s ease-in-out',
        'prFloat7 5.8s infinite 0.5s ease-in-out',
        'prFloat8 6.5s infinite 1.1s ease-in-out'
    ];

    function makeCol(side, svgs, offset) {
        var col = document.createElement('div');
        col.style.cssText = 'position:absolute;top:100px;bottom:40px;width:calc((100vw - 1120px)/2 - 10px);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:50px;' + side + ':12px;';
        svgs.forEach(function(svg, i) {
            var d = document.createElement('div');
            var idx = i + offset;
            d.style.cssText = 'width:'+sizes[idx]+'px;height:'+sizes[idx]+'px;animation:'+anims[idx]+';';
            d.innerHTML = svg;
            d.querySelector('svg').style.filter = 'drop-shadow(0 4px 24px rgba(124,92,252,0.25))';
            col.appendChild(d);
        });
        return col;
    }

    f.appendChild(makeCol('left', leftSVGs, 0));
    f.appendChild(makeCol('right', rightSVGs, 4));

    // Append directly to <html> element — not body — so nothing can break position:fixed
    document.documentElement.appendChild(f);

    // Hide on narrow screens
    function checkWidth() { f.style.display = window.innerWidth < 1400 ? 'none' : ''; }
    checkWidth();
    window.addEventListener('resize', checkWidth);
})();
</script>
{% endblock %}

{% extends 'base.html.twig' %}

{% set darkPage = true %}

{% block title %}Profile - LearnAdapt{% endblock %}

{% block stylesheets %}
<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

    :root {
        --bg: #04060e;
        --purple: #7b61f1;
        --cyan: #38bdd1;
        --green: #34d399;
        --text: #f6f8fc;
        --muted: #9aa9c0;
        --glass: rgba(255,255,255,0.04);
        --glass-b: rgba(255,255,255,0.08);
        --grad: linear-gradient(135deg, #7856ed 0%, #3cc5d9 100%);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: 'Inter', sans-serif !important;
        background: var(--bg) !important;
        color: var(--text);
    }

    footer { display: none !important; }

    .p-site {
        min-height: 100vh;
        background:
            radial-gradient(1100px 700px at 80% -10%, rgba(34,211,238,0.05), transparent 62%),
            radial-gradient(900px 600px at 10% 5%, rgba(124,58,237,0.07), transparent 60%),
            var(--bg);
    }

    /* ── Brand ── */
    .p-brand {
        position: fixed; top: 20px; left: 32px; z-index: 100;
        text-decoration: none; font-size: 1.1rem; font-weight: 800;
        letter-spacing: -0.02em;
        background: linear-gradient(135deg, #a78bfa, #22d3ee);
        -webkit-background-clip: text; background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* ── Container ── */
    .p-container { max-width: 1100px; margin: 0 auto; padding: 0 32px; }

    /* ── Cover ── */
    .p-cover {
        margin-top: 86px; height: 240px; position: relative; overflow: hidden;
        background: url('https://images.unsplash.com/photo-1518709268805-4e9042af9f23?auto=format&fit=crop&w=2000&q=80') center/cover;
    }
    .p-cover.has-custom { background: none; }
    .p-cover-img { width: 100%; height: 100%; object-fit: cover; }
    .p-cover::after {
        content: ''; position: absolute; inset: 0;
        background: linear-gradient(180deg, rgba(4,6,14,0.3) 0%, rgba(4,6,14,0.85) 100%);
    }
    .p-cover-edit {
        position: absolute; bottom: 16px; right: 16px; z-index: 3;
        display: flex; align-items: center; gap: 6px;
        padding: 8px 16px; border-radius: 10px; cursor: pointer;
        background: rgba(0,0,0,0.5); backdrop-filter: blur(8px);
        border: 1px solid rgba(255,255,255,0.15);
        color: #fff; font-size: 0.78rem; font-weight: 600;
        transition: background 0.2s;
    }
    .p-cover-edit:hover { background: rgba(0,0,0,0.7); }
    .p-cover-edit input { display: none; }

    /* ── Header ── */
    .p-header {
        display: flex; gap: 24px; align-items: flex-end;
        margin-top: -52px; position: relative; z-index: 2; flex-wrap: wrap;
    }
    .p-avatar-img {
        width: 120px; height: 120px; border-radius: 24px;
        border: 3px solid rgba(255,255,255,0.1);
        box-shadow: 0 12px 32px rgba(0,0,0,0.4);
        object-fit: cover; background: rgba(255,255,255,0.05);
    }
    .p-avatar-wrap {
        position: relative; width: 120px; height: 120px; flex-shrink: 0;
    }
    .p-avatar-overlay {
        position: absolute; inset: 0; border-radius: 24px;
        display: flex; align-items: center; justify-content: center;
        background: rgba(0,0,0,0.55); opacity: 0; cursor: pointer;
        transition: opacity 0.25s; color: #fff; font-size: 1.4rem;
    }
    .p-avatar-wrap:hover .p-avatar-overlay { opacity: 1; }
    .p-avatar-overlay input { display: none; }
    .p-header-info { flex: 1; min-width: 200px; padding-bottom: 6px; }
    .p-role {
        display: inline-flex; padding: 5px 14px; border-radius: 999px;
        background: rgba(123,97,241,0.12); color: #a78bfa;
        font-size: 0.72rem; font-weight: 600; border: 1px solid rgba(123,97,241,0.2);
    }
    .p-name {
        font-size: 2rem; font-weight: 800; letter-spacing: -0.04em;
        margin-top: 10px; color: #fff;
    }
    .p-bio {
        margin-top: 8px; color: var(--muted); font-size: 0.88rem;
        line-height: 1.7; max-width: 500px;
    }

    /* ── Metrics ── */
    .p-metrics {
        display: flex; gap: 12px; margin-left: auto; flex-wrap: wrap;
        align-self: flex-end; padding-bottom: 6px;
    }
    .p-metric {
        padding: 16px 22px; border-radius: 14px;
        border: 1px solid rgba(255,255,255,0.07);
        background: rgba(255,255,255,0.03);
        text-align: center; min-width: 95px;
        backdrop-filter: blur(10px);
    }
    .p-metric strong {
        display: block; font-size: 1.5rem; font-weight: 800;
        letter-spacing: -0.03em; color: #fff;
    }
    .p-metric span {
        display: block; margin-top: 4px; font-size: 0.62rem;
        letter-spacing: 0.1em; text-transform: uppercase;
        color: rgba(154,169,192,0.7); font-weight: 700;
    }

    /* ── Cards ── */
    .p-card {
        border-radius: 18px; border: 1px solid rgba(255,255,255,0.07);
        background: linear-gradient(180deg, rgba(38,48,84,0.4), rgba(24,31,58,0.35));
        backdrop-filter: blur(14px); padding: 28px 30px;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.04), 0 16px 40px rgba(0,0,0,0.25);
    }
    .p-label {
        font-size: 0.62rem; letter-spacing: 0.13em; text-transform: uppercase;
        color: rgba(154,169,192,0.6); font-weight: 700;
    }
    .p-card h2 {
        font-size: 1.4rem; font-weight: 800; letter-spacing: -0.03em;
        margin-top: 8px; color: #fff;
    }
    .p-card p { color: rgba(255,255,255,0.55); line-height: 1.7; font-size: 0.9rem; margin-top: 10px; }

    .p-info-grid {
        display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 20px;
    }
    .p-info-tile {
        padding: 18px 20px; border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.03);
    }
    .p-info-tile .p-label { margin-bottom: 10px; }
    .p-info-tile p { font-size: 0.84rem; color: rgba(255,255,255,0.75); margin-top: 0; }
    .p-info-tile .detail { color: var(--muted); font-size: 0.82rem; margin-top: 2px; }
    .p-tag {
        display: inline-flex; padding: 6px 14px; border-radius: 999px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.05);
        font-size: 0.78rem; font-weight: 500; color: rgba(167,139,250,0.85);
    }

    /* ── Badges ── */
    .p-badge-row {
        display: flex; gap: 16px; align-items: center;
        padding: 16px 18px; border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.03);
    }
    .p-badge-icon {
        width: 48px; height: 48px; border-radius: 14px;
        background: rgba(123,97,241,0.12); border: 1px solid rgba(123,97,241,0.2);
        display: flex; align-items: center; justify-content: center;
        color: #a78bfa; flex-shrink: 0;
    }
    .p-badge-icon svg {
        width: 22px; height: 22px; fill: none; stroke: currentColor;
        stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round;
    }

    /* ── Ranking ── */
    .p-rank-row {
        display: grid; grid-template-columns: 56px 1fr auto; gap: 14px;
        align-items: center; padding: 16px 18px; border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.025);
    }
    .p-rank-badge {
        width: 48px; height: 48px; border-radius: 12px;
        background: linear-gradient(135deg, rgba(135,190,255,0.15), rgba(55,98,255,0.18));
        border: 1px solid rgba(123,97,241,0.2);
        display: flex; align-items: center; justify-content: center;
        color: #d8ebff; font-weight: 800; font-size: 0.9rem;
        box-shadow: 0 8px 20px rgba(52,98,230,0.12);
    }
    .p-rank-name { font-weight: 600; color: #fff; font-size: 0.9rem; }
    .p-rank-sub { color: rgba(255,255,255,0.45); font-size: 0.78rem; margin-top: 2px; }
    .p-rank-status { font-weight: 700; font-size: 0.82rem; color: rgba(167,139,250,0.9); }

    @media (max-width: 768px) {
        .p-header { flex-direction: column; align-items: flex-start; gap: 16px; }
        .p-metrics { margin-left: 0; width: 100%; }
        .p-info-grid { grid-template-columns: 1fr; }
    }

    .p-flash {
        padding: 12px 18px; border-radius: 12px; margin-bottom: 14px;
        font-size: 0.84rem; font-weight: 600;
    }
    .p-flash.success {
        background: rgba(52,211,153,0.12); border: 1px solid rgba(52,211,153,0.25); color: #34d399;
    }
    .p-flash.error {
        background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.25); color: #ef4444;
    }
</style>
{% endblock %}

{% block body %}
<div class="p-site">

    <div class="p-cover {{ user.banner_base64 ? 'has-custom' : '' }}">
        {% if user.banner_base64 %}
            <img src="{{ user.banner_base64 }}" alt="Banner" class="p-cover-img">
        {% endif %}
        <label class="p-cover-edit">
            <i class='bx bx-camera'></i> Change banner
            <form id="bannerForm" action="{{ path('app_profile_upload_banner') }}" method="post" enctype="multipart/form-data">
                <input type="file" name="banner" accept="image/jpeg,image/png,image/gif,image/webp" onchange="document.getElementById('bannerForm').submit()">
            </form>
        </label>
    </div>

    <div class="p-container" style="padding-top: 16px; padding-bottom: 80px;">

        {% for message in app.flashes('success') %}
            <div class="p-flash success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="p-flash error">{{ message }}</div>
        {% endfor %}

        <div class="p-header">
            <div class="p-avatar-wrap">
                <img src="{{ user.avatar_base64 ?: 'https://ui-avatars.com/api/?name=' ~ user.full_name|url_encode ~ '&size=240&background=7b61f1&color=fff&bold=true' }}" alt="{{ user.full_name }}" class="p-avatar-img">
                <label class="p-avatar-overlay">
                    <i class='bx bx-camera'></i>
                    <form id="avatarForm" action="{{ path('app_profile_upload_avatar') }}" method="post" enctype="multipart/form-data">
                        <input type="file" name="avatar" accept="image/jpeg,image/png,image/gif,image/webp" onchange="document.getElementById('avatarForm').submit()">
                    </form>
                </label>
            </div>
            <div class="p-header-info">
                <span class="p-role">{{ user.role|lower|title }}</span>
                <h1 class="p-name">{{ user.full_name }}</h1>
                {% if user.bio %}
                    <p class="p-bio">{{ user.bio }}</p>
                {% endif %}
            </div>
            <div class="p-metrics">
                <div class="p-metric"><strong>{{ user.courses|length }}</strong><span>Courses</span></div>
                <div class="p-metric"><strong>{{ user.created_at|date('Y') }}</strong><span>Joined</span></div>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1.15fr 0.85fr; gap: 18px; margin-top: 28px;">
            <div class="p-card">
                <div class="p-label">Profile overview</div>
                <h2>{{ user.full_name }}</h2>
                {% if user.bio %}
                    <p>{{ user.bio }}</p>
                {% else %}
                    <p style="color: rgba(255,255,255,0.35);">No bio yet.</p>
                {% endif %}
                <div class="p-info-grid">
                    <div class="p-info-tile">
                        <div class="p-label">Contact</div>
                        <p><strong>Email:</strong> {{ user.email }}</p>
                        {% if user.phone %}
                            <p class="detail"><strong>Phone:</strong> {{ user.phone }}</p>
                        {% endif %}
                        {% if user.location %}
                            <p class="detail"><strong>Location:</strong> {{ user.location }}</p>
                        {% endif %}
                    </div>
                    <div class="p-info-tile">
                        <div class="p-label">Account</div>
                        <p><strong>Role:</strong> {{ user.role|lower|title }}</p>
                        <p class="detail"><strong>Joined:</strong> {{ user.created_at|date('M d, Y') }}</p>
                        {% if user.last_login %}
                            <p class="detail"><strong>Last login:</strong> {{ user.last_login|date('M d, Y H:i') }}</p>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="p-card">
                <div class="p-label">Recognition</div>
                <h2>Badges and platform status</h2>
                <div style="display: grid; gap: 12px; margin-top: 18px;">
                    <div class="p-badge-row">
                        <div class="p-badge-icon">
                            <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        </div>
                        <div>
                            <div style="font-weight: 600; color: #fff; font-size: 0.9rem;">Verified operator</div>
                            <div style="color: var(--muted); font-size: 0.82rem; margin-top: 2px;">Access granted to global delivery controls and analytics.</div>
                        </div>
                    </div>
                    <div class="p-badge-row">
                        <div class="p-badge-icon">
                            <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
                        </div>
                        <div>
                            <div style="font-weight: 600; color: #fff; font-size: 0.9rem;">Top cohort score</div>
                            <div style="color: var(--muted); font-size: 0.82rem; margin-top: 2px;">Maintained excellence across five consecutive cohort launches.</div>
                        </div>
                    </div>
                    <div class="p-badge-row">
                        <div class="p-badge-icon" style="background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.08); color: var(--muted);">
                            <svg viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>
                        </div>
                        <div>
                            <div style="font-weight: 600; color: #fff; font-size: 0.9rem;">More badges coming</div>
                            <div style="color: var(--muted); font-size: 0.82rem; margin-top: 2px;">Advanced certifications will appear here as they are earned.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="p-card" style="margin-top: 18px;">
            <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px;">
                <div>
                    <div class="p-label">Performance board</div>
                    <h2>Current team ranking</h2>
                </div>
                <span style="color: var(--muted); font-size: 0.78rem;">Updated from live workspace performance</span>
            </div>
            <div style="display: grid; gap: 10px; margin-top: 20px;">
                <div class="p-rank-row">
                    <div class="p-rank-badge">#1</div>
                    <div>
                        <div class="p-rank-name">Edge Learning Team</div>
                        <div class="p-rank-sub">7210 points · 5 consecutive delivery wins</div>
                    </div>
                    <div class="p-rank-status">Top performer</div>
                </div>
                <div class="p-rank-row">
                    <div class="p-rank-badge">#2</div>
                    <div>
                        <div class="p-rank-name">Cohort Analytics Team</div>
                        <div class="p-rank-sub">6970 points · engagement score rising</div>
                    </div>
                    <div class="p-rank-status" style="color: rgba(255,255,255,0.5);">Stable</div>
                </div>
                <div class="p-rank-row">
                    <div class="p-rank-badge">#3</div>
                    <div>
                        <div class="p-rank-name">Global Launch Team</div>
                        <div class="p-rank-sub">6520 points · 1 new market added</div>
                    </div>
                    <div class="p-rank-status" style="color: rgba(255,255,255,0.5);">Growing</div>
                </div>
                <div class="p-rank-row">
                    <div class="p-rank-badge">#4</div>
                    <div>
                        <div class="p-rank-name">Experience Operations</div>
                        <div class="p-rank-sub">5875 points · automation workflows enabled</div>
                    </div>
                    <div class="p-rank-status" style="color: rgba(255,255,255,0.5);">Monitoring</div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

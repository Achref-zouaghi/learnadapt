{% extends 'base.html.twig' %}
{% set darkPage = true %}
{% block title %}Pricing – LearnAdapt{% endblock %}

{% block stylesheets %}
<style>
    @import url('https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css');
    :root {
        --bg: #04060e; --purple: #7b61f1; --cyan: #38bdd1;
        --text: #f6f8fc; --muted: #9aa9c0;
        --glass: rgba(255,255,255,0.04); --glass-b: rgba(255,255,255,0.07);
        --grad: linear-gradient(135deg,#7856ed 0%,#3cc5d9 100%);
        --green: #059669; --card: rgba(255,255,255,0.03);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif !important; background: #020a10 !important; color: var(--text); }
    footer { display: none !important; }

    .pr-wrap { max-width: 1060px; margin: 0 auto; padding: 60px 24px; }
    .pr-hero { text-align: center; margin-bottom: 48px; }
    .pr-label { font-size: 0.65rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--purple); font-weight: 700; margin-bottom: 12px; }
    .pr-title { font-size: 2.8rem; font-weight: 900; letter-spacing: -0.05em; line-height: 1.1; }
    .pr-sub { color: var(--muted); font-size: 1rem; margin-top: 14px; }

    .pr-toggle { display: flex; align-items: center; justify-content: center; gap: 12px; margin-top: 28px; margin-bottom: 48px; }
    .pr-toggle span { font-size: 0.88rem; font-weight: 600; color: var(--muted); }
    .pr-toggle span.active { color: var(--text); }
    .pr-toggle-pill {
        width: 52px; height: 30px; border-radius: 999px; background: rgba(123,97,241,0.2);
        border: 1px solid rgba(123,97,241,0.35); cursor: pointer; position: relative;
        transition: background 0.2s;
    }
    .pr-toggle-pill::after {
        content: ''; position: absolute; top: 4px; left: 4px;
        width: 20px; height: 20px; border-radius: 50%;
        background: var(--purple); transition: left 0.2s;
    }
    .pr-toggle-pill.annual::after { left: 26px; }

    .pr-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    @media (max-width: 820px) { .pr-grid { grid-template-columns: 1fr; } .pr-title { font-size: 2rem; } }

    .pr-card {
        border-radius: 20px; border: 1px solid var(--glass-b);
        background: var(--card); padding: 30px 26px;
        display: flex; flex-direction: column; transition: transform 0.2s, box-shadow 0.2s;
        position: relative; overflow: hidden;
    }
    .pr-card:hover { transform: translateY(-4px); box-shadow: 0 24px 60px rgba(0,0,0,0.4); }
    .pr-card.popular {
        border-color: rgba(123,97,241,0.5);
        background: rgba(123,97,241,0.06);
    }
    .pr-card.popular::before {
        content: '⭐ Most popular';
        position: absolute; top: 16px; right: 16px;
        font-size: 0.64rem; font-weight: 800; letter-spacing: 0.05em;
        color: var(--purple); background: rgba(123,97,241,0.15);
        padding: 4px 10px; border-radius: 999px;
        border: 1px solid rgba(123,97,241,0.25);
    }
    .pr-card-name { font-size: 1rem; font-weight: 700; color: var(--muted); margin-bottom: 16px; }
    .pr-price { font-size: 3rem; font-weight: 900; letter-spacing: -0.04em; line-height: 1; }
    .pr-price sup { font-size: 1.2rem; vertical-align: top; margin-top: 8px; }
    .pr-price-cycle { font-size: 0.8rem; color: var(--muted); margin-top: 6px; margin-bottom: 24px; }
    .pr-divider { height: 1px; background: var(--glass-b); margin-bottom: 20px; }
    .pr-features { list-style: none; flex: 1; margin-bottom: 28px; }
    .pr-features li { display: flex; align-items: center; gap: 10px; font-size: 0.87rem; color: var(--muted); padding: 6px 0; }
    .pr-features li i { font-size: 1rem; flex-shrink: 0; }
    .pr-btn {
        display: block; text-align: center; padding: 13px 20px; border-radius: 14px;
        font-size: 0.88rem; font-weight: 700; cursor: pointer;
        text-decoration: none; transition: opacity 0.2s, transform 0.15s;
        border: none; font-family: inherit;
    }
    .pr-btn:hover { opacity: 0.88; transform: scale(0.98); }
    .pr-btn-purple { background: var(--grad); color: #fff; }
    .pr-btn-outline { background: transparent; border: 1px solid var(--glass-b); color: var(--text); }
    .pr-btn-disabled { background: rgba(255,255,255,0.04); color: var(--muted); cursor: default; }
    .pr-btn-current { background: rgba(52,211,153,0.1); color: #34d399; border: 1px solid rgba(52,211,153,0.25); cursor: default; }

    .pr-save-badge {
        display: inline-block; margin-left: 8px; font-size: 0.65rem; font-weight: 800;
        background: rgba(52,211,153,0.15); color: #34d399; padding: 2px 8px;
        border-radius: 999px; border: 1px solid rgba(52,211,153,0.25);
    }
</style>
<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="pr-wrap">
    <div class="pr-hero">
        <div class="pr-label">Simple, transparent pricing</div>
        <h1 class="pr-title">Plans for every learner</h1>
        <p class="pr-sub">Start free. Upgrade anytime. Cancel whenever.</p>

        <div class="pr-toggle">
            <span id="lbl-monthly" class="active">Monthly</span>
            <div class="pr-toggle-pill" id="cycleToggle" onclick="toggleCycle()"></div>
            <span id="lbl-annual">Annual <span class="pr-save-badge">Save 20%</span></span>
        </div>
    </div>

    <div class="pr-grid">
        {% for key, plan in plans %}
        <div class="pr-card {% if plan.popular is defined and plan.popular %}popular{% endif %}">
            <div class="pr-card-name" style="color: {{ plan.color }};">{{ plan.name }}</div>

            <div class="pr-price" style="color: var(--text);">
                <sup>$</sup><span class="price-val" data-monthly="{{ plan.monthly }}" data-annual="{{ plan.annual }}">{{ plan.monthly }}</span>
            </div>
            <div class="pr-price-cycle"><span class="cycle-label">per month</span></div>
            <div class="pr-divider"></div>

            <ul class="pr-features">
                {% for feature in plan.features %}
                <li>
                    <i class='bx bx-check-circle' style="color: {{ plan.color }};"></i>
                    {{ feature }}
                </li>
                {% endfor %}
            </ul>

            {% if currentPlan == key %}
                <span class="pr-btn pr-btn-current">✓ Current plan</span>
                <form method="POST" action="{{ path('app_plan_cancel') }}" style="margin-top:10px;" onsubmit="return confirm('Cancel your subscription?')">
                    <button type="submit" style="width:100%; background:transparent; border:none; color:#f87171; font-size:0.76rem; cursor:pointer; padding:6px; font-family:inherit;">Cancel subscription</button>
                </form>
            {% elseif currentPlan != 'free' and key != currentPlan %}
                <a href="{{ path('app_checkout', {plan: key, cycle: 'monthly'}) }}" id="btn-{{ key }}" class="pr-btn pr-btn-outline">Switch to {{ plan.name }}</a>
            {% else %}
                <a href="{{ path('app_checkout', {plan: key, cycle: 'monthly'}) }}" id="btn-{{ key }}" class="pr-btn {% if plan.popular is defined and plan.popular %}pr-btn-purple{% else %}pr-btn-outline{% endif %}">Get started</a>
            {% endif %}
        </div>
        {% endfor %}
    </div>

    {% for msg in app.flashes('success') %}
    <div style="margin-top:28px; padding:14px 18px; border-radius:12px; background:rgba(52,211,153,0.1); border:1px solid rgba(52,211,153,0.25); color:#34d399; font-size:0.88rem; text-align:center;">
        <i class='bx bx-check-circle'></i> {{ msg }}
    </div>
    {% endfor %}
</div>

<script>
let isAnnual = false;

function toggleCycle() {
    isAnnual = !isAnnual;
    document.getElementById('cycleToggle').classList.toggle('annual', isAnnual);
    document.getElementById('lbl-monthly').classList.toggle('active', !isAnnual);
    document.getElementById('lbl-annual').classList.toggle('active', isAnnual);

    document.querySelectorAll('.price-val').forEach(el => {
        el.textContent = isAnnual ? el.dataset.annual : el.dataset.monthly;
    });
    document.querySelectorAll('.cycle-label').forEach(el => {
        el.textContent = isAnnual ? 'per month, billed annually' : 'per month';
    });

    const cycle = isAnnual ? 'annual' : 'monthly';
    {% for key, plan in plans %}
    const btn{{ loop.index }} = document.getElementById('btn-{{ key }}');
    if (btn{{ loop.index }}) {
        const base = btn{{ loop.index }}.href.split('/checkout/')[0];
        btn{{ loop.index }}.href = base + '/checkout/{{ key }}/' + cycle;
    }
    {% endfor %}
}
</script>
{% endblock %}

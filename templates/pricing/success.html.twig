{% extends 'base.html.twig' %}
{% set darkPage = true %}
{% block title %}Payment Successful – LearnAdapt{% endblock %}

{% block stylesheets %}
<style>
    :root {
        --purple: #7b61f1; --text: #f6f8fc; --muted: #9aa9c0;
        --glass: rgba(255,255,255,0.04); --glass-b: rgba(255,255,255,0.07);
        --green: #34d399;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif !important; background: #020a10 !important; color: var(--text); }
    footer { display: none !important; }

    .su-wrap { max-width: 520px; margin: 0 auto; padding: 80px 24px; text-align: center; }
    .su-icon {
        width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 28px;
        background: rgba(52,211,153,0.12); border: 2px solid rgba(52,211,153,0.35);
        display: flex; align-items: center; justify-content: center;
        animation: pop 0.5s cubic-bezier(0.34,1.56,0.64,1) both;
    }
    @keyframes pop { from { transform: scale(0); opacity: 0; } to { transform: scale(1); opacity: 1; } }
    .su-icon i { font-size: 2.4rem; color: var(--green); }
    .su-title { font-size: 2rem; font-weight: 900; letter-spacing: -0.04em; margin-bottom: 10px; }
    .su-sub { font-size: 0.92rem; color: var(--muted); line-height: 1.7; margin-bottom: 32px; }

    .su-card {
        border-radius: 16px; border: 1px solid var(--glass-b);
        background: var(--glass); padding: 22px 24px; text-align: left; margin-bottom: 28px;
    }
    .su-row { display: flex; justify-content: space-between; padding: 8px 0; font-size: 0.88rem; border-bottom: 1px solid var(--glass-b); }
    .su-row:last-child { border-bottom: none; }
    .su-row-label { color: var(--muted); }
    .su-row-value { font-weight: 600; color: var(--text); }

    .su-actions { display: flex; gap: 12px; justify-content: center; }
    .su-btn {
        padding: 12px 28px; border-radius: 14px; font-size: 0.88rem; font-weight: 700;
        text-decoration: none; cursor: pointer; font-family: inherit; transition: opacity 0.2s;
    }
    .su-btn-primary { background: linear-gradient(135deg,#7856ed,#3cc5d9); color: #fff; border: none; }
    .su-btn-outline { background: transparent; border: 1px solid var(--glass-b); color: var(--text); }
    .su-btn:hover { opacity: 0.85; }
</style>
<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="su-wrap">
    <div class="su-icon"><i class='bx bx-check'></i></div>

    <h1 class="su-title">Payment successful!</h1>
    <p class="su-sub">
        Welcome to the <strong>{{ planData.name }}</strong> plan!<br>
        Your account has been upgraded and all features are now unlocked.
    </p>

    <div class="su-card">
        <div class="su-row">
            <span class="su-row-label">Plan</span>
            <span class="su-row-value">{{ planData.name }}</span>
        </div>
        <div class="su-row">
            <span class="su-row-label">Billing</span>
            <span class="su-row-value">{{ cycle|capitalize }}</span>
        </div>
        <div class="su-row">
            <span class="su-row-label">Status</span>
            <span class="su-row-value" style="color:var(--green);">✓ Active</span>
        </div>
        {% if expiresAt %}
        <div class="su-row">
            <span class="su-row-label">Renews on</span>
            <span class="su-row-value">{{ expiresAt|date('M d, Y') }}</span>
        </div>
        {% endif %}
    </div>

    <div class="su-actions">
        <a href="{{ path('app_home') }}" class="su-btn su-btn-primary">Go to dashboard</a>
        <a href="{{ path('app_pricing') }}" class="su-btn su-btn-outline">Manage plan</a>
    </div>
</div>
{% endblock %}

{% extends 'base.html.twig' %}
{% set darkPage = true %}
{% block title %}Checkout – {{ planData.name }} Plan – LearnAdapt{% endblock %}

{% block stylesheets %}
<style>
    :root {
        --bg: #04060e; --purple: #7b61f1; --text: #f6f8fc; --muted: #9aa9c0;
        --glass: rgba(255,255,255,0.04); --glass-b: rgba(255,255,255,0.07);
        --grad: linear-gradient(135deg,#7856ed 0%,#3cc5d9 100%);
        --card: rgba(255,255,255,0.03); --green: #34d399;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif !important; background: #020a10 !important; color: var(--text); }
    footer { display: none !important; }

    .co-wrap { max-width: 860px; margin: 0 auto; padding: 56px 24px; }
    .co-back { display: inline-flex; align-items: center; gap: 6px; color: var(--muted); font-size: 0.85rem; text-decoration: none; margin-bottom: 32px; transition: color 0.2s; }
    .co-back:hover { color: var(--text); }
    .co-grid { display: grid; grid-template-columns: 1fr 360px; gap: 24px; }
    @media (max-width: 720px) { .co-grid { grid-template-columns: 1fr; } }

    .co-panel {
        border-radius: 20px; border: 1px solid var(--glass-b);
        background: var(--card); padding: 28px;
    }
    .co-panel h2 { font-size: 1.2rem; font-weight: 800; margin-bottom: 20px; color: var(--text); }

    /* Card selection */
    .co-card-option {
        display: flex; align-items: center; gap: 14px;
        padding: 14px 16px; border-radius: 14px;
        border: 1px solid var(--glass-b); background: var(--glass);
        margin-bottom: 10px; cursor: pointer; transition: border-color 0.2s;
    }
    .co-card-option:hover { border-color: rgba(123,97,241,0.35); }
    .co-card-option.selected { border-color: rgba(123,97,241,0.6); background: rgba(123,97,241,0.07); }
    .co-card-radio { width: 18px; height: 18px; border-radius: 50%; border: 2px solid var(--muted); flex-shrink: 0; transition: all 0.2s; display: flex; align-items: center; justify-content: center; }
    .co-card-option.selected .co-card-radio { border-color: var(--purple); background: var(--purple); }
    .co-card-option.selected .co-card-radio::after { content: ''; width: 6px; height: 6px; border-radius: 50%; background: #fff; }
    .co-card-brand { width: 44px; height: 28px; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .co-card-info { flex: 1; }
    .co-card-num { font-weight: 600; font-size: 0.9rem; color: var(--text); }
    .co-card-meta { font-size: 0.76rem; color: var(--muted); margin-top: 2px; }
    .co-default-badge { font-size: 0.64rem; font-weight: 700; background: rgba(123,97,241,0.15); color: var(--purple); padding: 2px 8px; border-radius: 999px; border: 1px solid rgba(123,97,241,0.25); }

    .co-no-card { padding: 20px; text-align: center; color: var(--muted); font-size: 0.88rem; }
    .co-add-link { color: var(--purple); text-decoration: none; font-weight: 600; }

    /* Summary panel */
    .co-summary-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid var(--glass-b); font-size: 0.88rem; }
    .co-summary-row:last-of-type { border-bottom: none; }
    .co-summary-label { color: var(--muted); }
    .co-summary-value { font-weight: 600; color: var(--text); }
    .co-total { font-size: 1.4rem; font-weight: 900; color: var(--text); }

    .co-btn {
        display: block; width: 100%; padding: 14px; border-radius: 14px;
        border: none; background: var(--grad); color: #fff;
        font-size: 0.9rem; font-weight: 700; cursor: pointer;
        font-family: inherit; transition: opacity 0.2s, transform 0.15s;
        margin-top: 20px; text-align: center;
    }
    .co-btn:hover:not(:disabled) { opacity: 0.88; transform: scale(0.98); }
    .co-btn:disabled { opacity: 0.4; cursor: not-allowed; }

    .co-secure { display: flex; align-items: center; gap: 6px; justify-content: center; margin-top: 12px; font-size: 0.74rem; color: var(--muted); }

    /* Flash */
    .co-flash-error { padding: 12px 16px; border-radius: 10px; background: rgba(248,113,113,0.1); border: 1px solid rgba(248,113,113,0.25); color: #f87171; font-size: 0.86rem; margin-bottom: 16px; }

    /* ── Animated card preview ─────────────────────────────── */
    .cc-preview-wrap {
        perspective: 1200px;
        margin-bottom: 28px;
        display: flex;
        justify-content: center;
    }
    .cc-card {
        width: 320px;
        height: 190px;
        border-radius: 20px;
        padding: 22px 24px 20px;
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        box-shadow: 0 24px 60px rgba(0,0,0,0.55), 0 4px 16px rgba(0,0,0,0.3);
        transform-style: preserve-3d;
        animation: ccFloat 4s ease-in-out infinite, ccEntry 0.55s cubic-bezier(0.22,1,0.36,1) both;
        transition: background 0.4s ease, box-shadow 0.4s ease;
        cursor: default;
        user-select: none;
    }
    @keyframes ccFloat {
        0%,100% { transform: translateY(0) rotateX(2deg); }
        50%      { transform: translateY(-7px) rotateX(-1deg); }
    }
    @keyframes ccEntry {
        from { opacity:0; transform: translateY(-30px) rotateX(25deg) scale(0.92); }
        to   { opacity:1; transform: translateY(0) rotateX(2deg) scale(1); }
    }
    @keyframes ccBrandSwap {
        0%   { opacity:0; transform: translateY(8px); }
        100% { opacity:1; transform: translateY(0); }
    }
    /* Shimmer sweep */
    .cc-shimmer {
        position: absolute;
        inset: 0;
        background: linear-gradient(115deg, transparent 30%, rgba(255,255,255,0.12) 50%, transparent 70%);
        background-size: 200% 100%;
        animation: ccShimmer 3.5s linear infinite;
        border-radius: inherit;
        pointer-events: none;
    }
    @keyframes ccShimmer {
        0%   { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }
    /* Circles pattern (decorative) */
    .cc-circles {
        position: absolute;
        top: -40px; right: -40px;
        width: 200px; height: 200px;
        border-radius: 50%;
        border: 1px solid rgba(255,255,255,0.08);
        pointer-events: none;
    }
    .cc-circles::after {
        content: '';
        position: absolute;
        inset: 30px;
        border-radius: 50%;
        border: 1px solid rgba(255,255,255,0.06);
    }
    /* Chip */
    .cc-chip {
        width: 42px; height: 30px;
        border-radius: 6px;
        background: linear-gradient(135deg, #d4af37 0%, #f5e17a 40%, #c8960c 100%);
        position: relative;
        box-shadow: 0 2px 6px rgba(0,0,0,0.3);
    }
    .cc-chip::before {
        content: '';
        position: absolute;
        inset: 6px 4px;
        border: 1px solid rgba(0,0,0,0.2);
        border-radius: 3px;
    }
    .cc-chip::after {
        content: '';
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%,-50%);
        width: 1px; height: 18px;
        background: rgba(0,0,0,0.18);
    }
    /* Card number */
    .cc-num {
        font-family: 'Courier New', monospace;
        font-size: 1.1rem;
        letter-spacing: 0.18em;
        color: rgba(255,255,255,0.9);
        text-shadow: 0 1px 4px rgba(0,0,0,0.4);
    }
    /* Bottom row */
    .cc-bottom {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
    }
    .cc-label { font-size: 0.52rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.55); margin-bottom: 3px; }
    .cc-holder { font-size: 0.78rem; font-weight: 600; color: rgba(255,255,255,0.92); letter-spacing: 0.03em; max-width: 120px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .cc-expiry { font-size: 0.82rem; font-weight: 600; color: rgba(255,255,255,0.92); }
    /* Brand logo area */
    .cc-logo {
        font-size: 1.6rem;
        font-weight: 900;
        font-style: italic;
        letter-spacing: -0.04em;
        color: rgba(255,255,255,0.95);
        text-shadow: 0 2px 8px rgba(0,0,0,0.35);
        animation: ccBrandSwap 0.3s ease both;
        line-height: 1;
    }
    .cc-logo.mc {
        font-style: normal;
        font-size: 1rem;
        letter-spacing: 0.04em;
    }
    .cc-mc-circles {
        display: flex;
        gap: -8px;
        position: relative;
        width: 40px; height: 26px;
    }
    .cc-mc-circles span {
        width: 24px; height: 24px;
        border-radius: 50%;
        position: absolute;
        top: 0;
    }
    .cc-mc-circles span:first-child { background: rgba(235,0,27,0.85); left: 0; }
    .cc-mc-circles span:last-child  { background: rgba(247,158,27,0.85); left: 14px; mix-blend-mode: screen; }
    /* Processing animation on submit */
    .cc-card.processing {
        animation: ccProcessing 0.6s ease-in-out infinite;
    }
    @keyframes ccProcessing {
        0%,100% { transform: scale(1); box-shadow: 0 24px 60px rgba(0,0,0,0.55); }
        50%      { transform: scale(1.025); box-shadow: 0 30px 80px rgba(123,97,241,0.45); }
    }
</style>
<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="co-wrap">
    <a href="{{ path('app_pricing') }}" class="co-back"><i class='bx bx-arrow-back'></i> Back to pricing</a>

    {% for msg in app.flashes('error') %}
    <div class="co-flash-error"><i class='bx bx-error-circle'></i> {{ msg }}</div>
    {% endfor %}

    <div class="co-grid">
        {# LEFT: payment method selection #}
        <form method="POST" action="{{ path('app_checkout_process', {plan: planKey, cycle: cycle}) }}" id="checkoutForm">
            <div class="co-panel">
                <h2><i class='bx bx-credit-card' style="color:var(--purple); margin-right:8px;"></i>Select payment method</h2>

                {% if paymentMethods|length > 0 %}
                {# ── Animated card preview ── #}
                <div class="cc-preview-wrap" id="ccPreviewWrap">
                    <div class="cc-card" id="ccCard">
                        <div class="cc-circles"></div>
                        <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                            <div class="cc-chip"></div>
                            <span style="font-size:0.62rem; letter-spacing:0.12em; color:rgba(255,255,255,0.5); text-transform:uppercase; margin-top:6px;">LearnAdapt</span>
                        </div>
                        <div class="cc-num" id="ccNum">•••• •••• •••• ----</div>
                        <div class="cc-bottom">
                            <div>
                                <div class="cc-label">Card Holder</div>
                                <div class="cc-holder" id="ccHolder">----</div>
                            </div>
                            <div>
                                <div class="cc-label">Expires</div>
                                <div class="cc-expiry" id="ccExpiry">--/--</div>
                            </div>
                            <div id="ccLogoWrap"></div>
                        </div>
                        <div class="cc-shimmer"></div>
                    </div>
                </div>

                    {% for card in paymentMethods %}
                    <label class="co-card-option {% if card.is_default %}selected{% endif %}" for="card_{{ card.id }}">
                        <input type="radio" name="payment_method_id" id="card_{{ card.id }}" value="{{ card.id }}"
                               {% if card.is_default %}checked{% endif %}
                               style="display:none;" onchange="syncSelection()">
                        <div class="co-card-radio"></div>
                        <div class="co-card-brand" style="background: {% if card.card_brand == 'Visa' %}linear-gradient(135deg,#1a1f71,#2d5dab){% elseif card.card_brand == 'Mastercard' %}linear-gradient(135deg,#eb001b,#f79e1b){% elseif card.card_brand == 'Amex' %}linear-gradient(135deg,#007bc1,#00a9e0){% else %}linear-gradient(135deg,#374151,#6b7280){% endif %};">
                            <span style="color:#fff; font-size:0.52rem; font-weight:800;">{{ card.card_brand|upper }}</span>
                        </div>
                        <div class="co-card-info">
                            <div class="co-card-num">•••• •••• •••• {{ card.card_last4 }}</div>
                            <div class="co-card-meta">{{ card.card_holder }} · Expires {{ card.expiry_month }}/{{ card.expiry_year }}{% if card.is_default %} &nbsp;<span class="co-default-badge">Default</span>{% endif %}</div>
                        </div>
                    </label>
                    {% endfor %}

                    <a href="{{ path('app_settings', {section: 'payment'}) }}" style="display:block; text-align:center; margin-top:12px; font-size:0.82rem; color:var(--purple); text-decoration:none;">+ Add another card</a>
                {% else %}
                    <div class="co-no-card">
                        <i class='bx bx-credit-card' style="font-size:2rem; display:block; margin-bottom:8px;"></i>
                        No saved cards yet.<br>
                        <a href="{{ path('app_settings', {section: 'payment'}) }}" class="co-add-link">Add a card in Settings →</a>
                    </div>
                {% endif %}
            </div>

            <button type="submit" class="co-btn" id="payBtn" {% if paymentMethods|length == 0 %}disabled{% endif %}>
                <i class='bx bx-lock-alt' style="margin-right:6px;"></i>
                Pay ${{ amount|number_format(2) }} now
            </button>
            <div class="co-secure"><i class='bx bx-shield-alt-2'></i> 256-bit SSL encrypted · Secure checkout</div>
        </form>

        {# RIGHT: order summary #}
        <div>
            <div class="co-panel">
                <h2>Order summary</h2>

                <div style="display:flex; align-items:center; gap:12px; margin-bottom:20px;">
                    <div style="width:44px; height:44px; border-radius:12px; background: rgba(123,97,241,0.15); display:flex; align-items:center; justify-content:center;">
                        <i class='bx bx-graduation' style="font-size:1.4rem; color:var(--purple);"></i>
                    </div>
                    <div>
                        <div style="font-weight:700; font-size:1rem; color:var(--text);">{{ planData.name }} Plan</div>
                        <div style="font-size:0.78rem; color:var(--muted);">LearnAdapt · {{ cycle|capitalize }} billing</div>
                    </div>
                </div>

                <div class="co-summary-row">
                    <span class="co-summary-label">Plan</span>
                    <span class="co-summary-value">{{ planData.name }}</span>
                </div>
                <div class="co-summary-row">
                    <span class="co-summary-label">Billing</span>
                    <span class="co-summary-value">{{ cycle|capitalize }}</span>
                </div>
                <div class="co-summary-row">
                    <span class="co-summary-label">Subtotal</span>
                    <span class="co-summary-value">${{ amount|number_format(2) }}</span>
                </div>
                <div class="co-summary-row" style="margin-top:10px; padding-top:14px; border-top:1px solid var(--glass-b); border-bottom:none;">
                    <span style="font-size:0.9rem; font-weight:700; color:var(--text);">Total due today</span>
                    <span class="co-total">${{ amount|number_format(2) }}</span>
                </div>

                <div style="margin-top:18px; padding:12px 14px; border-radius:10px; background:rgba(52,211,153,0.06); border:1px solid rgba(52,211,153,0.18); font-size:0.77rem; color:var(--muted);">
                    <i class='bx bx-check' style="color:#34d399; margin-right:4px;"></i>
                    {% if cycle == 'annual' %}
                    Billed once per year. Cancel anytime.
                    {% else %}
                    Billed monthly. Cancel anytime.
                    {% endif %}
                </div>

                <ul style="list-style:none; margin-top:18px;">
                    {% for feature in planData.features %}
                    <li style="display:flex; align-items:center; gap:8px; font-size:0.82rem; color:var(--muted); padding:5px 0;">
                        <i class='bx bx-check-circle' style="color:var(--purple); font-size:0.95rem; flex-shrink:0;"></i>{{ feature }}
                    </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </div>
</div>

<script>
// ── Card data from server ─────────────────────────────────────────────
const CARD_DATA = {
    {% for card in paymentMethods %}
    "{{ card.id }}": {
        brand:  "{{ card.card_brand }}",
        last4:  "{{ card.card_last4 }}",
        holder: "{{ card.card_holder|e('js') }}",
        month:  "{{ card.expiry_month }}",
        year:   "{{ card.expiry_year }}"
    }{{ not loop.last ? ',' : '' }}
    {% endfor %}
};

// Brand → gradient + logo HTML
const BRAND_STYLES = {
    'Visa': {
        bg: 'linear-gradient(135deg, #1a1f71 0%, #2b5bab 55%, #1e90d4 100%)',
        shadow: '0 24px 60px rgba(26,31,113,0.6), 0 4px 16px rgba(0,0,0,0.4)',
        logo: '<span class="cc-logo">VISA</span>'
    },
    'Mastercard': {
        bg: 'linear-gradient(135deg, #1c1c2e 0%, #2d2d44 100%)',
        shadow: '0 24px 60px rgba(0,0,0,0.6)',
        logo: '<div class="cc-mc-circles"><span></span><span></span></div>'
    },
    'Amex': {
        bg: 'linear-gradient(135deg, #006fcf 0%, #00a1e0 100%)',
        shadow: '0 24px 60px rgba(0,111,207,0.5)',
        logo: '<span class="cc-logo" style="font-size:0.8rem;letter-spacing:0.08em;font-style:normal">AMEX</span>'
    },
    'Discover': {
        bg: 'linear-gradient(135deg, #1a1a2e 0%, #e65c00 100%)',
        shadow: '0 24px 60px rgba(230,92,0,0.45)',
        logo: '<span class="cc-logo" style="font-size:0.75rem;letter-spacing:0.06em;font-style:normal">DISCOVER</span>'
    },
};
const DEFAULT_STYLE = {
    bg: 'linear-gradient(135deg, #1f2937 0%, #374151 100%)',
    shadow: '0 24px 60px rgba(0,0,0,0.55)',
    logo: '<span class="cc-logo" style="font-size:0.9rem;">CARD</span>'
};

function updateCardPreview(cardId) {
    const data = CARD_DATA[cardId];
    if (!data) return;
    const card   = document.getElementById('ccCard');
    const style  = BRAND_STYLES[data.brand] || DEFAULT_STYLE;

    // Update visuals
    card.style.background  = style.bg;
    card.style.boxShadow   = style.shadow;
    document.getElementById('ccNum').textContent    = '•••• •••• •••• ' + data.last4;
    document.getElementById('ccHolder').textContent = data.holder.toUpperCase();
    document.getElementById('ccExpiry').textContent = data.month + '/' + data.year;
    const logoWrap = document.getElementById('ccLogoWrap');
    logoWrap.innerHTML = style.logo;

    // Re-trigger entry animation
    card.style.animation = 'none';
    void card.offsetWidth; // reflow
    card.style.animation = 'ccFloat 4s ease-in-out infinite, ccEntry 0.45s cubic-bezier(0.22,1,0.36,1) both';
}

// Keep label highlight in sync with radio change
document.querySelectorAll('input[name="payment_method_id"]').forEach(radio => {
    radio.addEventListener('change', () => { syncSelection(); updateCardPreview(radio.value); });
});

function syncSelection() {
    document.querySelectorAll('.co-card-option').forEach(opt => opt.classList.remove('selected'));
    const checked = document.querySelector('input[name="payment_method_id"]:checked');
    if (checked) checked.closest('.co-card-option').classList.add('selected');
}

// Clicking label selects radio
document.querySelectorAll('.co-card-option').forEach(opt => {
    opt.addEventListener('click', () => {
        const radio = opt.querySelector('input[type="radio"]');
        if (radio) { radio.checked = true; syncSelection(); updateCardPreview(radio.value); }
    });
});

// Init preview with default-selected card
const initChecked = document.querySelector('input[name="payment_method_id"]:checked');
if (initChecked) updateCardPreview(initChecked.value);

// Processing animation on submit
document.getElementById('checkoutForm').addEventListener('submit', () => {
    const card = document.getElementById('ccCard');
    if (card) {
        card.style.animation = 'ccProcessing 0.6s ease-in-out infinite';
        document.getElementById('ccNum').textContent = '•••• •••• •••• ····';
    }
});
</script>
{% endblock %}

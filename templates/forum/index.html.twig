<script>
/* Toast system */
(function(){
    var container = document.createElement('div');
    container.className = 'toast-container';
    document.body.appendChild(container);
    window.showToast = function(msg, type) {
        type = type || 'error';
        var icons = {error:'<i class="bx bx-error-circle"></i>',success:'<i class="bx bx-check-circle"></i>',warn:'<i class="bx bx-shield-x"></i>'};
        var titles = {error:'Error',success:'Success',warn:'Warning'};
        var toast = document.createElement('div');
        toast.className = 'toast';
        toast.style.position = 'relative';
        toast.style.overflow = 'hidden';
        toast.innerHTML = '<div class="toast-icon '+type+'">'+icons[type]+'</div>'+
            '<div class="toast-body"><div class="toast-title '+type+'">'+titles[type]+'</div><div class="toast-msg">'+msg+'</div></div>'+
            '<button class="toast-close"><i class="bx bx-x"></i></button>'+
            '<div class="toast-progress" style="width:100%"></div>';
        container.appendChild(toast);
        var progress = toast.querySelector('.toast-progress');
        var duration = 5000;
        setTimeout(function(){ toast.classList.add('show'); }, 10);
        progress.style.transitionDuration = duration + 'ms';
        setTimeout(function(){ progress.style.width = '0%'; }, 50);
        var autoClose = setTimeout(function(){ dismissToast(toast); }, duration);
        toast.querySelector('.toast-close').addEventListener('click', function(){ clearTimeout(autoClose); dismissToast(toast); });
        function dismissToast(t){ t.classList.remove('show'); t.classList.add('hide'); setTimeout(function(){ t.remove(); }, 400); }
    };
})();

/* Show textarea on title focus */
document.getElementById('topicTitleInput').addEventListener('focus', function() {
    document.getElementById('topicContent').style.display = 'block';
});

/* Composer emoji */
var composerEmojiBox = document.getElementById('composerEmojiBox');
var emojiCodes = [0x1F600, 0x1F60D, 0x1F525, 0x1F44D, 0x1F44F, 0x1F3AF, 0x1F4A1, 0x1F680, 0x2764, 0x1F602, 0x1F91D, 0x1F389, 0x1F60E, 0x1F914, 0x1F4AA, 0x2705, 0x1F31F, 0x1F4DD];
emojiCodes.forEach(function(code) {
    var emoji = String.fromCodePoint(code);
    var btn = document.createElement('button');
    btn.type = 'button'; btn.className = 'emoji-btn'; btn.textContent = emoji;
    btn.addEventListener('click', function() {
        var ta = document.getElementById('topicContent');
        ta.style.display = 'block';
        var start = ta.selectionStart || 0, end = ta.selectionEnd || 0;
        ta.value = ta.value.slice(0, start) + emoji + ta.value.slice(end);
        ta.focus(); ta.setSelectionRange(start + emoji.length, start + emoji.length);
    });
    composerEmojiBox.appendChild(btn);
});
document.getElementById('composerEmojiBtn').addEventListener('click', function() {
    composerEmojiBox.classList.toggle('open');
});

/* File accumulation with previews */
var cPhoto = document.getElementById('composerPhoto');
var cVideo = document.getElementById('composerVideo');
var cHint = document.getElementById('composerFileHint');
var cPreviews = document.getElementById('composerPreviews');
var pendingFiles = []; // {file, isImage, blobUrl}

function addFiles(fileList, isImage) {
    for (var i = 0; i < fileList.length; i++) {
        if (pendingFiles.length >= 10) break;
        var f = fileList[i];
        // Avoid duplicate by name+size
        var dup = pendingFiles.some(function(p) { return p.file.name === f.name && p.file.size === f.size; });
        if (dup) continue;
        pendingFiles.push({file: f, isImage: isImage, blobUrl: URL.createObjectURL(f)});
    }
    renderPreviews();
}

function removeFile(idx) {
    if (pendingFiles[idx]) URL.revokeObjectURL(pendingFiles[idx].blobUrl);
    pendingFiles.splice(idx, 1);
    renderPreviews();
}

function renderPreviews() {
    cPreviews.innerHTML = '';
    var photoCount = 0, videoCount = 0;
    pendingFiles.forEach(function(item, idx) {
        if (item.isImage) photoCount++; else videoCount++;
        var div = document.createElement('div');
        div.className = 'preview-item';
        if (item.isImage) {
            var img = document.createElement('img');
            img.src = item.blobUrl;
            img.alt = '';
            div.appendChild(img);
        } else {
            var vid = document.createElement('video');
            vid.src = item.blobUrl;
            vid.muted = true;
            vid.style.width = '90px'; vid.style.height = '90px'; vid.style.objectFit = 'cover'; vid.style.display = 'block';
            div.appendChild(vid);
        }
        var badge = document.createElement('span');
        badge.className = 'preview-badge ' + (item.isImage ? 'img-badge' : 'vid-badge');
        badge.textContent = item.isImage ? 'IMG' : 'VID';
        div.appendChild(badge);
        var rm = document.createElement('button');
        rm.type = 'button'; rm.className = 'preview-remove'; rm.innerHTML = '<i class="bx bx-x"></i>';
        rm.addEventListener('click', (function(i) { return function() { removeFile(i); }; })(idx));
        div.appendChild(rm);
        cPreviews.appendChild(div);
    });
    // Update hint
    var total = pendingFiles.length;
    if (total > 10) { cHint.textContent = 'Max 10 files allowed.'; cHint.style.display = 'block'; cHint.style.color = '#dc2626'; return; }
    var parts = [];
    if (photoCount) parts.push(photoCount + ' photo' + (photoCount > 1 ? 's' : ''));
    if (videoCount) parts.push(videoCount + ' vidéo' + (videoCount > 1 ? 's' : ''));
    if (parts.length) { cHint.textContent = parts.join(' + ') + ' — ' + total + '/10'; cHint.style.display = 'block'; cHint.style.color = ''; }
    else { cHint.style.display = 'none'; }
    // Sync hidden file inputs for form submission
    syncFormFiles();
}

function syncFormFiles() {
    // Remove old hidden inputs
    document.querySelectorAll('#newTopicForm input[name="photos[]"], #newTopicForm input[name="videos[]"]').forEach(function(el) { el.remove(); });
    var photoDT = new DataTransfer();
    var videoDT = new DataTransfer();
    pendingFiles.forEach(function(item) {
        if (item.isImage) photoDT.items.add(item.file);
        else videoDT.items.add(item.file);
    });
    if (photoDT.files.length) {
        var pi = document.createElement('input'); pi.type = 'file'; pi.name = 'photos[]'; pi.multiple = true; pi.style.display = 'none'; pi.files = photoDT.files;
        document.getElementById('newTopicForm').appendChild(pi);
    }
    if (videoDT.files.length) {
        var vi = document.createElement('input'); vi.type = 'file'; vi.name = 'videos[]'; vi.multiple = true; vi.style.display = 'none'; vi.files = videoDT.files;
        document.getElementById('newTopicForm').appendChild(vi);
    }
}

cPhoto.addEventListener('change', function() { addFiles(this.files, true); this.value = ''; });
cVideo.addEventListener('change', function() { addFiles(this.files, false); this.value = ''; });

/* Edit topic modal */
function openEditTopic(id, title, category) {
    document.getElementById('editTopicForm').action = '/forum/topic/' + id + '/edit';
    document.getElementById('editTopicTitle').value = title;
    document.getElementById('editTopicCategory').value = category;
    document.getElementById('editTopicModal').classList.add('open');
}
document.getElementById('editTopicModal').addEventListener('click', function(e) {
    if (e.target === this) this.classList.remove('open');
});

/* Close menus on outside click */
document.addEventListener('click', function(e) {
    if (!e.target.closest('.feed-dots') && !e.target.closest('.feed-dots + div')) {
        document.querySelectorAll('.feed-dots + div').forEach(function(d) { d.style.display = 'none'; });
    }
});

/* Flash auto-dismiss */
document.querySelectorAll('.flash').forEach(function(el) {
    setTimeout(function() { el.style.opacity = '0'; el.style.transform = 'translateX(20px)'; el.style.transition = 'all .4s'; setTimeout(function(){ el.remove(); }, 400); }, 4500);
});

/* ═══════════════════════════════════════════
   LIKE BUTTON (on forum index cards)
   ═══════════════════════════════════════════ */
document.querySelectorAll('.like-btn').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
        e.preventDefault();
        var postId = this.dataset.postId;
        if (!postId) return;
        var button = this;
        fetch('/forum/post/' + postId + '/react', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({type: 'like'})
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            var icon = button.querySelector('i');
            var countEl = button.querySelector('.like-count');
            if (data.userReaction === 'like') {
                button.classList.add('liked');
                icon.className = 'bx bxs-like';
            } else {
                button.classList.remove('liked');
                icon.className = 'bx bx-like';
            }
            countEl.textContent = data.likes > 0 ? data.likes : '';
        });
    });
});

/* ═══════════════════════════════════════════
   COMMENT MODAL
   ═══════════════════════════════════════════ */
var currentTopicId = null;
var replyToPostId = null;
var commentModalEl = document.getElementById('commentModal');
var commentListEl = document.getElementById('commentList');
var commentInputEl = document.getElementById('commentInput');
var commentSendBtn = document.getElementById('commentSendBtn');
var replyIndicator = document.getElementById('replyIndicator');
var replyToNameEl = document.getElementById('replyToName');

// Open comment modal
document.querySelectorAll('.comment-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
        currentTopicId = this.dataset.topicId;
        var title = this.dataset.topicTitle || 'Commentaires';
        document.getElementById('commentModalTitle').textContent = title;
        commentModalEl.classList.add('open');
        cancelReply();
        loadComments(currentTopicId);
        commentInputEl.focus();
    });
});

// Close on background click
commentModalEl.addEventListener('click', function(e) {
    if (e.target === this) this.classList.remove('open');
});

// Load comments
function loadComments(topicId) {
    commentListEl.innerHTML = '<div style="text-align:center;padding:30px;color:var(--muted)"><i class="bx bx-loader-alt bx-spin" style="font-size:1.5rem"></i></div>';
    fetch('/forum/topic/' + topicId + '/comments')
        .then(function(r) { return r.json(); })
        .then(function(data) {
            renderComments(data.posts || [], data.currentUserId);
        })
        .catch(function() {
            commentListEl.innerHTML = '<div class="cmt-empty"><i class="bx bx-error-circle"></i><p>Erreur de chargement</p></div>';
        });
}

function renderComments(posts, currentUserId) {
    if (posts.length === 0) {
        commentListEl.innerHTML = '<div class="cmt-empty"><i class="bx bx-message-rounded-dots"></i><p>Aucun commentaire. Soyez le premier !</p></div>';
        return;
    }
    // Build a map of posts and their replies
    var topLevel = [];
    var repliesMap = {};
    posts.forEach(function(p) {
        if (p.parent_post_id) {
            if (!repliesMap[p.parent_post_id]) repliesMap[p.parent_post_id] = [];
            repliesMap[p.parent_post_id].push(p);
        } else {
            topLevel.push(p);
        }
    });

    var html = '';
    topLevel.forEach(function(p) {
        html += renderSingleComment(p, repliesMap, 0);
    });
    commentListEl.innerHTML = html;
    bindCommentActions();
}

function renderSingleComment(post, repliesMap, depth) {
    var roleClass = (post.author_role || '').toLowerCase();
    if (['student','expert','teacher','admin'].indexOf(roleClass) === -1) roleClass = 'student';
    var timeStr = formatTimeAgo(post.created_at);

    var html = '<div class="cmt-item" data-post-id="' + post.id + '">';
    html += '<div class="cmt-head">';
    html += '<img src="' + escHtml(post.author_avatar) + '" alt="">';
    html += '<div style="flex:1;min-width:0">';
    html += '<span class="cmt-author">' + escHtml(post.author_name) + '</span> ';
    html += '<span class="cmt-role role-badge ' + roleClass + '">' + escHtml(post.author_role || 'User') + '</span>';
    html += '<div class="cmt-time">' + timeStr + '</div>';
    html += '</div></div>';

    if (post.parent_post_id) {
        html += '<div class="cmt-reply-indicator"><i class="bx bx-reply"></i> réponse</div>';
    }
    html += '<div class="cmt-content">' + escHtml(post.content) + '</div>';

    html += '<div class="cmt-actions">';
    html += '<button type="button" class="cmt-action-btn cmt-like-btn ' + (post.user_reaction === 'like' ? 'active-like' : '') + '" data-post-id="' + post.id + '" data-type="like"><i class="bx ' + (post.user_reaction === 'like' ? 'bxs-like' : 'bx-like') + '"></i> <span>' + (post.like_count > 0 ? post.like_count : '') + '</span></button>';
    html += '<button type="button" class="cmt-action-btn cmt-dislike-btn ' + (post.user_reaction === 'dislike' ? 'active-dislike' : '') + '" data-post-id="' + post.id + '" data-type="dislike"><i class="bx ' + (post.user_reaction === 'dislike' ? 'bxs-dislike' : 'bx-dislike') + '"></i> <span>' + (post.dislike_count > 0 ? post.dislike_count : '') + '</span></button>';
    html += '<button type="button" class="cmt-action-btn cmt-reply-btn" data-post-id="' + post.id + '" data-author="' + escHtml(post.author_name) + '"><i class="bx bx-reply"></i> Répondre</button>';
    html += '</div>';

    // Render replies
    var replies = repliesMap[post.id] || [];
    if (replies.length > 0) {
        html += '<div class="cmt-replies">';
        replies.forEach(function(r) {
            html += renderSingleComment(r, repliesMap, depth + 1);
        });
        html += '</div>';
    }

    html += '</div>';
    return html;
}

function bindCommentActions() {
    // Like/dislike buttons in comments
    commentListEl.querySelectorAll('.cmt-like-btn, .cmt-dislike-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var postId = this.dataset.postId;
            var type = this.dataset.type;
            var button = this;
            var item = button.closest('.cmt-item');
            fetch('/forum/post/' + postId + '/react', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({type: type})
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var likeBtn = item.querySelector('.cmt-like-btn[data-post-id="' + postId + '"]');
                var dislikeBtn = item.querySelector('.cmt-dislike-btn[data-post-id="' + postId + '"]');
                if (likeBtn) {
                    likeBtn.classList.toggle('active-like', data.userReaction === 'like');
                    likeBtn.querySelector('i').className = 'bx ' + (data.userReaction === 'like' ? 'bxs-like' : 'bx-like');
                    likeBtn.querySelector('span').textContent = data.likes > 0 ? data.likes : '';
                }
                if (dislikeBtn) {
                    dislikeBtn.classList.toggle('active-dislike', data.userReaction === 'dislike');
                    dislikeBtn.querySelector('i').className = 'bx ' + (data.userReaction === 'dislike' ? 'bxs-dislike' : 'bx-dislike');
                    dislikeBtn.querySelector('span').textContent = data.dislikes > 0 ? data.dislikes : '';
                }
            });
        });
    });

    // Reply buttons
    commentListEl.querySelectorAll('.cmt-reply-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            replyToPostId = parseInt(this.dataset.postId);
            replyToNameEl.textContent = 'Répondre à ' + this.dataset.author;
            replyIndicator.style.display = 'flex';
            commentInputEl.focus();
        });
    });
}

function cancelReply() {
    replyToPostId = null;
    replyIndicator.style.display = 'none';
    replyToNameEl.textContent = '';
}

// Send comment
commentSendBtn.addEventListener('click', sendComment);
commentInputEl.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendComment();
    }
});

function sendComment() {
    var content = commentInputEl.value.trim();
    if (!content || !currentTopicId) return;
    commentSendBtn.disabled = true;
    var payload = {content: content};
    if (replyToPostId) payload.parent_post_id = replyToPostId;

    fetch('/forum/topic/' + currentTopicId + '/comment', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(payload)
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.success) {
            commentInputEl.value = '';
            cancelReply();
            loadComments(currentTopicId);
            // Update comment count on the card
            var cardBtn = document.querySelector('.comment-btn[data-topic-id="' + currentTopicId + '"]');
            if (cardBtn) {
                var feedCard = cardBtn.closest('.feed-card');
                if (feedCard) {
                    var replySpan = feedCard.querySelector('.reaction-summary span[style*="margin-left"]');
                    if (replySpan) {
                        var num = parseInt(replySpan.textContent) || 0;
                        replySpan.textContent = (num + 1) + ' réponses';
                    }
                }
            }
        } else {
            showToast(data.error || 'Erreur', 'warn');
        }
    })
    .catch(function() { showToast('Erreur réseau'); })
    .finally(function() { commentSendBtn.disabled = false; });
}

// Helpers
function escHtml(str) {
    if (!str) return '';
    var d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
}

function formatTimeAgo(dateStr) {
    if (!dateStr) return '';
    var d = new Date(dateStr.replace(' ', 'T'));
    var now = new Date();
    var diff = Math.floor((now - d) / 1000);
    if (diff < 60) return 'à l\'instant';
    if (diff < 3600) return Math.floor(diff / 60) + ' min';
    if (diff < 86400) return Math.floor(diff / 3600) + ' h';
    if (diff < 2592000) return Math.floor(diff / 86400) + ' j';
    return d.toLocaleDateString('fr-FR', {day: 'numeric', month: 'short', year: 'numeric'});
}

/* ═══════════════════════════════════════════
   LIGHTBOX (full-page image viewer)
   ═══════════════════════════════════════════ */
var lightboxEl = document.getElementById('lightbox');
var lightboxImgEl = document.getElementById('lightboxImg');
var lightboxCounterEl = document.getElementById('lightboxCounter');
var lightboxImages = [];
var lightboxIndex = 0;

document.addEventListener('click', function(e) {
    var trigger = e.target.closest('.lightbox-trigger');
    if (!trigger) return;
    e.preventDefault();
    // Collect all images in the same media grid
    var grid = trigger.closest('.feed-media-grid') || trigger.closest('.feed-media');
    if (grid) {
        lightboxImages = Array.from(grid.querySelectorAll('.lightbox-trigger')).map(function(img) { return img.src; });
        lightboxIndex = lightboxImages.indexOf(trigger.src);
    } else {
        lightboxImages = [trigger.src];
        lightboxIndex = 0;
    }
    if (lightboxIndex < 0) lightboxIndex = 0;
    showLightbox();
});

function showLightbox() {
    lightboxImgEl.src = lightboxImages[lightboxIndex];
    lightboxCounterEl.textContent = lightboxImages.length > 1 ? (lightboxIndex + 1) + ' / ' + lightboxImages.length : '';
    document.querySelector('.lightbox-prev').style.display = lightboxImages.length > 1 ? '' : 'none';
    document.querySelector('.lightbox-next').style.display = lightboxImages.length > 1 ? '' : 'none';
    lightboxEl.classList.add('open');
    document.body.style.overflow = 'hidden';
}

function closeLightbox() {
    lightboxEl.classList.remove('open');
    document.body.style.overflow = '';
    lightboxImgEl.src = '';
}

function lightboxNav(dir) {
    lightboxIndex = (lightboxIndex + dir + lightboxImages.length) % lightboxImages.length;
    lightboxImgEl.src = lightboxImages[lightboxIndex];
    lightboxCounterEl.textContent = (lightboxIndex + 1) + ' / ' + lightboxImages.length;
}

lightboxEl.addEventListener('click', function(e) {
    if (e.target === this) closeLightbox();
});

document.addEventListener('keydown', function(e) {
    if (!lightboxEl.classList.contains('open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') lightboxNav(-1);
    if (e.key === 'ArrowRight') lightboxNav(1);
});

/* ═══════════════════════════════════════════
   SHARE / SEND TO FRIEND
   ═══════════════════════════════════════════ */
var shareModal = document.getElementById('shareModal');
var shareList = document.getElementById('shareList');
var shareSearchInput = document.getElementById('shareSearchInput');
var shareTopicId = null;
var shareTopicTitle = '';
var shareFriendsCache = null;

document.querySelectorAll('.share-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
        shareTopicId = this.dataset.topicId;
        shareTopicTitle = this.dataset.topicTitle || '';
        shareSearchInput.value = '';
        shareModal.classList.add('open');
        loadFriends();
    });
});

shareModal.addEventListener('click', function(e) {
    if (e.target === this) this.classList.remove('open');
});

function loadFriends() {
    if (shareFriendsCache) {
        renderFriends(shareFriendsCache);
        return;
    }
    shareList.innerHTML = '<div style="text-align:center;padding:30px;color:var(--muted)"><i class="bx bx-loader-alt bx-spin" style="font-size:1.5rem"></i></div>';
    fetch('/chat/contacts')
        .then(function(r) { return r.json(); })
        .then(function(data) {
            shareFriendsCache = data.friends || [];
            renderFriends(shareFriendsCache);
        })
        .catch(function() {
            shareList.innerHTML = '<div class="share-empty">Erreur de chargement</div>';
        });
}

function renderFriends(friends) {
    var query = shareSearchInput.value.trim().toLowerCase();
    var filtered = friends;
    if (query) {
        filtered = friends.filter(function(f) { return f.full_name.toLowerCase().indexOf(query) !== -1; });
    }
    if (filtered.length === 0) {
        shareList.innerHTML = '<div class="share-empty"><i class="bx bx-user-x" style="font-size:2rem;color:rgba(255,255,255,0.08);display:block;margin-bottom:8px"></i>' + (query ? 'Aucun ami trouvé' : 'Pas encore d\'amis') + '</div>';
        return;
    }
    var html = '';
    filtered.forEach(function(f) {
        var avatar = f.avatar_base64 || ('https://ui-avatars.com/api/?name=' + encodeURIComponent(f.full_name) + '&size=76&background=e2e8f0&color=0f172a&bold=true&format=svg');
        html += '<div class="share-friend" data-friend-id="' + f.id + '">';
        html += '<img src="' + escHtml(avatar) + '" alt="">';
        html += '<div style="flex:1;min-width:0"><div class="share-friend-name">' + escHtml(f.full_name) + '</div><div class="share-friend-role">' + escHtml(f.role || 'Membre') + '</div></div>';
        html += '<button type="button" class="share-send-btn" data-friend-id="' + f.id + '"><i class="bx bx-send"></i> Envoyer</button>';
        html += '</div>';
    });
    shareList.innerHTML = html;
    bindShareSendButtons();
}

shareSearchInput.addEventListener('input', function() {
    if (shareFriendsCache) renderFriends(shareFriendsCache);
});

function bindShareSendButtons() {
    shareList.querySelectorAll('.share-send-btn').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var friendId = this.dataset.friendId;
            var button = this;
            if (button.classList.contains('sent')) return;
            button.disabled = true;
            var url = window.location.origin + '/forum/topic/' + shareTopicId;
            var message = '📌 Je te partage ce topic : "' + shareTopicTitle + '"\n' + url;
            fetch('/chat/send', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({receiver_id: parseInt(friendId), content: message})
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.error) {
                    showToast(data.error, 'warn');
                    button.disabled = false;
                } else {
                    button.classList.add('sent');
                    button.innerHTML = '<i class="bx bx-check"></i> Envoyé';
                }
            })
            .catch(function() { showToast('Erreur réseau'); button.disabled = false; });
        });
    });
}
</script>

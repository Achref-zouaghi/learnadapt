{% extends 'base.html.twig' %}
{% set darkPage = true %}
{% block title %}Forum — LearnAdapt{% endblock %}

{% block stylesheets %}
<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

:root{--bg:#04060e;--purple:#7b61f1;--purple-soft:#a78bfa;--cyan:#38bdd1;--green:#34d399;--red:#f87171;--orange:#fb923c;--yellow:#fbbf24;--text:#f6f8fc;--muted:#8896ab;--glass:rgba(255,255,255,0.035);--card:rgba(255,255,255,0.025);--card-h:rgba(255,255,255,0.05);--border:rgba(255,255,255,0.06);--shadow:0 4px 24px rgba(0,0,0,0.3)}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',sans-serif!important;background:#020a10!important;color:var(--text)}
footer{display:none!important}

.fm{min-height:100vh;padding:100px 0 60px;background:transparent;position:relative;z-index:1}
.fm-wrap{max-width:1120px;margin:0 auto;padding:0 32px}

/* ── Entrance Animations ── */
@keyframes fmSlideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes fmCardFade{from{opacity:0;transform:translateY(8px) scale(0.98)}to{opacity:1;transform:translateY(0) scale(1)}}

/* ── Header ── */
.fm-head{display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:28px;animation:fmSlideUp .5s ease-out}
.fm-head h1{font-size:1.85rem;font-weight:900;letter-spacing:-0.03em;background:linear-gradient(135deg,var(--purple),var(--cyan));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
.fm-head p{color:var(--muted);font-size:0.84rem;margin-top:4px}
.fm-new-btn{display:inline-flex;align-items:center;gap:8px;padding:11px 24px;background:linear-gradient(135deg,var(--purple),#9b7bf7);border:none;border-radius:12px;color:#fff;font-weight:700;font-size:0.84rem;cursor:pointer;transition:all .2s ease;box-shadow:0 4px 20px rgba(123,97,241,0.3);font-family:inherit}
.fm-new-btn:hover{transform:translateY(-1px);box-shadow:0 6px 28px rgba(123,97,241,0.4)}
.fm-new-btn i{font-size:1.1rem}

/* ── Stats Bar ── */
.fm-stats{display:flex;gap:12px;margin-bottom:28px;flex-wrap:wrap;animation:fmSlideUp .5s ease-out .05s backwards}
.fm-st{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px 22px;min-width:120px;backdrop-filter:blur(12px);transition:all .2s ease}
.fm-st:hover{background:var(--card-h);border-color:rgba(123,97,241,0.15);transform:translateY(-1px)}
.fm-st-v{font-size:1.5rem;font-weight:900;letter-spacing:-0.02em}
.fm-st-l{font-size:0.68rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;margin-top:2px}

/* ── Filter Bar ── */
.fm-filters{display:flex;align-items:center;gap:10px;margin-bottom:20px;flex-wrap:wrap;animation:fmSlideUp .5s ease-out .1s backwards}
.fm-filter-btn{padding:8px 16px;border-radius:10px;font-size:0.72rem;font-weight:700;cursor:pointer;border:1px solid var(--border);background:var(--card);color:var(--muted);transition:all .2s;font-family:inherit;text-transform:uppercase;letter-spacing:0.04em}
.fm-filter-btn:hover{border-color:rgba(123,97,241,0.2);color:var(--purple)}
.fm-filter-btn.active{background:linear-gradient(135deg,rgba(123,97,241,0.15),rgba(56,189,209,0.08));border-color:rgba(123,97,241,0.3);color:var(--purple-soft)}
.fm-search{flex:1;min-width:200px;max-width:320px;margin-left:auto}
.fm-search input{width:100%;padding:10px 14px 10px 38px;background:var(--card);border:1px solid var(--border);border-radius:12px;color:var(--text);font-size:0.84rem;font-family:inherit;transition:border-color .2s;outline:none}
.fm-search input:focus{border-color:rgba(123,97,241,0.3)}
.fm-search{position:relative}
.fm-search i{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:1rem}

/* ── Topic Cards ── */
.fm-topics{display:grid;gap:12px}
.fm-topic{background:var(--glass);border:1px solid var(--border);border-radius:18px;padding:22px 26px;backdrop-filter:blur(14px);position:relative;overflow:hidden;transition:all .22s ease;animation:fmCardFade .4s ease-out backwards;cursor:pointer;text-decoration:none;display:block;color:inherit}
.fm-topic::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;z-index:2}
.fm-topic::after{content:'';position:absolute;top:0;left:-100%;width:50%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.02),transparent);transition:left .5s ease;pointer-events:none}
.fm-topic:hover{border-color:rgba(123,97,241,0.18);transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,0,0,0.15)}
.fm-topic:hover::after{left:100%}

/* Category colors */
.fm-topic.cat-GENERAL::before{background:linear-gradient(90deg,#3b82f6,#60a5fa)}
.fm-topic.cat-ADVICE::before{background:linear-gradient(90deg,var(--green),#6ee7b7)}
.fm-topic.cat-DIFFICULTIES::before{background:linear-gradient(90deg,var(--orange),var(--yellow))}
.fm-topic.cat-APP_HELP::before{background:linear-gradient(90deg,var(--purple),var(--purple-soft))}
.fm-topic.cat-SUCCESS_STORY::before{background:linear-gradient(90deg,var(--cyan),#67e8f9)}

.fm-topic-head{display:flex;align-items:flex-start;gap:14px}
.fm-topic-avatar{width:44px;height:44px;border-radius:14px;object-fit:cover;border:2px solid rgba(123,97,241,0.15);flex-shrink:0;background:rgba(255,255,255,0.03)}
.fm-topic-info{flex:1;min-width:0}
.fm-topic-title{font-size:1rem;font-weight:800;color:#fff;letter-spacing:-0.01em;margin-bottom:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.fm-topic-meta{display:flex;align-items:center;gap:12px;font-size:0.72rem;color:var(--muted);flex-wrap:wrap}
.fm-topic-meta span{display:inline-flex;align-items:center;gap:4px}
.fm-topic-meta i{font-size:0.85rem}
.fm-cat-tag{display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:8px;font-size:0.6rem;font-weight:800;text-transform:uppercase;letter-spacing:0.06em;border:1px solid}

.fm-cat-tag.cat-GENERAL{background:rgba(59,130,246,0.1);color:#60a5fa;border-color:rgba(59,130,246,0.08)}
.fm-cat-tag.cat-ADVICE{background:rgba(52,211,153,0.1);color:var(--green);border-color:rgba(52,211,153,0.08)}
.fm-cat-tag.cat-DIFFICULTIES{background:rgba(251,146,60,0.1);color:var(--orange);border-color:rgba(251,146,60,0.08)}
.fm-cat-tag.cat-APP_HELP{background:rgba(123,97,241,0.1);color:var(--purple-soft);border-color:rgba(123,97,241,0.08)}
.fm-cat-tag.cat-SUCCESS_STORY{background:rgba(56,189,209,0.1);color:var(--cyan);border-color:rgba(56,189,209,0.08)}

.fm-topic-right{display:flex;flex-direction:column;align-items:flex-end;gap:6px;flex-shrink:0;margin-left:16px}
.fm-reply-count{display:inline-flex;align-items:center;gap:5px;padding:6px 12px;border-radius:10px;background:rgba(123,97,241,0.08);border:1px solid rgba(123,97,241,0.12);color:var(--purple-soft);font-size:0.72rem;font-weight:800}
.fm-reply-count i{font-size:0.9rem}
.fm-topic-time{font-size:0.66rem;color:rgba(148,163,184,0.5);font-weight:600}

/* ── Closed badge ── */
.fm-closed{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:8px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.08);color:var(--red);font-size:0.6rem;font-weight:800;text-transform:uppercase}

/* ── Empty state ── */
.fm-empty{text-align:center;padding:60px 20px;color:var(--muted)}
.fm-empty i{font-size:3.5rem;color:rgba(255,255,255,0.08);display:block;margin-bottom:16px}
.fm-empty p{font-size:0.88rem}

/* ── Modal ── */
.fm-modal-bg{position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.6);backdrop-filter:blur(6px);display:none;align-items:center;justify-content:center;padding:20px}
.fm-modal-bg.open{display:flex}
.fm-modal{background:rgba(10,14,26,0.95);border:1px solid var(--border);border-radius:22px;padding:32px;width:100%;max-width:520px;backdrop-filter:blur(20px);box-shadow:0 40px 100px rgba(0,0,0,0.5),0 0 40px rgba(123,97,241,0.06)}
.fm-modal h2{font-size:1.2rem;font-weight:900;color:#fff;margin-bottom:4px;background:linear-gradient(135deg,var(--purple),var(--cyan));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;display:inline-block}
.fm-modal p.sub{font-size:0.82rem;color:var(--muted);margin-bottom:20px}
.fm-modal label{display:block;font-size:0.72rem;font-weight:700;color:var(--muted);margin-bottom:5px;text-transform:uppercase;letter-spacing:0.06em}
.fm-modal input,.fm-modal select,.fm-modal textarea{width:100%;padding:11px 14px;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:12px;color:var(--text);font-size:0.86rem;margin-bottom:14px;transition:border-color .2s;font-family:inherit;outline:none}
.fm-modal input:focus,.fm-modal select:focus,.fm-modal textarea:focus{border-color:var(--purple);box-shadow:0 0 0 3px rgba(123,97,241,0.1)}
.fm-modal select option{background:#1a1e2e;color:#f6f8fc}
.fm-modal textarea{resize:vertical;min-height:100px}
.fm-modal-foot{display:flex;gap:10px;justify-content:flex-end;margin-top:6px}
.fm-modal-cancel{padding:10px 22px;background:transparent;border:1px solid var(--border);border-radius:10px;color:var(--muted);font-weight:600;font-size:0.84rem;cursor:pointer;transition:all .15s;font-family:inherit}
.fm-modal-cancel:hover{border-color:var(--red);color:var(--red)}
.fm-modal-submit{padding:10px 28px;background:linear-gradient(135deg,var(--purple),#9b7bf7);border:none;border-radius:10px;color:#fff;font-weight:700;font-size:0.84rem;cursor:pointer;transition:all .15s;box-shadow:0 4px 16px rgba(123,97,241,0.25);font-family:inherit}
.fm-modal-submit:hover{opacity:.9;transform:translateY(-1px)}

/* ── Toast ── */
.fm-toast-container{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:9999;display:flex;flex-direction:column;gap:10px;align-items:center}
.fm-flash{padding:14px 24px;border-radius:14px;font-size:0.84rem;font-weight:600;backdrop-filter:blur(16px);box-shadow:0 8px 32px rgba(0,0,0,0.4);display:flex;align-items:center;animation:fmSlideUp .4s cubic-bezier(0.22,1,0.36,1)}
.fm-flash.success{background:rgba(52,211,153,0.15);border:1px solid rgba(52,211,153,0.3);color:#34d399}
.fm-flash.error{background:rgba(239,68,68,0.15);border:1px solid rgba(239,68,68,0.3);color:#ef4444}
.fm-flash.fade-out{opacity:0;transform:translateX(40px);transition:opacity .5s,transform .5s}

/* ── Glow line ── */
.fm-glow-line{height:1px;border:none;margin:28px 0;background:linear-gradient(90deg,transparent,rgba(123,97,241,0.15),rgba(56,189,209,0.08),transparent)}

@media(max-width:768px){
    .fm-topic-head{flex-direction:column}
    .fm-topic-right{flex-direction:row;margin-left:0;margin-top:8px}
    .fm-filters{flex-direction:column;align-items:stretch}
    .fm-search{max-width:100%;margin-left:0}
}
</style>
{% endblock %}

{% block body %}
<script>document.documentElement.setAttribute('data-theme','dark');</script>
{% include 'partials/_background.html.twig' %}
<div class="fm" style="position:relative;z-index:1">

    <div class="fm-toast-container">
        {% for message in app.flashes('success') %}
            <div class="fm-flash success"><i class='bx bx-check-circle' style="margin-right:6px"></i>{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="fm-flash error"><i class='bx bx-error-circle' style="margin-right:6px"></i>{{ message }}</div>
        {% endfor %}
    </div>

    <div class="fm-wrap">

        {# ── Header ── #}
        <div class="fm-head">
            <div>
                <h1><i class='bx bx-conversation' style="-webkit-text-fill-color:var(--purple);margin-right:8px"></i>Community Forum</h1>
                <p>Share ideas, ask questions, and help fellow learners</p>
            </div>
            <button class="fm-new-btn" onclick="document.getElementById('newTopicModal').classList.add('open')">
                <i class='bx bx-plus'></i> New Topic
            </button>
        </div>

        {# ── Stats ── #}
        <div class="fm-stats">
            <div class="fm-st">
                <div class="fm-st-v" style="color:var(--purple-soft)">{{ stats.total_topics }}</div>
                <div class="fm-st-l">Topics</div>
            </div>
            <div class="fm-st">
                <div class="fm-st-v" style="color:var(--cyan)">{{ stats.total_posts }}</div>
                <div class="fm-st-l">Replies</div>
            </div>
            <div class="fm-st">
                <div class="fm-st-v" style="color:var(--green)">{{ stats.active_users }}</div>
                <div class="fm-st-l">Active Users</div>
            </div>
        </div>

        {# ── Filters ── #}
        <div class="fm-filters">
            <a href="{{ path('app_forum') }}" class="fm-filter-btn {{ currentCategory == '' ? 'active' : '' }}" style="text-decoration:none">All</a>
            {% for cat in categories %}
                <a href="{{ path('app_forum', {category: cat}) }}" class="fm-filter-btn {{ currentCategory == cat ? 'active' : '' }}" style="text-decoration:none">{{ cat|replace({'_': ' '}) }}</a>
            {% endfor %}
            <form class="fm-search" method="get" action="{{ path('app_forum') }}">
                {% if currentCategory %}<input type="hidden" name="category" value="{{ currentCategory }}">{% endif %}
                <i class='bx bx-search'></i>
                <input type="text" name="q" value="{{ search }}" placeholder="Search topics...">
            </form>
        </div>

        <hr class="fm-glow-line">

        {# ── Topic List ── #}
        <div class="fm-topics">
            {% if topics|length > 0 %}
                {% for topic in topics %}
                    <a href="{{ path('app_forum_topic', {id: topic.id}) }}" class="fm-topic cat-{{ topic.category }}" style="animation-delay:{{ loop.index0 * 0.06 }}s">
                        <div style="display:flex;align-items:flex-start;justify-content:space-between">
                            <div class="fm-topic-head">
                                <img src="{{ topic.author_avatar ?: 'https://ui-avatars.com/api/?name=' ~ topic.author_name|url_encode ~ '&size=88&background=7c5cfc&color=fff&bold=true&format=svg' }}" alt="" class="fm-topic-avatar">
                                <div class="fm-topic-info">
                                    <div class="fm-topic-title">{{ topic.title }}</div>
                                    <div class="fm-topic-meta">
                                        <span><i class='bx bx-user'></i> {{ topic.author_name }}</span>
                                        <span class="fm-cat-tag cat-{{ topic.category }}">{{ topic.category|replace({'_': ' '}) }}</span>
                                        {% if topic.is_closed %}<span class="fm-closed"><i class='bx bx-lock-alt'></i> Closed</span>{% endif %}
                                        <span><i class='bx bx-time-five'></i> {{ topic.created_at|date('M d, Y') }}</span>
                                    </div>
                                </div>
                            </div>
                            <div class="fm-topic-right">
                                <span class="fm-reply-count"><i class='bx bx-message-detail'></i> {{ topic.reply_count }}</span>
                                {% if topic.last_reply_at %}
                                    <span class="fm-topic-time">Last reply {{ topic.last_reply_at|date('M d · H:i') }}</span>
                                {% endif %}
                            </div>
                        </div>
                    </a>
                {% endfor %}
            {% else %}
                <div class="fm-empty">
                    <i class='bx bx-message-square-dots'></i>
                    <p>No topics yet. Be the first to start a discussion!</p>
                </div>
            {% endif %}
        </div>
    </div>
</div>

{# ── New Topic Modal ── #}
<div class="fm-modal-bg" id="newTopicModal">
    <div class="fm-modal">
        <h2>Create New Topic</h2>
        <p class="sub">Start a discussion with the community</p>
        <form method="post" action="{{ path('app_forum_create') }}">
            <label>Title</label>
            <input type="text" name="title" placeholder="What's on your mind?" required maxlength="220">
            <label>Category</label>
            <select name="category">
                {% for cat in categories %}
                    <option value="{{ cat }}">{{ cat|replace({'_': ' '})|title }}</option>
                {% endfor %}
            </select>
            <label>Content</label>
            <textarea name="content" placeholder="Describe your topic in detail..." required></textarea>
            <div class="fm-modal-foot">
                <button type="button" class="fm-modal-cancel" onclick="document.getElementById('newTopicModal').classList.remove('open')">Cancel</button>
                <button type="submit" class="fm-modal-submit">Create Topic</button>
            </div>
        </form>
    </div>
</div>

<script>
document.getElementById('newTopicModal').addEventListener('click', function(e) {
    if (e.target === this) this.classList.remove('open');
});
document.querySelectorAll('.fm-flash').forEach(function(el) {
    setTimeout(function() { el.classList.add('fade-out'); setTimeout(function(){ el.remove(); }, 500); }, 5000);
});
</script>
{% endblock %}

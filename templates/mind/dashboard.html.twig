{% extends 'base.html.twig' %}{% block title %}LearnAdapt Mind — Cognitive Learning Intelligence{% endblock %}{% block body %}<style>/* ═══════════════════════════════════════════════════════════   LEARNADAPT MIND — PREMIUM DASHBOARD═══════════════════════════════════════════════════════════ */:root {    --mp:      #7b61f1;    --mc:      #38bdd1;    --mg:      #f5c842;    --mr:      #f05e5e;    --mgreen:  #4ade80;    --mbg:     #0b0d19;    --mcard:   rgba(255,255,255,0.03);    --mborder: rgba(255,255,255,0.07);    --mtext:   rgba(255,255,255,0.85);    --mtext2:  rgba(255,255,255,0.45);    --mtext3:  rgba(255,255,255,0.2);}/* ── Page shell ───────────────────────────────────────────── */.md-page {    min-height: 100vh;    background: var(--mbg);    padding-bottom: 80px;    font-family: 'Inter', system-ui, sans-serif;}/* ── Top banner ───────────────────────────────────────────── */.md-banner {    background: linear-gradient(135deg,        rgba(123,97,241,.18) 0%,        rgba(56,189,209,.09) 50%,        rgba(11,13,25,0) 100%);    border-bottom: 1px solid var(--mborder);    padding: 40px 40px 36px;    position: relative;    overflow: hidden;}.md-banner::after {    content:'';    position: absolute;    inset: 0;    background: radial-gradient(ellipse 70% 120% at 10% 50%, rgba(123,97,241,.1), transparent);    pointer-events: none;}.md-banner-inner {    max-width: 1160px;    margin: 0 auto;    display: flex;    align-items: center;    justify-content: space-between;    gap: 24px;    flex-wrap: wrap;    position: relative;    z-index: 1;}.md-banner-left { flex: 1; min-width: 280px; }.md-badge {    display: inline-flex;    align-items: center;    gap: 8px;    font-size: .66rem;    font-weight: 800;    letter-spacing: .2em;    text-transform: uppercase;    color: var(--mp);    margin-bottom: 10px;}.md-badge-dot {    width: 6px; height: 6px;    background: var(--mc);    border-radius: 50%;    animation: bpulse 2s ease-in-out infinite;}@keyframes bpulse {    0%,100%{opacity:1;transform:scale(1)}    50%{opacity:.5;transform:scale(1.5)}}.md-banner h1 {    font-size: clamp(1.6rem, 3.5vw, 2.4rem);    font-weight: 900;    color: #fff;    margin: 0 0 6px;    letter-spacing: -.03em;    line-height: 1.1;}.md-banner h1 em {    font-style: normal;    background: linear-gradient(90deg, var(--mp), var(--mc));    -webkit-background-clip: text;    -webkit-text-fill-color: transparent;}.md-banner-sub {    color: var(--mtext2);    font-size: .88rem;    line-height: 1.6;    max-width: 480px;}.md-banner-right {    display: flex;    align-items: center;    gap: 12px;    flex-wrap: wrap;}.md-status-chip {    display: flex;    align-items: center;    gap: 6px;    padding: 8px 16px;    border-radius: 40px;    font-size: .75rem;    font-weight: 700;    border: 1px solid;}.md-status-chip.great  { background: rgba(74,222,128,.1);  border-color: rgba(74,222,128,.25);  color: var(--mgreen); }.md-status-chip.good   { background: rgba(123,97,241,.1);  border-color: rgba(123,97,241,.25);  color: var(--mp); }.md-status-chip.ok     { background: rgba(245,200,66,.1);  border-color: rgba(245,200,66,.25);  color: var(--mg); }.md-status-chip.risk   { background: rgba(240,94,94,.1);   border-color: rgba(240,94,94,.25);   color: var(--mr); }/* ── Quick Stats Row ──────────────────────────────────────── */.md-stats-row {    max-width: 1160px;    margin: 0 auto;    padding: 28px 40px 0;    display: grid;    grid-template-columns: repeat(4, 1fr);    gap: 16px;}@media(max-width:900px){ .md-stats-row { grid-template-columns: repeat(2,1fr); padding: 20px 20px 0; } }@media(max-width:500px){ .md-stats-row { grid-template-columns: 1fr; } }.md-stat {    background: var(--mcard);    border: 1px solid var(--mborder);    border-radius: 16px;    padding: 20px 22px;    display: flex;    align-items: center;    gap: 16px;    transition: border-color .2s, transform .2s;}.md-stat:hover { border-color: rgba(123,97,241,.3); transform: translateY(-2px); }.md-stat-icon {    width: 44px; height: 44px;    border-radius: 12px;    display: flex;    align-items: center;    justify-content: center;    font-size: 1.3rem;    flex-shrink: 0;}.md-stat-icon.p { background: rgba(123,97,241,.15); color: var(--mp); }.md-stat-icon.c { background: rgba(56,189,209,.15);  color: var(--mc); }.md-stat-icon.g { background: rgba(245,200,66,.15);  color: var(--mg); }.md-stat-icon.r { background: rgba(74,222,128,.15);  color: var(--mgreen); }.md-stat-icon.bad { background: rgba(240,94,94,.12); color: var(--mr); }.md-stat-body {}.md-stat-val {    font-size: 1.45rem;    font-weight: 900;    color: #fff;    line-height: 1;    letter-spacing: -.03em;}.md-stat-lbl {    font-size: .7rem;    font-weight: 600;    color: var(--mtext2);    letter-spacing: .05em;    text-transform: uppercase;    margin-top: 4px;}.md-stat-delta {    font-size: .65rem;    font-weight: 700;    margin-top: 3px;}.md-stat-delta.up   { color: var(--mgreen); }.md-stat-delta.down { color: var(--mr); }.md-stat-delta.neu  { color: var(--mtext3); }/* ── Main Content Grid ────────────────────────────────────── */.md-main {    max-width: 1160px;    margin: 24px auto 0;    padding: 0 40px;    display: grid;    grid-template-columns: 320px 1fr;    gap: 20px;    align-items: start;}@media(max-width:960px){ .md-main { grid-template-columns:1fr; padding: 0 20px; } }/* ── Card base ────────────────────────────────────────────── */.md-card {    background: var(--mcard);    border: 1px solid var(--mborder);    border-radius: 20px;    overflow: hidden;}.md-card-head {    display: flex;    align-items: center;    justify-content: space-between;    padding: 18px 22px 16px;    border-bottom: 1px solid var(--mborder);    gap: 10px;}.md-card-head-left {    display: flex;    align-items: center;    gap: 9px;}.md-card-head-icon {    width: 30px; height: 30px;    border-radius: 8px;    display: flex;    align-items: center;    justify-content: center;    font-size: .95rem;    background: rgba(123,97,241,.12);    color: var(--mp);}.md-card-title {    font-size: .72rem;    font-weight: 800;    letter-spacing: .12em;    text-transform: uppercase;    color: var(--mtext2);}.md-card-body { padding: 22px; }/* ── Gauge ────────────────────────────────────────────────── */.md-gauge-wrap {    display: flex;    flex-direction: column;    align-items: center;    padding: 8px 0 20px;}.md-gauge {    position: relative;    width: 190px;    height: 190px;}.md-gauge svg { transform: rotate(-90deg); }.md-gauge-track { fill: none; stroke: rgba(255,255,255,.05); stroke-width: 13; }.md-gauge-bar {    fill: none;    stroke-width: 13;    stroke-linecap: round;    stroke-dasharray: 534.07;    stroke: url(#gGrad);    transition: stroke-dashoffset 1.4s cubic-bezier(.34,1.56,.64,1);}.md-gauge-inner {    position: absolute;    inset: 0;    display: flex;    flex-direction: column;    align-items: center;    justify-content: center;}.md-gauge-num {    font-size: 2.6rem;    font-weight: 900;    color: #fff;    line-height: 1;    letter-spacing: -.05em;}.md-gauge-sub {    font-size: .6rem;    letter-spacing: .1em;    text-transform: uppercase;    color: var(--mtext3);    margin-top: 3px;}.md-verdict {    margin-top: 14px;    padding: 7px 22px;    border-radius: 30px;    font-size: .78rem;    font-weight: 800;    letter-spacing: .04em;    border: 1px solid;    text-align: center;}.md-verdict.great { background:rgba(74,222,128,.1);  border-color:rgba(74,222,128,.25);  color:var(--mgreen); }.md-verdict.good  { background:rgba(123,97,241,.1);  border-color:rgba(123,97,241,.25);  color:var(--mp); }.md-verdict.ok    { background:rgba(245,200,66,.1);  border-color:rgba(245,200,66,.25);  color:var(--mg); }.md-verdict.risk  { background:rgba(240,94,94,.1);   border-color:rgba(240,94,94,.25);   color:var(--mr); }/* ── Divider ──────────────────────────────────────────────── */.md-divider { height:1px; background: var(--mborder); margin: 0; }/* ── Buttons ──────────────────────────────────────────────── */.md-btn {    width: 100%;    padding: 14px;    border-radius: 12px;    border: none;    cursor: pointer;    font-size: .85rem;    font-weight: 800;    letter-spacing: .04em;    display: flex;    align-items: center;    justify-content: center;    gap: 9px;    transition: all .2s ease;    text-decoration: none;    font-family: inherit;}.md-btn.prim {    background: linear-gradient(135deg, var(--mp), var(--mc));    color: #fff;    box-shadow: 0 6px 28px rgba(123,97,241,.38);}.md-btn.prim:hover { transform:translateY(-2px); box-shadow:0 10px 36px rgba(123,97,241,.5); }.md-btn.sec {    background: rgba(255,255,255,.04);    border: 1px solid var(--mborder);    color: var(--mtext2);}.md-btn.sec:hover { border-color:rgba(123,97,241,.4); color:var(--mp); }.md-btn:disabled { opacity:.5; cursor:not-allowed; transform:none !important; }.md-btn i { font-size:1.05rem; }.md-spinner {    width: 17px; height: 17px;    border: 2px solid rgba(255,255,255,.3);    border-top-color: #fff;    border-radius: 50%;    animation: spin .7s linear infinite;    display: none;    flex-shrink: 0;}@keyframes spin { to{transform:rotate(360deg)} }/* ── Narrative ────────────────────────────────────────────── */.md-narrative-box {    font-size: .875rem;    line-height: 1.85;    color: var(--mtext);    white-space: pre-wrap;    max-height: 420px;    overflow-y: auto;    padding-right: 6px;}.md-narrative-box::-webkit-scrollbar { width:3px; }.md-narrative-box::-webkit-scrollbar-track { background:transparent; }.md-narrative-box::-webkit-scrollbar-thumb { background:rgba(123,97,241,.35); border-radius:4px; }/* ── Insight Chips ────────────────────────────────────────── */.md-chips { display:flex; flex-wrap:wrap; gap:7px; }.md-chip {    display: inline-flex;    align-items: center;    gap: 5px;    padding: 5px 11px;    border-radius: 8px;    font-size: .73rem;    font-weight: 700;    border: 1px solid;}.md-chip.p { background:rgba(123,97,241,.08); border-color:rgba(123,97,241,.22); color:var(--mp); }.md-chip.c { background:rgba(56,189,209,.08);  border-color:rgba(56,189,209,.22);  color:var(--mc); }.md-chip.g { background:rgba(245,200,66,.08);  border-color:rgba(245,200,66,.22);  color:var(--mg); }.md-chip.gn{ background:rgba(74,222,128,.08);  border-color:rgba(74,222,128,.22);  color:var(--mgreen); }.md-chip.r { background:rgba(240,94,94,.08);   border-color:rgba(240,94,94,.22);   color:var(--mr); }/* ── Action row ───────────────────────────────────────────── */.md-actions {    display: grid;    grid-template-columns: 1fr 1fr;    gap: 10px;}/* ── History ──────────────────────────────────────────────── */.md-history {    max-width: 1160px;    margin: 20px auto 0;    padding: 0 40px;}@media(max-width:960px){ .md-history { padding:0 20px; } }.md-history-grid {    display: grid;    grid-template-columns: repeat(auto-fill, minmax(260px,1fr));    gap: 14px;}.md-history-card {    background: var(--mcard);    border: 1px solid var(--mborder);    border-radius: 16px;    padding: 18px 20px;    text-decoration: none;    display: flex;    align-items: center;    justify-content: space-between;    gap: 12px;    transition: all .2s ease;    cursor: pointer;}.md-history-card:hover {    border-color: rgba(123,97,241,.35);    background: rgba(123,97,241,.05);    transform: translateY(-2px);}.md-hist-date { font-size: .82rem; font-weight: 700; color: #fff; }.md-hist-range { font-size: .68rem; color: var(--mtext3); margin-top: 3px; }.md-hist-right { display:flex; align-items:center; gap:8px; }.md-hist-badge {    font-size: .68rem;    font-weight: 700;    padding: 2px 8px;    border-radius: 6px;    border: 1px solid;}.md-ai-tag {    font-size: .6rem;    font-weight: 700;    padding: 2px 7px;    border-radius: 6px;    background: rgba(56,189,209,.1);    border: 1px solid rgba(56,189,209,.2);    color: var(--mc);    letter-spacing: .06em;}/* ── Empty state ──────────────────────────────────────────── */.md-empty {    text-align: center;    padding: 60px 24px;    display: flex;    flex-direction: column;    align-items: center;    gap: 10px;}.md-empty-icon {    width: 72px; height: 72px;    border-radius: 20px;    background: rgba(123,97,241,.1);    border: 1px solid rgba(123,97,241,.15);    display: flex;    align-items: center;    justify-content: center;    font-size: 2rem;    color: rgba(123,97,241,.6);    margin-bottom: 8px;}.md-empty h3 { font-size: 1rem; font-weight: 700; color: var(--mtext); margin:0; }.md-empty p  { font-size: .83rem; color: var(--mtext2); margin:0; max-width: 320px; line-height: 1.6; }.md-empty small { font-size: .72rem; color: var(--mtext3); }/* ── Section header ───────────────────────────────────────── */.md-section-head {    display: flex;    align-items: center;    justify-content: space-between;    margin-bottom: 16px;}.md-section-title {    font-size: .72rem;    font-weight: 800;    letter-spacing: .14em;    text-transform: uppercase;    color: var(--mtext2);    display: flex;    align-items: center;    gap: 8px;}.md-section-title i { color: var(--mp); font-size: 1rem; }/* ── Toast ────────────────────────────────────────────────── */.md-toast {    position: fixed;    bottom: 28px; right: 28px;    padding: 13px 20px;    border-radius: 14px;    font-size: .83rem;    font-weight: 700;    z-index: 9999;    transform: translateY(80px);    opacity: 0;    pointer-events: none;    transition: all .35s cubic-bezier(.34,1.56,.64,1);    display: flex;    align-items: center;    gap: 8px;}.md-toast.show { transform:translateY(0); opacity:1; }.md-toast.success { background:rgba(74,222,128,.12);  border:1px solid rgba(74,222,128,.3);  color:var(--mgreen); }.md-toast.error   { background:rgba(240,94,94,.12);   border:1px solid rgba(240,94,94,.3);   color:var(--mr); }/* ── Responsive ───────────────────────────────────────────── */@media(max-width:700px){    .md-banner { padding: 28px 20px 24px; }    .md-banner-right { width:100%; }}</style>{% set m = lastReport ? lastReport.metrics : {} %}{% set hs = lastReport ? lastReport.health_score : 0 %}{% set velChange = m.learning_velocity.change_pct ?? 0 %}{% set focusMins = m.focus_minutes_week ?? 0 %}{% set activeDays = m.active_days_week ?? 0 %}{% set totalXP = m.total_xp ?? 0 %}{% set abandoned = m.abandoned_courses ?? [] %}<div class="md-page">{# ══ TOP BANNER ══════════════════════════════════════════════ #}<div class="md-banner">    <div class="md-banner-inner">        <div class="md-banner-left">            <div class="md-badge">                <div class="md-badge-dot"></div>                LearnAdapt Mind v1.0                <div class="md-badge-dot"></div>            </div>            <h1>Your <em>Cognitive Learning</em><br>Intelligence Dashboard</h1>            <p class="md-banner-sub">                AI-powered analysis of your focus habits, quiz performance, course progress                and knowledge gaps — distilled into a weekly report written for you.            </p>        </div>        <div class="md-banner-right">            {% if lastReport %}                <div style="text-align:right">                    <div style="font-size:.68rem;color:var(--mtext3);letter-spacing:.08em;text-transform:uppercase;margin-bottom:4px">Last report</div>                    <div style="font-size:.85rem;font-weight:700;color:var(--mtext)">{{ lastReport.week_start|date('M d') }} – {{ lastReport.week_end|date('M d, Y') }}</div>                </div>                {% if hs >= 80 %}                    <div class="md-status-chip great"><i class='bx bx-trending-up'></i> Excellent</div>                {% elseif hs >= 60 %}                    <div class="md-status-chip good"><i class='bx bx-check-circle'></i> On Track</div>                {% elseif hs >= 40 %}                    <div class="md-status-chip ok"><i class='bx bx-time'></i> Needs Focus</div>                {% else %}                    <div class="md-status-chip risk"><i class='bx bx-error'></i> At Risk</div>                {% endif %}            {% else %}                <div class="md-status-chip" style="background:rgba(255,255,255,.04);border-color:var(--mborder);color:var(--mtext2)">                    <i class='bx bx-brain'></i> No Report Yet                </div>            {% endif %}        </div>    </div></div>{# ══ QUICK STATS ROW ═════════════════════════════════════════ #}<div class="md-stats-row">    {# Focus Time #}    <div class="md-stat">        <div class="md-stat-icon p"><i class='bx bx-time-five'></i></div>        <div class="md-stat-body">            <div class="md-stat-val">{{ lastReport ? focusMins : '—' }}<span style="font-size:.9rem;color:var(--mtext2);font-weight:600"> min</span></div>            <div class="md-stat-lbl">Focus This Week</div>            {% if lastReport and focusMins > 0 %}                <div class="md-stat-delta up">▲ {{ (focusMins / 60)|round(1) }}h of deep work</div>            {% endif %}        </div>    </div>    {# Active Days #}    <div class="md-stat">        <div class="md-stat-icon c"><i class='bx bx-calendar-check'></i></div>        <div class="md-stat-body">            <div class="md-stat-val">{{ lastReport ? activeDays : '—' }}<span style="font-size:.9rem;color:var(--mtext2);font-weight:600">/7</span></div>            <div class="md-stat-lbl">Active Days</div>            {% if lastReport %}                {% if activeDays >= 5 %}                    <div class="md-stat-delta up">▲ Consistent learner</div>                {% elseif activeDays >= 3 %}                    <div class="md-stat-delta neu">◆ Room to improve</div>                {% else %}                    <div class="md-stat-delta down">▼ Low engagement</div>                {% endif %}            {% endif %}        </div>    </div>    {# XP #}    <div class="md-stat">        <div class="md-stat-icon g"><i class='bx bx-bolt-circle'></i></div>        <div class="md-stat-body">            <div class="md-stat-val">{{ lastReport ? totalXP : '—' }}</div>            <div class="md-stat-lbl">Total XP Earned</div>            {% if lastReport and totalXP > 0 %}                <div class="md-stat-delta up">▲ Keep earning</div>            {% endif %}        </div>    </div>    {# Velocity #}    <div class="md-stat">        <div class="md-stat-icon {{ velChange >= 0 ? 'r' : 'bad' }}"><i class='bx bx-{{ velChange >= 0 ? "trending-up" : "trending-down" }}'></i></div>        <div class="md-stat-body">            <div class="md-stat-val" style="color:{{ velChange >= 0 ? 'var(--mgreen)' : 'var(--mr)' }}">                {{ lastReport ? ((velChange >= 0 ? '+' : '') ~ velChange ~ '%') : '—' }}            </div>            <div class="md-stat-lbl">Learning Velocity</div>            {% if lastReport %}                <div class="md-stat-delta {{ velChange >= 0 ? 'up' : 'down' }}">                    {{ velChange >= 0 ? '▲ Accelerating' : '▼ Slowing down' }}                </div>            {% endif %}        </div>    </div></div>{# ══ MAIN GRID ═══════════════════════════════════════════════ #}<div class="md-main">    {# ── LEFT COLUMN ── #}    <div style="display:flex;flex-direction:column;gap:18px">        {# Health Score Card #}        <div class="md-card">            <div class="md-card-head">                <div class="md-card-head-left">                    <div class="md-card-head-icon"><i class='bx bx-pulse'></i></div>                    <span class="md-card-title">Health Score</span>                </div>                {% if lastReport %}                    <span style="font-size:.68rem;color:var(--mtext3)">Updated {{ lastReport.created_at|date('M d') }}</span>                {% endif %}            </div>            <div class="md-card-body">                {% if lastReport %}                    {% set dashOffset = 534.07 - (hs / 100 * 534.07) %}                    <div class="md-gauge-wrap">                        <div class="md-gauge">                            <svg width="190" height="190" viewBox="0 0 190 190">                                <defs>                                    <linearGradient id="gGrad" x1="0%" y1="0%" x2="100%" y2="0%">                                        <stop offset="0%"   stop-color="#7b61f1"/>                                        <stop offset="100%" stop-color="#38bdd1"/>                                    </linearGradient>                                </defs>                                <circle class="md-gauge-track" cx="95" cy="95" r="85"/>                                <circle class="md-gauge-bar" cx="95" cy="95" r="85"                                    style="stroke-dashoffset:{{ dashOffset }}"/>                            </svg>                            <div class="md-gauge-inner">                                <div class="md-gauge-num">{{ hs }}</div>                                <div class="md-gauge-sub">out of 100</div>                            </div>                        </div>                        {% if hs >= 80 %}                            <div class="md-verdict great">🏆 Excellent — Keep crushing it!</div>                        {% elseif hs >= 60 %}                            <div class="md-verdict good">✅ Good — Room to grow</div>                        {% elseif hs >= 40 %}                            <div class="md-verdict ok">⚡ Fair — Needs attention</div>                        {% else %}                            <div class="md-verdict risk">⚠️ At Risk — Take action now</div>                        {% endif %}                    </div>                    {# Insight chips #}                    {% if abandoned|length > 0 or m.knowledge_gaps is defined %}                    <div class="md-chips" style="margin-bottom:18px">                        {% if abandoned|length > 0 %}                            <span class="md-chip r"><i class='bx bx-error'></i> {{ abandoned|length }} stalled</span>                        {% endif %}                        {% if m.knowledge_gaps is defined and m.knowledge_gaps|length > 0 %}                            <span class="md-chip g"><i class='bx bx-book-open'></i> {{ m.knowledge_gaps|length }} gaps</span>                        {% endif %}                        {% if m.micro_goal is defined %}                            <span class="md-chip c"><i class='bx bx-target-lock'></i> Goal set</span>                        {% endif %}                    </div>                    {% endif %}                {% else %}                    <div class="md-empty" style="padding:40px 0">                        <div class="md-empty-icon"><i class='bx bx-brain'></i></div>                        <h3>No score yet</h3>                        <p>Generate your first report to see your learning health score.</p>                    </div>                {% endif %}                {# Divider + Buttons #}                <div class="md-divider" style="margin-bottom:18px"></div>                <button class="md-btn prim" id="genBtn" onclick="generateReport()" style="margin-bottom:10px">                    <div class="md-spinner" id="genSpinner"></div>                    <i class='bx bx-analyse' id="genIcon"></i>                    <span id="genLabel">                        {% if lastReport %}Regenerate This Week{% else %}Generate My First Report{% endif %}                    </span>                </button>                {% if lastReport %}                    <a href="{{ path('app_mind_report', {id: lastReport.id}) }}" class="md-btn sec">                        <i class='bx bx-file-blank'></i> View Full Report                    </a>                {% endif %}                <p style="text-align:center;font-size:.65rem;color:var(--mtext3);margin-top:14px;line-height:1.5">                    Powered by LearnAdapt Mind AI<br>Your data stays private                </p>            </div>        </div>        {# Report History Card #}        {% if allReports|length > 0 %}        <div class="md-card">            <div class="md-card-head">                <div class="md-card-head-left">                    <div class="md-card-head-icon" style="background:rgba(56,189,209,.12);color:var(--mc)"><i class='bx bx-history'></i></div>                    <span class="md-card-title">Past Reports</span>                </div>                <span style="font-size:.7rem;color:var(--mtext3)">{{ allReports|length }} total</span>            </div>            <div style="padding:14px 16px;display:flex;flex-direction:column;gap:8px">                {% for r in allReports %}                    {% set rhs = r.health_score %}                    <a href="{{ path('app_mind_report', {id: r.id}) }}" class="md-history-card" style="padding:14px 16px">                        <div>                            <div class="md-hist-date">{{ r.week_start|date('M d, Y') }}</div>                            <div class="md-hist-range">{{ r.week_start|date('M d') }} – {{ r.week_end|date('M d') }}</div>                        </div>                        <div class="md-hist-right">                            {% if r.groq_used %}<span class="md-ai-tag">AI</span>{% endif %}                            <div class="md-hist-badge" style="                                {% if rhs >= 80 %}background:rgba(74,222,128,.1);border-color:rgba(74,222,128,.25);color:var(--mgreen)                                {% elseif rhs >= 60 %}background:rgba(123,97,241,.1);border-color:rgba(123,97,241,.25);color:var(--mp)                                {% elseif rhs >= 40 %}background:rgba(245,200,66,.1);border-color:rgba(245,200,66,.25);color:var(--mg)                                {% else %}background:rgba(240,94,94,.1);border-color:rgba(240,94,94,.25);color:var(--mr)                                {% endif %}                            ">{{ rhs }}/100</div>                            <i class='bx bx-chevron-right' style="color:var(--mtext3);font-size:1.1rem"></i>                        </div>                    </a>                {% endfor %}            </div>        </div>        {% endif %}    </div>    {# ── RIGHT COLUMN ── #}    <div style="display:flex;flex-direction:column;gap:18px">        {# Latest Report Narrative #}        <div class="md-card">            <div class="md-card-head">                <div class="md-card-head-left">                    <div class="md-card-head-icon" style="background:rgba(245,200,66,.12);color:var(--mg)"><i class='bx bx-brain'></i></div>                    <div>                        <div class="md-card-title">                            {% if lastReport %}AI Narrative — Week of {{ lastReport.week_start|date('M d, Y') }}                            {% else %}Weekly AI Report{% endif %}                        </div>                        {% if lastReport and lastReport.groq_used %}                            <div style="font-size:.62rem;color:var(--mc);margin-top:2px;letter-spacing:.06em">● Generated by LearnAdapt Mind AI</div>                        {% endif %}                    </div>                </div>                {% if lastReport %}                    <div style="display:flex;gap:8px;align-items:center">                        <a href="{{ path('app_mind_report_print', {id: lastReport.id}) }}" target="_blank"                           style="display:flex;align-items:center;gap:5px;padding:6px 12px;background:rgba(56,189,209,.08);border:1px solid rgba(56,189,209,.18);border-radius:8px;color:var(--mc);text-decoration:none;font-size:.72rem;font-weight:700;transition:all .2s" title="Print / PDF">                            <i class='bx bx-printer'></i> PDF                        </a>                        <a href="{{ path('app_mind_report', {id: lastReport.id}) }}"                           style="display:flex;align-items:center;gap:5px;padding:6px 12px;background:rgba(123,97,241,.08);border:1px solid rgba(123,97,241,.18);border-radius:8px;color:var(--mp);text-decoration:none;font-size:.72rem;font-weight:700;transition:all .2s">                            <i class='bx bx-expand-alt'></i> Full View                        </a>                    </div>                {% endif %}            </div>            <div class="md-card-body">                {% if lastReport %}                    <div class="md-narrative-box">{{ lastReport.ai_narrative }}</div>                {% else %}                    <div class="md-empty">                        <div class="md-empty-icon"><i class='bx bx-file-blank'></i></div>                        <h3>No report generated yet</h3>                        <p>Click <strong>"Generate My First Report"</strong> — LearnAdapt Mind will analyze your Pomodoro sessions, quiz results, course progress, and knowledge gaps, then write your personalized weekly report.</p>                        <small>Takes about 10–20 seconds · Powered by Groq AI</small>                    </div>                {% endif %}            </div>        </div>        {# Quick Insights (only if report exists) #}        {% if lastReport %}        <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px">            {# Peak Learning Window #}            <div class="md-card">                <div class="md-card-head">                    <div class="md-card-head-left">                        <div class="md-card-head-icon" style="background:rgba(56,189,209,.12);color:var(--mc)"><i class='bx bx-time'></i></div>                        <span class="md-card-title">Peak Window</span>                    </div>                </div>                <div class="md-card-body" style="padding:16px 20px">                    {% set pw = m.peak_window ?? {} %}                    {% if pw.hour_label is defined %}                        <div style="font-size:1.5rem;font-weight:900;color:#fff;letter-spacing:-.03em">{{ pw.hour_label }}</div>                        <div style="font-size:.75rem;color:var(--mtext2);margin-top:4px">{{ pw.sessions_in_window ?? 0 }} sessions in this window</div>                        <div style="margin-top:12px;height:4px;border-radius:4px;background:rgba(255,255,255,.06);overflow:hidden">                            {% set barW = min(100, (pw.sessions_in_window ?? 0) * 20) %}                            <div style="height:100%;width:{{ barW }}%;background:linear-gradient(90deg,var(--mc),var(--mp));border-radius:4px;transition:width 1s ease"></div>                        </div>                    {% else %}                        <div style="color:var(--mtext3);font-size:.82rem;padding:8px 0">No session data available.</div>                    {% endif %}                </div>            </div>            {# Micro-Goal #}            <div class="md-card">                <div class="md-card-head">                    <div class="md-card-head-left">                        <div class="md-card-head-icon" style="background:rgba(245,200,66,.12);color:var(--mg)"><i class='bx bx-target-lock'></i></div>                        <span class="md-card-title">Micro-Goal</span>                    </div>                </div>                <div class="md-card-body" style="padding:16px 20px">                    {% set mg = m.micro_goal ?? {} %}                    {% if mg.goal is defined %}                        <div style="font-size:.85rem;font-weight:700;color:var(--mtext);line-height:1.5">{{ mg.goal }}</div>                        {% if mg.reason is defined %}                            <div style="font-size:.73rem;color:var(--mtext2);margin-top:8px;line-height:1.5">{{ mg.reason }}</div>                        {% endif %}                    {% else %}                        <div style="color:var(--mtext3);font-size:.82rem;padding:8px 0">Generate a report to get your micro-goal.</div>                    {% endif %}                </div>            </div>        </div>        {# Stalled Courses + Knowledge Gaps #}        {% if abandoned|length > 0 or (m.knowledge_gaps is defined and m.knowledge_gaps|length > 0) %}        <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px">            {# Stalled Courses #}            {% if abandoned|length > 0 %}            <div class="md-card">                <div class="md-card-head">                    <div class="md-card-head-left">                        <div class="md-card-head-icon" style="background:rgba(240,94,94,.12);color:var(--mr)"><i class='bx bx-error-circle'></i></div>                        <span class="md-card-title">Stalled Courses</span>                    </div>                    <span style="font-size:.7rem;color:var(--mr)">{{ abandoned|length }}</span>                </div>                <div style="padding:10px 16px;display:flex;flex-direction:column;gap:8px">                    {% for c in abandoned|slice(0,4) %}                    <div style="display:flex;align-items:center;justify-content:space-between;gap:10px">                        <div style="font-size:.78rem;font-weight:600;color:var(--mtext);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1">                            {{ c.title ?? 'Course' }}                        </div>                        <div style="font-size:.7rem;font-weight:700;color:var(--mr);flex-shrink:0">{{ c.progress ?? 0 }}%</div>                    </div>                    {% if not loop.last %}                    <div style="height:1px;background:var(--mborder)"></div>                    {% endif %}                    {% endfor %}                </div>            </div>            {% endif %}            {# Knowledge Gaps #}            {% if m.knowledge_gaps is defined and m.knowledge_gaps|length > 0 %}            <div class="md-card">                <div class="md-card-head">                    <div class="md-card-head-left">                        <div class="md-card-head-icon" style="background:rgba(245,200,66,.12);color:var(--mg)"><i class='bx bx-book-open'></i></div>                        <span class="md-card-title">Knowledge Gaps</span>                    </div>                    <span style="font-size:.7rem;color:var(--mg)">{{ m.knowledge_gaps|length }}</span>                </div>                <div style="padding:10px 16px;display:flex;flex-direction:column;gap:8px">                    {% for gap in m.knowledge_gaps|slice(0,4) %}                    <div style="display:flex;align-items:center;gap:8px">                        <div style="width:6px;height:6px;border-radius:50%;background:var(--mg);flex-shrink:0"></div>                        <div style="font-size:.78rem;font-weight:600;color:var(--mtext)">{{ gap }}</div>                    </div>                    {% if not loop.last %}                    <div style="height:1px;background:var(--mborder)"></div>                    {% endif %}                    {% endfor %}                </div>            </div>            {% endif %}        </div>        {% endif %}        {% endif %}    </div></div></div>{# /md-page #}<div class="md-toast" id="mdToast"></div><script>function generateReport() {    const btn     = document.getElementById('genBtn');    const spinner = document.getElementById('genSpinner');    const icon    = document.getElementById('genIcon');    const label   = document.getElementById('genLabel');    btn.disabled          = true;    spinner.style.display = 'block';    icon.style.display    = 'none';    label.textContent     = 'Analyzing your data…';    fetch('{{ path("app_mind_generate") }}', {        method: 'POST',        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },        credentials: 'same-origin',    })    .then(r => r.json())    .then(data => {        if (data.ok && data.redirect) {            showToast('✅ Report generated! Loading…', 'success');            setTimeout(() => { window.location.href = data.redirect; }, 900);        } else {            throw new Error(data.error || 'Unknown error');        }    })    .catch(err => {        btn.disabled          = false;        spinner.style.display = 'none';        icon.style.display    = 'block';        label.textContent     = '{{ lastReport ? "Regenerate This Week" : "Generate My First Report" }}';        showToast('Failed: ' + err.message, 'error');    });}function showToast(msg, type) {    const t = document.getElementById('mdToast');    t.innerHTML = msg;    t.className = 'md-toast ' + type;    t.classList.add('show');    setTimeout(() => t.classList.remove('show'), 4200);}</script>{% endblock %}
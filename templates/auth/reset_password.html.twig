<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LearnAdapt | {{ 'reset.title'|trans }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
    <style>
        :root {
            --bg: #041120;
            --panel: rgba(7, 20, 38, 0.58);
            --line: rgba(181, 224, 255, 0.14);
            --text: #f3f8ff;
            --muted: rgba(212, 229, 248, 0.65);
            --blue: #2da9ff;
            --blue-strong: #177af7;
            --cyan: #79f0ff;
            --glow: 0 0 34px rgba(45, 169, 255, 0.28);
            --ease: cubic-bezier(0.22, 1, 0.36, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { min-height: 100%; }

        body {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
            padding: 24px 0;
            font-family: 'Inter', sans-serif;
            color: var(--text);
            background:
                radial-gradient(900px 600px at 18% -10%, rgba(44, 130, 255, 0.38), transparent 55%),
                radial-gradient(820px 540px at 82% 110%, rgba(0, 157, 255, 0.24), transparent 52%),
                linear-gradient(180deg, #071a33 0%, #051225 48%, #03101c 100%);
        }

        .background-scene {
            position: fixed; inset: 0; overflow: hidden; pointer-events: none;
        }
        .background-scene::before {
            content: '';
            position: absolute; inset: 0;
            background:
                radial-gradient(circle at 20% 14%, rgba(118, 232, 255, 0.14), transparent 22%),
                radial-gradient(circle at 80% 20%, rgba(60, 156, 255, 0.16), transparent 18%),
                radial-gradient(circle at 72% 82%, rgba(38, 122, 255, 0.16), transparent 18%);
        }

        .particle-field { position: absolute; inset: 0; }
        .particle {
            position: absolute;
            width: var(--size); height: var(--size);
            left: var(--x); top: var(--y);
            border-radius: 50%;
            background: radial-gradient(circle, rgba(139, 247, 255, 0.98), rgba(53, 174, 255, 0.72) 48%, transparent 72%);
            box-shadow: 0 0 calc(var(--glow-size) * 1px) rgba(84, 198, 255, 0.42);
            opacity: var(--opacity);
            animation: particleFloat var(--duration) ease-in-out infinite, particlePulse var(--pulse) ease-in-out infinite alternate;
            animation-delay: var(--delay);
            filter: blur(var(--blur));
        }
        .particle.tiny {
            background: rgba(176, 241, 255, 0.95);
            box-shadow: 0 0 8px rgba(121, 240, 255, 0.45);
        }
        @keyframes particleFloat {
            0% { transform: translate3d(0,0,0) scale(0.92); }
            100% { transform: translate3d(var(--shift-x), var(--shift-y), 0) scale(1.12); }
        }
        @keyframes particlePulse {
            0% { opacity: calc(var(--opacity) * 0.55); }
            100% { opacity: var(--opacity); }
        }

        .home-link {
            position: fixed; top: 22px; left: 22px; z-index: 40;
            display: inline-flex; align-items: center; gap: 6px;
            padding: 9px 13px; border-radius: 999px;
            border: 1px solid rgba(190, 225, 255, 0.16);
            background: rgba(255,255,255,0.04); color: rgba(243,248,255,0.78);
            text-decoration: none; font-size: 0.82rem; font-weight: 700;
            backdrop-filter: blur(14px);
            transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease, color 0.25s ease;
        }
        .home-link:hover {
            color: #fff; transform: translateY(-1px);
            border-color: rgba(121,240,255,0.34);
            box-shadow: 0 0 0 3px rgba(121,240,255,0.1);
        }

        .rp-card {
            position: relative; z-index: 20;
            width: min(480px, calc(100vw - 48px));
            border-radius: 28px;
            border: 1px solid var(--line);
            background: linear-gradient(180deg, rgba(7,21,40,0.64), rgba(6,17,33,0.82));
            backdrop-filter: blur(24px) saturate(120%);
            overflow: hidden;
            box-shadow: 0 30px 90px rgba(0,0,0,0.44), inset 0 1px 0 rgba(255,255,255,0.08), 0 0 26px rgba(45,169,255,0.14);
            padding: 48px 40px;
            animation: cardIn 0.6s var(--ease);
        }
        .rp-card::before {
            content: '';
            position: absolute; inset: 0; border-radius: inherit; padding: 1px;
            background: linear-gradient(135deg, rgba(255,255,255,0.22), rgba(255,255,255,0.02) 24%, rgba(45,169,255,0.18) 64%, rgba(121,240,255,0.18));
            mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            mask-composite: exclude; -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            -webkit-mask-composite: xor; pointer-events: none;
        }
        @keyframes cardIn {
            from { opacity: 0; transform: translateY(18px) scale(0.97); }
            to { opacity: 1; transform: none; }
        }

        .rp-icon {
            width: 64px; height: 64px; border-radius: 16px;
            display: flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg, rgba(16,185,129,0.15), rgba(121,240,255,0.08));
            border: 1px solid rgba(16,185,129,0.18);
            margin: 0 auto 20px;
        }
        .rp-icon svg { width: 28px; height: 28px; color: #6ee7b7; }

        .rp-title {
            text-align: center; font-family: 'Sora', sans-serif;
            font-size: 1.5rem; font-weight: 800;
            background: linear-gradient(135deg, #f3f8ff, #6ee7b7);
            -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
            margin-bottom: 8px;
        }
        .rp-subtitle {
            text-align: center; font-size: 0.88rem; color: var(--muted);
            margin-bottom: 28px; line-height: 1.5;
        }

        .rp-field {
            position: relative; margin-bottom: 18px;
        }
        .rp-field input {
            width: 100%; padding: 14px 16px 14px 44px;
            border-radius: 12px; border: 1px solid rgba(181,224,255,0.14);
            background: rgba(255,255,255,0.04); color: var(--text);
            font-size: 0.9rem; outline: none;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }
        .rp-field input:focus {
            border-color: rgba(16,185,129,0.5);
            box-shadow: 0 0 0 3px rgba(16,185,129,0.12);
        }
        .rp-field input::placeholder { color: rgba(212,229,248,0.45); }
        .rp-field i {
            position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
            font-size: 1.1rem; color: rgba(212,229,248,0.45);
        }
        .rp-field label {
            display: block; font-size: 0.82rem; font-weight: 600;
            color: var(--muted); margin-bottom: 6px;
        }

        .rp-btn {
            width: 100%; padding: 14px 0;
            border-radius: 12px; border: none;
            background: linear-gradient(135deg, #059669, #10b981);
            color: #fff; font-size: 0.92rem; font-weight: 700;
            cursor: pointer; letter-spacing: 0.02em;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .rp-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 24px rgba(16,185,129,0.35);
        }

        .rp-requirements {
            margin: 0 0 20px; padding: 14px 16px;
            border-radius: 10px;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(181,224,255,0.08);
        }
        .rp-requirements p {
            font-size: 0.78rem; color: rgba(212,229,248,0.5);
            margin-bottom: 6px; font-weight: 600;
        }
        .rp-requirements ul {
            list-style: none; padding: 0;
        }
        .rp-requirements li {
            font-size: 0.76rem; color: rgba(212,229,248,0.4);
            padding: 2px 0; display: flex; align-items: center; gap: 6px;
        }
        .rp-requirements li::before {
            content: ''; width: 4px; height: 4px; border-radius: 50%;
            background: rgba(121,240,255,0.4); flex-shrink: 0;
        }

        .flash-messages { margin-bottom: 18px; }
        .flash-msg {
            padding: 12px 16px; border-radius: 10px;
            font-size: 0.84rem; font-weight: 600; margin-bottom: 8px;
            animation: flashIn 0.35s var(--ease);
        }
        .flash-msg.success {
            background: rgba(16,185,129,0.14); border: 1px solid rgba(16,185,129,0.3); color: #6ee7b7;
        }
        .flash-msg.error {
            background: rgba(239,68,68,0.14); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5;
        }
        @keyframes flashIn {
            from { opacity: 0; transform: translateY(-6px); }
            to { opacity: 1; transform: none; }
        }

        @media (max-width: 480px) {
            .rp-card { padding: 36px 24px; }
        }
    </style>
</head>
<body>
    <div class="background-scene">
        <div class="particle-field">
            <div class="particle" style="--x:12%;--y:18%;--size:6px;--opacity:0.7;--duration:7s;--pulse:3s;--delay:0s;--blur:0px;--shift-x:20px;--shift-y:-15px;--glow-size:12"></div>
            <div class="particle" style="--x:78%;--y:22%;--size:4px;--opacity:0.5;--duration:9s;--pulse:4s;--delay:1s;--blur:1px;--shift-x:-18px;--shift-y:12px;--glow-size:8"></div>
            <div class="particle tiny" style="--x:45%;--y:72%;--size:3px;--opacity:0.6;--duration:6s;--pulse:2.5s;--delay:0.5s;--blur:0px;--shift-x:14px;--shift-y:-20px;--glow-size:6"></div>
            <div class="particle" style="--x:88%;--y:65%;--size:5px;--opacity:0.45;--duration:11s;--pulse:3.5s;--delay:2s;--blur:1px;--shift-x:-22px;--shift-y:8px;--glow-size:10"></div>
            <div class="particle tiny" style="--x:25%;--y:85%;--size:2px;--opacity:0.55;--duration:8s;--pulse:3s;--delay:1.5s;--blur:0px;--shift-x:10px;--shift-y:-12px;--glow-size:5"></div>
        </div>
    </div>

    <a href="{{ path('app_login') }}" class="home-link">
        <i class="bx bx-arrow-back"></i> {{ 'reset.back_login'|trans }}
    </a>

    <div class="rp-card">
        <div class="rp-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
        </div>

        <h1 class="rp-title">{{ 'reset.heading'|trans }}</h1>
        <p class="rp-subtitle">{{ 'reset.subtitle'|trans }}</p>

        {% for type in ['success', 'error'] %}
            {% for message in app.flashes(type) %}
                <div class="flash-messages">
                    <div class="flash-msg {{ type }}">{{ message }}</div>
                </div>
            {% endfor %}
        {% endfor %}

        <form method="post" action="{{ path('app_reset_password', {token: token}) }}">
            <div class="rp-field">
                <label>{{ 'reset.new_password'|trans }}</label>
                <input type="password" name="password" placeholder="{{ 'reset.new_password_placeholder'|trans }}" required minlength="8" autocomplete="new-password" autofocus>
                <i class="bx bxs-lock-alt"></i>
            </div>

            <div class="rp-field">
                <label>{{ 'reset.confirm_password'|trans }}</label>
                <input type="password" name="confirm_password" placeholder="{{ 'reset.confirm_placeholder'|trans }}" required minlength="8" autocomplete="new-password">
                <i class="bx bxs-lock"></i>
            </div>

            <div class="rp-requirements">
                <p>{{ 'reset.requirements'|trans }}</p>
                <ul>
                    <li>{{ 'reset.req_length'|trans }}</li>
                    <li>{{ 'reset.req_mix'|trans }}</li>
                </ul>
            </div>

            <button type="submit" class="rp-btn">{{ 'reset.submit_button'|trans }}</button>
        </form>
    </div>
</body>
</html>

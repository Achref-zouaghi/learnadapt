</svg>
        </div>

        <section class="form-pane sign-in">
            <div class="form-card">
                <div class="card-main">
                    <div class="panel-kicker"><i class="bx bx-log-in-circle"></i> {{ 'auth.sign_in'|trans }}</div>
                    <h1 class="form-title">{{ 'auth.welcome_back'|trans }}</h1>
                    <p class="form-subtitle">{{ 'auth.continue_learning'|trans }}</p>

                    <div class="flash-list">
                        {% for message in successFlashes %}
                            <div class="flash success">{{ message }}</div>
                        {% endfor %}
                        {% for message in errorFlashes %}
                            <div class="flash error">{{ message }}</div>
                        {% endfor %}
                    </div>

                    <div class="social-actions">
                        <a href="{{ path('app_auth_social', {provider: 'google'}) }}" class="social-button">
                            <i class="bx bxl-google"></i>
                            <span>{{ 'auth.google'|trans }}</span>
                        </a>
                        <a href="{{ path('app_auth_social', {provider: 'github'}) }}" class="social-button">
                            <i class="bx bxl-github"></i>
                            <span>{{ 'auth.github'|trans }}</span>
                        </a>
                        <button type="button" class="social-button face-id-btn" id="faceIdBtn" onclick="startFaceIdLogin()" style="grid-column: 1 / -1; border-color: rgba(121,240,255,0.2);">
                            <i class="bx bx-face" style="color:#79f0ff;"></i>
                            <span>Sign in with Face ID / Passkey</span>
                        </button>
                        <button type="button" class="social-button ai-voice-btn" id="aiVoiceBtn" onclick="openVoiceModal()" style="grid-column: 1 / -1;">
                            <i class="bx bx-microphone" style="color:#c084fc;"></i>
                            <span>🧠 AI Personal Assistant Login</span>
                        </button>
                    </div>

                    <div class="separator">{{ 'auth.or'|trans }}</div>

                    <form method="post" action="{{ path('app_login') }}" class="auth-form">
                        <div class="field">
                            <input type="email" name="email" value="{{ loginData.email|default('') }}" placeholder="{{ 'auth.email'|trans }}" required autocomplete="email">
                            <i class="bx bxs-envelope"></i>
                        </div>

                        <div class="field">
                            <input type="password" name="password" placeholder="{{ 'auth.password'|trans }}" required autocomplete="current-password">
                            <i class="bx bxs-lock-alt"></i>
                        </div>

                        <div class="options-row">
                            <label><input type="checkbox" name="remember"> {{ 'auth.remember_me'|trans }}</label>
                            <a href="{{ path('app_forgot_password') }}">{{ 'auth.forgot'|trans }}</a>
                        </div>

                        <button type="submit" class="primary-button">{{ 'auth.login_button'|trans }}</button>
                    </form>

                    <div class="clean-switch">
                        {{ 'auth.new_here'|trans }} <a href="#" class="inline-switch signup-trigger">{{ 'auth.create_account'|trans }}</a>
                    </div>

                    <div class="mobile-toggle">
                        {{ 'auth.need_account'|trans }} <a href="#" class="inline-switch signup-trigger">{{ 'auth.sign_up'|trans }}</a>
                    </div>
                </div>
            </div>
        </section>

        <section class="form-pane sign-up">
            <div class="form-card">
                <div class="card-main">
                    <div class="panel-kicker"><i class="bx bx-user-plus"></i> {{ 'auth.register'|trans }}</div>
                    <h1 class="form-title">{{ 'auth.create_account'|trans }}</h1>
                    <p class="form-subtitle">{{ 'auth.start_clean'|trans }}</p>

                    <div class="flash-list">
                        {% for message in successFlashes %}
                            <div class="flash success">{{ message }}</div>
                        {% endfor %}
                        {% for message in errorFlashes %}
                            <div class="flash error">{{ message }}</div>
                        {% endfor %}
                    </div>

                    <div class="social-actions">
                        <a href="{{ path('app_auth_social', {provider: 'google'}) }}" class="social-button">
                            <i class="bx bxl-google"></i>
                            <span>Google</span>
                        </a>
                        <a href="{{ path('app_auth_social', {provider: 'github'}) }}" class="social-button">
                            <i class="bx bxl-github"></i>
                            <span>GitHub</span>
                        </a>
                    </div>

                    <div class="separator">or</div>

                    <form method="post" action="{{ path('app_register') }}" class="auth-form">
                        {% set errors = fieldErrors|default({}) %}
                        <div class="field{{ errors.full_name is defined ? ' has-error' : '' }}">
                            <input type="text" name="full_name" value="{{ registerData.full_name|default('') }}" placeholder="{{ 'auth.full_name'|trans }}" required minlength="2" maxlength="160" autocomplete="name" pattern="^[A-Za-zÀ-ÿ\s\-]+$">
                            <i class="bx bxs-user"></i>
                            {% if errors.full_name is defined %}<div class="field-error">{{ errors.full_name }}</div>{% endif %}
                        </div>

                        <div class="field{{ errors.email is defined ? ' has-error' : '' }}">
                            <input type="email" name="email" value="{{ registerData.email|default('') }}" placeholder="{{ 'auth.email'|trans }}" required maxlength="180" autocomplete="email">
                            <i class="bx bxs-envelope"></i>
                            {% if errors.email is defined %}<div class="field-error">{{ errors.email }}</div>{% endif %}
                        </div>

                        <div class="field{{ errors.role is defined ? ' has-error' : '' }}">
                            <select name="role" required>
                                {% for roleOption in roleOptions %}
                                    <option value="{{ roleOption }}" {{ registerData.role|default('STUDENT') == roleOption ? 'selected' : '' }}>{{ roleOption|title }}</option>
                                {% endfor %}
                            </select>
                            <i class="bx bx-chevron-down"></i>
                            {% if errors.role is defined %}<div class="field-error">{{ errors.role }}</div>{% endif %}
                        </div>

                        <div class="field{{ errors.phone is defined ? ' has-error' : '' }}">
                            <input type="tel" name="phone" value="{{ registerData.phone|default('') }}" placeholder="{{ 'auth.phone_number'|trans }}" required pattern="^\d{8}$" maxlength="8" autocomplete="tel">
                            <i class="bx bxs-phone"></i>
                            {% if errors.phone is defined %}<div class="field-error">{{ errors.phone }}</div>{% endif %}
                        </div>

                        <div class="field{{ errors.password is defined ? ' has-error' : '' }}">
                            <input type="password" name="password" placeholder="{{ 'auth.password'|trans }}" required minlength="8" autocomplete="new-password">
                            <i class="bx bxs-lock-alt"></i>
                            {% if errors.password is defined %}<div class="field-error">{{ errors.password }}</div>{% endif %}
                        </div>

                        <div class="field{{ errors.confirm_password is defined ? ' has-error' : '' }}">
                            <input type="password" name="confirm_password" placeholder="{{ 'auth.confirm_password'|trans }}" required autocomplete="new-password">
                            <i class="bx bxs-lock"></i>
                            {% if errors.confirm_password is defined %}<div class="field-error">{{ errors.confirm_password }}</div>{% endif %}
                        </div>

                        <div class="field">
                            <input type="text" name="invite_code" placeholder="Invite code" required autocomplete="off">
                            <i class="bx bxs-key"></i>
                        </div>

                        <button type="submit" class="primary-button">{{ 'auth.register_button'|trans }}</button>
                    </form>

                    <div class="clean-switch">
                        {{ 'auth.already_registered'|trans }} <a href="#" class="inline-switch login-trigger">{{ 'auth.login_button'|trans }}</a>
                    </div>

                    <div class="mobile-toggle">
                        {{ 'auth.already_registered'|trans }} <a href="#" class="inline-switch login-trigger">{{ 'auth.sign_in'|trans }}</a>
                    </div>
                </div>
            </div>
        </section>

        <div class="overlay-wrap">
            <div class="overlay">
                <section class="overlay-panel overlay-left">
                    <div class="panel-kicker"><i class="bx bx-shield-quarter"></i> {{ 'auth.blue_mode'|trans }}</div>
                    <h2 class="overlay-title">{{ 'auth.keep_flow'|trans }}</h2>
                    <p class="overlay-text">{{ 'auth.one_clean_workspace'|trans }}</p>
                    <div class="overlay-icons">
                        <span class="icon-badge"><i class="bx bx-bulb"></i></span>
                        <span class="icon-badge"><i class="bx bx-time-five"></i></span>
                        <span class="icon-badge"><i class="bx bx-line-chart"></i></span>
                    </div>

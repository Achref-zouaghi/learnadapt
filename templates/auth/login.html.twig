    <script>
        const authShell = document.getElementById('authShell');
        const signupTriggers = document.querySelectorAll('.signup-trigger');
        const loginTriggers = document.querySelectorAll('.login-trigger');
        const particleField = document.getElementById('particleField');

        function showRegister(event) {
            if (event) {
                event.preventDefault();
            }
            authShell.classList.add('active');
        }

        function showLogin(event) {
            if (event) {
                event.preventDefault();
            }
            authShell.classList.remove('active');
        }

        signupTriggers.forEach((element) => element.addEventListener('click', showRegister));
        loginTriggers.forEach((element) => element.addEventListener('click', showLogin));

        if (particleField) {
            for (let index = 0; index < 52; index += 1) {
                const particle = document.createElement('span');
                const size = Math.random() * 11 + 2;
                const duration = Math.random() * 10 + 8;
                const delay = Math.random() * -14;
                const shiftX = `${(Math.random() * 60 - 30).toFixed(2)}px`;
                const shiftY = `${(Math.random() * 80 - 40).toFixed(2)}px`;
                const opacity = (Math.random() * 0.65 + 0.18).toFixed(2);
                const blur = `${Math.random() > 0.65 ? 1.6 : 0}px`;

                particle.className = `particle${size < 4 ? ' tiny' : ''}`;
                particle.style.setProperty('--size', `${size.toFixed(2)}px`);
                particle.style.setProperty('--glow-size', `${(size * 3.4).toFixed(2)}`);
                particle.style.setProperty('--x', `${(Math.random() * 100).toFixed(2)}%`);
                particle.style.setProperty('--y', `${(Math.random() * 100).toFixed(2)}%`);
                particle.style.setProperty('--shift-x', shiftX);
                particle.style.setProperty('--shift-y', shiftY);
                particle.style.setProperty('--duration', `${duration.toFixed(2)}s`);
                particle.style.setProperty('--pulse', `${(duration * 0.55).toFixed(2)}s`);
                particle.style.setProperty('--delay', `${delay.toFixed(2)}s`);
                particle.style.setProperty('--opacity', opacity);
                particle.style.setProperty('--blur', blur);

                particleField.appendChild(particle);
            }
        }
    </script>

    <script>
    /* ── Face ID / WebAuthn Login ── */
    async function startFaceIdLogin() {
        if (!window.PublicKeyCredential) {
            alert('Your browser does not support Face ID / passkeys.');
            return;
        }
        if (location.hostname === '127.0.0.1') {
            location.replace(location.href.replace('127.0.0.1', 'localhost'));
            return;
        }

        // Get email from the login form
        const emailInput = document.querySelector('input[name="email"]');
        const email = emailInput ? emailInput.value.trim() : '';
        if (!email) {
            emailInput && emailInput.focus();
            showFaceIdMsg('Enter your email address first.', 'error');
            return;
        }

        const btn = document.getElementById('faceIdBtn');
        const origContent = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="bx bx-loader-alt" style="animation:spin 0.8s linear infinite;color:#79f0ff;"></i><span>Waiting for biometric…</span>';

        try {
            // Step 1: Get challenge from server
            const optRes = await fetch('/auth/webauthn/login-options', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ email })
            });
            const optData = await optRes.json();

            if (!optRes.ok) {
                showFaceIdMsg(optData.error || 'No passkey registered. Register one in your Profile.', 'error');
                btn.disabled = false;
                btn.innerHTML = origContent;
                return;
            }

            // Step 2: Trigger browser Face ID / biometric prompt
            const publicKey = prepareGetOptions(optData.publicKey);
            const credential = await navigator.credentials.get({ publicKey });

            // Step 3: Send assertion to server
            const verifyRes = await fetch('/auth/webauthn/login-verify', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    rawId:             bufToB64(credential.rawId),
                    clientDataJSON:    bufToB64(credential.response.clientDataJSON),
                    authenticatorData: bufToB64(credential.response.authenticatorData),
                    signature:         bufToB64(credential.response.signature),
                    userHandle:        credential.response.userHandle ? bufToB64(credential.response.userHandle) : null,
                })
            });
            const verifyData = await verifyRes.json();

            if (verifyRes.ok && verifyData.status === 'ok') {
                showFaceIdMsg('Identity confirmed! Signing you in…', 'success');
                setTimeout(() => window.location.href = verifyData.redirect || '/', 800);
            } else {
                showFaceIdMsg(verifyData.error || 'Verification failed.', 'error');
                btn.disabled = false;
                btn.innerHTML = origContent;
            }
        } catch (err) {
            if (err.name === 'NotAllowedError') {
                showFaceIdMsg('Biometric prompt was cancelled.', 'error');
            } else {
                showFaceIdMsg('Error: ' + err.message, 'error');
            }
            btn.disabled = false;
            btn.innerHTML = origContent;
        }
    }

    function prepareGetOptions(opts) {
        opts.challenge = b64ToBuf(opts.challenge);
        if (opts.allowCredentials) {
            opts.allowCredentials = opts.allowCredentials.map(c => ({
                ...c,
                id: b64ToBuf(c.id)
            }));
        }
        return opts;
    }

    function b64ToBuf(b64) {
        b64 = b64.replace(/-/g,'+').replace(/_/g,'/');
        while (b64.length % 4) b64 += '=';
        const bin = atob(b64);
        const buf = new Uint8Array(bin.length);
        for (let i = 0; i < bin.length; i++) buf[i] = bin.charCodeAt(i);
        return buf.buffer;
    }

    function bufToB64(buf) {
        return btoa(String.fromCharCode(...new Uint8Array(buf)));
    }

    function showFaceIdMsg(msg, type) {
        let el = document.getElementById('faceIdMsg');
        if (!el) {
            el = document.createElement('div');
            el.id = 'faceIdMsg';
            el.style.cssText = 'margin-top:10px;padding:10px 14px;border-radius:12px;font-size:0.82rem;text-align:center;border:1px solid;transition:all 0.3s;';
            document.getElementById('faceIdBtn').after(el);
        }
        if (type === 'success') {
            el.style.color='#aef7ff'; el.style.borderColor='rgba(121,240,255,0.3)'; el.style.background='rgba(71,200,255,0.1)';
        } else {
            el.style.color='#ffd7e1'; el.style.borderColor='rgba(242,122,160,0.24)'; el.style.background='rgba(178,67,106,0.1)';
        }
        el.textContent = msg;
    }

    // Spin keyframe for loader icon
    const styleEl = document.createElement('style');
    styleEl.textContent = '@keyframes spin { to { transform: rotate(360deg); } }';
    document.head.appendChild(styleEl);
    </script>

    <script>
    /* ── AI Personal Assistant Voice Login ── */
    (function () {
        'use strict';

        let recognition   = null;
        let isListening   = false;
        let synth         = window.speechSynthesis;

        /* ---- helpers ---- */
        function el(id) { return document.getElementById(id); }

        function setStatus(msg) {
            const s = el('aiStatus');
            if (s) s.textContent = msg;
        }

        function showTranscript(text) {
            const t = el('aiTranscript');
            if (!t) return;
            t.style.display = text ? 'block' : 'none';
            t.textContent   = text ? '🎙 "' + text + '"' : '';
        }

        function showBubble(msg, onEnd) {
            const wrap = el('aiBubble');
            const txt  = el('aiBubbleText');
            if (!wrap || !txt) { if (onEnd) setTimeout(onEnd, 0); return; }
            txt.textContent    = msg;
            wrap.style.display = 'flex';
            /* Speak the response — fire onEnd only after speech finishes */
            if (synth) {
                synth.cancel();
                const utt  = new SpeechSynthesisUtterance(msg);
                utt.lang   = 'en-US';
                utt.rate   = 1.05;
                utt.pitch  = 1.05;
                if (onEnd) utt.onend = onEnd;
                synth.speak(utt);
            } else if (onEnd) {
                setTimeout(onEnd, 300);
            }
        }

        function setListeningUI(active) {
            const btn  = el('aiMicBtn');
            const icon = el('aiMicIcon');
            const wave = el('aiWaveform');
            isListening = active;
            if (btn)  { btn.classList.toggle('active', active); }
            if (icon) { icon.className = active ? 'bx bx-stop-circle' : 'bx bx-microphone'; }
            if (wave) { wave.classList.toggle('listening', active); }
        }

        /* ---- intent detection ---- */
        const EMAIL_REGEX = /[\w.+\-]+@[\w.\-]+\.[a-z]{2,}/i;

        function extractEmail(rawText) {
            // 1. Direct match — user said or the STT produced a real email address
            let m = rawText.match(EMAIL_REGEX);
            if (m) return m[0].toLowerCase();

            // 2. Spoken word normalisation — replace "at" / "dot" etc.
            //    Use word boundaries so we don't mangle words like "that", "attend"
            let t = rawText
                .replace(/\bat\b/gi, '@')
                .replace(/\bdot\b/gi, '.')
                .replace(/\bunderscore\b/gi, '_')
                .replace(/\bdash\b|\bhyphen\b/gi, '-');

            // 3. Remove spaces only immediately around @ and .
            //    (keeps other words separated so the regex can find the email token)
            t = t
                .replace(/\s*@\s*/g, '@')
                .replace(/\s*\.\s*/g, '.');

            // 4. Try full-string regex on normalised text
            m = t.match(EMAIL_REGEX);
            if (m) return m[0].toLowerCase();

            // 5. Token scan — find the one word-token that looks like an email
            const tokens = t.split(/\s+/);
            for (const tok of tokens) {
                if (EMAIL_REGEX.test(tok)) return tok.toLowerCase().match(EMAIL_REGEX)[0];
            }

            // 6. Adjacent token join — user may have paused between parts:
            //    e.g. ["john@gmail", ".", "com"] or ["john", "@gmail.com"]
            const joined = tokens.join('');
            m = joined.match(EMAIL_REGEX);
            if (m) return m[0].toLowerCase();

            return null;
        }

        const LOGIN_INTENTS = [
            /log\s*me\s*in/i, /sign\s*me\s*in/i, /it'?s\s*me/i,
            /let\s*me\s*in/i, /my\s*email\s*is/i, /log\s*in/i,
            /sign\s*in/i,     /authenticate/i,    /access/i,
        ];

        function hasLoginIntent(text) {
            return LOGIN_INTENTS.some(re => re.test(text));
        }

        /* ---- voice check API ---- */
        async function fetchVoiceCheck(email) {
            try {
                const res = await fetch('/auth/voice-check', {
                    method : 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body   : JSON.stringify({ email }),
                });
                if (!res.ok) return null;
                return await res.json();
            } catch (_) {
                return null;
            }
        }

        /* ---- handle final transcript ---- */
        async function handleTranscript(text) {
            showTranscript(text);
            setStatus('Processing…');

            const email = extractEmail(text);
            const hasIntent = hasLoginIntent(text) || email !== null;

            if (!hasIntent && !email) {
                setStatus('Press the mic and say your email');
                showBubble("I didn't catch that. Try saying: \"Hey, it's me — log me in, my email is you@example.com\"");
                return;
            }

            if (!email) {
                /* Check if the user already typed their email in the fallback input */
                const fallbackInput = el('aiFallbackEmail');
                const typedEmail = fallbackInput ? fallbackInput.value.trim().toLowerCase() : '';
                if (typedEmail && /^[\w.+\-]+@[\w.\-]+\.[a-z]{2,}$/i.test(typedEmail)) {
                    /* Use the typed email automatically — continue as if they said it */
                    return handleTranscript(typedEmail);
                }
                setStatus('Email not detected, please try again');
                showBubble("I heard you want to log in! Could you also say your email address, or type it in the box below.");
                return;
            }

            /* Fill email field */
            const emailInput = document.querySelector('input[name="email"]');
            if (emailInput) {
                emailInput.value = email;
                emailInput.dispatchEvent(new Event('input', { bubbles: true }));
            }

            setStatus('Recognised — checking account…');

            const info = await fetchVoiceCheck(email);

            if (!info || !info.exists) {
                showBubble("Hmm, I couldn't find an account for " + email + ". Double-check the address or register first!");
                setStatus('Account not found');
                return;
            }

            /* Personalised greeting */
            let greeting = 'Welcome back, ' + info.name + '!';
            if (info.daysAgo === 0) {
                greeting += " You were here earlier today — great to see you again!";
            } else if (info.daysAgo === 1) {
                greeting += " Your last session was yesterday. Let's pick up where you left off!";
            } else if (info.daysAgo !== null && info.daysAgo <= 30) {
                greeting += ' Your last session was ' + info.daysAgo + ' days ago. Ready to continue?';
            } else {
                greeting += " It's been a while — welcome back! Let's get you in.";
            }

            /* Check voice registration and chain speech → mic correctly */
            const VL_KEY = 'learnadapt_voice_reg';
            let voiceReg = null;
            try { voiceReg = JSON.parse(localStorage.getItem(VL_KEY) || '{}'); } catch(e) {}

            if (voiceReg && voiceReg.confirmed && voiceReg.email.toLowerCase() === email.toLowerCase()) {
                /* Speak greeting, then when speech ENDS start the passphrase mic */
                passphraseAttempts = 0;
                setStatus('Voice passphrase found — listen for the prompt…');
                showBubble(greeting + ' Say your passphrase now to sign in instantly!', () => {
                    setStatus('🎤 Listening for your passphrase…');
                    startPassphraseListening(email, voiceReg.passphrase);
                });
            } else {
                showBubble(greeting, () => {
                    setStatus('Account found! Enter your password to continue.');
                    const pwInput = document.querySelector('input[name="password"]');
                    if (pwInput) pwInput.focus();
                });
            }
        }

        /* ---- voice passphrase matching & auto-login ---- */
        function normalizePhrase(s) {
            return s.toLowerCase().replace(/[^a-z0-9@.]/g, ' ').replace(/\s+/g, ' ').trim();
        }

        function levenshtein(a, b) {
            const m = a.length, n = b.length;
            const dp = Array.from({length: m + 1}, (_, i) => Array.from({length: n + 1}, (_, j) => i === 0 ? j : j === 0 ? i : 0));
            for (let i = 1; i <= m; i++) for (let j = 1; j <= n; j++)
                dp[i][j] = a[i-1] === b[j-1] ? dp[i-1][j-1] : 1 + Math.min(dp[i-1][j], dp[i][j-1], dp[i-1][j-1]);
            return dp[m][n];
        }

        function passphraseMatches(spoken, saved) {
            const a = normalizePhrase(spoken);
            const b = normalizePhrase(saved);
            if (a === b) return true;
            /* Substring match — passphrase appears inside what was spoken */
            if (a.includes(b) || b.includes(a)) return true;
            /* Character-level similarity (Levenshtein) */
            const maxLen = Math.max(a.length, b.length);
            if (maxLen > 0 && levenshtein(a, b) / maxLen <= 0.35) return true;
            /* Word overlap — 60% of saved words must appear in spoken */
            const savedWords  = b.split(' ').filter(w => w.length > 1);
            const spokenWords = a.split(' ');
            if (savedWords.length === 0) return false;
            const exactMatches = savedWords.filter(w => spokenWords.includes(w)).length;
            if (exactMatches / savedWords.length >= 0.6) return true;
            /* Fuzzy word match — word within edit distance 1 */
            const fuzzyMatches = savedWords.filter(sw => spokenWords.some(pw => levenshtein(sw, pw) <= 1)).length;
            return fuzzyMatches / savedWords.length >= 0.7;
        }

        let passphraseRec = null;
        let passphraseAttempts = 0;

        function startPassphraseListening(email, savedPassphrase) {
            /* Stop any running mic and any speech synthesis before opening mic */
            stopListening();
            if (synth) synth.cancel();
            const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
            if (!SR) {
                setStatus('Account found! Enter your password to continue.');
                return;
            }
            passphraseRec = new SR();
            passphraseRec.lang = 'en-US';
            passphraseRec.interimResults = false;
            passphraseRec.maxAlternatives = 5;

            setListeningUI(true);

            passphraseRec.onresult = async (e) => {
                setListeningUI(false);
                passphraseAttempts++;

                /* Collect all alternatives */
                const alternatives = [];
                for (let i = 0; i < e.results[0].length; i++) {
                    alternatives.push(e.results[0][i].transcript);
                }
                const bestSpoken = alternatives[0] || '';
                showTranscript('"' + bestSpoken + '"');

                const matched = alternatives.some(spoken => passphraseMatches(spoken, savedPassphrase));

                if (matched) {
                    passphraseAttempts = 0;
                    setStatus('✓ Voice matched — logging you in…');
                    showBubble('Voice confirmed! Logging you in now…');
                    try {
                        const res = await fetch('/auth/voice-login', {
                            method : 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body   : JSON.stringify({ email }),
                        });
                        const data = await res.json();
                        if (data.success) {
                            window.location.href = data.redirect || '/home';
                        } else {
                            setStatus('Login failed — try your password');
                            showBubble('Something went wrong. Please enter your password instead.');
                        }
                    } catch(_) {
                        setStatus('Connection error — try your password');
                    }
                } else if (passphraseAttempts < 3) {
                    setStatus('Not recognised — try again (' + (3 - passphraseAttempts) + ' attempt' + (passphraseAttempts < 2 ? 's' : '') + ' left)');
                    showBubble("I heard: \"" + bestSpoken + "\" — that didn't match. Try saying your passphrase again.");
                    setTimeout(() => startPassphraseListening(email, savedPassphrase), 2200);
                } else {
                    passphraseAttempts = 0;
                    setStatus('Voice login skipped — enter your password below');
                    showBubble("I couldn't match your passphrase. No worries — just enter your password below to sign in.");
                }
            };

            passphraseRec.onerror = (e) => {
                setListeningUI(false);
                if (e.error !== 'no-speech') {
                    setStatus('Mic error — enter your password below');
                } else if (passphraseAttempts < 3) {
                    /* No speech detected — keep listening */
                    setTimeout(() => startPassphraseListening(email, savedPassphrase), 1000);
                }
            };

            passphraseRec.onend = () => setListeningUI(false);
            passphraseRec.start();
        }

        /* ---- speech recognition ---- */
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

        function buildRecognition() {
            if (!SpeechRecognition) return null;
            const r          = new SpeechRecognition();
            r.lang           = 'en-US';
            r.interimResults = true;
            r.maxAlternatives = 1;
            r.continuous     = false;

            r.onstart = function () {
                setListeningUI(true);
                setStatus('Listening… speak now');
            };

            r.onresult = function (event) {
                let interim = '';
                let finalText = '';
                for (let i = event.resultIndex; i < event.results.length; i++) {
                    const t = event.results[i][0].transcript;
                    if (event.results[i].isFinal) { finalText += t; }
                    else { interim += t; }
                }
                if (interim) { setStatus('Hearing: "' + interim + '"'); }
                if (finalText.trim()) { handleTranscript(finalText.trim()); }
            };

            r.onerror = function (event) {
                setListeningUI(false);
                if (event.error === 'not-allowed' || event.error === 'denied') {
                    setStatus('Microphone access denied');
                    showBubble("I need microphone access to hear you. Please allow it in your browser settings.");
                } else if (event.error === 'no-speech') {
                    setStatus('No speech detected — try again');
                } else if (event.error === 'aborted') {
                    /* Silently ignore — happens when we stop the mic intentionally */
                } else {
                    setStatus('Error: ' + event.error);
                }
            };

            r.onend = function () { setListeningUI(false); };
            return r;
        }

        /* ── public API ── */
        window.openVoiceModal = function () {
            const modal = el('aiVoiceModal');
            if (!modal) return;
            modal.style.display = 'flex';
            /* reset state */
            showTranscript('');
            const bubble = el('aiBubble');
            if (bubble) bubble.style.display = 'none';
            const fallback = el('aiFallbackEmail');
            if (fallback) fallback.value = '';
            setStatus('Press the mic and say your email');
            setListeningUI(false);

            if (!SpeechRecognition) {
                setStatus('Voice not supported in this browser');
                showBubble("Your browser doesn't support Web Speech API. Try Chrome or Edge, or use the form below.");
            } else {
                /* Greet the user */
                setTimeout(() => {
                    showBubble("Hey there! I'm your 9rayti+ Assistant. Press the mic and say your email address to log in — or say something like \"Hey, it's me, log me in\".");
                }, 300);
            }
        };

        window.closeVoiceModal = function () {
            stopListening();
            if (synth) synth.cancel();
            const modal = el('aiVoiceModal');
            if (modal) modal.style.display = 'none';
        };

        window.toggleVoiceRecognition = function () {
            if (isListening) { stopListening(); }
            else             { startListening(); }
        };

        function startListening() {
            recognition = buildRecognition();
            if (!recognition) {
                setStatus('Speech recognition not available');
                return;
            }
            try { recognition.start(); }
            catch (_) { /* already started */ }
        }

        function stopListening() {
            if (recognition) {
                try { recognition.stop(); } catch (_) {}
                recognition = null;
            }
            setListeningUI(false);
        }

        /* ---- fallback manual email submit ---- */
        window.submitFallbackEmail = async function () {
            const input = el('aiFallbackEmail');
            if (!input) return;
            const email = input.value.trim().toLowerCase();
            if (!email || !/^[\w.+\-]+@[\w.\-]+\.[a-z]{2,}$/i.test(email)) {
                input.focus();
                setStatus('Enter a valid email address');
                return;
            }

            /* Fill the login email field immediately */
            const emailInput = document.querySelector('input[name="email"]');
            if (emailInput) {
                emailInput.value = email;
                emailInput.dispatchEvent(new Event('input', { bubbles: true }));
            }

            showTranscript(email);
            setStatus('Recognised — checking account…');

            const info = await fetchVoiceCheck(email);

            if (!info || !info.exists) {
                showBubble("Hmm, I couldn't find an account for " + email + ". Double-check the address or register first!");
                setStatus('Account not found');
                return;
            }

            let greeting = 'Welcome back, ' + info.name + '!';
            if (info.daysAgo === 0) {
                greeting += " You were here earlier today — great to see you again!";
            } else if (info.daysAgo === 1) {
                greeting += " Your last session was yesterday. Let's pick up where you left off!";
            } else if (info.daysAgo !== null && info.daysAgo <= 30) {
                greeting += ' Your last session was ' + info.daysAgo + ' days ago. Ready to continue?';
            } else {
                greeting += " It's been a while — welcome back! Let's get you in.";
            }
            /* Check voice registration — same smart chain as above */
            const VL_KEY2 = 'learnadapt_voice_reg';
            let voiceReg2 = null;
            try { voiceReg2 = JSON.parse(localStorage.getItem(VL_KEY2) || '{}'); } catch(e) {}

            if (voiceReg2 && voiceReg2.confirmed && voiceReg2.email.toLowerCase() === email.toLowerCase()) {
                passphraseAttempts = 0;
                setStatus('Voice passphrase found — listen for the prompt…');
                showBubble(greeting + ' Say your passphrase now to sign in instantly!', () => {
                    setStatus('🎤 Listening for your passphrase…');
                    startPassphraseListening(email, voiceReg2.passphrase);
                });
            } else {
                showBubble(greeting);
                setStatus('✓ Email recognised — enter your password to sign in');
            }
        };

        /* Allow Enter key in fallback input */
        document.addEventListener('keydown', function (e) {
            if (e.target && e.target.id === 'aiFallbackEmail' && e.key === 'Enter') {
                window.submitFallbackEmail();
            }
        });

        /* Close on Escape */
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') { window.closeVoiceModal(); }
        });
    }());
    </script>
</body>
</html>
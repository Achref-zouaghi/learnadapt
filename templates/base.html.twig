        .la-splat-6  { width:9px;  height:9px;  top:6%;  left:88%;  animation:la-splat-p 5.6s ease-in-out 0.3s infinite; background:rgba(147,197,253,0.50); }
        .la-splat-7  { width:10px; height:10px; top:10%; left:65%;  animation:la-splat-p 4.1s ease-in-out 2.1s infinite; background:rgba(96,165,250,0.38); }
        .la-splat-8  { width:7px;  height:7px;  top:2%;  left:35%;  animation:la-splat-p 3.9s ease-in-out 0.7s infinite; background:rgba(186,230,253,0.54); }
        .la-splat-9  { width:16px; height:12px; top:16%; left:80%;  animation:la-splat-p 5.2s ease-in-out 1.3s infinite; background:rgba(147,197,253,0.44); border-radius:58% 42% 54% 46%/52% 48% 52% 48%; }
        .la-splat-10 { width:5px;  height:5px;  top:9%;  left:48%;  animation:la-splat-p 4.3s ease-in-out 0.4s infinite; background:rgba(37,99,235,0.32); }
        .la-splat-11 { width:10px; height:7px;  top:20%; left:35%;  animation:la-splat-p 5.9s ease-in-out 1.9s infinite; background:rgba(96,165,250,0.35); border-radius:56% 44%; }
        .la-splat-12 { width:7px;  height:7px;  top:5%;  left:20%;  animation:la-splat-p 3.7s ease-in-out 2.6s infinite; background:rgba(147,197,253,0.54); }
        .la-splat-13 { width:8px;  height:8px;  top:24%; left:60%;  animation:la-splat-p 4.8s ease-in-out 3.1s infinite; background:rgba(96,165,250,0.32); }
        .la-splat-14 { width:5px;  height:5px;  top:12%; left:78%;  animation:la-splat-p 6.3s ease-in-out 1.7s infinite; background:rgba(186,230,253,0.60); }
        .la-splat-15 { width:4px;  height:4px;  top:22%; left:9%;   animation:la-splat-p 4.0s ease-in-out 0.9s infinite; background:rgba(59,130,246,0.28); }
        /* Book containers */
        .la-books-stack {
            position:absolute; bottom:-1%; right:0%;
            width:min(380px,40vw); min-width:200px;
            animation:la-books-float 7s ease-in-out infinite;

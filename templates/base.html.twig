        @keyframes la-bs-a2 { 0%,100%{ transform:translateY(0) rotate(4deg); }  50%{ transform:translateY(-22px) rotate(7deg); } }
        @keyframes la-bs-a3 { 0%,100%{ transform:translateY(0) rotate(-8deg); } 50%{ transform:translateY(-20px) rotate(-11deg); } }
        @keyframes la-fb-a1 { 0%,100%{ transform:translateY(0) rotate(-6deg); }  50%{ transform:translateY(-22px) rotate(-9deg); } }
        @keyframes la-fb-a2 { 0%,100%{ transform:translateY(0) rotate(9deg); }   50%{ transform:translateY(-26px) rotate(13deg); } }
        @keyframes la-fb-a3 { 0%,100%{ transform:translateY(0) rotate(4deg); }   40%{ transform:translateY(-18px) rotate(7deg); } 80%{ transform:translateY(-10px) rotate(2deg); } }
        @keyframes la-fb-a4 { 0%,100%{ transform:translateY(0) rotate(-11deg); } 60%{ transform:translateY(-24px) rotate(-8deg); } }
        @keyframes la-fb-a5 { 0%,100%{ transform:translateY(0) rotate(7deg); }   50%{ transform:translateY(-20px) rotate(11deg); } }
        @media(max-width:768px){ .la-books-stack{width:min(240px,46vw)} .la-book-open{width:min(210px,40vw)} .la-bs-2,.la-bs-3{display:none} .la-fb-3,.la-fb-4,.la-fb-5,.la-fb-6,.la-fb-7{display:none} }

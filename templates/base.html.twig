<!DOCTYPE html>
<html lang="{{ app.request.locale }}" data-theme="{{ userTheme|default('dark') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Learn Adapt{% endblock %}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        display: ['Playfair Display', 'serif'],
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        forest: {
                            50: '#f0f5f4',
                            100: '#d1e0dc',
                            200: '#a3c1b9',
                            300: '#75a296',
                            400: '#4a7d6e',
                            500: '#2d5c4f',
                            600: '#1e4a3e',
                            700: '#1a3c34',
                            800: '#142e28',
                            900: '#0e201c',
                        },
                        cream: {
                            50: '#fdfcf9',
                            100: '#f8f4ec',
                            200: '#f3ede0',
                            300: '#e8dece',
                            400: '#d4c4a8',
                        },
                        coral: {
                            500: '#e85d4a',
                            600: '#d14a38',
                        },
                    },
                }
            }
        }
    </script>
    <style>
        .card-hover {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .card-hover:hover {
            transform: translateY(-6px);
            box-shadow: 0 16px 32px rgba(0,0,0,0.1);
        }

        #main-navbar.navbar-scrolled #main-navbar-shell {
            background: rgba(10, 14, 24, 0.88);
            border-color: rgba(134, 178, 255, 0.14);
            box-shadow: 0 20px 50px rgba(0,0,0,0.42), inset 0 1px 0 rgba(255,255,255,0.04);
            transform: translateY(2px) scale(0.99);
        }

        /* ── Light theme: Override CSS variables globally ── */
        html[data-theme="light"] {
            --bg: #f5f7fa;
            --text: #1a1a2e;
            --muted: #6b7280;
            --glass: rgba(0,0,0,0.03);
            --glass-b: rgba(0,0,0,0.06);
            --card: rgba(0,0,0,0.02);
            --card-h: rgba(0,0,0,0.04);
            --border: rgba(0,0,0,0.08);
            --shadow: 0 2px 12px rgba(0,0,0,0.06);
            --purple: #7b61f1;
            --purple-soft: #8b5cf6;
            --cyan: #0891b2;
            --green: #059669;
            --red: #dc2626;
            --orange: #ea580c;
            --yellow: #d97706;
            --gold: #b45309;
            /* Legacy lt- variables kept for existing rules */
            --lt-bg: #f5f7fa;
            --lt-bg-alt: #ffffff;
            --lt-text: #1a1a2e;
            --lt-text-muted: #6b7280;
            --lt-border: rgba(0,0,0,0.08);
            --lt-glass: rgba(255,255,255,0.85);
            --lt-glass-b: rgba(0,0,0,0.06);
            --lt-purple: #7b61f1;
            --lt-green: #059669;
            --lt-shadow: 0 2px 12px rgba(0,0,0,0.06);
        }
        html[data-theme="light"] body,
        html[data-theme="light"] body.dark-page {
            background: #f5f7fa !important;
            color: #1a1a2e !important;
        }
        [data-theme="light"] .s-site {
            background: var(--lt-bg) !important;
        }
        [data-theme="light"] .s-header-card,
        [data-theme="light"] .s-sidebar,
        [data-theme="light"] .s-panel,
        [data-theme="light"] .s-tile,
        [data-theme="light"] .s-data-stat {
            background: var(--lt-glass) !important;
            border-color: var(--lt-glass-b) !important;
            backdrop-filter: none !important;
            box-shadow: var(--lt-shadow) !important;
        }
        [data-theme="light"] .s-header-card h1,
        [data-theme="light"] .s-panel h2,
        [data-theme="light"] .s-field-label,
        [data-theme="light"] .s-sidebar-link.active {
            color: var(--lt-text) !important;
        }
        [data-theme="light"] .s-header-card p,
        [data-theme="light"] .s-panel p.sub,
        [data-theme="light"] .s-label,
        [data-theme="light"] .s-field-hint,
        [data-theme="light"] .s-sidebar-link,
        [data-theme="light"] .s-data-stat-label {
            color: var(--lt-text-muted) !important;
        }
        [data-theme="light"] .s-sidebar-link:hover {
            color: var(--lt-text) !important;
            background: rgba(0,0,0,0.03) !important;
        }
        [data-theme="light"] .s-sidebar-link.active {
            background: rgba(123,97,241,0.08) !important;
            border-color: rgba(123,97,241,0.18) !important;
        }
        [data-theme="light"] .s-input,
        [data-theme="light"] .s-textarea {
            background: #fff !important;
            border-color: var(--lt-glass-b) !important;
            color: var(--lt-text) !important;
        }
        [data-theme="light"] .s-input::placeholder,
        [data-theme="light"] .s-textarea::placeholder {
            color: #9ca3af !important;
        }
        [data-theme="light"] .s-data-stat-value {
            color: var(--lt-text) !important;
        }
        [data-theme="light"] .s-flash-success {
            background: rgba(5,150,105,0.08) !important;
            border-color: rgba(5,150,105,0.2) !important;
            color: var(--lt-green) !important;
        }
        [data-theme="light"] .s-flash-error {
            background: rgba(220,38,38,0.08) !important;
            border-color: rgba(220,38,38,0.18) !important;
            color: #dc2626 !important;
        }
        [data-theme="light"] .s-modal {
            background: #fff !important;
            border-color: var(--lt-glass-b) !important;
        }
        [data-theme="light"] .s-modal h3 { color: #dc2626 !important; }
        [data-theme="light"] .s-modal p { color: var(--lt-text-muted) !important; }

        /* ── Light theme: Profile page ── */
        [data-theme="light"] .pr-scene {
            background:
                radial-gradient(1100px 700px at 80% -10%, rgba(123,97,241,0.04), transparent 62%),
                radial-gradient(900px 600px at 10% 5%, rgba(56,189,209,0.04), transparent 60%),
                var(--lt-bg) !important;
        }
        [data-theme="light"] .pr-stats-card,
        [data-theme="light"] .pr-card,
        [data-theme="light"] .pr-banner-wrap {
            background: var(--lt-glass) !important;
            border-color: var(--lt-glass-b) !important;
            backdrop-filter: none !important;
            box-shadow: var(--lt-shadow) !important;
        }
        [data-theme="light"] .pr-card h3,
        [data-theme="light"] .pr-stat-val,
        [data-theme="light"] .pr-user-name {
            color: var(--lt-text) !important;
        }
        [data-theme="light"] .pr-stat-lbl,
        [data-theme="light"] .pr-user-role,
        [data-theme="light"] .pr-user-location {
            color: var(--lt-text-muted) !important;
        }

        /* ── Light theme: Navbar (dark-page variant) ── */
        [data-theme="light"] .nav {
            background: linear-gradient(180deg, rgba(245,247,250,0.92), rgba(245,247,250,0.6)) !important;
        }
        [data-theme="light"] .nav.scrolled {
            background: transparent !important;
        }
        [data-theme="light"] .nav-menu-shell {
            background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(255,255,255,0.82)) !important;
            border-color: rgba(0,0,0,0.1) !important;
            box-shadow: 0 4px 24px rgba(0,0,0,0.08), inset 0 1px 0 rgba(255,255,255,0.9) !important;
        }
        [data-theme="light"] .nav-links a {
            color: #374151 !important;
        }
        [data-theme="light"] .nav-links a:hover,
        [data-theme="light"] .nav-links a.is-active {
            color: #111827 !important;
            background: rgba(0,0,0,0.04) !important;
        }
        [data-theme="light"] .nav-notif-panel {
            background: #fff !important;
            border-color: rgba(0,0,0,0.08) !important;
            box-shadow: 0 12px 40px rgba(0,0,0,0.12) !important;
        }
        [data-theme="light"] .nav-notif-title,
        [data-theme="light"] .nav-notif-item p {
            color: var(--lt-text) !important;
        }
        [data-theme="light"] .nav-notif-meta,
        [data-theme="light"] .nav-notif-action {
            color: var(--lt-text-muted) !important;
        }
        [data-theme="light"] .nav-profile-dropdown {
            background: #fff !important;
            border-color: rgba(0,0,0,0.08) !important;
            box-shadow: 0 12px 40px rgba(0,0,0,0.12) !important;
        }
        [data-theme="light"] .nav-profile-dropdown a {
            color: #374151 !important;
        }
        [data-theme="light"] .nav-profile-dropdown a:hover {
            background: rgba(0,0,0,0.04) !important;
            color: #111827 !important;
        }
        [data-theme="light"] .page-brand-kicker {
            color: #6b7280 !important;
        }

        /* ── Light theme: Hide dark animated background ── */
        [data-theme="light"] .la-bg,
        [data-theme="light"] .stars-canvas {
            display: none !important;
        }

        /* ── Stars animated background ── */
        .stars-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 0;
            pointer-events: none;
        }

        /* ── Light theme: Global catch-all for common patterns ── */
        /* Page wrappers */
        [data-theme="light"] .cr-page,
        [data-theme="light"] .cs-page,
        [data-theme="light"] .ex-page,
        [data-theme="light"] .fm,
        [data-theme="light"] .ft,
        [data-theme="light"] .av,
        [data-theme="light"] .kb,
        [data-theme="light"] .qz-page,
        [data-theme="light"] .qt-page,
        [data-theme="light"] .qr-page,
        [data-theme="light"] .adm {
            color: #1a1a2e !important;
        }

        /* Cards, tiles, panels */
        [data-theme="light"] .cr-card,
        [data-theme="light"] .cs-section,
        [data-theme="light"] .cs-ex-card,
        [data-theme="light"] .ex-card,
        [data-theme="light"] .fm-topic,
        [data-theme="light"] .ft-post,
        [data-theme="light"] .ft-reply,
        [data-theme="light"] .av-card,
        [data-theme="light"] .kb-card,
        [data-theme="light"] .kb-col,
        [data-theme="light"] .qz-card,
        [data-theme="light"] .qt-question,
        [data-theme="light"] .qr-q,
        [data-theme="light"] .qr-stat,
        [data-theme="light"] .adm-panel,
        [data-theme="light"] .adm-stat {
            background: rgba(255,255,255,0.85) !important;
            border-color: rgba(0,0,0,0.08) !important;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06) !important;
            backdrop-filter: none !important;
        }

        /* Hero / header sections */
        [data-theme="light"] .cr-hero,
        [data-theme="light"] .cs-hero,
        [data-theme="light"] .ex-hero,
        [data-theme="light"] .av-hero,
        [data-theme="light"] .qr-score-hero {
            background: linear-gradient(135deg, rgba(123,97,241,0.06), rgba(56,189,209,0.04)) !important;
        }

        /* Headings */
        [data-theme="light"] .cr-card h3,
        [data-theme="light"] .cs-section h2,
        [data-theme="light"] .ex-card h3,
        [data-theme="light"] .fm-topic h3,
        [data-theme="light"] .ft-post h4,
        [data-theme="light"] .av-card h3,
        [data-theme="light"] .kb-col h3,
        [data-theme="light"] .kb-card h4,
        [data-theme="light"] .qz-card h3,
        [data-theme="light"] .qt-question h3,
        [data-theme="light"] .qr-q h4,
        [data-theme="light"] .adm-panel h2,
        [data-theme="light"] .adm-stat h3 {
            color: #1a1a2e !important;
        }

        /* Muted text */
        [data-theme="light"] .cr-card p,
        [data-theme="light"] .cs-ex-card p,
        [data-theme="light"] .ex-card p,
        [data-theme="light"] .fm-topic p,
        [data-theme="light"] .ft-post p,
        [data-theme="light"] .av-card p,
        [data-theme="light"] .kb-card p,
        [data-theme="light"] .qz-card p {
            color: #374151 !important;
        }

        /* Search/input fields */
        [data-theme="light"] .cr-search,
        [data-theme="light"] .fm-search,
        [data-theme="light"] .ex-search,
        [data-theme="light"] .kb-search {
            background: #fff !important;
            border-color: rgba(0,0,0,0.1) !important;
            color: #1a1a2e !important;
        }

        /* Modals */
        [data-theme="light"] .fm-modal,
        [data-theme="light"] .ft-modal,
        [data-theme="light"] .av-modal,
        [data-theme="light"] .kb-modal,
        [data-theme="light"] .adm-modal,
        [data-theme="light"] .qt-modal {
            background: #fff !important;
            border-color: rgba(0,0,0,0.08) !important;
            box-shadow: 0 20px 60px rgba(0,0,0,0.15) !important;
            color: #1a1a2e !important;
        }

        /* Modal overlays */
        [data-theme="light"] .fm-modal-bg,
        [data-theme="light"] .ft-modal-bg,
        [data-theme="light"] .kb-modal-bg,
        [data-theme="light"] .adm-modal-mask {
            background: rgba(0,0,0,0.3) !important;
        }

        /* Badges & chips */
        [data-theme="light"] .cr-badge,
        [data-theme="light"] .cs-badge,
        [data-theme="light"] .ex-badge,
        [data-theme="light"] .fm-role,
        [data-theme="light"] .qz-badge,
        [data-theme="light"] .qr-level,
        [data-theme="light"] .adm-role-tag {
            border-color: rgba(0,0,0,0.1) !important;
        }

        /* Stats */
        [data-theme="light"] .cr-stat,
        [data-theme="light"] .ex-st,
        [data-theme="light"] .fm-stat,
        [data-theme="light"] .av-stat,
        [data-theme="light"] .kb-st,
        [data-theme="light"] .qz-stat,
        [data-theme="light"] .qr-stat-val,
        [data-theme="light"] .adm-stat-val {
            color: #1a1a2e !important;
        }

        /* Quiz options */
        [data-theme="light"] .qt-option {
            background: #fff !important;
            border-color: rgba(0,0,0,0.1) !important;
            color: #1a1a2e !important;
        }
        [data-theme="light"] .qt-option:hover {
            background: rgba(123,97,241,0.04) !important;
            border-color: rgba(123,97,241,0.2) !important;
        }

        /* Admin sidebar */
        [data-theme="light"] .adm-side {
            background: rgba(255,255,255,0.92) !important;
            border-color: rgba(0,0,0,0.06) !important;
        }
        [data-theme="light"] .adm-side a {
            color: #374151 !important;
        }
        [data-theme="light"] .adm-side a:hover,
        [data-theme="light"] .adm-side a.active {
            background: rgba(123,97,241,0.06) !important;
            color: #1a1a2e !important;
        }

        /* Tables (admin) */
        [data-theme="light"] .cr-table th,
        [data-theme="light"] .ex-table th,
        [data-theme="light"] .usr-table th,
        [data-theme="light"] .adm-table th {
            color: #6b7280 !important;
            border-color: rgba(0,0,0,0.06) !important;
        }
        [data-theme="light"] .cr-table td,
        [data-theme="light"] .ex-table td,
        [data-theme="light"] .usr-table td,
        [data-theme="light"] .adm-table td {
            color: #1a1a2e !important;
            border-color: rgba(0,0,0,0.04) !important;
        }
        [data-theme="light"] .adm-user-row:hover {
            background: rgba(0,0,0,0.02) !important;
        }

        /* Select elements (admin) */
        [data-theme="light"] select,
        [data-theme="light"] select option {
            background: #fff !important;
            color: #1a1a2e !important;
        }

        /* Taskboard kanban */
        [data-theme="light"] .kb-board {
            background: transparent !important;
        }
        [data-theme="light"] .kb-pomo {
            background: rgba(255,255,255,0.85) !important;
            border-color: rgba(0,0,0,0.08) !important;
        }

        /* Forum filter buttons */
        [data-theme="light"] .fm-filter-btn {
            background: rgba(0,0,0,0.03) !important;
            border-color: rgba(0,0,0,0.08) !important;
            color: #374151 !important;
        }
        [data-theme="light"] .fm-filter-btn.active,
        [data-theme="light"] .fm-filter-btn:hover {
            background: rgba(123,97,241,0.08) !important;
            border-color: rgba(123,97,241,0.2) !important;
            color: #7b61f1 !important;
        }

        /* Feedback reactions */
        [data-theme="light"] .av-react-btn {
            background: rgba(0,0,0,0.03) !important;
            border-color: rgba(0,0,0,0.08) !important;
        }

        /* Auth page */
        [data-theme="light"] .auth-shell {
            background: #f5f7fa !important;
        }
        [data-theme="light"] .form-pane {
            background: rgba(255,255,255,0.9) !important;
            border-color: rgba(0,0,0,0.08) !important;
            box-shadow: 0 4px 24px rgba(0,0,0,0.06) !important;
        }
        [data-theme="light"] .auth-form .field input {
            background: #fff !important;
            border-color: rgba(0,0,0,0.12) !important;
            color: #1a1a2e !important;
        }
        [data-theme="light"] .auth-form .field label {
            color: #374151 !important;
        }
        [data-theme="light"] .social-button {
            background: #fff !important;
            border-color: rgba(0,0,0,0.12) !important;
            color: #374151 !important;
        }

        /* Profile specific */
        [data-theme="light"] .pr-modal {
            background: #fff !important;
            border-color: rgba(0,0,0,0.08) !important;
        }
        [data-theme="light"] .pr-timeline-dot {
            border-color: rgba(0,0,0,0.08) !important;
        }
        [data-theme="light"] .pr-badge-icon {
            background: rgba(123,97,241,0.08) !important;
        }

        /* Scrollbar for light theme */
        [data-theme="light"] ::-webkit-scrollbar-track {
            background: #f1f5f9 !important;
        }
        [data-theme="light"] ::-webkit-scrollbar-thumb {
            background: #cbd5e1 !important;
        }
        [data-theme="light"] ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8 !important;
        }

        /* Flash messages */
        [data-theme="light"] .av-flash,
        [data-theme="light"] .kb-flash,
        [data-theme="light"] .fm-flash {
            background: rgba(5,150,105,0.08) !important;
            border-color: rgba(5,150,105,0.2) !important;
            color: #059669 !important;
        }

        /* Navbar scrolled state for light */
        [data-theme="light"] #main-navbar.navbar-scrolled #main-navbar-shell {
            background: rgba(255,255,255,0.88) !important;
            border-color: rgba(0,0,0,0.08) !important;
            box-shadow: 0 4px 24px rgba(0,0,0,0.06) !important;
        }

        /* Download/action buttons */
        [data-theme="light"] .ex-download-btn,
        [data-theme="light"] .cs-back {
            background: rgba(0,0,0,0.03) !important;
            border-color: rgba(0,0,0,0.1) !important;
            color: #374151 !important;
        }

        /* Links in light mode */
        [data-theme="light"] a:not([class]) {
            color: #7b61f1;
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body class="font-sans antialiased {{ userTheme|default('dark') == 'light' ? 'text-gray-800 bg-[#f5f7fa]' : (darkPage|default(false) ? 'text-gray-100 bg-[#050508]' : 'text-gray-800 bg-[#f5f7fa]') }}">
    <canvas class="stars-canvas" id="starsCanvas"></canvas>
    {% include 'partials/_navbar.html.twig' with { darkPage: darkPage|default(false) } %}

    {% block body %}{% endblock %}

    {% if not darkPage|default(false) %}
        {% include 'partials/_footer.html.twig' %}
    {% endif %}

    <script>
        // Mobile menu toggle
        const mobileBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        if (mobileBtn && mobileMenu) {
            mobileBtn.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));
        }

        // Navbar scroll effect
        const navbar = document.getElementById('main-navbar');
        if (navbar) {
            window.addEventListener('scroll', () => {
                if (window.scrollY > 10) {
                    navbar.classList.add('shadow-md');
                    navbar.classList.add('navbar-scrolled');
                } else {
                    navbar.classList.remove('shadow-md');
                    navbar.classList.remove('navbar-scrolled');
                }
            });
        }

        // Notification dropdown toggle
        const notifBell = document.getElementById('notif-bell');
        const notifDropdown = document.getElementById('notif-dropdown');
        const notifWrapper = document.getElementById('notif-wrapper');
        if (notifBell && notifDropdown) {
            notifBell.addEventListener('click', (e) => {
                e.stopPropagation();
                notifDropdown.classList.toggle('hidden');
            });
            document.addEventListener('click', (e) => {
                if (notifWrapper && !notifWrapper.contains(e.target)) {
                    notifDropdown.classList.add('hidden');
                }
            });
        }
    </script>
    {% block javascripts %}{% endblock %}

    <script>
    (function() {
        var c = document.getElementById('starsCanvas');
        if (!c) return;
        // Skip on light theme
        if (document.documentElement.getAttribute('data-theme') === 'light') return;

        var ctx = c.getContext('2d');
        var dpr = window.devicePixelRatio || 1;
        var W, H, stars = [], shooters = [], icons = [], nebulas = [];
        var STAR_COUNT = 140;
        var ICON_COUNT = 22;
        var SHOOTER_CHANCE = 0.0015;
        var time = 0;

        // ── Education icon SVG paths (drawn on canvas) ──
        var iconDefs = [
            { name: 'book', draw: function(ctx, s) {
                ctx.beginPath(); ctx.moveTo(-s,-s*0.8); ctx.lineTo(0,-s*0.4); ctx.lineTo(s,-s*0.8);
                ctx.lineTo(s,s*0.8); ctx.lineTo(0,s*0.4); ctx.lineTo(-s,s*0.8); ctx.closePath(); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(0,-s*0.4); ctx.lineTo(0,s*0.4); ctx.stroke();
            }},
            { name: 'gradcap', draw: function(ctx, s) {
                ctx.beginPath(); ctx.moveTo(0,-s*0.6); ctx.lineTo(s,0); ctx.lineTo(0,s*0.3);
                ctx.lineTo(-s,0); ctx.closePath(); ctx.fill(); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(s*0.5,s*0.1); ctx.lineTo(s*0.5,s*0.7);
                ctx.lineTo(0,s*0.9); ctx.lineTo(-s*0.5,s*0.7); ctx.lineTo(-s*0.5,s*0.1); ctx.stroke();
                ctx.beginPath(); ctx.arc(s,0,s*0.12,0,Math.PI*2); ctx.fill();
                ctx.beginPath(); ctx.moveTo(s,s*0.12); ctx.lineTo(s,s*0.8); ctx.stroke();
            }},
            { name: 'lightbulb', draw: function(ctx, s) {
                ctx.beginPath(); ctx.arc(0,-s*0.15,s*0.55,Math.PI*0.8,Math.PI*0.2); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(-s*0.25,s*0.35); ctx.lineTo(-s*0.25,s*0.65);
                ctx.lineTo(s*0.25,s*0.65); ctx.lineTo(s*0.25,s*0.35); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(-s*0.18,s*0.75); ctx.lineTo(s*0.18,s*0.75); ctx.stroke();
                // Rays
                for (var i = 0; i < 5; i++) {
                    var a = -Math.PI/2 + (i-2)*0.45;
                    ctx.beginPath();
                    ctx.moveTo(Math.cos(a)*s*0.65, Math.sin(a)*s*0.65 - s*0.15);
                    ctx.lineTo(Math.cos(a)*s*0.85, Math.sin(a)*s*0.85 - s*0.15);
                    ctx.stroke();
                }
            }},
            { name: 'pencil', draw: function(ctx, s) {
                ctx.beginPath();
                ctx.moveTo(-s*0.1,-s); ctx.lineTo(s*0.1,-s);
                ctx.lineTo(s*0.1,s*0.6); ctx.lineTo(0,s);
                ctx.lineTo(-s*0.1,s*0.6); ctx.closePath(); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(-s*0.1,s*0.6); ctx.lineTo(s*0.1,s*0.6); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(-s*0.1,-s*0.7); ctx.lineTo(s*0.1,-s*0.7); ctx.stroke();
            }},
            { name: 'atom', draw: function(ctx, s) {
                ctx.beginPath(); ctx.arc(0,0,s*0.12,0,Math.PI*2); ctx.fill();
                for (var i = 0; i < 3; i++) {
                    ctx.save(); ctx.rotate(i * Math.PI / 3);
                    ctx.beginPath(); ctx.ellipse(0,0,s*0.8,s*0.3,0,0,Math.PI*2); ctx.stroke();
                    ctx.restore();
                }
            }},
            { name: 'flask', draw: function(ctx, s) {
                ctx.beginPath();
                ctx.moveTo(-s*0.15,-s); ctx.lineTo(-s*0.15,-s*0.3);
                ctx.lineTo(-s*0.6,s*0.7); ctx.quadraticCurveTo(-s*0.6,s,0,s);
                ctx.quadraticCurveTo(s*0.6,s,s*0.6,s*0.7);
                ctx.lineTo(s*0.15,-s*0.3); ctx.lineTo(s*0.15,-s);
                ctx.closePath(); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(-s*0.25,-s); ctx.lineTo(s*0.25,-s); ctx.stroke();
            }},
            { name: 'globe', draw: function(ctx, s) {
                ctx.beginPath(); ctx.arc(0,0,s*0.75,0,Math.PI*2); ctx.stroke();
                ctx.beginPath(); ctx.ellipse(0,0,s*0.35,s*0.75,0,0,Math.PI*2); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(-s*0.75,0); ctx.lineTo(s*0.75,0); ctx.stroke();
                ctx.beginPath();
                ctx.ellipse(0,-s*0.3,s*0.6,s*0.15,0,0,Math.PI*2); ctx.stroke();
            }},
            { name: 'calculator', draw: function(ctx, s) {
                ctx.strokeRect(-s*0.5,-s,s,s*2);
                ctx.fillRect(-s*0.35,-s*0.8,s*0.7,s*0.4);
                for (var r = 0; r < 3; r++) {
                    for (var cc = 0; cc < 3; cc++) {
                        ctx.fillRect(-s*0.35+cc*s*0.28, -s*0.2+r*s*0.32, s*0.18, s*0.2);
                    }
                }
            }},
            { name: 'music', draw: function(ctx, s) {
                ctx.beginPath(); ctx.ellipse(-s*0.3,s*0.6,s*0.25,s*0.18,0.3,0,Math.PI*2); ctx.fill();
                ctx.beginPath(); ctx.ellipse(s*0.3,s*0.3,s*0.25,s*0.18,-0.3,0,Math.PI*2); ctx.fill();
                ctx.beginPath(); ctx.moveTo(-s*0.08,-s*0.9); ctx.lineTo(-s*0.08,s*0.55); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(s*0.52,-s*0.6); ctx.lineTo(s*0.52,s*0.25); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(-s*0.08,-s*0.9); ctx.lineTo(s*0.52,-s*0.6); ctx.stroke();
            }},
            { name: 'star5', draw: function(ctx, s) {
                ctx.beginPath();
                for (var i = 0; i < 5; i++) {
                    var a = -Math.PI/2 + i * Math.PI * 2 / 5;
                    var ar = a + Math.PI * 2 / 10;
                    ctx.lineTo(Math.cos(a)*s*0.8, Math.sin(a)*s*0.8);
                    ctx.lineTo(Math.cos(ar)*s*0.35, Math.sin(ar)*s*0.35);
                }
                ctx.closePath(); ctx.stroke(); ctx.fill();
            }},
            { name: 'pi', draw: function(ctx, s) {
                ctx.font = 'bold ' + (s*1.8) + 'px Inter, sans-serif';
                ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
                ctx.strokeText('\u03C0', 0, 0);
            }},
            { name: 'infinity', draw: function(ctx, s) {
                ctx.font = 'bold ' + (s*2) + 'px Inter, sans-serif';
                ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
                ctx.strokeText('\u221E', 0, 0);
            }},
            { name: 'rocket', draw: function(ctx, s) {
                ctx.beginPath();
                ctx.moveTo(0,-s); ctx.quadraticCurveTo(s*0.4,-s*0.4,s*0.3,s*0.4);
                ctx.lineTo(s*0.5,s*0.8); ctx.lineTo(0,s*0.5);
                ctx.lineTo(-s*0.5,s*0.8); ctx.lineTo(-s*0.3,s*0.4);
                ctx.quadraticCurveTo(-s*0.4,-s*0.4,0,-s); ctx.closePath(); ctx.stroke();
                ctx.beginPath(); ctx.arc(0,-s*0.1,s*0.15,0,Math.PI*2); ctx.stroke();
            }},
            { name: 'trophy', draw: function(ctx, s) {
                ctx.beginPath();
                ctx.moveTo(-s*0.35,-s*0.8); ctx.lineTo(s*0.35,-s*0.8);
                ctx.quadraticCurveTo(s*0.5,0,0,s*0.2);
                ctx.quadraticCurveTo(-s*0.5,0,-s*0.35,-s*0.8); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(0,s*0.2); ctx.lineTo(0,s*0.6); ctx.stroke();
                ctx.beginPath(); ctx.moveTo(-s*0.3,s*0.6); ctx.lineTo(s*0.3,s*0.6);
                ctx.lineTo(s*0.35,s*0.8); ctx.lineTo(-s*0.35,s*0.8); ctx.closePath(); ctx.stroke();
                // Handles
                ctx.beginPath(); ctx.arc(-s*0.4,-s*0.4,s*0.2,Math.PI*1.5,Math.PI*0.5); ctx.stroke();
                ctx.beginPath(); ctx.arc(s*0.4,-s*0.4,s*0.2,Math.PI*0.5,Math.PI*1.5); ctx.stroke();
            }}
        ];

        // Color palette for icons
        var iconColors = [
            { stroke: 'rgba(123,97,241,0.18)', fill: 'rgba(123,97,241,0.06)' },  // purple
            { stroke: 'rgba(56,189,209,0.18)',  fill: 'rgba(56,189,209,0.06)' },  // cyan
            { stroke: 'rgba(52,211,153,0.15)',  fill: 'rgba(52,211,153,0.05)' },  // green
            { stroke: 'rgba(251,146,60,0.14)',  fill: 'rgba(251,146,60,0.05)' },  // orange
            { stroke: 'rgba(248,113,113,0.14)', fill: 'rgba(248,113,113,0.05)' }, // red
            { stroke: 'rgba(196,181,253,0.16)', fill: 'rgba(196,181,253,0.05)' }, // lavender
            { stroke: 'rgba(147,197,253,0.16)', fill: 'rgba(147,197,253,0.05)' }  // sky
        ];

        function resize() {
            W = window.innerWidth;
            H = window.innerHeight;
            c.width = W * dpr;
            c.height = H * dpr;
            c.style.width = W + 'px';
            c.style.height = H + 'px';
            ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        }

        function initStars() {
            stars = [];
            for (var i = 0; i < STAR_COUNT; i++) {
                stars.push({
                    x: Math.random() * W,
                    y: Math.random() * H,
                    r: Math.random() * 1.4 + 0.2,
                    a: Math.random(),
                    da: (Math.random() * 0.006 + 0.001) * (Math.random() < 0.5 ? 1 : -1),
                    color: ['#fff','#c4b5fd','#93c5fd','#6ee7b7','#fde68a'][Math.floor(Math.random() * 5)],
                    drift: (Math.random() - 0.5) * 0.06
                });
            }
        }

        function initIcons() {
            icons = [];
            for (var i = 0; i < ICON_COUNT; i++) {
                var col = iconColors[Math.floor(Math.random() * iconColors.length)];
                icons.push({
                    x: Math.random() * W,
                    y: Math.random() * H,
                    size: Math.random() * 14 + 10,
                    rot: Math.random() * Math.PI * 2,
                    rotSpeed: (Math.random() - 0.5) * 0.004,
                    vx: (Math.random() - 0.5) * 0.2,
                    vy: (Math.random() - 0.5) * 0.15 - 0.05,
                    a: Math.random() * 0.5 + 0.3,
                    da: (Math.random() * 0.003 + 0.001) * (Math.random() < 0.5 ? 1 : -1),
                    wobbleAmp: Math.random() * 0.3 + 0.1,
                    wobbleSpeed: Math.random() * 0.01 + 0.005,
                    wobbleOffset: Math.random() * Math.PI * 2,
                    defIdx: Math.floor(Math.random() * iconDefs.length),
                    stroke: col.stroke,
                    fill: col.fill,
                    lineW: Math.random() * 0.6 + 0.8
                });
            }
        }

        function initNebulas() {
            nebulas = [];
            for (var i = 0; i < 3; i++) {
                nebulas.push({
                    x: Math.random() * W,
                    y: Math.random() * H,
                    rx: Math.random() * 200 + 150,
                    ry: Math.random() * 150 + 100,
                    color: ['rgba(123,97,241,0.015)','rgba(56,189,209,0.012)','rgba(248,113,113,0.01)'][i],
                    vx: (Math.random() - 0.5) * 0.08,
                    vy: (Math.random() - 0.5) * 0.06,
                    pulsePhase: Math.random() * Math.PI * 2
                });
            }
        }

        function spawnShooter() {
            var startX = Math.random() * W * 0.8;
            var startY = Math.random() * H * 0.4;
            shooters.push({
                x: startX, y: startY,
                len: Math.random() * 80 + 40,
                speed: Math.random() * 6 + 4,
                angle: Math.PI / 4 + (Math.random() - 0.5) * 0.3,
                life: 1,
                decay: Math.random() * 0.015 + 0.01
            });
        }

        function draw() {
            time++;
            ctx.clearRect(0, 0, W, H);

            // ── Nebula blobs ──
            for (var n = 0; n < nebulas.length; n++) {
                var nb = nebulas[n];
                nb.x += nb.vx;
                nb.y += nb.vy;
                if (nb.x < -nb.rx) nb.x = W + nb.rx;
                if (nb.x > W + nb.rx) nb.x = -nb.rx;
                if (nb.y < -nb.ry) nb.y = H + nb.ry;
                if (nb.y > H + nb.ry) nb.y = -nb.ry;
                var pulse = 1 + Math.sin(time * 0.005 + nb.pulsePhase) * 0.15;
                ctx.globalAlpha = 1;
                var grd = ctx.createRadialGradient(nb.x, nb.y, 0, nb.x, nb.y, nb.rx * pulse);
                grd.addColorStop(0, nb.color);
                grd.addColorStop(1, 'rgba(0,0,0,0)');
                ctx.fillStyle = grd;
                ctx.beginPath();
                ctx.ellipse(nb.x, nb.y, nb.rx * pulse, nb.ry * pulse, 0, 0, Math.PI * 2);
                ctx.fill();
            }

            // ── Stars ──
            for (var i = 0; i < stars.length; i++) {
                var s = stars[i];
                s.a += s.da;
                if (s.a <= 0.08 || s.a >= 1) s.da *= -1;
                s.a = Math.max(0.08, Math.min(1, s.a));
                s.y += s.drift;
                if (s.y < -2) s.y = H + 2;
                if (s.y > H + 2) s.y = -2;

                ctx.beginPath();
                ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
                ctx.fillStyle = s.color;
                ctx.globalAlpha = s.a * 0.8;
                ctx.fill();
                if (s.r > 1.0) {
                    ctx.beginPath();
                    ctx.arc(s.x, s.y, s.r * 2.5, 0, Math.PI * 2);
                    ctx.globalAlpha = s.a * 0.06;
                    ctx.fill();
                }
            }

            // ── Floating education icons ──
            for (var k = 0; k < icons.length; k++) {
                var ic = icons[k];
                // Animate position
                ic.x += ic.vx + Math.sin(time * ic.wobbleSpeed + ic.wobbleOffset) * ic.wobbleAmp;
                ic.y += ic.vy;
                ic.rot += ic.rotSpeed;
                // Alpha pulse
                ic.a += ic.da;
                if (ic.a <= 0.15 || ic.a >= 0.7) ic.da *= -1;
                ic.a = Math.max(0.15, Math.min(0.7, ic.a));
                // Wrap around
                if (ic.x < -60) ic.x = W + 60;
                if (ic.x > W + 60) ic.x = -60;
                if (ic.y < -60) { ic.y = H + 60; ic.x = Math.random() * W; }
                if (ic.y > H + 60) { ic.y = -60; ic.x = Math.random() * W; }

                ctx.save();
                ctx.translate(ic.x, ic.y);
                ctx.rotate(ic.rot);
                ctx.globalAlpha = ic.a;
                ctx.strokeStyle = ic.stroke;
                ctx.fillStyle = ic.fill;
                ctx.lineWidth = ic.lineW;
                ctx.lineCap = 'round';
                ctx.lineJoin = 'round';
                iconDefs[ic.defIdx].draw(ctx, ic.size);
                ctx.restore();
            }

            // ── Shooting stars ──
            if (Math.random() < SHOOTER_CHANCE) spawnShooter();
            for (var j = shooters.length - 1; j >= 0; j--) {
                var sh = shooters[j];
                sh.x += Math.cos(sh.angle) * sh.speed;
                sh.y += Math.sin(sh.angle) * sh.speed;
                sh.life -= sh.decay;
                if (sh.life <= 0) { shooters.splice(j, 1); continue; }

                var tailX = sh.x - Math.cos(sh.angle) * sh.len;
                var tailY = sh.y - Math.sin(sh.angle) * sh.len;
                var grad = ctx.createLinearGradient(tailX, tailY, sh.x, sh.y);
                grad.addColorStop(0, 'rgba(255,255,255,0)');
                grad.addColorStop(1, 'rgba(255,255,255,' + (sh.life * 0.6) + ')');
                ctx.beginPath();
                ctx.moveTo(tailX, tailY);
                ctx.lineTo(sh.x, sh.y);
                ctx.strokeStyle = grad;
                ctx.globalAlpha = 1;
                ctx.lineWidth = 1.5;
                ctx.stroke();
                ctx.beginPath();
                ctx.arc(sh.x, sh.y, 2, 0, Math.PI * 2);
                ctx.fillStyle = '#fff';
                ctx.globalAlpha = sh.life * 0.8;
                ctx.fill();
            }

            ctx.globalAlpha = 1;
            requestAnimationFrame(draw);
        }

        resize();
        initStars();
        initIcons();
        initNebulas();
        draw();
        window.addEventListener('resize', function() { resize(); initStars(); initIcons(); initNebulas(); });
    })();
    </script>
</body>
</html>

            filter:drop-shadow(0 28px 48px rgba(0,0,0,0.16)) drop-shadow(0 8px 16px rgba(0,0,0,0.08));
        }
        .la-book-open {
            position:absolute; bottom:-1%; left:1%;
            width:min(320px,36vw); min-width:180px;

        /* ═══════════════════════════════════════════
           Page transition — clean light professional fade
           ═══════════════════════════════════════════ */
        #la-page-veil {
            position: fixed; inset: 0; z-index: 99999;
            background: rgba(248,250,252,0.97);
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
            display: flex; align-items: center; justify-content: center;
            flex-direction: column;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.28s cubic-bezier(0.4,0,0.2,1);
        }

        /* ── Slim top progress bar (NProgress style) ── */
        #la-veil-bar {
            position: absolute; top: 0; left: 0;
            height: 3px; width: 0%; z-index: 5;
            background: linear-gradient(90deg,
                #3B82F6 0%, #6366F1 40%, #8B5CF6 70%, #3B82F6 100%);
            background-size: 300% 100%;
            border-radius: 0 2px 2px 0;
            box-shadow: 0 0 10px rgba(99,102,241,0.4);
        }
        @keyframes la-bar-shimmer {
            0%   { background-position: 100% 0; }
            100% { background-position: -100% 0; }
        }

        /* ── Dot spinner ── */
        #la-veil-dots {
            display: flex; gap: 7px; align-items: center;
        }
        .la-veil-dot {
            width: 8px; height: 8px; border-radius: 50%;
            background: linear-gradient(135deg, #6366F1, #3B82F6);
            opacity: 0.15;
        }
        @keyframes la-dot-pulse {
            0%, 80%, 100% { opacity: 0.15; transform: scale(0.8); }
            40%            { opacity: 1;    transform: scale(1); }
        }
        .la-veil-dot:nth-child(1) { animation: la-dot-pulse 1.1s ease-in-out 0s    infinite; }
        .la-veil-dot:nth-child(2) { animation: la-dot-pulse 1.1s ease-in-out 0.18s infinite; }
        .la-veil-dot:nth-child(3) { animation: la-dot-pulse 1.1s ease-in-out 0.36s infinite; }

        /* ── Fade IN (navigating away) ── */
        #la-page-veil.la-veil-in {
            opacity: 1;
            pointer-events: all;
            transition: opacity 0.2s cubic-bezier(0.4,0,0.2,1);
        }
        #la-page-veil.la-veil-in #la-veil-bar {
            width: 85%;
            transition: width 0.55s cubic-bezier(0.4,0,0.2,1);
            animation: la-bar-shimmer 1.4s linear infinite;
        }

        /* ── Fade OUT (new page revealed) ── */
        #la-page-veil.la-veil-out {
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.32s cubic-bezier(0.4,0,0.2,1);
        }
        #la-page-veil.la-veil-out #la-veil-bar {
            width: 100%;
            opacity: 0;
            transition: width 0.12s ease, opacity 0.2s ease 0.1s;
        }


        .la-fb-4 { width:34px; top:18%; right:30%; animation:la-fb-a4 10.2s ease-in-out 2.2s infinite; }
        .la-fb-5 { width:38px; top:38%; right:25%; animation:la-fb-a5 8.8s ease-in-out 0.6s infinite; }
        .la-fb-6 { width:30px; top:55%; left:8%;   animation:la-fb-a2 12s ease-in-out 3.5s infinite; }
        .la-fb-7 { width:40px; top:45%; left:42%;  animation:la-fb-a1 9.6s ease-in-out 1.8s infinite; }
        /* Keyframes */
        @keyframes la-wc-1 {
            0%,100%{ transform:translate(0,0) scale(1) rotate(0deg); }
            25%    { transform:translate(20px,-16px) scale(1.04) rotate(1.4deg); }
            50%    { transform:translate(-18px,20px) scale(0.96) rotate(-1.2deg); }
            75%    { transform:translate(12px,8px) scale(1.02) rotate(0.5deg); }
        }
        @keyframes la-wc-2 {
            0%,100%{ transform:translate(0,0) scale(1); }

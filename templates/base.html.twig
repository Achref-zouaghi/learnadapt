        .la-splat-2  { width:9px;  height:9px;  top:4%;  left:55%;  animation:la-splat-p 5.1s ease-in-out 0.5s infinite; background:rgba(147,197,253,0.58); }
        .la-splat-3  { width:7px;  height:7px;  top:14%; left:42%;  animation:la-splat-p 3.7s ease-in-out 1.1s infinite; background:rgba(59,130,246,0.40); }

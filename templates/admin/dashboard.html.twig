{% extends 'base.html.twig' %}
{% set darkPage = true %}
{% block title %}Admin Dashboard — LearnAdapt{% endblock %}

{% block stylesheets %}
<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

:root{--bg:#04060e;--purple:#7b61f1;--cyan:#38bdd1;--green:#34d399;--red:#f87171;--orange:#fb923c;--yellow:#fbbf24;--text:#f6f8fc;--muted:#8896ab;--glass:rgba(255,255,255,0.035);--glass-b:rgba(255,255,255,0.06);--card:rgba(255,255,255,0.025);--card-h:rgba(255,255,255,0.05);--border:rgba(255,255,255,0.06);--ease:cubic-bezier(0.4,0,0.2,1)}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body,body.dark-page{font-family:'Inter',sans-serif!important;background:#020a10!important;color:var(--text)}
footer{display:none!important}

/* ═══ LAYOUT ═══ */
.adm{display:flex;min-height:100vh;padding-top:72px}

/* ═══ SIDEBAR ═══ */
.adm-side{width:260px;position:fixed;top:72px;left:0;bottom:0;background:rgba(6,12,22,0.95);border-right:1px solid var(--border);backdrop-filter:blur(20px);padding:28px 16px;display:flex;flex-direction:column;z-index:50;overflow-y:auto}
.adm-side-head{padding:0 12px 20px;border-bottom:1px solid var(--border);margin-bottom:16px}
.adm-side-head h2{font-size:1.1rem;font-weight:900;letter-spacing:-0.03em}
.adm-side-head h2 span{background:linear-gradient(135deg,var(--cyan),var(--green));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
.adm-side-head p{font-size:0.72rem;color:var(--muted);margin-top:4px}
.adm-nav{list-style:none;display:flex;flex-direction:column;gap:4px;flex:1}
.adm-nav a{display:flex;align-items:center;gap:12px;padding:12px 16px;border-radius:12px;color:var(--muted);text-decoration:none;font-size:0.84rem;font-weight:600;transition:all .22s var(--ease);position:relative}
.adm-nav a:hover{color:var(--text);background:rgba(255,255,255,0.04)}
.adm-nav a.is-active{color:var(--cyan);background:rgba(56,189,209,0.08)}
.adm-nav a.is-active::before{content:'';position:absolute;left:0;top:50%;transform:translateY(-50%);width:3px;height:20px;background:var(--cyan);border-radius:0 3px 3px 0}
.adm-nav a i{font-size:1.2rem;width:22px;text-align:center}
.adm-nav-divider{height:1px;background:var(--border);margin:12px 8px}

/* ═══ MAIN ═══ */
.adm-main{flex:1;margin-left:260px;padding:32px;overflow-x:hidden;position:relative}

/* Ambient bg */
.adm-bg-orb{position:fixed;border-radius:50%;filter:blur(120px);opacity:0.08;pointer-events:none;z-index:0}
.adm-bg-orb--1{width:500px;height:500px;background:radial-gradient(circle,var(--cyan),transparent 70%);top:-5%;right:10%;animation:orbF1 18s ease-in-out infinite}
.adm-bg-orb--2{width:400px;height:400px;background:radial-gradient(circle,var(--purple),transparent 70%);bottom:10%;left:30%;animation:orbF2 22s ease-in-out infinite}
@keyframes orbF1{0%,100%{transform:translate(0,0)}50%{transform:translate(40px,30px)}}
@keyframes orbF2{0%,100%{transform:translate(0,0)}50%{transform:translate(-30px,-40px)}}

/* ═══ HERO ═══ */
.adm-hero{position:relative;padding:32px 36px;background:linear-gradient(135deg,rgba(56,189,209,0.06),rgba(123,97,241,0.04));border:1px solid rgba(56,189,209,0.08);border-radius:20px;backdrop-filter:blur(20px);overflow:hidden;margin-bottom:28px;animation:fadeIn .5s var(--ease)}
.adm-hero::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(56,189,209,0.3),rgba(123,97,241,0.2),transparent)}
@keyframes fadeIn{from{opacity:0;transform:translateY(-12px)}to{opacity:1;transform:none}}
.adm-hero-row{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px}
.adm-hero-greet{font-size:0.82rem;color:var(--cyan);font-weight:600;margin-bottom:4px}
.adm-hero h1{font-size:1.9rem;font-weight:900;letter-spacing:-0.04em}
.adm-hero-sub{color:var(--muted);font-size:0.82rem;margin-top:6px}
.adm-hero-avatar{width:56px;height:56px;border-radius:16px;background:linear-gradient(135deg,rgba(56,189,209,0.15),rgba(123,97,241,0.1));border:1px solid rgba(56,189,209,0.12);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0}
.adm-hero-avatar img{width:100%;height:100%;object-fit:cover}
.adm-hero-avatar i{font-size:1.6rem;color:var(--cyan)}

/* ═══ STAT GRID ═══ */
.adm-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px}
@media(max-width:1100px){.adm-stats{grid-template-columns:repeat(2,1fr)}}
.adm-stat{position:relative;background:var(--card);border:1px solid var(--border);border-radius:16px;padding:22px 24px;backdrop-filter:blur(14px);transition:all .3s var(--ease);overflow:hidden;animation:stUp .5s var(--ease) backwards}
.adm-stat:nth-child(1){animation-delay:0s}.adm-stat:nth-child(2){animation-delay:.06s}.adm-stat:nth-child(3){animation-delay:.12s}.adm-stat:nth-child(4){animation-delay:.18s}
@keyframes stUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
.adm-stat::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;opacity:0;transition:opacity .3s}
.adm-stat:hover{transform:translateY(-3px);border-color:rgba(255,255,255,0.1)}.adm-stat:hover::after{opacity:1}
.adm-stat:nth-child(1)::after{background:linear-gradient(90deg,var(--cyan),var(--green))}
.adm-stat:nth-child(2)::after{background:linear-gradient(90deg,var(--purple),#a78bfa)}
.adm-stat:nth-child(3)::after{background:linear-gradient(90deg,var(--orange),var(--yellow))}
.adm-stat:nth-child(4)::after{background:linear-gradient(90deg,var(--green),#6ee7b7)}
.adm-stat-row{display:flex;align-items:center;gap:16px}
.adm-stat-icon{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0}
.adm-stat:nth-child(1) .adm-stat-icon{background:rgba(56,189,209,0.12);color:var(--cyan)}
.adm-stat:nth-child(2) .adm-stat-icon{background:rgba(123,97,241,0.12);color:var(--purple)}
.adm-stat:nth-child(3) .adm-stat-icon{background:rgba(251,191,36,0.12);color:var(--yellow)}
.adm-stat:nth-child(4) .adm-stat-icon{background:rgba(52,211,153,0.12);color:var(--green)}
.adm-stat-val{font-size:1.8rem;font-weight:900;letter-spacing:-0.03em;line-height:1}
.adm-stat-label{font-size:0.7rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;margin-top:3px}
.adm-stat-badge{font-size:0.65rem;font-weight:700;padding:3px 8px;border-radius:6px;margin-top:6px;display:inline-flex;align-items:center;gap:3px}
.adm-stat-badge.up{background:rgba(52,211,153,0.1);color:var(--green)}
.adm-stat-badge.neutral{background:rgba(136,150,171,0.1);color:var(--muted)}

/* ═══ 2-COL LAYOUT ═══ */
.adm-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:20px;margin-bottom:28px}
@media(max-width:900px){.adm-grid{grid-template-columns:1fr}}

/* ═══ PANEL ═══ */
.adm-panel{background:var(--card);border:1px solid var(--border);border-radius:18px;backdrop-filter:blur(14px);overflow:hidden;animation:stUp .5s var(--ease) .2s backwards}
.adm-panel-head{display:flex;align-items:center;justify-content:space-between;padding:20px 24px;border-bottom:1px solid var(--border)}
.adm-panel-title{font-size:0.92rem;font-weight:800;display:flex;align-items:center;gap:8px}
.adm-panel-title i{font-size:1.1rem;color:var(--cyan)}
.adm-panel-link{font-size:0.76rem;font-weight:600;color:var(--cyan);text-decoration:none;transition:opacity .2s}.adm-panel-link:hover{opacity:.7}
.adm-panel-body{padding:16px 24px}

/* ═══ USER ROW ═══ */
.adm-user-row{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.03);transition:background .15s}
.adm-user-row:last-child{border-bottom:none}
.adm-user-row:hover{background:rgba(255,255,255,0.015);border-radius:10px;padding-left:8px;padding-right:8px}
.adm-user-av{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,rgba(56,189,209,0.15),rgba(123,97,241,0.1));display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0;font-size:0.72rem;font-weight:800;color:var(--cyan)}
.adm-user-av img{width:100%;height:100%;object-fit:cover}
.adm-user-info{flex:1;min-width:0}
.adm-user-name{font-size:0.82rem;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.adm-user-email{font-size:0.7rem;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.adm-role-tag{padding:3px 10px;border-radius:7px;font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em}
.adm-role-tag.student{background:rgba(56,189,209,0.1);color:var(--cyan)}
.adm-role-tag.teacher{background:rgba(123,97,241,0.1);color:var(--purple)}
.adm-role-tag.expert{background:rgba(52,211,153,0.1);color:var(--green)}
.adm-role-tag.parent{background:rgba(251,191,36,0.1);color:var(--yellow)}
.adm-role-tag.admin{background:rgba(248,113,113,0.1);color:var(--red)}
.adm-status-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.adm-status-dot.active{background:var(--green);box-shadow:0 0 6px rgba(52,211,153,0.4)}
.adm-status-dot.inactive{background:var(--red);box-shadow:0 0 6px rgba(248,113,113,0.3)}

/* ═══ TOPIC ROW ═══ */
.adm-topic-row{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.03)}
.adm-topic-row:last-child{border-bottom:none}
.adm-topic-icon{width:36px;height:36px;border-radius:10px;background:rgba(123,97,241,0.08);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--purple);font-size:1rem}
.adm-topic-info{flex:1;min-width:0}
.adm-topic-name{font-size:0.82rem;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.adm-topic-meta{font-size:0.7rem;color:var(--muted);display:flex;gap:10px;margin-top:2px}
.adm-cat-tag{padding:3px 10px;border-radius:7px;font-size:0.65rem;font-weight:700;text-transform:uppercase;background:rgba(123,97,241,0.08);color:var(--purple);letter-spacing:0.04em}

/* ═══ FEEDBACK ROW ═══ */
.adm-fb-row{padding:14px 0;border-bottom:1px solid rgba(255,255,255,0.03)}
.adm-fb-row:last-child{border-bottom:none}
.adm-fb-top{display:flex;align-items:center;gap:10px;margin-bottom:6px}
.adm-fb-stars{display:flex;gap:2px;color:var(--yellow);font-size:0.85rem}
.adm-fb-author{font-size:0.75rem;color:var(--muted);margin-left:auto}
.adm-fb-text{font-size:0.8rem;color:var(--text);opacity:0.85;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}

/* ═══ MINI STAT CARDS ═══ */
.adm-mini-stats{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px}
.adm-mini{background:var(--glass);border:1px solid var(--border);border-radius:14px;padding:18px 20px;text-align:center;transition:all .25s var(--ease)}
.adm-mini:hover{background:var(--glass-b);transform:translateY(-2px)}
.adm-mini-val{font-size:1.5rem;font-weight:900;letter-spacing:-0.03em}
.adm-mini-lbl{font-size:0.68rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-top:3px}

/* ═══ RATING VISUAL ═══ */
.adm-rating-bar{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.adm-rating-label{font-size:0.72rem;color:var(--muted);width:14px;text-align:center;font-weight:700}
.adm-rating-track{flex:1;height:6px;background:rgba(255,255,255,0.04);border-radius:3px;overflow:hidden}
.adm-rating-fill{height:100%;border-radius:3px;transition:width .6s var(--ease)}
.adm-rating-count{font-size:0.68rem;color:var(--muted);width:26px;text-align:right;font-weight:600}

/* ═══ REVENUE SECTION ═══ */
.rev-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px}
@media(max-width:1100px){.rev-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.rev-grid{grid-template-columns:1fr}}
.rev-card{position:relative;border-radius:16px;padding:20px 22px;overflow:hidden;border:1px solid transparent;transition:transform .25s var(--ease)}
.rev-card:hover{transform:translateY(-3px)}
.rev-card--total{background:linear-gradient(135deg,rgba(120,86,237,0.18),rgba(56,189,209,0.08));border-color:rgba(120,86,237,0.2)}
.rev-card--month{background:linear-gradient(135deg,rgba(52,211,153,0.14),rgba(56,189,209,0.06));border-color:rgba(52,211,153,0.2)}
.rev-card--active{background:linear-gradient(135deg,rgba(251,191,36,0.12),rgba(251,113,133,0.06));border-color:rgba(251,191,36,0.18)}
.rev-card--plans{background:linear-gradient(135deg,rgba(56,189,209,0.1),rgba(123,97,241,0.06));border-color:rgba(56,189,209,0.15)}
.rev-card-lbl{font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);margin-bottom:8px;display:flex;align-items:center;gap:6px}
.rev-card-lbl i{font-size:0.95rem}
.rev-card-val{font-size:2rem;font-weight:900;letter-spacing:-0.04em;line-height:1}
.rev-card-sub{font-size:0.7rem;color:var(--muted);margin-top:6px}
.rev-glow{position:absolute;top:-30px;right:-30px;width:90px;height:90px;border-radius:50%;filter:blur(35px);opacity:0.25;pointer-events:none}
.rev-panel-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:28px}
@media(max-width:860px){.rev-panel-grid{grid-template-columns:1fr}}
.rev-plan-row{display:flex;align-items:center;gap:12px;padding:14px 0;border-bottom:1px solid rgba(255,255,255,0.04)}
.rev-plan-row:last-child{border-bottom:none}
.rev-plan-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.rev-plan-name{font-size:0.84rem;font-weight:700;flex:1;text-transform:capitalize}
.rev-plan-badge{font-size:0.62rem;padding:3px 8px;border-radius:6px;font-weight:700;background:rgba(255,255,255,0.05);color:var(--muted)}
.rev-plan-revenue{font-size:0.84rem;font-weight:800;color:var(--green);margin-left:auto;margin-right:0;min-width:70px;text-align:right}
.rev-plan-bar-wrap{width:100%;height:4px;background:rgba(255,255,255,0.04);border-radius:2px;margin-top:6px;overflow:hidden}
.rev-plan-bar{height:100%;border-radius:2px;transition:width .7s var(--ease)}
.rev-sub-row{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.04)}
.rev-sub-row:last-child{border-bottom:none}
.rev-sub-av{width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,rgba(123,97,241,0.2),rgba(56,189,209,0.1));display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:800;color:var(--purple);flex-shrink:0}
.rev-sub-info{flex:1;min-width:0}
.rev-sub-name{font-size:0.8rem;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.rev-sub-email{font-size:0.68rem;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.rev-plan-tag{font-size:0.63rem;font-weight:700;padding:3px 9px;border-radius:6px;text-transform:uppercase;letter-spacing:0.04em}
.rev-plan-tag.starter{background:rgba(136,150,171,0.12);color:#a0aec0}
.rev-plan-tag.pro{background:rgba(123,97,241,0.14);color:#a78bfa}
.rev-plan-tag.teams{background:rgba(52,211,153,0.12);color:var(--green)}
.rev-amount{font-size:0.82rem;font-weight:800;color:var(--green);margin-left:auto;white-space:nowrap}
.rev-cycle{font-size:0.6rem;color:var(--muted);text-align:right;margin-top:2px}
.rev-section-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}
.rev-section-title{font-size:1.05rem;font-weight:900;display:flex;align-items:center;gap:8px}
.rev-section-title i{color:var(--green)}
.rev-divider{height:1px;background:linear-gradient(90deg,rgba(52,211,153,0.3),transparent);margin-bottom:24px}

/* ═══ QUICK ACTIONS ═══ */
.adm-actions{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;padding:20px 24px}
.adm-action-btn{display:flex;align-items:center;gap:10px;padding:14px 18px;background:var(--glass);border:1px solid var(--border);border-radius:14px;color:var(--text);text-decoration:none;font-size:0.8rem;font-weight:700;transition:all .25s var(--ease)}
.adm-action-btn:hover{background:var(--glass-b);transform:translateY(-2px);border-color:rgba(56,189,209,0.15)}
.adm-action-btn i{font-size:1.2rem;color:var(--cyan)}

/* ═══ RESPONSIVE ═══ */
@media(max-width:768px){
	.adm-side{display:none}
	.adm-main{margin-left:0}
	.adm-stats{grid-template-columns:1fr 1fr}
	.adm-mini-stats{grid-template-columns:1fr 1fr}
	.adm-actions{grid-template-columns:1fr}
}
</style>
{% endblock %}

{% block body %}
{% include 'admin/_premium.html.twig' %}

<div class="adm">
	<!-- ═══ SIDEBAR ═══ -->
	<aside class="adm-side">
		<div class="adm-side-head">
			<h2><span>Admin</span> Panel</h2>
			<p>LearnAdapt Management</p>
		</div>
		<ul class="adm-nav">
			<li><a href="{{ path('app_admin') }}" class="is-active"><i class='bx bxs-dashboard'></i> Dashboard</a></li>
			<li><a href="{{ path('app_admin_users') }}"><i class='bx bxs-group'></i> Users</a></li>
			<li><a href="{{ path('app_admin_forum') }}"><i class='bx bxs-chat'></i> Forum</a></li>
			<li><a href="{{ path('app_admin_feedback') }}"><i class='bx bxs-star-half'></i> Feedback</a></li>
			<li><a href="{{ path('app_admin_exercises') }}"><i class='bx bxs-book-content'></i> Exercises</a></li>
			<li><a href="{{ path('app_admin_quizzes') }}"><i class='bx bxs-brain'></i> Quizzes</a></li>
			<li><a href="{{ path('app_admin_courses') }}"><i class='bx bxs-book-alt'></i> Courses</a></li>
			<div class="adm-nav-divider"></div>
			<li><a href="{{ path('app_home') }}"><i class='bx bx-arrow-back'></i> Back to App</a></li>
			<li><a href="{{ path('app_settings') }}"><i class='bx bx-cog'></i> Settings</a></li>
		</ul>
	</aside>

	<!-- ═══ MAIN ═══ -->
	<main class="adm-main">
		<!-- Hero -->
		<div class="adm-hero">
			<div class="adm-hero-row">
				<div>
					<div class="adm-hero-greet">Welcome back 👋</div>
					<h1>Dashboard</h1>
					<p class="adm-hero-sub">Here's what's happening on your platform today</p>
				</div>
				<div class="adm-hero-avatar">
					{% if user.avatarBase64 %}
						<img src="{{ user.avatarBase64 }}" alt="">
					{% else %}
						<i class='bx bxs-user'></i>
					{% endif %}
				</div>
			</div>
		</div>

		<!-- Top Stats -->
		<div class="adm-stats">
			<div class="adm-stat">
				<div class="adm-stat-row">
					<div class="adm-stat-icon"><i class='bx bxs-group'></i></div>
					<div>
						<div class="adm-stat-val">{{ userStats.total_users|default(0) }}</div>
						<div class="adm-stat-label">Total Users</div>
						<span class="adm-stat-badge up"><i class='bx bx-trending-up'></i> +{{ userStats.new_this_week|default(0) }} this week</span>
					</div>
				</div>
			</div>
			<div class="adm-stat">
				<div class="adm-stat-row">
					<div class="adm-stat-icon"><i class='bx bxs-chat'></i></div>
					<div>
						<div class="adm-stat-val">{{ forumStats.total_topics|default(0) }}</div>
						<div class="adm-stat-label">Forum Topics</div>
						<span class="adm-stat-badge up"><i class='bx bx-message-dots'></i> {{ forumStats.total_posts|default(0) }} posts</span>
					</div>
				</div>
			</div>
			<div class="adm-stat">
				<div class="adm-stat-row">
					<div class="adm-stat-icon"><i class='bx bxs-star-half'></i></div>
					<div>
						<div class="adm-stat-val">{{ feedbackStats.avg_rating|default('0') }}</div>
						<div class="adm-stat-label">Avg Rating</div>
						<span class="adm-stat-badge neutral"><i class='bx bx-message-detail'></i> {{ feedbackStats.total_feedback|default(0) }} reviews</span>
					</div>
				</div>
			</div>
			<div class="adm-stat">
				<div class="adm-stat-row">
					<div class="adm-stat-icon"><i class='bx bxs-book-content'></i></div>
					<div>
						<div class="adm-stat-val">{{ exerciseStats.total_exercises|default(0) }}</div>
						<div class="adm-stat-label">Exercises</div>
						<span class="adm-stat-badge up"><i class='bx bx-category'></i> {{ exerciseStats.total_modules|default(0) }} modules</span>
					</div>
				</div>
			</div>
		</div>

		<!-- 2-col grid -->
		<div class="adm-grid">
			<!-- Recent Users -->
			<div class="adm-panel">
				<div class="adm-panel-head">
					<span class="adm-panel-title"><i class='bx bxs-group'></i> Recent Users</span>
					<a href="{{ path('app_admin_users') }}" class="adm-panel-link">View all →</a>
				</div>
				<div class="adm-panel-body">
					{% for u in recentUsers %}
					<div class="adm-user-row">
						<div class="adm-user-av">
							{{ u.full_name|default('?')|slice(0,2)|upper }}
						</div>
						<div class="adm-user-info">
							<div class="adm-user-name">{{ u.full_name }}</div>
							<div class="adm-user-email">{{ u.email }}</div>
						</div>
						<span class="adm-role-tag {{ u.role|lower }}">{{ u.role }}</span>
						<span class="adm-status-dot {{ u.is_active ? 'active' : 'inactive' }}" title="{{ u.is_active ? 'Active' : 'Inactive' }}"></span>
					</div>
					{% endfor %}
				</div>
			</div>

			<!-- Right column -->
			<div style="display:flex;flex-direction:column;gap:20px">
				<!-- User breakdown -->
				<div class="adm-panel">
					<div class="adm-panel-head">
						<span class="adm-panel-title"><i class='bx bxs-pie-chart-alt-2'></i> User Breakdown</span>
					</div>
					<div class="adm-panel-body">
						<div class="adm-mini-stats">
							<div class="adm-mini">
								<div class="adm-mini-val" style="color:var(--cyan)">{{ userStats.students|default(0) }}</div>
								<div class="adm-mini-lbl">Students</div>
							</div>
							<div class="adm-mini">
								<div class="adm-mini-val" style="color:var(--purple)">{{ userStats.teachers|default(0) }}</div>
								<div class="adm-mini-lbl">Teachers</div>
							</div>
							<div class="adm-mini">
								<div class="adm-mini-val" style="color:var(--green)">{{ userStats.experts|default(0) }}</div>
								<div class="adm-mini-lbl">Experts</div>
							</div>
							<div class="adm-mini">
								<div class="adm-mini-val" style="color:var(--yellow)">{{ userStats.parents|default(0) }}</div>
								<div class="adm-mini-lbl">Parents</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Quick actions -->
				<div class="adm-panel">
					<div class="adm-panel-head">
						<span class="adm-panel-title"><i class='bx bxs-zap'></i> Quick Actions</span>
					</div>
					<div class="adm-actions">
						<a href="{{ path('app_admin_users') }}" class="adm-action-btn"><i class='bx bx-user-plus'></i> Manage Users</a>
						<a href="{{ path('app_admin_forum') }}" class="adm-action-btn"><i class='bx bx-message-square-edit'></i> Moderate Forum</a>
						<a href="{{ path('app_admin_exercises') }}" class="adm-action-btn"><i class='bx bx-book-add'></i> Manage Exercises</a>
						<a href="{{ path('app_admin_feedback') }}" class="adm-action-btn"><i class='bx bx-bar-chart-alt-2'></i> View Feedback</a>
					</div>
				</div>
			</div>
		</div>

		<!-- Bottom grid -->
		<div class="adm-grid">
			<!-- Recent Forum -->
			<div class="adm-panel">
				<div class="adm-panel-head">
					<span class="adm-panel-title"><i class='bx bxs-chat'></i> Recent Forum Topics</span>
					<a href="{{ path('app_admin_forum') }}" class="adm-panel-link">View all →</a>
				</div>
				<div class="adm-panel-body">
					{% for t in recentTopics %}
					<div class="adm-topic-row">
						<div class="adm-topic-icon"><i class='bx bx-message-rounded-dots'></i></div>
						<div class="adm-topic-info">
							<div class="adm-topic-name">{{ t.title }}</div>
							<div class="adm-topic-meta">
								<span>{{ t.author_name }}</span>
								<span>{{ t.reply_count }} replies</span>
								<span>{{ t.created_at|date('M d') }}</span>
							</div>
						</div>
						<span class="adm-cat-tag">{{ t.category }}</span>
					</div>
					{% endfor %}
				</div>
			</div>

			<!-- Feedback overview -->
			<div class="adm-panel">
				<div class="adm-panel-head">
					<span class="adm-panel-title"><i class='bx bxs-star-half'></i> Feedback Overview</span>
					<a href="{{ path('app_admin_feedback') }}" class="adm-panel-link">View all →</a>
				</div>
				<div class="adm-panel-body">
					<!-- Rating bars -->
					<div style="margin-bottom:20px">
						{% set totalFb = feedbackStats.total_feedback|default(1) %}
						{% set stars = {5: feedbackStats.five_star|default(0), 4: feedbackStats.four_star|default(0), 3: feedbackStats.three_star|default(0), 2: feedbackStats.two_star|default(0), 1: feedbackStats.one_star|default(0)} %}
						{% for i in 5..1 %}
						{% set count = stars[i]|default(0) %}
						<div class="adm-rating-bar">
							<span class="adm-rating-label">{{ i }}</span>
							<div class="adm-rating-track">
								<div class="adm-rating-fill" style="width:{{ totalFb > 0 ? (count / totalFb * 100) : 0 }}%;background:{{ i >= 4 ? 'var(--green)' : (i == 3 ? 'var(--yellow)' : 'var(--red)') }}"></div>
							</div>
							<span class="adm-rating-count">{{ count }}</span>
						</div>
						{% endfor %}
					</div>

					<!-- Recent feedback -->
					{% for fb in recentFeedback|slice(0, 3) %}
					<div class="adm-fb-row">
						<div class="adm-fb-top">
							<div class="adm-fb-stars">
								{% for i in 1..5 %}
									<i class='bx {{ i <= fb.rating ? "bxs-star" : "bx-star" }}'></i>
								{% endfor %}
							</div>
							<span class="adm-fb-author">{{ fb.author_name }} · {{ fb.created_at|date('M d') }}</span>
						</div>
						{% if fb.comment %}
							<div class="adm-fb-text">{{ fb.comment }}</div>
						{% endif %}
					</div>
					{% endfor %}
				</div>
			</div>
		</div>

		{# ══════════ REVENUE & SUBSCRIPTIONS ══════════ #}
		{% set totalRev = revenueStats.total_revenue|default(0)|number_format(2) %}
		{% set monthRev = revenueStats.revenue_this_month|default(0)|number_format(2) %}
		<div class="rev-section-head">
			<div class="rev-section-title"><i class='bx bxs-dollar-circle'></i> Revenue &amp; Subscriptions</div>
		</div>
		<div class="rev-divider"></div>

		{# Top 4 metric cards #}
		<div class="rev-grid">
			<div class="rev-card rev-card--total">
				<div class="rev-glow" style="background:#7856ed"></div>
				<div class="rev-card-lbl"><i class='bx bx-dollar'></i> Total Revenue</div>
				<div class="rev-card-val">${{ totalRev }}</div>
				<div class="rev-card-sub">{{ revenueStats.total_subscriptions|default(0) }} total purchases</div>
			</div>
			<div class="rev-card rev-card--month">
				<div class="rev-glow" style="background:#34d399"></div>
				<div class="rev-card-lbl"><i class='bx bx-calendar'></i> This Month</div>
				<div class="rev-card-val">${{ monthRev }}</div>
				<div class="rev-card-sub">Revenue for {{ 'now'|date('F Y') }}</div>
			</div>
			<div class="rev-card rev-card--active">
				<div class="rev-glow" style="background:#fbbf24"></div>
				<div class="rev-card-lbl"><i class='bx bx-user-check'></i> Active Subscribers</div>
				<div class="rev-card-val">{{ revenueStats.active_subscriptions|default(0) }}</div>
				<div class="rev-card-sub">{{ revenueStats.monthly_subs|default(0) }} monthly · {{ revenueStats.annual_subs|default(0) }} annual</div>
			</div>
			<div class="rev-card rev-card--plans">
				<div class="rev-glow" style="background:#38bdd1"></div>
				<div class="rev-card-lbl"><i class='bx bx-layer'></i> Paid Plans</div>
				<div class="rev-card-val">{{ planBreakdown|length }}</div>
				<div class="rev-card-sub">{{ planBreakdown|reduce((carry, p) => carry + p.active, 0) }} active plan holders</div>
			</div>
		</div>

		{# Plan breakdown + Recent purchases #}
		<div class="rev-panel-grid">
			{# Plan breakdown #}
			<div class="adm-panel">
				<div class="adm-panel-head">
					<span class="adm-panel-title"><i class='bx bxs-layer'></i> Plan Breakdown</span>
				</div>
				<div class="adm-panel-body">
					{% set planColors = {starter: '#9ca3af', pro: '#a78bfa', teams: '#34d399'} %}
					{% set totalPlanRev = revenueStats.total_revenue|default(1) %}
					{% if planBreakdown|length > 0 %}
						{% for plan in planBreakdown %}
						{% set barColor = planColors[plan.plan]|default('#38bdd1') %}
						{% set pct = totalPlanRev > 0 ? (plan.revenue / totalPlanRev * 100) : 0 %}
						<div class="rev-plan-row">
							<div class="rev-plan-dot" style="background:{{ barColor }}"></div>
							<div style="flex:1">
								<div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
									<div class="rev-plan-name">{{ plan.plan|capitalize }}</div>
									<div class="rev-plan-badge">{{ plan.active }} active</div>
									<div class="rev-plan-revenue">${{ plan.revenue|number_format(2) }}</div>
								</div>
								<div class="rev-plan-bar-wrap">
									<div class="rev-plan-bar" style="width:{{ pct|number_format(1) }}%;background:{{ barColor }}"></div>
								</div>
								<div style="font-size:0.62rem;color:var(--muted);margin-top:3px">{{ pct|number_format(1) }}% of total revenue · {{ plan.subscribers }} purchases</div>
							</div>
						</div>
						{% endfor %}
					{% else %}
						<div style="text-align:center;padding:32px 0;color:var(--muted);font-size:0.82rem">
							<i class='bx bx-dollar-circle' style="font-size:2.5rem;display:block;margin-bottom:10px;opacity:0.3"></i>
							No subscriptions yet
						</div>
					{% endif %}
				</div>
			</div>

			{# Recent purchases #}
			<div class="adm-panel">
				<div class="adm-panel-head">
					<span class="adm-panel-title"><i class='bx bxs-receipt'></i> Recent Purchases</span>
				</div>
				<div class="adm-panel-body">
					{% if recentSubscriptions|length > 0 %}
						{% for sub in recentSubscriptions %}
						<div class="rev-sub-row">
							<div class="rev-sub-av">{{ sub.full_name|default('?')|slice(0,2)|upper }}</div>
							<div class="rev-sub-info">
								<div class="rev-sub-name">{{ sub.full_name|default('—') }}</div>
								<div class="rev-sub-email">{{ sub.email }}</div>
							</div>
							<div style="text-align:right;flex-shrink:0">
								<span class="rev-plan-tag {{ sub.plan }}">{{ sub.plan|capitalize }}</span>
								<div class="rev-amount">${{ sub.amount|number_format(2) }}</div>
								<div class="rev-cycle">{{ sub.billing_cycle }} · {{ sub.started_at|date('M d, Y') }}</div>
							</div>
						</div>
						{% endfor %}
					{% else %}
						<div style="text-align:center;padding:32px 0;color:var(--muted);font-size:0.82rem">
							<i class='bx bx-shopping-bag' style="font-size:2.5rem;display:block;margin-bottom:10px;opacity:0.3"></i>
							No purchases yet
						</div>
					{% endif %}
				</div>
			</div>
		</div>

	</main>
</div>
{% endblock %}

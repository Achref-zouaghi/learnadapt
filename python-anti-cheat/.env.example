# LearnAdapt Anti-Cheat Service — Environment Variables
# Copy this file to .env and fill in the values before starting the service.

# ── Symfony ──────────────────────────────────────────────────────────────────
# Base URL of the Symfony application (no trailing slash)
SYMFONY_BASE_URL=http://localhost:8000

# ── Security ─────────────────────────────────────────────────────────────────
# Shared HMAC-SHA256 secret — MUST match ANTI_CHEAT_SECRET in Symfony's .env
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
ANTI_CHEAT_SECRET=CHANGE_ME_GENERATE_A_STRONG_SECRET

# ── Camera ───────────────────────────────────────────────────────────────────
# OpenCV camera index (0 = default webcam)
CAMERA_INDEX=0

# ── YOLOv8 ───────────────────────────────────────────────────────────────────
# Path to the YOLOv8 weights file.
# Leave as "yolov8n.pt" to auto-download the nano model on first run.
YOLO_MODEL_PATH=yolov8n.pt
